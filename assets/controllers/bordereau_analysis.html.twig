{# templates/admin/bordereau/bordereau_analysis.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analyse : Bordereau {{ bordereau.reference }}</title>
    <link rel="icon" href="{{ asset('images/entreprises/logofav.png') }}" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
        }
        .analysis-container {
            max-width: 800px;
            margin: 2rem auto;
            background-color: #fff;
            border: 1px solid #dee2e6;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,.15);
        }
        .analysis-header {
            padding: 2rem;
            border-bottom: 1px solid #dee2e6;
        }
        .analysis-body {
            padding: 2rem;
        }
        .analysis-footer {
            padding: 2rem;
            background-color: #f8f9fa;
            border-top: 1px solid #dee2e6;
        }
        .actions-bar {
            padding: 1rem;
            text-align: center;
            background-color: #343a40;
        }

        @media print {
            .actions-bar {
                display: none !important;
            }
            .analysis-container {
                margin: 0;
                border: none;
                box-shadow: none;
                max-width: 100%;
            }
        }
    </style>
</head>
<body>

    <div class="actions-bar sticky-top">
        <button class="btn btn-light d-inline-flex align-items-center gap-2" data-controller="ripple" onclick="window.close()">
            <twig:UX:Icon name="{{ resolve_icon_name('action:close') }}" width="18px" height="18px" />
            <span>Retourner à l'édition</span>
        </button>

        <button class="btn btn-primary d-inline-flex align-items-center gap-2" data-controller="ripple" onclick="window.print()">
            <twig:UX:Icon name="{{ resolve_icon_name('action:print') }}" width="18px" height="18px" />
            <span>Imprimer</span>
        </button>
    </div>

    <div class="analysis-container">
        <div class="analysis-header">
            <div class="row align-items-center">
                <div class="col">
                    <h4 class="mt-2 mb-0">{{ entreprise.nom|default('Votre Entreprise') }}</h4>
                    <p class="text-muted">{{ entreprise.adresse|default('') }}</p>
                </div>
                <div class="col text-end">
                    <h2>Analyse de Bordereau</h2>
                    <p class="mb-1"><strong>Référence :</strong> {{ bordereau.reference }}</p>
                    <p class="mb-0"><strong>Période :</strong> {{ bordereau.periodeDebut|date('d/m/Y') }} au {{ bordereau.periodeFin|date('d/m/Y') }}</p>
                </div>
            </div>
        </div>

        <div class="analysis-body">
            <h5>Analyse du bordereau : {{ bordereau.nom }}</h5>
            
            <div class="alert alert-info mt-4">
                <h4 class="alert-heading">Page en construction</h4>
                <p>Cette page est destinée à afficher l'analyse détaillée du bordereau. Le contenu sera ajouté dans une prochaine étape.</p>
            </div>

        </div>

        <div class="analysis-footer text-center">
            <p class="mb-1 fw-bold">{{ entreprise.nom|default('Votre Entreprise') }}</p>
            <p class="text-muted small fst-italic mb-0">
                {{ entreprise.adresse|default('') }}
            </p>
        </div>
    </div>

</body>
</html>