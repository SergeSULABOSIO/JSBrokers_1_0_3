<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		{# Horloge de RÉFÉRENCE de l'application (APP_TIMEZONE, posée par App\Kernel::boot).
		   Lue telle quelle sur l'horloge PHP courante : une seule source de vérité, que le
		   serveur ET le front suivent pour afficher exactement la même heure. #}
		<meta name="app-timezone" content="{{ 'now'|date('e') }}">
		<title>
			{% block title %}
				{{ "base_welcome" | trans }}
			{% endblock %}
		</title>
		<link rel="icon" type="image/png" href="{{ asset('images/entreprises/logofav.png') }}">
		{# <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>"> #}
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous"> {% block stylesheets %}{% endblock %}
		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</head>
	<body
		data-controller="cerveau dialog-manager"
	>
		{# Conteneur pour le corps de la page #}
		{% block body %}{% endblock %}
		{# Conteneur pour les notifications (toasts).
		   Décalé sous la barre de titre (jamais en superposition) via --jsb-toast-top
		   qu'une page peut surcharger selon la hauteur réelle de sa barre.
		   Les toasts s'empilent verticalement (flex-column), alignés du haut vers
		   le bas et calés sur le bord droit (align-items-end). #}
		<div
			aria-live="polite"
			aria-atomic="true"
			class="position-fixed end-0 p-3 d-flex flex-column align-items-end"
			style="top: var(--jsb-toast-top, 4.5rem); z-index: 1100"
			data-controller="notification-manager"
		>
			{# Les toasts seront injectés ici par Stimulus #}
		</div>
		{{ include("components/_confirmation_dialog.html.twig") }}
	</body>
</html>
