{% extends 'base.html.twig' %}

{% block title %}{{ pageName }} — JS Brokers{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ============================================================
       Conditions d'utilisation — même pattern que la création de
       compte / l'édition d'entreprise. Charte : cobalt #0047AB +
       neutres Bootstrap. Aucune couleur hors charte.
       ============================================================ */
    /* L'espace de travail impose globalement `body, html { overflow: hidden }`
       (interactive-menu.css) ; on rétablit le défilement sur cette page autonome. */
    html, body { height: auto !important; overflow: auto !important; }
    /* Le défilement laisse passer l'ancrage sous la barre fixe. */
    html { scroll-padding-top: var(--cgu-topbar-h, 64px); }

    .cgu-page {
        --cgu-topbar-h: 64px;
        min-height: 100vh; display: flex; flex-direction: column;
        background-color: #f3f3f3; padding-top: var(--cgu-topbar-h);
    }

    /* Barre applicative — fixée en haut, comme le portail public. */
    .cgu-topbar {
        position: fixed; top: 0; left: 0; right: 0; width: 100%; z-index: 1030;
        display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; padding: .75rem 1.5rem;
        background-color: #ffffff; border-bottom: 1px solid #dee2e6;
    }
    .cgu-brand { display: flex; align-items: center; gap: .6rem; text-decoration: none; }
    .cgu-brand img { width: 36px; height: 36px; border-radius: 8px; }
    .cgu-brand span { font-weight: 700; color: #0047AB; font-size: 1.1rem; }
    .cgu-topbar-actions { display: flex; align-items: center; gap: .5rem; }

    /* Contenu : colonne de lecture confortable */
    .cgu-content { max-width: 860px; margin: 0 auto; padding: 1.5rem; width: 100%; }
    .cgu-back-row { display: flex; align-items: center; gap: .4rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .cgu-back { display: inline-flex; align-items: center; gap: .35rem; font-size: .9rem; color: #6c757d; text-decoration: none; }
    .cgu-back:hover { color: #0047AB; }

    .cgu-head { margin-bottom: 1.25rem; }
    .cgu-head h1 { display: flex; align-items: center; gap: .55rem; font-size: 1.6rem; font-weight: 700; color: #212529; margin: 0 0 .35rem; }
    .cgu-head-icon { flex: 0 0 auto; color: #0047AB; }
    .cgu-meta { color: #6c757d; font-size: .9rem; margin: 0; }

    /* Carte document */
    .cgu-card {
        background-color: #ffffff; border: 1px solid #dee2e6; border-radius: 12px;
        padding: 1.75rem 2rem; box-shadow: 0 4px 16px rgba(0, 71, 171, .06);
        color: #343a40; line-height: 1.65;
    }
    .cgu-intro { color: #495057; margin-bottom: 1.5rem; }
    .cgu-section { margin-bottom: 1.5rem; }
    .cgu-section:last-child { margin-bottom: 0; }
    .cgu-card h2 {
        font-size: 1.05rem; font-weight: 700; color: #0047AB;
        margin: 0 0 .6rem; padding-bottom: .35rem; border-bottom: 1px solid #e9ecef;
    }
    .cgu-card p { margin: 0 0 .65rem; }
    .cgu-card ul { margin: 0 0 .65rem; padding-left: 1.25rem; }
    .cgu-card li { margin-bottom: .35rem; }
    .cgu-card strong { color: #212529; }

    /* Bascule de langue : drapeaux SVG (FR / Royaume-Uni). */
    .cgu-lang { display: inline-flex; gap: .25rem; padding: .25rem; border: 1px solid #dee2e6; border-radius: 10px; background-color: #fff; }
    .cgu-lang a { display: inline-flex; align-items: center; justify-content: center; min-width: 44px; min-height: 36px; padding: 0 .55rem; border-radius: 7px; text-decoration: none; background-color: transparent; transition: background-color .15s ease; }
    .cgu-lang .public-lang__flag { width: 26px; height: 18px; display: block; border-radius: 3px; box-shadow: 0 0 0 1px rgba(0,0,0,.08); opacity: .5; filter: grayscale(.4); transition: opacity .15s ease, filter .15s ease; }
    .cgu-lang a:hover .public-lang__flag { opacity: .9; filter: none; }
    .cgu-lang a.is-active { background-color: #0047AB; }
    .cgu-lang a.is-active .public-lang__flag { opacity: 1; filter: none; box-shadow: 0 0 0 1px rgba(255,255,255,.6); }
    .cgu-lang a:focus-visible { outline: 2px solid #0047AB; outline-offset: 2px; }

    /* La zone de contenu grandit pour pousser le pied de page en bas de fenêtre. */
    .cgu-content { flex: 1 0 auto; }

    /* ---------- Pied de page public réutilisé (même style que la vitrine) ---------- */
    .public-footer { background-color: #fff; border-top: 1px solid #dee2e6; margin-top: 1rem; }
    .public-footer__inner { max-width: 1140px; margin: 0 auto; padding: 2.5rem 1.5rem 1.5rem;
        display: flex; flex-wrap: wrap; align-items: flex-start; gap: 1.5rem; }
    .public-footer__brand { display: flex; align-items: center; gap: .75rem; flex: 1 1 280px; text-decoration: none; }
    .public-footer__brand:hover { opacity: .85; }
    .public-footer__brand img { border-radius: 8px; }
    .public-footer__name { font-weight: 700; color: #0047AB; margin: 0; font-size: 1.05rem; }
    .public-footer__tagline { color: #6c757d; margin: 0; font-size: .9rem; max-width: 360px; }
    .public-footer__links { display: flex; flex-wrap: wrap; gap: .25rem 1.25rem; }
    .public-footer__links a { display: inline-flex; align-items: center; min-height: 44px;
        color: #495057; text-decoration: none; font-size: .92rem; font-weight: 600; }
    .public-footer__links a:hover { color: #0047AB; }
    .public-footer__links a:focus-visible { outline: 2px solid #0047AB; outline-offset: 2px; border-radius: 4px; }
    .public-footer__credit { max-width: 1140px; margin: 0 auto; padding: 1rem 1.5rem;
        border-top: 1px solid #dee2e6; text-align: center; color: #6c757d; font-size: .85rem; }
    .public-lang { display: inline-flex; gap: .25rem; padding: .25rem; border: 1px solid #dee2e6; border-radius: 10px; background-color: #fff; }
    .public-lang a { display: inline-flex; align-items: center; justify-content: center; min-width: 44px; min-height: 36px; padding: 0 .55rem; border-radius: 7px; text-decoration: none; background-color: transparent; transition: background-color .15s ease; }
    .public-lang__flag { width: 26px; height: 18px; display: block; border-radius: 3px; box-shadow: 0 0 0 1px rgba(0,0,0,.08); opacity: .5; filter: grayscale(.4); transition: opacity .15s ease, filter .15s ease; }
    .public-lang a:hover .public-lang__flag { opacity: .9; filter: none; }
    .public-lang a.is-active { background-color: #0047AB; }
    .public-lang a.is-active .public-lang__flag { opacity: 1; filter: none; box-shadow: 0 0 0 1px rgba(255,255,255,.6); }
    .public-lang a:focus-visible { outline: 2px solid #0047AB; outline-offset: 2px; }
    .public-lang__code { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

    @media (max-width: 575.98px) {
        .cgu-card { padding: 1.25rem; }
    }

    /* Impression : on ne garde que le document. */
    @media print {
        .cgu-topbar, .cgu-back-row, .cgu-no-print, .public-footer { display: none !important; }
        .cgu-page { background: #fff; padding-top: 0; }
        .cgu-card { border: none; box-shadow: none; padding: 0; }
    }
</style>
{% endblock %}

{% block body %}
{% import 'components/_lang_flag.html.twig' as flags %}
{% set isEn = (lang == 'en') %}
{% set backHref = app.user is not null ? path('admin.entreprise.index') : path('app_login') %}

<main class="cgu-page">

    {# Barre applicative #}
    <header class="cgu-topbar">
        {# La marque renvoie toujours à l'accueil public ; le bouton « retour » ci-dessous gère le retour contextuel. #}
        <a href="{{ path('app_index') }}" class="cgu-brand"
           aria-label="JS Brokers — retour à l'accueil" title="Retour à l'accueil JS Brokers">
            <img src="{{ asset('images/entreprises/logofav.png') }}" alt="">
            <span>JS Brokers</span>
        </a>
        <div class="cgu-topbar-actions cgu-no-print">
            {# Bascule de langue : auto-suffisante via ?lang= (fonctionne hors session). #}
            <span class="cgu-lang" role="group" aria-label="{{ isEn ? 'Language' : 'Langue' }}">
                <a href="{{ path('app_terms', {'lang': 'fr'}) }}" class="{{ isEn ? '' : 'is-active' }}" title="Français" lang="fr" {{ isEn ? '' : 'aria-current="true"' }}>{{ flags.fr() }}<span class="public-lang__code">FR</span></a>
                <a href="{{ path('app_terms', {'lang': 'en'}) }}" class="{{ isEn ? 'is-active' : '' }}" title="English" lang="en" {{ isEn ? 'aria-current="true"' : '' }}>{{ flags.uk('lang-cgu-top') }}<span class="public-lang__code">EN</span></a>
            </span>
            <button type="button" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center"
                    onclick="window.print()">
                {{ ux_icon(resolve_icon_name('mdi:printer-outline'), {height: '18px', width: '18px'}) }}
                <span class="ms-1">{{ isEn ? 'Print' : 'Imprimer' }}</span>
            </button>
        </div>
    </header>

    <div class="cgu-content">

        <div class="cgu-back-row">
            <a href="{{ backHref }}" class="cgu-back">
                {{ ux_icon(resolve_icon_name('hugeicons:arrow-left-01'), {height: '18px', width: '18px'}) }}
                {{ app.user is not null
                    ? (isEn ? 'Back to my workspace' : 'Retour à mon espace')
                    : (isEn ? 'Back to sign in' : 'Retour à la connexion') }}
            </a>
        </div>

        <div class="cgu-head">
            <h1>
                {{ ux_icon(resolve_icon_name('mdi:file-document-outline'), {height: '28px', width: '28px', class: 'cgu-head-icon'}) }}
                {{ pageName }}
            </h1>
            <p class="cgu-meta">
                {{ isEn ? 'Version' : 'Version' }} {{ cguVersion }} —
                {{ isEn ? 'last updated on' : 'dernière mise à jour le' }}
                {{ cguDate|date(isEn ? 'F j, Y' : 'd/m/Y') }}
            </p>
        </div>

        <article class="cgu-card">
            {% include 'legal/_cgu_' ~ (lang|default('fr')) ~ '.html.twig' %}
        </article>
    </div>

    {% include 'components/_public_footer.html.twig' with { lang: lang } %}
</main>
{% endblock %}
