{# templates/components/_analysis_result_item.html.twig #}
{% set status_config = {
    'new':         { 'class': 'border-info',    'icon': 'lucide:plus-circle',    'icon_class': 'text-info' },
    'discrepancy': { 'class': 'border-warning',  'icon': 'lucide:alert-triangle', 'icon_class': 'text-warning' },
    'match':       { 'class': 'border-success',  'icon': 'lucide:check-circle',   'icon_class': 'text-success' },
    'warning':     { 'class': 'border-danger',   'icon': 'lucide:alert-octagon',  'icon_class': 'text-danger' }
}[result.type] ?? {
    'class':      'border-secondary',
    'icon':       'lucide:help-circle',
    'icon_class': 'text-secondary'
} %}

<li class="analysis-item list-group-item p-0 {{ status_config.class }}"
    data-controller="analysis-result-item"
    data-analysis-result-item-actions-value="{{ result.actions|json_encode|e('html_attr') }}"
    data-analysis-result-item-icon-prefix-value="{{ bordereau_id }}-{{ loop.index }}-"
>
    {# Ligne 1: La barre de titre cliquable pour l'accordéon #}
    <div class="analysis-item-header p-3"
         data-action="click->analysis-result-item#toggleDetails mouseenter->analysis-result-item#showActions mouseleave->analysis-result-item#hideActions">

        <div class="d-flex justify-content-between align-items-center">
            {# Titre principal avec icône de statut #}
            <div class="analysis-item-title-wrapper">
                <h5 class="mb-0 d-flex align-items-center gap-2">
                    <twig:UX:Icon name="{{ status_config.icon }}" class="{{ status_config.icon_class }}" width="20px" height="20px" />
                    <span class="fw-bold">
                        {% if result.type == 'warning' %}
                            Données obsolètes — Analyse requise
                        {% else %}
                            {{ result.bordereau_line_info.reference_police|default('Avenant sans référence') }}
                        {% endif %}
                    </span>
                    <twig:UX:Icon name="lucide:chevron-down" class="chevron-icon" data-analysis-result-item-target="chevronIcon" width="18px" height="18px" />
                </h5>
            </div>

            {# Conteneur pour les boutons d'action contextuels #}
            <div class="analysis-item-actions" data-analysis-result-item-target="actionsContainer">
                {% set action_count = result.actions|length %}
                {% for action in result.actions %}
                    <button class="btn btn-sm btn-light p-1"
                            data-action="click->analysis-result-item#handleAction"
                            data-event-name="{{ action.event }}"
                            data-payload="{{ action.payload|json_encode|e('html_attr') }}"
                            data-analysis-result-item-target="actionButton"
                            data-tooltip-text="{{ action.label }}"
                    >
                        {# La cible pour l'icône qui sera chargée dynamiquement #}
                        <span class="button-icon" data-analysis-result-item-target="actionIcon"></span>
                        {# NOUVEAU : Afficher le texte seulement si moins de 3 boutons #}
                        {% if action_count < 3 %}
                            <span class="button-label ms-1">{{ action.label }}</span>
                        {% endif %}
                    </button>
                {% endfor %}
            </div>
        </div>

        {# Ligne 2: Le texte de synthèse #}
        <p class="mb-0 mt-1 text-muted small">{{ result.details }}</p>
    </div>

    {# Contenu détaillé (accordéon), caché par défaut #}
    {# Pour le type warning, bordereau_line_info est vide, on n'affiche pas le panneau #}
    {% if result.type != 'warning' and result.bordereau_line_info is not empty %}
        <div class="analysis-item-details" data-analysis-result-item-target="detailsPanel">
            <div class="p-3">
                <p class="mb-2 small fst-italic"><strong>Détails de la ligne du bordereau :</strong></p>
                {# NOUVEAU : La carte des formats est maintenant passée directement depuis le contrôleur parent #}
                {% set currency_code = viewData.display_currency_code ?? '' %}
                {% set system_formats = viewData.system_field_formats ?? {} %}
                <div class="analysis-details-grid small text-muted mb-3">
                    {% for key, value in result.bordereau_line_info %}
                        <div class="row">
                            <div class="col-md-6">
                                {# NOUVEAU : Remplacer les underscores par des espaces et capitaliser pour un meilleur affichage #}
                                {# ex: 'chargement_1_Prime_Nette' devient 'Chargement 1 Prime Nette' #}
                                <strong>{{ key|replace({'_': ' '})|title }}</strong>
                            </div>
                            <div class="col-md-6">
                                {% if value is not null and value is not same as('') %}
                                    {# NOUVEAU : Logique de formatage enrichie #}
                                    {% set format = system_formats[key] ?? 'text' %}
                                    {% if format == 'date' %}
                                        {% if value.date is defined %}
                                            {# Objet DateTime sérialisé par Twig (données venant de la DB) #}
                                            {{ value.date|format_datetime('full', 'short', locale='fr') }}
                                        {% elseif value is not null and value is not same as('') %}
                                            {# String Y-m-d retournée par parseExcelValue() après refactorisation #}
                                            {{ value|date('d/m/Y') }}
                                        {% else %}
                                            N/A
                                        {% endif %}
                                    {% elseif format == 'number' %}
                                        {# Formatage monétaire avec code de devise #}
                                        {{ currency_code }} {{ value|number_format(2, ',', ' ') }}
                                    {% else %}
                                        {{ value }}
                                    {% endif %}
                                {% else %}
                                    N/A
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {# NOUVEAU : Tableau des écarts financiers pour les résultats discrepancy #}
                {% if result.type == 'discrepancy' and result.financial_gaps is defined
                    and result.financial_gaps is not empty %}
                    <div class="mt-3">
                        <p class="mb-2 small fst-italic">
                            <strong>Analyse des écarts financiers :</strong>
                        </p>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0"
                                   style="font-size:0.82rem; border-radius:8px; overflow:hidden;">
                                <thead class="table-light">
                                    <tr>
                                        <th class="text-muted fw-normal">Champ</th>
                                        <th class="text-center text-muted fw-normal">
                                            Valeur DB (attendue)
                                        </th>
                                        <th class="text-center text-muted fw-normal">
                                            Valeur bordereau (reçue)
                                        </th>
                                        <th class="text-center text-muted fw-normal">Écart</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for field, gap in result.financial_gaps %}
                                        <tr class="{{ gap.gap != 0 ? 'table-warning' : '' }}">
                                            <td class="fw-bold">{{ gap.label }}</td>
                                            <td class="text-center">
                                                {{ gap.db_value|number_format(2, ',', ' ') }}
                                            </td>
                                            <td class="text-center">
                                                {{ gap.excel_value|number_format(2, ',', ' ') }}
                                            </td>
                                            <td class="text-center fw-bold {{ gap.gap_class }}">
                                                {% if gap.gap != 0 %}
                                                    {{ gap.gap_sign }}{{ gap.gap|number_format(2, ',', ' ') }}
                                                {% else %}
                                                    <span class="text-muted">—</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}
</li>