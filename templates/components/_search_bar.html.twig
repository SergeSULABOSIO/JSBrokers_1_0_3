{# templates/components/_search_bar.html.twig #}
<div
    class="jsb-search-bar"
    data-controller="search-bar"
    data-search-bar-nom-entite-value="{{ entite_nom|default('') }}"
    data-search-bar-criteria-value="{{ searchCanvas|json_encode|e('html_attr') }}"
    data-search-bar-autocomplete-url-value="{{ autocomplete_url|default('') }}"
>
    {# ── Ligne principale (pill) ── #}
    <div class="jsb-search-bar__row">
        <span class="jsb-search-bar__icon" aria-hidden="true">
            <twig:ux:icon name="{{ resolve_icon_name('lucide:search') }}" />
        </span>

        {#
            readonly + focus->enableEditing : technique anti-autofill robuste.
            Chrome ignore souvent autocomplete="off" et injecte l'email de connexion ;
            en revanche il n'autofill JAMAIS un champ readonly. On retire readonly au
            focus pour permettre la saisie normale. Les autres attributs neutralisent
            les gestionnaires de mots de passe (LastPass / 1Password).
        #}
        <input
            type="search"
            class="jsb-search-bar__input"
            aria-label="Rechercher dans la liste"
            data-search-bar-target="simpleSearchInput"
            data-action="keydown.enter->search-bar#submitSimpleSearch focus->search-bar#enableEditing"
            placeholder="Rechercher..."
            name="jsb-recherche"
            readonly
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            data-lpignore="true"
            data-1p-ignore
            data-form-type="other"
        >

        <span class="jsb-search-bar__divider" aria-hidden="true"></span>

        <select
            class="jsb-search-bar__criterion"
            aria-label="Critère de recherche"
            data-search-bar-target="simpleSearchCriterion"
            data-action="change->search-bar#updateSimpleSearchPlaceholder"
        ></select>

        <div class="jsb-search-bar__actions">
            <button
                class="jsb-search-bar__btn jsb-search-bar__btn--advanced"
                aria-label="Ouvrir la recherche avancée"
                data-action="click->search-bar#openAdvancedSearch"
            >
                <twig:ux:icon name="{{ resolve_icon_name('lucide:sliders-horizontal') }}" aria-hidden="true" />
                <span class="jsb-search-bar__btn-label">Avancée</span>
            </button>
            <button
                class="jsb-search-bar__btn jsb-search-bar__btn--reset"
                aria-label="Réinitialiser la recherche"
                data-action="click->search-bar#resetAllFilters"
            >
                <twig:ux:icon name="{{ resolve_icon_name('lucide:x') }}" aria-hidden="true" />
            </button>
        </div>
    </div>

    {# ── Filtres actifs (masqué si vide via CSS :has) ── #}
    <div
        class="jsb-search-bar__filters"
        data-search-bar-target="summaryContainer"
        role="status"
        aria-live="polite"
        aria-label="Filtres actifs"
    >
        <div data-search-bar-target="summary"></div>
    </div>
</div>
