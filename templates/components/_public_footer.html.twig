{# ============================================================
   Pied de page public réutilisable (vitrine JS Brokers).
   Marque + tagline, liens (fonctionnalités, tarifs, CGU) et bascule de langue.
   Charte : cobalt #0047AB, neutres Bootstrap. Styles dans _home_styles.html.twig.
   ============================================================ #}
{% set lang = lang|default(app.request.locale|default('fr')) %}

{# Réutilisable hors vitrine : si l'on n'est pas déjà sur la home, les ancres de
   section deviennent des liens absolus vers le portail (`/?lang=…#section`) pour
   ne pas rompre la navigation. Sur la home, on garde l'ancre nue (défilement). #}
{% set onHome = app.request.attributes.get('_route') == 'app_index' %}
{% set homeBase = onHome ? '' : path('app_index', {'lang': lang}) %}

{# Bascule de langue : on reste sur la page courante en ne changeant que `lang`.
   On reconstruit l'URL active (route + paramètres + query string) au lieu de
   renvoyer systématiquement vers la vitrine. Repli sur la home si la route est
   indéterminée (sous-requête). #}
{% set switchRoute = app.request.attributes.get('_route')|default('app_index') %}
{% set switchParams = (app.request.attributes.get('_route_params')|default({}))|merge(app.request.query.all) %}

<footer class="public-footer">
    <div class="public-footer__inner">

        <a href="{{ path('app_index') }}" class="public-footer__brand" aria-label="JS Brokers — retour à l'accueil"
           data-action="click->top-progress#show">
            <img src="{{ asset('images/entreprises/logofav.png') }}" alt="" width="40" height="40">
            <div>
                <p class="public-footer__name">JS Brokers</p>
                <p class="public-footer__tagline">{{ "security_some_key_fitures_description" | trans }}</p>
            </div>
        </a>

        <nav class="public-footer__links" aria-label="{{ "home_nav_features" | trans }}">
            <a href="{{ homeBase }}#features">{{ "home_nav_features" | trans }}</a>
            <a href="{{ homeBase }}#guide">{{ "home_nav_guide" | trans }}</a>
            <a href="{{ homeBase }}#pricing_plan">{{ "home_nav_pricing" | trans }}</a>
            <a href="{{ homeBase }}#contact">{{ "home_nav_contact" | trans }}</a>
            <a href="{{ path('app_terms') }}" data-action="click->top-progress#show">{{ "terms_link" | trans }}</a>
        </nav>

        {# Bascule de langue unifiée : recharge la page courante dans l'autre langue
           (navigation serveur) → barre de progression du haut (top-progress#show).
           uid distinct de la topbar (lang-foot) car les deux coexistent sur la home. #}
        {{ include('components/_lang_switch.html.twig', {current: lang, route: switchRoute, params: switchParams, uid: 'lang-foot'}) }}
    </div>

    <p class="public-footer__credit">{{ "base_base_de_page" | trans }}</p>
</footer>
