{#
  Composant « Paramètres IA » (groupe IA) — colonne 3.

  Nommage du personnage de l'assistant, unique par entreprise. Réservé au
  propriétaire / gestionnaire d'invités (contrôleur fail-closed). Rendu inspiré
  du formulaire console (coupon) : fieldset à légende cobalt avec icône, champ
  blanc 48px sur panneau clair, illustration latérale, action à icône. Champ à
  icône incrustée (alias `utilisateur` = identité du personnage). Soumission
  AJAX portée par le contrôleur Stimulus `assistant-ia-parametres` ; AUCUN
  <script> inline.
#}
<div class="jsb-ai-params"
     data-controller="assistant-ia-parametres"
     data-assistant-ia-parametres-url-value="{{ path('admin.assistantia.workspace_parametres', {idEntreprise: idEntreprise}) }}">
    <style>
        .jsb-ai-params { padding: 1.25rem 1.5rem; }
        /* Entête au modèle de l'édition d'entreprise (.ent-head) : titre à icône
           cobalt + message contextuel adressé à l'utilisateur, séparé par un filet. */
        .jsb-ai-params .aip-head { margin:0 0 1.5rem; }
        .jsb-ai-params .aip-head h2 {
            display:flex; align-items:center; gap:.55rem;
            font-size:1.6rem; font-weight:700; color:#212529; margin:0 0 .25rem;
        }
        .jsb-ai-params .aip-head-icon { flex:0 0 auto; color:#0047AB; }
        .jsb-ai-params .aip-head p { color:#6c757d; margin:0; }
        .jsb-ai-params .aip-head hr { margin:.75rem 0 0; border-color:#dee2e6; opacity:1; }

        /* Carte du formulaire (modèle console, sans illustration). */
        .jsb-ai-params .aip-panel {
            background:#ffffff; border:1px solid #dee2e6; border-radius:12px;
            padding:1.25rem; max-width:640px;
        }

        /* Section à légende cobalt (modèle .cs-fieldset / .cs-legend du coupon). */
        .jsb-ai-params .aip-fieldset {
            border:1px solid #dee2e6; border-radius:10px; background:#f8f9fa;
            padding:1.15rem 1.25rem 1rem; margin:0;
        }
        .jsb-ai-params .aip-legend {
            display:inline-flex; align-items:center; gap:.45rem;
            font-size:.78rem; text-transform:uppercase; letter-spacing:.04em; font-weight:700;
            color:#0047AB; margin-bottom:1rem; padding:0; width:auto; float:none;
        }
        .jsb-ai-params .form-label { font-weight:600; color:#343a40; margin-bottom:.35rem; }
        .jsb-ai-params .form-text { color:#6c757d; }

        /* Champ à icône incrustée (identité du personnage). */
        .jsb-ai-params .aip-inputbox { position:relative; }
        .jsb-ai-params .aip-inputbox .aip-input-ic {
            position:absolute; left:.8rem; top:50%; transform:translateY(-50%);
            color:#6c757d; display:flex; pointer-events:none;
        }
        .jsb-ai-params .aip-inputbox .form-control {
            height:48px; font-size:1rem; color:#000000; background:#ffffff;
            padding-left:2.6rem;
        }
        .jsb-ai-params .form-control:focus { border-color:#0047AB; box-shadow:0 0 0 .25rem rgba(0,71,171,.35); }
        .jsb-ai-params .aip-inputbox:focus-within .aip-input-ic { color:#0047AB; }

        /* Action d'enregistrement (relief cobalt, états visibles). */
        .jsb-ai-params .aip-actions { display:flex; justify-content:flex-end; margin-top:1.1rem; }
        .jsb-ai-params .btn-cobalt {
            background:#0047AB; border-color:#0047AB; color:#ffffff;
            display:inline-flex; align-items:center; gap:.45rem;
            border-radius:10px; padding:.55rem 1.1rem; font-weight:600; min-height:44px;
            box-shadow:0 2px 6px rgba(0,71,171,.25);
            transition: background-color .15s ease, box-shadow .15s ease, transform .1s ease;
        }
        .jsb-ai-params .btn-cobalt:hover { background:#003380; border-color:#003380; color:#ffffff; box-shadow:0 4px 12px rgba(0,71,171,.25); }
        .jsb-ai-params .btn-cobalt:active { transform:scale(.97); }
        .jsb-ai-params .btn-cobalt:focus-visible { outline:2px solid #0047AB; outline-offset:2px; }
        .jsb-ai-params .btn-cobalt:disabled { opacity:.65; pointer-events:none; }
        .jsb-ai-params .btn-cobalt .spinner-border { width:1rem; height:1rem; border-width:.16em; }

        .jsb-ai-params .aip-feedback { border-radius:8px; padding:.65rem .9rem; font-size:.9rem; margin:0 0 1rem; }
        .jsb-ai-params .aip-feedback--success { background:#d1e7dd; color:#0f5132; }
        .jsb-ai-params .aip-feedback--error { background:#f8d7da; color:#842029; }

        /* ── Documentation des capacités (avant le formulaire) ─────────────────
           Cartes en grille responsive, une par outil de l'assistant : icône en
           pastille cobalt-subtil, titre, apport concret et exemple de question.
           Couleurs strictement dans la charte (cobalt #0047AB en accent seul,
           textes gris Bootstrap sur fonds clairs — contrastes AA). */
        .jsb-ai-params .aip-doc { max-width:980px; margin:0 0 1.75rem; }
        .jsb-ai-params .aip-doc h3 {
            display:flex; align-items:center; gap:.5rem;
            font-size:1.15rem; font-weight:700; color:#212529; margin:0 0 .3rem;
        }
        .jsb-ai-params .aip-doc h3 .aip-doc-ic { color:#0047AB; flex:0 0 auto; }
        .jsb-ai-params .aip-doc > p { color:#6c757d; margin:0 0 1.1rem; max-width:70ch; }
        .jsb-ai-params .aip-doc h4 {
            font-size:.78rem; text-transform:uppercase; letter-spacing:.04em;
            font-weight:700; color:#0047AB; margin:1.35rem 0 .7rem;
        }
        .jsb-ai-params .aip-doc-grid {
            list-style:none; margin:0; padding:0;
            display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:.8rem;
        }
        .jsb-ai-params .aip-doc-card {
            display:flex; gap:.8rem; align-items:flex-start;
            background:#ffffff; border:1px solid #dee2e6; border-radius:10px;
            padding:.85rem .95rem;
        }
        .jsb-ai-params .aip-doc-card-ic {
            flex:0 0 auto; display:inline-flex; align-items:center; justify-content:center;
            width:38px; height:38px; border-radius:9px;
            background:#e8f0fb; color:#0047AB;
        }
        .jsb-ai-params .aip-doc-card h5 { font-size:.95rem; font-weight:700; color:#212529; margin:0 0 .2rem; }
        .jsb-ai-params .aip-doc-card p { font-size:.875rem; color:#495057; margin:0; }
        .jsb-ai-params .aip-doc-ex {
            display:block; margin-top:.3rem; font-size:.85rem; font-style:italic; color:#6c757d;
        }

        /* Encadré des limites : fond cobalt-subtil, information rassurante (role=note). */
        .jsb-ai-params .aip-doc-limites {
            background:#e8f0fb; border:1px solid #dee2e6; border-radius:10px;
            padding:1rem 1.1rem; margin-top:1.35rem;
        }
        .jsb-ai-params .aip-doc-limites h4 {
            display:flex; align-items:center; gap:.45rem; margin:0 0 .55rem; color:#0047AB;
        }
        .jsb-ai-params .aip-doc-limites ul { list-style:none; margin:0; padding:0; display:grid; gap:.4rem; }
        .jsb-ai-params .aip-doc-limites li {
            display:flex; gap:.5rem; align-items:flex-start;
            font-size:.875rem; color:#212529;
        }
        .jsb-ai-params .aip-doc-limites li .aip-lim-ic { color:#0047AB; flex:0 0 auto; margin-top:.1rem; }
    </style>

    {# ── Entête (modèle édition d'entreprise) ── #}
    <div class="aip-head">
        <h2>
            {{ ux_icon(resolve_icon_name('assistant-ia-parametres'), {height: '28px', width: '28px', class: 'aip-head-icon'}) }}
            Paramètres de l'assistant IA de {{ entrepriseNom }}
        </h2>
        <p>
            <strong>{{ utilisateurNom }}</strong>,<br>
            vous êtes sur le point de personnaliser l'assistant IA de <strong>{{ entrepriseNom }}</strong>.<br>
            Merci de renseigner le nom de votre assistant dans le formulaire ci-dessous :
            il s'adressera sous cette identité à tous les collaborateurs de l'espace de travail.
        </p>
        <hr>
    </div>

    {# ── Documentation des capacités : ce que l'assistant sait faire, outil par
          outil, et ses limites protectrices — pour que l'utilisateur sache quoi
          lui demander AVANT de le personnaliser. #}
    <section class="aip-doc" aria-labelledby="aip-doc-titre">
        <h3 id="aip-doc-titre">
            <span class="aip-doc-ic" aria-hidden="true">
                <twig:UX:Icon name="{{ resolve_icon_name('assistant-ia') }}" style="width:22px;height:22px;" />
            </span>
            Ce que {{ assistantNom }} sait faire pour vous
        </h3>
        <p>
            Votre assistant répond en langage naturel, dans les limites des droits d'accès
            de chaque collaborateur. Voici ses capacités, avec des exemples de questions à lui poser.
        </p>

        <h4>Consulter et analyser vos données</h4>
        <ul class="aip-doc-grid">
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:count') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Compter vos enregistrements</h5>
                    <p>Dénombre instantanément les fiches d'une rubrique : clients, avenants, pistes, sinistres…
                        <span class="aip-doc-ex">« Combien de clients avons-nous ? »</span></p>
                </div>
            </li>
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:search') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Rechercher et lister</h5>
                    <p>Liste les fiches d'une rubrique, avec filtre sur le nom et pagination.
                        <span class="aip-doc-ex">« Liste nos avenants » · « Cherche les clients dont le nom contient TRANS »</span></p>
                </div>
            </li>
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:description') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Lire une fiche en détail</h5>
                    <p>Restitue les attributs enregistrés d'une fiche précise : adresse, contacts, statut, références…
                        <span class="aip-doc-ex">« Quelle est l'adresse du client Kin Avia ? »</span></p>
                </div>
            </li>
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('revenu') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Calculer vos indicateurs financiers</h5>
                    <p>Prime totale, commissions, taux de sinistralité… calculés en temps réel pour un client,
                       un portefeuille, un avenant — ou toute l'entreprise, avec période au choix.
                        <span class="aip-doc-ex">« Quelle est la commission totale de l'entreprise ce trimestre ? »</span></p>
                </div>
            </li>
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('document-comptable') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Lire vos états comptables</h5>
                    <p>Trésorerie, compte de résultat, bilan, balance, TVA : les états SYSCOHADA du cabinet,
                       générés à l'instant de la demande.
                        <span class="aip-doc-ex">« Quel est le solde de la trésorerie ? »</span></p>
                </div>
            </li>
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('tranche') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Établir des statistiques</h5>
                    <p>Comptes, sommes, moyennes et répartitions sur vos données, par groupe ou par période.
                        <span class="aip-doc-ex">« Répartition des clients par groupe ? »</span></p>
                </div>
            </li>
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:calendar') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Surveiller vos échéances</h5>
                    <p>Le brief du jour : polices à renouveler sous N jours, tâches en retard,
                       pistes en cours, derniers sinistres notifiés.
                        <span class="aip-doc-ex">« Quelles sont mes échéances ? » · « Mes renouvellements sous 60 jours ? »</span></p>
                </div>
            </li>
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:analyser') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Analyser votre portefeuille</h5>
                    <p>Classements par primes, commissions, sinistralité et part de marché ;
                       production encaissée par mois ; derniers encaissements.
                        <span class="aip-doc-ex">« Top 5 de nos assureurs ? » · « Production mensuelle 2026 ? »</span></p>
                </div>
            </li>
        </ul>

        <h4>Agir dans votre espace de travail et vous guider</h4>
        <ul class="aip-doc-grid">
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:edit') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Préparer vos saisies</h5>
                    <p>Ouvre le formulaire de création ou de modification d'une fiche, pré-rempli
                       avec les valeurs que vous dictez — c'est toujours vous qui vérifiez et enregistrez.
                        <span class="aip-doc-ex">« Crée un client Kabila Corp, tél. +243… » · « Modifie l'avenant X »</span></p>
                </div>
            </li>
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:download') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Lancer vos exports</h5>
                    <p>Déclenche le téléchargement du classeur comptable Excel ou d'une note /
                       bordereau en PDF, générés par les circuits d'export standards.
                        <span class="aip-doc-ex">« Exporte le classeur comptable » · « Imprime la note X en PDF »</span></p>
                </div>
            </li>
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:send-email') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Préparer l'envoi d'un relevé SOA</h5>
                    <p>Ouvre la boîte d'envoi du relevé de compte pré-ciblée sur le client —
                       vous choisissez le destinataire et confirmez l'envoi.
                        <span class="aip-doc-ex">« Envoie le SOA du client Kin Avia »</span></p>
                </div>
            </li>
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:open') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Naviguer pour vous</h5>
                    <p>Ouvre directement la rubrique demandée ou le tableau de bord — et peut
                       proposer la fermeture de l'espace de travail (toujours confirmée par vous).
                        <span class="aip-doc-ex">« Ouvre la rubrique bordereaux » · « Ouvre le tableau de bord »</span></p>
                </div>
            </li>
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:view') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Afficher une fiche à l'écran</h5>
                    <p>Ouvre l'enregistrement demandé dans la colonne de visualisation, avec ses indicateurs.
                        <span class="aip-doc-ex">« Visualise le client Kin Avia »</span></p>
                </div>
            </li>
            <li class="aip-doc-card">
                <span class="aip-doc-card-ic" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:information') }}" style="width:20px;height:20px;" />
                </span>
                <div>
                    <h5>Expliquer le métier et la plateforme</h5>
                    <p>S'appuie sur des fiches de connaissance : cycle de production, bordereaux,
                       indicateurs, rôles et droits d'accès…
                        <span class="aip-doc-ex">« Comment fonctionnent les bordereaux ? » · « Que peux-tu faire ? »</span></p>
                </div>
            </li>
        </ul>

        {# Limites présentées comme une protection (jamais une liste de restrictions sèche). #}
        <aside class="aip-doc-limites" role="note" aria-labelledby="aip-doc-limites-titre">
            <h4 id="aip-doc-limites-titre">
                <twig:UX:Icon name="{{ resolve_icon_name('action:password') }}" style="width:16px;height:16px;" aria-hidden="true" />
                Ses limites protègent vos données
            </h4>
            <ul>
                <li>
                    <span class="aip-lim-ic" aria-hidden="true">
                        <twig:UX:Icon name="{{ resolve_icon_name('action:check') }}" style="width:16px;height:16px;" />
                    </span>
                    <span>Il ne voit que le périmètre d'accès du collaborateur qui l'interroge :
                          sans droit de lecture sur une rubrique, la donnée n'existe pas pour lui.</span>
                </li>
                <li>
                    <span class="aip-lim-ic" aria-hidden="true">
                        <twig:UX:Icon name="{{ resolve_icon_name('action:check') }}" style="width:16px;height:16px;" />
                    </span>
                    <span>Il n'écrit jamais directement dans vos données et n'envoie jamais rien lui-même :
                          toute création ou modification passe par un formulaire que le collaborateur valide,
                          le pré-remplissage n'utilise que les valeurs dictées, et tout envoi (relevé SOA)
                          est confirmé par le collaborateur dans la boîte d'envoi.</span>
                </li>
                <li>
                    <span class="aip-lim-ic" aria-hidden="true">
                        <twig:UX:Icon name="{{ resolve_icon_name('action:check') }}" style="width:16px;height:16px;" />
                    </span>
                    <span>Il n'invente jamais de chiffres : tout provient de vos données, calculé
                          à l'instant de la demande — et il n'a accès ni à internet ni aux autres espaces de travail.</span>
                </li>
            </ul>
        </aside>
    </section>

    <div class="aip-panel">
        {% if enregistre %}
            <p class="aip-feedback aip-feedback--success" role="status">
                Le nom de votre assistant a bien été enregistré : il s'appelle désormais
                « {{ assistantNom }} ».
            </p>
        {% endif %}
        {% if erreur %}
            <p class="aip-feedback aip-feedback--error" role="alert">{{ erreur }}</p>
        {% endif %}

        <form data-action="submit->assistant-ia-parametres#save" data-assistant-ia-parametres-target="form">
            <fieldset class="aip-fieldset">
                <legend class="aip-legend">
                    <twig:UX:Icon name="{{ resolve_icon_name('assistant-ia') }}" style="width:16px;height:16px;" />
                    Identité du personnage
                </legend>
                <label class="form-label" for="aip-nom">Nom de l'assistant</label>
                <div class="aip-inputbox">
                    <span class="aip-input-ic" aria-hidden="true">
                        <twig:UX:Icon name="{{ resolve_icon_name('utilisateur') }}" style="width:20px;height:20px;" />
                    </span>
                    <input type="text" class="form-control" id="aip-nom" name="nom"
                           value="{{ assistantNom }}" minlength="2" maxlength="60" required
                           placeholder="Ex. Modogo"
                           aria-describedby="aip-nom-aide">
                </div>
                <div class="form-text" id="aip-nom-aide">
                    Entre 2 et 60 caractères. Sans personnalisation, l'assistant s'appelle
                    « {{ nomParDefaut }} ».
                </div>
            </fieldset>

            <div class="aip-actions">
                <button type="submit" class="btn btn-cobalt" data-assistant-ia-parametres-target="submit">
                    <span class="spinner-border" role="status" aria-hidden="true"
                          style="display:none;" data-role="spinner"></span>
                    <span data-role="icon" style="display:inline-flex;">
                        <twig:UX:Icon name="{{ resolve_icon_name('action:save') }}" style="width:18px;height:18px;" />
                    </span>
                    <span data-role="label">Enregistrer</span>
                </button>
            </div>
        </form>
    </div>
</div>
