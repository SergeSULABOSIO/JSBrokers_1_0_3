{#
  Panneau de chat de l'assistant IA — injecté dans la COLONNE 4 (visualisation)
  via l'événement `app:workspace.open-html-in-visualization` (workspace-manager).

  Interface type « chat Claude » aux couleurs JS Brokers : bulles assistant à
  gauche (fond blanc bordé), bulles utilisateur à droite (fond cobalt subtil
  #e8f0fb — jamais de cobalt plein sous du texte courant), refus périmètre
  signalé par un liseré avertissement. AUCUN <script> inline : l'interactivité
  est portée par le contrôleur Stimulus `assistant-chat` (instancié
  automatiquement dans le HTML injecté).
#}
<div class="jsb-ai-chat"
     data-controller="assistant-chat"
     data-assistant-chat-send-url-value="{{ path('admin.assistantia.api.message.send', {idEntreprise: idEntreprise, idConversation: conversation.id}) }}"
     data-assistant-chat-dialog-context-url-value="{{ path('admin.assistantia.api.dialog_context', {idEntreprise: idEntreprise}) }}"
     data-assistant-chat-visual-context-url-value="{{ path('admin.assistantia.api.visual_context', {idEntreprise: idEntreprise}) }}"
     data-assistant-chat-contexte-url-value="{{ path('admin.assistantia.api.contexte.attach', {idEntreprise: idEntreprise, idConversation: conversation.id}) }}"
     data-assistant-chat-id-entreprise-value="{{ idEntreprise }}"
     data-assistant-chat-id-invite-value="{{ idInvite }}"
     data-assistant-chat-id-conversation-value="{{ conversation.id }}"
     data-assistant-chat-assistant-nom-value="{{ assistantNom }}"
     data-action="assistant:contexte.attach-request->assistant-chat#attachFromEvent">
    <style>
        .jsb-ai-chat { display:flex; flex-direction:column; height:100%; min-height:0; background:#f8f9fa; }

        /* ── Entête ── */
        .jsb-ai-chat .aic-header {
            display:flex; align-items:center; gap:.65rem; flex:0 0 auto;
            padding:.75rem 1rem; background:#ffffff; border-bottom:1px solid #dee2e6;
        }
        .jsb-ai-chat .aic-avatar {
            width:40px; height:40px; border-radius:50%; flex:0 0 auto;
            background:#0047AB; color:#ffffff; font-weight:700; font-size:1.05rem;
            display:flex; align-items:center; justify-content:center;
        }
        .jsb-ai-chat .aic-header-txt { min-width:0; }
        .jsb-ai-chat .aic-header-nom { color:#212529; font-weight:700; font-size:1rem; margin:0; }
        .jsb-ai-chat .aic-header-sub { color:#6c757d; font-size:.78rem; margin:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
        .jsb-ai-chat .aic-close {
            margin-left:auto; background:none; border:none; color:#6c757d; cursor:pointer;
            width:36px; height:36px; border-radius:8px; display:flex; align-items:center; justify-content:center;
        }
        .jsb-ai-chat .aic-close:hover { background:#e9ecef; color:#212529; }
        .jsb-ai-chat .aic-close:focus-visible { outline:2px solid #0047AB; outline-offset:2px; }

        /* ── Fil de messages ── */
        .jsb-ai-chat .aic-messages { flex:1 1 auto; min-height:0; overflow-y:auto; padding:1rem; display:flex; flex-direction:column; gap:.75rem; }
        .jsb-ai-chat .aic-msg { display:flex; gap:.5rem; max-width:92%; }
        .jsb-ai-chat .aic-msg--assistant { align-self:flex-start; }
        .jsb-ai-chat .aic-msg--user { align-self:flex-end; flex-direction:row-reverse; }
        .jsb-ai-chat .aic-msg-avatar {
            width:28px; height:28px; border-radius:50%; flex:0 0 auto; margin-top:2px;
            background:#0047AB; color:#ffffff; font-weight:700; font-size:.8rem;
            display:flex; align-items:center; justify-content:center;
        }
        .jsb-ai-chat .aic-msg-body { min-width:0; display:flex; flex-direction:column; gap:.15rem; }
        .jsb-ai-chat .aic-msg-text {
            margin:0; padding:.6rem .8rem; border-radius:12px;
            color:#212529; font-size:.9rem; line-height:1.5; white-space:pre-wrap; word-break:break-word;
        }
        .jsb-ai-chat .aic-msg--assistant .aic-msg-text {
            background:#ffffff; border:1px solid #dee2e6; border-top-left-radius:4px;
            /* Contenu HTML structuré (Markdown rendu) : les éléments de bloc
               gèrent déjà leurs propres marges, pre-wrap ne sert plus qu'à
               préserver les sauts de ligne du texte brut utilisateur. */
            white-space:normal;
        }
        .jsb-ai-chat .aic-msg--user .aic-msg-text { background:#e8f0fb; border-top-right-radius:4px; }
        .jsb-ai-chat .aic-msg--refus .aic-msg-text { border-left:3px solid #ffc107; }

        /* Rendu Markdown restreint des réponses assistant (voir
           assistant-markdown-render.js) : sobre, densité compacte adaptée à
           une bulle de largeur limitée. */
        .jsb-ai-chat .aic-msg-text p { margin:0 0 .5rem; }
        .jsb-ai-chat .aic-msg-text p:last-child { margin-bottom:0; }
        .jsb-ai-chat .aic-msg-text ul,
        .jsb-ai-chat .aic-msg-text ol { margin:0 0 .5rem; padding-left:1.2rem; }
        .jsb-ai-chat .aic-msg-text ul:last-child,
        .jsb-ai-chat .aic-msg-text ol:last-child { margin-bottom:0; }
        .jsb-ai-chat .aic-msg-text li { margin-bottom:.15rem; }
        .jsb-ai-chat .aic-msg-text strong { color:#212529; font-weight:700; }
        .jsb-ai-chat .aic-msg-text code {
            background:#f1f3f5; color:#212529; border-radius:4px;
            padding:.05rem .3rem; font-size:.85em;
        }
        .jsb-ai-chat .aic-md-heading { margin:.2rem 0 .35rem; font-size:.92rem; font-weight:700; color:#343a40; }
        /* Un tableau large ne doit JAMAIS élargir ni écraser la bulle : il devient
           lui-même la boîte défilante. `width:max-content` donne aux colonnes leur
           largeur naturelle, `max-width:100%` les borne à la bulle (donc à la colonne
           de visualisation) et `overflow-x:auto` ne montre la barre horizontale que
           si ça dépasse — les messages sans tableau large restent inchangés. */
        .jsb-ai-chat .aic-msg-text table {
            border-collapse:separate; border-spacing:0; margin:.3rem 0 .5rem; font-size:.83rem;
            display:block; width:max-content; max-width:100%; overflow-x:auto;
        }
        /* nowrap l'emporte sur le word-break hérité de .aic-msg-text : une
           référence de police ou un montant ne se casse plus en plusieurs lignes. */
        .jsb-ai-chat .aic-msg-text th,
        .jsb-ai-chat .aic-msg-text td { border-bottom:1px solid #dee2e6; padding:.3rem .5rem; text-align:left; white-space:nowrap; }
        .jsb-ai-chat .aic-msg-text th { color:#6c757d; font-weight:600; text-transform:uppercase; letter-spacing:.3px; font-size:.72rem; }
        .jsb-ai-chat .aic-msg-text td { color:#495057; }
        /* Feedback local sur chaque LIGNE de données, dans la même langue que
           les bulles et les listes du produit : SURVOL (fond #f8f9fa, idiome
           .table-enhanced / .jsb-picker-table d'app.css, texte plus contrasté)
           et CLIC (fond cobalt subtil, idiome .db-fb-item:active). L'entête
           n'est pas concerné : seules les données sont survolables. */
        .jsb-ai-chat .aic-msg-text tbody td { transition:background-color .12s ease, color .12s ease; }
        .jsb-ai-chat .aic-msg-text tbody tr:hover td { background:#f8f9fa; color:#212529; }
        .jsb-ai-chat .aic-msg-text tbody tr:active td { background:#e8f0fb; }
        /* Pastilles : mêmes couleurs sémantiques que .jsb-state-badge (app.css). */
        .jsb-ai-chat .aic-md-badge {
            display:inline-block; padding:.1rem .5rem; border-radius:999px;
            font-size:.75rem; font-weight:600; line-height:1.3; white-space:nowrap;
        }
        .jsb-ai-chat .aic-md-badge--success { background:#d1e7dd; color:#0f5132; }
        .jsb-ai-chat .aic-md-badge--danger  { background:#f8d7da; color:#842029; }
        .jsb-ai-chat .aic-md-badge--warning { background:#fff3cd; color:#664d03; }
        .jsb-ai-chat .aic-md-badge--info    { background:#e8f0fb; color:#0047AB; }
        .jsb-ai-chat .aic-md-badge--neutral { background:#e9ecef; color:#495057; }

        /* Feedback local sur chaque bulle : SURVOL (liseré cobalt + élévation
           légère) et CLIC (enfoncement bref) — l'utilisateur « sent » chaque
           message sous la souris. Transition douce, couleurs de la charte. */
        .jsb-ai-chat .aic-msg .aic-msg-text {
            transition: border-color .15s ease, box-shadow .15s ease, transform .08s ease;
            cursor: default;
        }
        .jsb-ai-chat .aic-msg:hover .aic-msg-text {
            border-color:#0047AB;
            box-shadow:0 3px 10px rgba(0,71,171,.12);
        }
        /* Bulle utilisateur sans bordure de base : on en révèle une au survol
           (transparente au repos pour éviter tout saut de mise en page). */
        .jsb-ai-chat .aic-msg--user .aic-msg-text { border:1px solid transparent; }
        /* Le liseré d'avertissement d'un refus reste jaune, même au survol. */
        .jsb-ai-chat .aic-msg--refus:hover .aic-msg-text { border-left-color:#ffc107; }
        .jsb-ai-chat .aic-msg:active .aic-msg-text { transform:scale(.985); }
        .jsb-ai-chat .aic-msg-time { color:#6c757d; font-size:.7rem; }
        .jsb-ai-chat .aic-msg--user .aic-msg-time { text-align:right; }

        /* Agrafe des messages utilisateur : instantané des objets du contexte à
           l'envoi (pastille discrète, alignée à droite sous la bulle). */
        .jsb-ai-chat .aic-msg-attach {
            align-self:flex-end; display:inline-flex; align-items:center; gap:3px;
            border:1px solid #dee2e6; background:#ffffff; color:#6c757d;
            font-size:.68rem; line-height:1.2; padding:1px 7px; border-radius:999px;
            cursor:pointer; font-family:inherit;
            transition:border-color .15s ease, color .15s ease;
        }
        .jsb-ai-chat .aic-msg-attach:hover { border-color:#0047AB; color:#0047AB; }
        .jsb-ai-chat .aic-msg-attach:focus-visible { outline:2px solid #0047AB; outline-offset:2px; }

        /* Bulles système (402 tokens / erreur réseau). */
        .jsb-ai-chat .aic-notice { margin:0; padding:.6rem .8rem; border-radius:8px; font-size:.85rem; align-self:center; max-width:92%; }
        .jsb-ai-chat .aic-notice--warning { background:#fff3cd; color:#664d03; }
        .jsb-ai-chat .aic-notice--error { background:#f8d7da; color:#842029; }

        /* Indicateur « réfléchit… ». */
        .jsb-ai-chat .aic-typing { flex:0 0 auto; display:flex; align-items:center; gap:.45rem; padding:.25rem 1rem .5rem; color:#6c757d; font-size:.82rem; }
        .jsb-ai-chat .aic-typing[hidden] { display:none; }
        .jsb-ai-chat .aic-typing .dot {
            width:6px; height:6px; border-radius:50%; background:#6c757d;
            animation: aic-blink 1.2s infinite ease-in-out;
        }
        .jsb-ai-chat .aic-typing .dot:nth-child(2) { animation-delay:.2s; }
        .jsb-ai-chat .aic-typing .dot:nth-child(3) { animation-delay:.4s; }
        @keyframes aic-blink { 0%, 80%, 100% { opacity:.25; } 40% { opacity:1; } }

        /* ── Zone de saisie (groupe champ + envoi, focus-within visible) ── */
        .jsb-ai-chat .aic-composer {
            flex:0 0 auto; display:flex; flex-direction:column; gap:.35rem;
            padding:.75rem 1rem .6rem; background:#ffffff; border-top:1px solid #dee2e6;
        }

        /* ── Objets attachés au contexte (puces au-dessus de la saisie) ── */
        .jsb-ai-chat .aic-context { display:flex; flex-direction:column; gap:.3rem; }
        .jsb-ai-chat .aic-context:empty { display:none; }
        .jsb-ai-chat .aic-context-head {
            display:flex; align-items:center; justify-content:space-between; gap:.75rem;
        }
        .jsb-ai-chat .aic-context-count { color:#6c757d; font-size:.74rem; }
        .jsb-ai-chat .aic-context-clear {
            display:inline-flex; align-items:center; gap:.25rem;
            background:none; border:none; cursor:pointer;
            color:#6c757d; font-size:.74rem; padding:.15rem .4rem; border-radius:6px;
            transition: color .15s ease, background-color .15s ease;
        }
        .jsb-ai-chat .aic-context-clear:hover { color:#842029; background:#f8d7da; }
        .jsb-ai-chat .aic-context-clear:focus-visible { outline:2px solid #0047AB; outline-offset:2px; }
        .jsb-ai-chat .aic-context-chips {
            display:flex; flex-wrap:wrap; gap:.35rem;
            list-style:none; margin:0; padding:0;
        }
        .jsb-ai-chat .aic-chip {
            display:inline-flex; align-items:center; gap:.3rem; max-width:100%;
            background:#e8f0fb; border:1px solid transparent; border-radius:999px;
            padding:.2rem .3rem .2rem .6rem; font-size:.78rem; color:#212529;
            transition: border-color .15s ease, box-shadow .15s ease;
        }
        .jsb-ai-chat .aic-chip:hover { border-color:#0047AB; box-shadow:0 2px 6px rgba(0,71,171,.25); }
        .jsb-ai-chat .aic-chip-icon { display:flex; flex:0 0 auto; color:#0047AB; }
        .jsb-ai-chat .aic-chip-label {
            min-width:0; max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
        }
        .jsb-ai-chat .aic-chip-remove {
            display:flex; align-items:center; justify-content:center; flex:0 0 auto;
            width:22px; height:22px; border-radius:50%; border:none; cursor:pointer;
            background:none; color:#6c757d;
            transition: background-color .15s ease, color .15s ease;
        }
        .jsb-ai-chat .aic-chip-remove:hover { background:#0047AB; color:#ffffff; }
        .jsb-ai-chat .aic-chip-remove:focus-visible { outline:2px solid #0047AB; outline-offset:1px; }
        .jsb-ai-chat .aic-inputbox {
            display:flex; align-items:flex-end; gap:.5rem;
            border:1px solid #ced4da; border-radius:12px; background:#ffffff;
            padding:.3rem .35rem .3rem .7rem;
            transition: border-color .15s ease, box-shadow .15s ease;
        }
        .jsb-ai-chat .aic-inputbox:focus-within { border-color:#0047AB; box-shadow:0 0 0 .25rem rgba(0,71,171,.35); }
        .jsb-ai-chat .aic-input-ic { flex:0 0 auto; align-self:center; display:flex; color:#6c757d; }
        .jsb-ai-chat .aic-input {
            flex:1 1 auto; resize:none; min-height:40px; max-height:160px;
            border:none; background:transparent; padding:.5rem .25rem;
            font-size:.9rem; color:#000000; line-height:1.45;
        }
        .jsb-ai-chat .aic-input:focus { outline:none; box-shadow:none; }
        .jsb-ai-chat .aic-send {
            flex:0 0 auto; width:44px; height:44px; border-radius:10px; border:none; cursor:pointer;
            background:#0047AB; color:#ffffff; display:flex; align-items:center; justify-content:center;
            transition: background-color .15s ease, opacity .15s ease;
        }
        .jsb-ai-chat .aic-send:hover { background:#003380; }
        .jsb-ai-chat .aic-send:focus-visible { outline:2px solid #0047AB; outline-offset:2px; }
        .jsb-ai-chat .aic-send:disabled { opacity:.65; pointer-events:none; }
        /* Pied du composer : indice de raccourcis + compteur près de la limite. */
        .jsb-ai-chat .aic-composer-foot {
            display:flex; justify-content:space-between; gap:.75rem;
            font-size:.72rem; color:#6c757d; padding:0 .25rem;
        }
        .jsb-ai-chat .aic-count[hidden] { display:none; }
        .jsb-ai-chat .aic-count--limite { color:#664d03; font-weight:600; }
        .jsb-ai-chat .visually-hidden {
            position:absolute; width:1px; height:1px; padding:0; margin:-1px;
            overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0;
        }
    </style>

    {# ── Entête ── #}
    <div class="aic-header">
        <span class="aic-avatar" aria-hidden="true">{{ assistantNom|first|upper }}</span>
        <div class="aic-header-txt">
            <p class="aic-header-nom">{{ assistantNom }}</p>
            <p class="aic-header-sub">Assistant IA · {{ entreprise.nom }}</p>
        </div>
        <button type="button" class="aic-close" data-action="click->workspace-manager#closeTab"
                aria-label="Fermer la conversation">
            <twig:UX:Icon name="{{ resolve_icon_name('action:exit') }}" style="width:20px;height:20px;" />
        </button>
    </div>

    {# ── Fil de messages ── #}
    <div class="aic-messages" role="log" aria-live="polite"
         aria-label="Conversation avec {{ assistantNom }}"
         data-assistant-chat-target="messages">
        {% if conversation.messages is empty %}
            <div class="aic-msg aic-msg--assistant">
                <span class="aic-msg-avatar" aria-hidden="true">{{ assistantNom|first|upper }}</span>
                <div class="aic-msg-body">
                    <p class="aic-msg-text">Bonjour ! Je suis {{ assistantNom }}, l'assistant IA de {{ entreprise.nom }}. Posez-moi une question sur les données de votre espace de travail — par exemple « Combien de clients avons-nous ? » ou « Quel est mon périmètre d'accès ? ».</p>
                </div>
            </div>
        {% endif %}
        {% for message in conversation.messages %}
            {% set estAssistant = message.role == 'assistant' %}
            {% set estRefus = estAssistant and (message.meta.refus ?? false) %}
            <div class="aic-msg aic-msg--{{ estAssistant ? 'assistant' : 'user' }}{{ estRefus ? ' aic-msg--refus' }}">
                {% if estAssistant %}
                    <span class="aic-msg-avatar" aria-hidden="true">{{ assistantNom|first|upper }}</span>
                {% endif %}
                <div class="aic-msg-body">
                    {% if estAssistant %}
                        <p class="aic-msg-text" data-md-source="{{ message.contenu|e('html_attr') }}">{{ message.contenu }}</p>
                    {% else %}
                        <p class="aic-msg-text">{{ message.contenu }}</p>
                    {% endif %}
                    {# Agrafe : instantané IMMUABLE des objets du contexte à l'envoi de CE
                       message (le contexte courant de la conversation évolue, ce cliché
                       jamais). Survol = infobulle sombre ; clic = épinglage. #}
                    {% if not estAssistant and message.contexteObjets %}
                        {% set agrafe = [] %}
                        {% for o in message.contexteObjets %}
                            {% set agrafe = agrafe|merge([o|merge({typeLabel: token_entite_label('App\\Entity\\' ~ o.type)})]) %}
                        {% endfor %}
                        <button type="button" class="aic-msg-attach"
                                data-msg-contextes="{{ agrafe|json_encode|e('html_attr') }}"
                                data-action="click->assistant-chat#toggleMsgContextes"
                                aria-label="{{ message.contexteObjets|length }} objet{{ message.contexteObjets|length > 1 ? 's' : '' }} en contexte à l'envoi de ce message">
                            {{ ux_icon(resolve_icon_name('lucide:paperclip'), {height: '11px', width: '11px'}) }}
                            <span>{{ message.contexteObjets|length }}</span>
                        </button>
                    {% endif %}
                    {# Heure seule pour les messages du jour, date + heure au-delà. #}
                    {% set memeJour = message.createdAt|date('Y-m-d') == 'now'|date('Y-m-d') %}
                    <span class="aic-msg-time">{{ message.createdAt|date(memeJour ? 'H:i' : 'd/m/Y H:i') }}</span>
                </div>
            </div>
        {% endfor %}
    </div>

    {# ── Indicateur de génération ── #}
    <div class="aic-typing" hidden data-assistant-chat-target="typing" aria-live="polite">
        <span class="dot" aria-hidden="true"></span>
        <span class="dot" aria-hidden="true"></span>
        <span class="dot" aria-hidden="true"></span>
        {# Libellé contextuel : « réfléchit… » pendant l'attente serveur,
           « écrit… » pendant le déploiement mot à mot de la réponse. #}
        <span data-assistant-chat-target="typingLabel">{{ assistantNom }} réfléchit…</span>
    </div>

    {# ── Zone de saisie ── #}
    <div class="aic-composer">
        {# Objets attachés au contexte : re-rendus par les endpoints API (clé
           `html`), le contrôleur Stimulus remplace ce innerHTML. #}
        <div class="aic-context" data-assistant-chat-target="contextBar">
            {% include 'components/_assistant_ia_chat_contextes.html.twig' with {
                conversation: conversation,
                fichesContextes: fichesContextes|default({}),
            } only %}
        </div>
        <div class="aic-inputbox">
            <span class="aic-input-ic" aria-hidden="true">
                <twig:UX:Icon name="{{ resolve_icon_name('feedback') }}" style="width:20px;height:20px;" />
            </span>
            <label class="visually-hidden" for="aic-input-{{ conversation.id }}">Votre message à {{ assistantNom }}</label>
            <textarea id="aic-input-{{ conversation.id }}" class="aic-input" rows="1"
                      placeholder="Posez votre question à {{ assistantNom }}…"
                      maxlength="4000"
                      aria-describedby="aic-hint-{{ conversation.id }} aic-count-{{ conversation.id }}"
                      data-assistant-chat-target="input"
                      data-action="keydown->assistant-chat#keydown input->assistant-chat#onInput"></textarea>
            <button type="button" class="aic-send" disabled
                    data-assistant-chat-target="send"
                    data-action="click->assistant-chat#send"
                    aria-label="Envoyer le message"
                    title="Envoyer le message">
                <twig:UX:Icon name="{{ resolve_icon_name('action:send-email') }}" style="width:20px;height:20px;" />
            </button>
        </div>
        <div class="aic-composer-foot">
            <span class="aic-hint" id="aic-hint-{{ conversation.id }}">Entrée : envoyer · Maj + Entrée : retour à la ligne</span>
            <span class="aic-count" id="aic-count-{{ conversation.id }}" hidden
                  aria-live="polite" data-assistant-chat-target="count"></span>
        </div>
    </div>
</div>
