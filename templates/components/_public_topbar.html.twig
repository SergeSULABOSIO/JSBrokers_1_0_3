{# ============================================================
   En-tête public réutilisable (vitrine JS Brokers).
   Logo + navigation par ancres + bascule de langue FR/EN + CTA.
   Charte : cobalt #0047AB, neutres Bootstrap. Styles dans _home_styles.html.twig.
   `lang` est fourni par le contrôleur ; on retombe sur la locale courante sinon.
   ============================================================ #}
{% set lang = lang|default(app.request.locale|default('fr')) %}

<header class="public-topbar">
    <div class="public-topbar__inner">

        {# Marque : retour en haut de la vitrine #}
        <a href="{{ path('app_index') }}" class="public-brand" aria-label="JS Brokers">
            <img src="{{ asset('images/entreprises/logofav.png') }}" alt="" width="36" height="36">
            <span>JS Brokers</span>
        </a>

        {# Navigation par ancres (masquée sous 768px pour rester lisible) #}
        <nav class="public-nav" aria-label="{{ 'security_some_key_fitures' | trans }}">
            <a href="#features">{{ "home_nav_features" | trans }}</a>
            <a href="#guide">{{ "home_nav_guide" | trans }}</a>
            <a href="#pricing_plan">{{ "home_nav_pricing" | trans }}</a>
            <a href="#contact">{{ "home_nav_contact" | trans }}</a>
        </nav>

        <div class="public-topbar__actions">

            {# Bascule de langue unifiée : auto-suffisante via ?lang= (fonctionne hors session).
               Chaque bascule est une navigation serveur complète → barre de progression
               du haut (top-progress#show) pour un feedback immédiat. #}
            {{ include('components/_lang_switch.html.twig', {current: lang, route: 'app_index', uid: 'lang-top'}) }}

            {# CTA contextuel selon l'état de connexion (réutilise les clés base_*).
               Chaque CTA mène à une requête serveur → feedback local (spinner via
               form-submit#navigating) + barre de progression (top-progress#show), et
               ripple au clic. Icônes via le provider (resolve_icon_name). #}
            {% if app.user %}
                <a href="{{ path('app_login') }}"
                   class="btn btn-cobalt public-cta gap-2"
                   data-controller="ripple"
                   data-action="click->form-submit#navigating click->top-progress#show"
                   data-loading-text="{{ 'base_mon_espace' | trans }}">
                    {{ ux_icon(resolve_icon_name('dashboard'), {height: '18px', width: '18px'}) }}
                    <span>{{ "base_mon_espace" | trans }}</span>
                </a>
            {% else %}
                <a href="{{ path('app_login') }}"
                   class="btn btn-outline-secondary public-cta public-cta--ghost gap-2"
                   data-controller="ripple"
                   data-action="click->form-submit#navigating click->top-progress#show"
                   data-loading-text="{{ 'base_connexion' | trans }}">
                    {{ ux_icon(resolve_icon_name('utilisateur'), {height: '18px', width: '18px'}) }}
                    <span>{{ "base_connexion" | trans }}</span>
                </a>
                <a href="{{ path('app_register', {idUtilisateur: -1}) }}"
                   class="btn btn-cobalt public-cta gap-2"
                   data-controller="ripple"
                   data-action="click->form-submit#navigating click->top-progress#show"
                   data-loading-text="{{ 'base_new_account' | trans }}">
                    {{ ux_icon(resolve_icon_name('action:add'), {height: '18px', width: '18px'}) }}
                    <span>{{ "base_new_account" | trans }}</span>
                </a>
            {% endif %}
        </div>
    </div>
</header>
