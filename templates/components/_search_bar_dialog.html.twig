<div
    class="modal fade app-dialog"
    data-controller="search-bar-dialog"
    data-search-bar-dialog-target="advancedSearchModal"
    tabindex="-1"
    data-bs-backdrop="static"
    data-bs-keyboard="false"
    role="dialog"
    aria-modal="true"
    aria-labelledby="jsb-advanced-search-title"
>
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content jsb-search-dialog">
            <div class="modal-header jsb-search-dialog__header">
                <h5 class="modal-title" id="jsb-advanced-search-title">
                    <twig:ux:icon name="{{ resolve_icon_name('lucide:sliders-horizontal') }}" aria-hidden="true" style="width:20px;height:20px;margin-right:.5rem;" />
                    Recherche Avancée
                </h5>
                <button type="button" class="btn-close btn-close-white"
                    data-action="click->search-bar-dialog#cancel"
                    aria-label="Fermer la recherche avancée"></button>
            </div>
            <div class="modal-body bg-white">
                <form aria-label="Formulaire de recherche avancée">
                    <div
                        data-search-bar-dialog-target="advancedFormContainer"
                        class="form-scrollable-content jsb-advanced-form"
                        data-action="input->search-bar-dialog#onFieldInput change->search-bar-dialog#onFieldInput click->search-bar-dialog#onFieldInput"
                    ></div>
                    <div class="d-flex justify-content-end mt-4 border-top pt-3 gap-2">
                        <button type="button" class="btn btn-outline-secondary"
                            data-action="click->search-bar-dialog#resetForm">
                            <twig:ux:icon name="{{ resolve_icon_name('lucide:rotate-cw') }}" aria-hidden="true" class="me-1" style="width:16px;height:16px;" />
                            Réinitialiser
                        </button>
                        <button type="button" class="btn jsb-btn-cobalt"
                            data-action="click->search-bar-dialog#submitAdvancedSearch">
                            <twig:ux:icon name="{{ resolve_icon_name('lucide:search') }}" aria-hidden="true" class="me-1" style="width:16px;height:16px;" />
                            Rechercher
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
