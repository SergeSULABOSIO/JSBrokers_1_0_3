<div class="mb-3">
    <h6 class="fw-semibold mb-3" style="color:#0047AB;">
        <twig:UX:Icon name="mdi:calendar-clock" style="width:18px;height:18px;" class="me-1" />
        Renouvellements à venir
        <span class="badge rounded-pill text-bg-secondary ms-1" style="font-size:.7rem;">30 jours</span>
    </h6>

    {% if renouvellements|length > 0 %}
        <div class="row g-2">
            {% for avenant in renouvellements %}
                <div class="col-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-3">
                            <p class="small fw-semibold mb-1 text-truncate"
                               title="{{ avenant.cotation.piste.client.nom ?? '—' }}">
                                {{ avenant.cotation.piste.client.nom ?? '—' }}
                            </p>
                            <p class="x-small text-muted mb-1 text-truncate">
                                {{ avenant.description }}
                            </p>
                            <p class="x-small text-muted mb-2">
                                <twig:UX:Icon name="mdi:shield" style="width:12px;height:12px;" class="me-1" />
                                {{ avenant.cotation.assureur.nom ?? '—' }}
                            </p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="small text-muted">
                                    {{ avenant.endingAt|date('d/m/Y') }}
                                </span>
                                <span class="badge rounded-pill bg-warning text-dark" style="font-size:.65rem;">
                                    Échéance
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p class="text-muted small">Aucun renouvellement dans les 30 prochains jours.</p>
    {% endif %}
</div>
