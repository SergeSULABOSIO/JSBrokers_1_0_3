{% set _now = date() %}
{% set countJ30 = 0 %}
{% set countJ60 = 0 %}
{% set countJ61plus = 0 %}
{% for s in derniersSinistres %}
    {% if s.notifiedAt %}
        {% set _diff = (_now|date('U') - s.notifiedAt|date('U')) / 86400 %}
        {% if _diff <= 30 %}
            {% set countJ30 = countJ30 + 1 %}
        {% elseif _diff <= 60 %}
            {% set countJ60 = countJ60 + 1 %}
        {% else %}
            {% set countJ61plus = countJ61plus + 1 %}
        {% endif %}
    {% else %}
        {% set countJ61plus = countJ61plus + 1 %}
    {% endif %}
{% endfor %}

<div class="px-3 pt-2 pb-2 bg-white">
            <div class="d-flex align-items-center gap-2">
                <div class="db-prod-tabs" id="dbSinToggleBar">
                    <button class="db-task-toggle active" data-mode="j30"     onclick="dbSinistreToggle(this)" aria-pressed="true">≤ 30 jrs ({{ countJ30 }})</button>
                    <button class="db-task-toggle"        data-mode="j60"     onclick="dbSinistreToggle(this)" aria-pressed="false">31-60 jrs ({{ countJ60 }})</button>
                    <button class="db-task-toggle"        data-mode="j61plus" onclick="dbSinistreToggle(this)" aria-pressed="false">61+ jrs ({{ countJ61plus }})</button>
                </div>
                <div class="ms-auto input-group input-group-sm flex-shrink-0" role="search" style="max-width:130px;">
                    <span class="input-group-text border-0 bg-light px-2">
                        <twig:UX:Icon name="mdi:magnify" style="width:13px;height:13px;color:#6c757d;" />
                    </span>
                    <input type="search"
                           aria-label="Filtrer les sinistres"
                           placeholder="Filtrer..."
                           class="form-control form-control-sm border-0 bg-light"
                           style="font-size:.72rem;"
                           oninput="dbSinistreSearch(this)">
                </div>
            </div>
        </div>
        <div id="db-sin-list"
             class="card-body p-2 db-tasks-scroll"
             data-sinistres-url="/admin/entreprise_dashbord/sinistres-fragment/{{ entreprise.id }}">
            {% include 'components/dashboard/_sinistres_list.html.twig' with {
                'derniersSinistres': derniersSinistres
            } %}
        </div>

<nav id="dbSinCtxMenu" class="context-menu" aria-label="Menu contextuel sinistre" style="display:none;"
     onmousedown="event.stopPropagation()">
    <ul role="menu" class="list-unstyled mb-0">
        <li role="menuitem" tabindex="-1" id="dbSinCtxEditItem"
            class="d-flex align-items-center gap-2 px-3 py-2" style="cursor:pointer;">
            <span class="context-menu-icon" aria-hidden="true">
                <twig:UX:Icon name="tabler:edit" style="width:16px;height:16px;" />
            </span>
            <span class="flex-grow-1">Éditer le sinistre</span>
        </li>
        <li role="separator" class="separator"></li>
        <li role="menuitem" tabindex="-1" id="dbSinCtxDeleteItem"
            class="d-flex align-items-center gap-2 px-3 py-2 is-danger" style="cursor:pointer;">
            <span class="context-menu-icon" aria-hidden="true">
                <twig:UX:Icon name="fluent:delete-20-filled" style="width:16px;height:16px;" />
            </span>
            <span class="flex-grow-1">Supprimer</span>
        </li>
    </ul>
</nav>
