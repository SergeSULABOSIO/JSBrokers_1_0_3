{% set tcTaux = revenusBreakdown.taxeCourtier.taux %}
{% set taTaux = revenusBreakdown.taxeAssureur.taux %}

<div class="kpi-carousel-wrapper mb-3">
    <div class="kpi-carousel">

        {# ── Polices actives ── #}
        <div class="kpi-card-slot">
            <div class="card kpi-card"
                 tabindex="0"
                 role="button"
                 style="border-left: 4px solid #0047AB !important;"
                 aria-label="Polices : {{ policiesActives }}">
                <div class="card-body py-3 px-3 d-flex flex-column justify-content-between">
                    <div class="d-flex align-items-center">
                        <twig:UX:Icon name="emojione-monotone:umbrella-with-rain-drops"
                                      style="width:16px;height:16px;color:#0047AB;"
                                      class="me-2 flex-shrink-0" />
                        <span class="small text-muted" style="font-size:.74rem;">Polices</span>
                    </div>
                    <p class="fw-bold mb-0" style="font-size:1.26rem;color:#0047AB;">{{ policiesActives }}</p>
                    <p class="small text-muted mb-0" style="font-size:.74rem;">En cours</p>
                </div>
            </div>
        </div>

        {# ── Primes TTC ── #}
        <div class="kpi-card-slot">
            <div class="card kpi-card"
                 tabindex="0"
                 role="button"
                 style="border-left: 4px solid #198754 !important;"
                 aria-label="Primes : {{ primesTotales|number_format(0, ',', ' ') }} $">
                <div class="card-body py-3 px-3 d-flex flex-column justify-content-between">
                    <div class="d-flex align-items-center">
                        <twig:UX:Icon name="healthicons:money-bag"
                                      style="width:16px;height:16px;color:#198754;"
                                      class="me-2 flex-shrink-0" />
                        <span class="small text-muted" style="font-size:.74rem;">Primes</span>
                    </div>
                    <p class="fw-bold mb-0" style="font-size:1.05rem;color:#198754;">{{ primesTotales|number_format(0, ',', ' ') }} $</p>
                    <p class="small text-muted mb-0" style="font-size:.74rem;">Polices actives</p>
                </div>
            </div>
        </div>

        {# ── Commissions TTC ── #}
        <div class="kpi-card-slot">
            <div class="card kpi-card"
                 tabindex="0"
                 role="button"
                 style="border-left: 4px solid #0d6efd !important;"
                 aria-label="Com : {{ commissions|number_format(0, ',', ' ') }} $">
                <div class="card-body py-3 px-3 d-flex flex-column justify-content-between">
                    <div class="d-flex align-items-center">
                        <twig:UX:Icon name="mdi:bank-transfer"
                                      style="width:16px;height:16px;color:#0d6efd;"
                                      class="me-2 flex-shrink-0" />
                        <span class="small text-muted" style="font-size:.74rem;">Com</span>
                    </div>
                    <p class="fw-bold mb-0" style="font-size:1.05rem;color:#0d6efd;">{{ commissions|number_format(0, ',', ' ') }} $</p>
                    <p class="small text-muted mb-0" style="font-size:.74rem;">Polices actives</p>
                </div>
            </div>
        </div>

        {# ── Rétrocommission ── #}
        <div class="kpi-card-slot">
            <div class="card kpi-card"
                 tabindex="0"
                 role="button"
                 style="border-left: 4px solid #e69500 !important;"
                 aria-label="Rétro : {{ retrocommissions|number_format(0, ',', ' ') }} $">
                <div class="card-body py-3 px-3 d-flex flex-column justify-content-between">
                    <div class="d-flex align-items-center">
                        <twig:UX:Icon name="mdi:hand-coin"
                                      style="width:16px;height:16px;color:#e69500;"
                                      class="me-2 flex-shrink-0" />
                        <span class="small text-muted" style="font-size:.74rem;">Rétro</span>
                    </div>
                    <p class="fw-bold mb-0" style="font-size:1.05rem;color:#e69500;">{{ retrocommissions|number_format(0, ',', ' ') }} $</p>
                    <p class="small text-muted mb-0" style="font-size:.74rem;">Polices actives</p>
                </div>
            </div>
        </div>

        {# ── Taxes (groupées : courtier + assureur) ── #}
        <div class="kpi-card-slot kpi-card-slot--taxes">
            <div class="card kpi-card kpi-card--taxes"
                 tabindex="0"
                 role="region"
                 style="border-left: 4px solid #6c757d !important;"
                 aria-label="Taxes — Courtier : {{ revenusBreakdown.taxeCourtier.montant|number_format(0, ',', ' ') }} $ / Assureur : {{ revenusBreakdown.taxeAssureur.montant|number_format(0, ',', ' ') }} $">
                <div class="card-body py-2 px-3 d-flex flex-column justify-content-between">

                    <div class="d-flex align-items-center gap-1 mb-1">
                        <twig:UX:Icon name="mdi:percent" style="width:12px;height:12px;color:#6c757d;" class="flex-shrink-0" />
                        <span class="fw-semibold" style="font-size:.74rem;color:#6c757d;">Taxes</span>
                    </div>

                    <div class="d-flex align-items-center justify-content-between gap-1">
                        <div class="d-flex align-items-center gap-1 overflow-hidden">
                            <span class="text-truncate" style="font-size:.60rem;color:#6c757d;">{{ revenusBreakdown.taxeCourtier.nom }}</span>
                            {% if tcTaux > 0 %}
                                <span class="kpi-tax-rate" style="color:#6c757d;">{{ tcTaux == tcTaux|round ? tcTaux|number_format(0) : tcTaux|number_format(1, ',') }}%</span>
                            {% endif %}
                        </div>
                        <span class="fw-bold" style="font-size:.68rem;color:#6c757d;flex-shrink:0;white-space:nowrap;">
                            {{ revenusBreakdown.taxeCourtier.montant|number_format(0, ',', ' ') }} $
                        </span>
                    </div>

                    <hr class="my-1" style="border-color:rgba(0,0,0,.10);">

                    <div class="d-flex align-items-center justify-content-between gap-1">
                        <div class="d-flex align-items-center gap-1 overflow-hidden">
                            <span class="text-truncate" style="font-size:.60rem;color:#495057;">{{ revenusBreakdown.taxeAssureur.nom }}</span>
                            {% if taTaux > 0 %}
                                <span class="kpi-tax-rate" style="color:#495057;">{{ taTaux == taTaux|round ? taTaux|number_format(0) : taTaux|number_format(1, ',') }}%</span>
                            {% endif %}
                        </div>
                        <span class="fw-bold" style="font-size:.68rem;color:#495057;flex-shrink:0;white-space:nowrap;">
                            {{ revenusBreakdown.taxeAssureur.montant|number_format(0, ',', ' ') }} $
                        </span>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>
