<div id="db-sidebar-content" data-workspace-url="/admin/entreprise_dashbord/sidebar/{{ entreprise.id }}">
    <div data-controller="lazy-block"
         data-lazy-block-url-value="/admin/entreprise_dashbord/block/tasks/{{ entreprise.id }}">
        {# Skeleton tasks header : titre + 3 lignes #}
        <div class="db-skeleton-block mb-3 p-3 d-flex flex-column gap-3" style="height:180px;">
            <div class="db-skel-line" style="width:45%;height:.9rem;"></div>
            <div class="d-flex align-items-center gap-2">
                <div class="db-skel-circle" style="width:26px;height:26px;"></div>
                <div class="flex-grow-1 d-flex flex-column gap-2">
                    <div class="db-skel-line" style="width:70%;"></div>
                    <div class="db-skel-line" style="width:35%;height:.55rem;"></div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="db-skel-circle" style="width:26px;height:26px;"></div>
                <div class="flex-grow-1 d-flex flex-column gap-2">
                    <div class="db-skel-line" style="width:55%;"></div>
                    <div class="db-skel-line" style="width:35%;height:.55rem;"></div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="db-skel-circle" style="width:26px;height:26px;"></div>
                <div class="flex-grow-1 d-flex flex-column gap-2">
                    <div class="db-skel-line" style="width:62%;"></div>
                    <div class="db-skel-line" style="width:35%;height:.55rem;"></div>
                </div>
            </div>
        </div>
        {# Skeleton liste tâches : 5 lignes avec badge date #}
        <div class="db-skeleton-block mb-3 p-3 d-flex flex-column gap-3" style="height:280px;">
            <div class="d-flex align-items-center gap-2">
                <div class="db-skel-circle" style="width:26px;height:26px;"></div>
                <div class="flex-grow-1 d-flex flex-column gap-2">
                    <div class="db-skel-line" style="width:65%;"></div>
                    <div class="db-skel-line" style="width:35%;height:.55rem;"></div>
                </div>
                <div class="db-skel-line" style="width:48px;height:.65rem;flex-shrink:0;"></div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="db-skel-circle" style="width:26px;height:26px;"></div>
                <div class="flex-grow-1 d-flex flex-column gap-2">
                    <div class="db-skel-line" style="width:50%;"></div>
                    <div class="db-skel-line" style="width:35%;height:.55rem;"></div>
                </div>
                <div class="db-skel-line" style="width:48px;height:.65rem;flex-shrink:0;"></div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="db-skel-circle" style="width:26px;height:26px;"></div>
                <div class="flex-grow-1 d-flex flex-column gap-2">
                    <div class="db-skel-line" style="width:72%;"></div>
                    <div class="db-skel-line" style="width:35%;height:.55rem;"></div>
                </div>
                <div class="db-skel-line" style="width:48px;height:.65rem;flex-shrink:0;"></div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="db-skel-circle" style="width:26px;height:26px;"></div>
                <div class="flex-grow-1 d-flex flex-column gap-2">
                    <div class="db-skel-line" style="width:45%;"></div>
                    <div class="db-skel-line" style="width:35%;height:.55rem;"></div>
                </div>
                <div class="db-skel-line" style="width:48px;height:.65rem;flex-shrink:0;"></div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <div class="db-skel-circle" style="width:26px;height:26px;"></div>
                <div class="flex-grow-1 d-flex flex-column gap-2">
                    <div class="db-skel-line" style="width:58%;"></div>
                    <div class="db-skel-line" style="width:35%;height:.55rem;"></div>
                </div>
                <div class="db-skel-line" style="width:48px;height:.65rem;flex-shrink:0;"></div>
            </div>
        </div>
    </div>

    {# Classements — fermé par défaut, chargement différé #}
    <details class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block">
        <summary class="card-header border-0 bg-white py-2 px-3">
            <div class="d-flex align-items-center gap-2">
                <twig:UX:Icon name="mdi:podium-gold" style="width:14px;height:14px;color:#0047AB;" />
                <span class="small fw-semibold" style="color:#0047AB;">Classements</span>
                <twig:UX:Icon name="mdi:chevron-down" class="db-block-chevron ms-auto" style="width:15px;height:15px;color:#6c757d;flex-shrink:0;" />
            </div>
        </summary>
        <div data-controller="lazy-block"
             data-lazy-block-url-value="/admin/entreprise_dashbord/block/top-lists/{{ entreprise.id }}">
        </div>
    </details>
</div>
