{#
    Ce template est le composant principal de l'interface utilisateur, représentant le menu interactif global.
    Il est piloté par le contrôleur Stimulus `workspace-manager` (anciennement `espace-de-travail`).

    Sa structure est divisée en quatre colonnes :
    1. `menu-col-1`: La barre de navigation principale avec les icônes des grands modules (Finances, Marketing, etc.).
    2. `menu-col-2`: Une zone de contexte qui affiche soit la description d'un module, soit la liste des "rubriques" (sous-menus) du module sélectionné.
    3. `menu-col-3`: L'espace de travail principal (`workspace`) où les composants de liste (ex: la liste des clients) sont chargés.
    4. `menu-col-4`: La colonne de visualisation (`visualizationColumn`) qui apparaît lorsqu'un élément d'une liste est ouvert. Elle contient un système d'onglets pour afficher les détails de plusieurs éléments.

    Le contrôleur `workspace-manager` gère :
    - La navigation et la mise en évidence des éléments actifs.
    - Le chargement dynamique des composants dans l'espace de travail via des appels au "Cerveau".
    - La création, l'activation et la fermeture des onglets dans la colonne de visualisation.
    - La persistance de l'état (se souvenir de la dernière rubrique ouverte).
#}
{% set menu = menu_data %}
<style>
    /* État d'accueil de l'espace vide (charte cobalt JS Brokers) */
    .ws-welcome { max-width: 720px; margin: 0 auto; padding: 2.5rem 1.5rem; }
    .ws-welcome-head { text-align: center; margin-bottom: 1.75rem; }
    .ws-welcome-emoji {
        display: inline-flex; align-items: center; justify-content: center;
        width: 72px; height: 72px; border-radius: 50%;
        background-color: #e8f0fb; color: #0047AB; margin-bottom: 1rem;
    }
    .ws-welcome-title { font-size: 1.5rem; font-weight: 700; color: #212529; margin: 0 0 .5rem; }
    .ws-welcome-intro { color: #6c757d; margin: 0 auto; max-width: 520px; }
    .ws-welcome-steps { display: flex; flex-direction: column; gap: .75rem; margin-bottom: 1.5rem; }
    .ws-step-card {
        display: flex; align-items: center; gap: 1rem; width: 100%; text-align: left;
        padding: 1rem 1.15rem; border: 1px solid #dee2e6; border-radius: 12px;
        background-color: #ffffff; cursor: pointer; transition: border-color .15s ease, box-shadow .15s ease, transform .1s ease;
    }
    .ws-step-card:hover { border-color: #0047AB; box-shadow: 0 4px 16px rgba(0, 71, 171, .12); transform: translateY(-1px); }
    .ws-step-card:focus-visible { outline: none; border-color: #0047AB; box-shadow: 0 0 0 .25rem rgba(0, 71, 171, .35); }
    .ws-step-num {
        flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
        width: 28px; height: 28px; border-radius: 50%;
        background-color: #0047AB; color: #ffffff; font-weight: 700; font-size: .9rem;
    }
    .ws-step-icon { flex: 0 0 auto; color: #0047AB; display: inline-flex; }
    .ws-step-text { display: flex; flex-direction: column; gap: .15rem; }
    .ws-step-text strong { color: #212529; font-size: 1rem; }
    .ws-step-text span { color: #6c757d; font-size: .88rem; }
    .ws-welcome-hint { text-align: center; color: #6c757d; font-size: .85rem; margin: 0; }
</style>
<div
    {{ stimulus_controller('workspace-manager') }}
    data-workspace-manager-id-entreprise-value="{{ idEntreprise }}"
    data-workspace-manager-id-invite-value="{{ idInvite }}"
    data-workspace-manager-entreprise-nom-value="{{ entrepriseNom }}"
>
    {# Barre de progression globale, contrôlée par Stimulus #}
    <div data-workspace-manager-target="progressBar" class="progress-bar"
        role="progressbar" aria-label="Chargement en cours"
        aria-valuemin="0" aria-valuemax="100"></div>
    <div class="interactive-menu">
        {# COLONNE 1 : Navigation principale #}
        <div class="menu-col-1">
            <nav aria-label="Menu principal">
            {# Ligne 1: Tableau de bord #}
            <div class="menu-col-1-row-1">
                <div class="nav-item"
                    role="button"
                    tabindex="0"
                    data-action="mouseenter->workspace-manager#showItemDescription mouseleave->workspace-manager#clearDescription click->workspace-manager#loadComponent"
                    data-workspace-manager-component-name-param="{{ menu.colonne_1.tableau_de_bord.composant_twig }}"
                    data-workspace-manager-description-param="{{ menu.colonne_1.tableau_de_bord.description }}"
                    data-workspace-manager-icon-param="{{ menu.colonne_1.tableau_de_bord.icone }}"
                    data-workspace-manager-target="dashboardItem"
                >
                    <twig:UX:Icon name="{{ resolve_icon_name(menu.colonne_1.tableau_de_bord.icone) }}" class="nav-icon" />
                    <span class="nav-text">{{ menu.colonne_1.tableau_de_bord.nom }}</span>
                </div>
            </div>

            {# Ligne 2: Groupes #}
            <div class="menu-col-1-row-2">
                {% for group_name, group_data in menu.colonne_1.groupes %}
                    <div class="nav-item"
                        role="button"
                        tabindex="0"
                        data-action="mouseenter->workspace-manager#showItemDescription mouseleave->workspace-manager#clearDescription click->workspace-manager#showGroupRubriques"
                        data-workspace-manager-group-name-param="{{ group_name }}"
                        data-workspace-manager-description-param="{{ group_data.description }}"
                    >
                        <twig:UX:Icon name="{{ resolve_icon_name(group_data.icone) }}" class="nav-icon" />
                        <span class="nav-text">{{ group_name }}</span>
                    </div>
                {% endfor %}

                {# Le groupe Paramètres est positionné en bas via une classe CSS dédiée.
                   - Administrateur de l'entreprise (propriétaire) : le clic ouvre la page d'édition de l'entreprise.
                   - Invité : le groupe reste visible mais est désactivé (grisé, non cliquable). #}
                {% set parametres = menu.colonne_1.parametres_group %}
                {% if isEntrepriseAdmin %}
                    <a href="{{ path('admin.entreprise.edit', {'id': idEntreprise}) }}"
                        class="nav-item nav-item-bottom"
                        role="button"
                        title="{{ parametres.nom }}"
                        data-action="mouseenter->workspace-manager#showItemDescription mouseleave->workspace-manager#clearDescription click->workspace-manager#handleLoadingStart"
                        data-workspace-manager-description-param="{{ parametres.description }}"
                    >
                        <twig:UX:Icon name="{{ resolve_icon_name(parametres.icone) }}" class="nav-icon" />
                        <span class="nav-text">{{ parametres.nom }}</span>
                    </a>
                {% else %}
                    <div class="nav-item nav-item-bottom nav-item-disabled"
                        role="button"
                        aria-disabled="true"
                        title="{{ parametres.nom }} — réservé à l'administrateur de l'entreprise"
                        data-action="mouseenter->workspace-manager#showItemDescription mouseleave->workspace-manager#clearDescription"
                        data-workspace-manager-description-param="{{ parametres.description }}"
                    >
                        <twig:UX:Icon name="{{ resolve_icon_name(parametres.icone) }}" class="nav-icon" />
                        <span class="nav-text">{{ parametres.nom }}</span>
                    </div>
                {% endif %}
            </div>

            {# Ligne 3: Fermer — revient à la liste des entreprises (sans déconnecter) #}
            {% set deconnexion = menu.colonne_1.deconnexion %}
            <div class="menu-col-1-row-3">
                <a href="{{ path('admin.entreprise.index') }}"
                    class="nav-item nav-item-logout"
                    role="button"
                    title="{{ deconnexion.nom }}"
                    data-action="mouseenter->workspace-manager#showItemDescription mouseleave->workspace-manager#clearDescription click->workspace-manager#handleLoadingStart"
                    data-workspace-manager-description-param="{{ deconnexion.description }}"
                >
                    <twig:UX:Icon name="{{ resolve_icon_name(deconnexion.icone) }}" class="nav-icon" />
                    <span class="nav-text">{{ deconnexion.nom }}</span>
                </a>
            </div>
            </nav>
        </div>

        {# COLONNE 2 : Rubriques & Descriptions #}
        <div class="menu-col-2">
            {# Ligne 1: Marque JS Brokers — version compacte pour laisser de la place aux rubriques #}
            <div class="menu-col-2-row-1">
                {# La marque renvoie toujours vers la page d'accueil publique (/). #}
                <a href="{{ path('app_index') }}" class="company-brand" aria-label="JS Brokers — retour à l'accueil" title="Retour à l'accueil JS Brokers">
                    <img src="{{ asset(menu.colonne_2.logo) }}" alt="Logo" class="company-logo">
                    <h2 class="company-title">{{ menu.colonne_2.titre }}</h2>
                </a>
                <p class="company-description">{{ menu.colonne_2.description }}</p>
                {# La version affichée est celle des conditions et termes d'utilisation (source : App\Legal\Cgu),
                   et non plus la version applicative. Le lien ouvre les CGU. #}
                <a class="company-version" href="{{ path('app_terms') }}" target="_blank" rel="noopener"
                   title="Lire les conditions et termes d'utilisation">
                    Version {{ constant('App\\Legal\\Cgu::VERSION') }} — dernière mise à jour le {{ constant('App\\Legal\\Cgu::DATE')|date('d/m/Y') }}
                </a>
            </div>
            {# Carte d'identité de l'entreprise courante #}
            {% if entreprise is defined and entreprise %}
                {% set ville = nom_ville(entreprise.ville) %}
                {% set pays = nom_pays(entreprise.pays) %}
                <section class="menu-col-2-company" aria-label="Entreprise courante">
                    <img class="company-card-logo"
                         src="{{ entreprise.thumbnail ? vich_uploader_asset(entreprise, 'thumbnailFile') : '/images/entreprises/default_entreprise.jpg' }}"
                         alt="{{ 'Logo de %s'|format(entreprise.nom) }}">
                    <h3 class="company-card-name">{{ entreprise.nom }}</h3>
                    {% set adresse_complete = [entreprise.adresse, ville, pays]|filter(v => v)|join(', ') %}
                    {% if adresse_complete %}
                        <p class="company-card-address">{{ adresse_complete }}</p>
                    {% endif %}
                    <dl class="company-card-details">
                        {% if entreprise.rccm %}
                            <div class="company-card-line">
                                <dt>RCCM</dt><dd>{{ entreprise.rccm }}</dd>
                            </div>
                        {% endif %}
                        {% if entreprise.idnat %}
                            <div class="company-card-line">
                                <dt>ID National</dt><dd>{{ entreprise.idnat }}</dd>
                            </div>
                        {% endif %}
                        {% if entreprise.licence %}
                            <div class="company-card-line">
                                <dt>Agrément / Licence</dt><dd>{{ entreprise.licence }}</dd>
                            </div>
                        {% endif %}
                        {% if entreprise.capitalSociale is not null %}
                            {% set monnaie_capital = monnaie_pays(entreprise.pays)|default(display_currency_code()) %}
                            <div class="company-card-line">
                                <dt>Capital social</dt><dd>{{ entreprise.capitalSociale|number_format(2, ',', ' ') }} {{ monnaie_capital }}</dd>
                            </div>
                        {% endif %}
                    </dl>
                </section>
            {% endif %}
            {# Ligne 2: Zone dynamique pour descriptions et rubriques #}
            <div class="menu-col-2-row-2">
                <div data-workspace-manager-target="rubriquesContainer"></div>
                <div data-workspace-manager-target="descriptionContainer" style="display: none;"></div>
            </div>
        </div>

        {# COLONNE 3 : Espace de travail #}
        <div class="menu-col-3" data-workspace-manager-target="workspace">
            {# Barre d'onglets — générée dynamiquement par workspace-manager_controller.js #}
            <div class="workspace-tab-bar" role="tablist" aria-label="Onglets de travail"
                 data-workspace-manager-target="workspaceTabBar"></div>
            {# Zone de contenu des onglets #}
            <div class="workspace-tab-panels" data-workspace-manager-target="workspaceTabPanels">
                {% if welcome|default(false) %}
                    {# État d'accueil de l'espace vide : panneau de bienvenue + étapes
                       suggérées. Porte la classe `workspace-initial-skeleton` pour être
                       retiré automatiquement dès l'ouverture du premier onglet (cf.
                       workspace-manager_controller.js). Chaque étape déclenche l'action
                       `loadComponent` existante avec les paramètres de la rubrique cible
                       (lus dans le menu pour rester cohérents avec la navigation). #}
                    {% set _groupes = menu.colonne_1.groupes %}
                    {% set _step_clients = _groupes.Production.rubriques.Clients|default(null) %}
                    {% set _step_taxes = _groupes.Finances.rubriques.Taxes|default(null) %}
                    {% set _step_invites = _groupes.Administration.rubriques['Invités']|default(null) %}
                    <div class="workspace-initial-skeleton ws-welcome">
                        <div class="ws-welcome-head">
                            <div class="ws-welcome-emoji" aria-hidden="true">
                                {{ ux_icon('mdi:rocket-launch-outline', {height: '40px', width: '40px'}) }}
                            </div>
                            <h2 class="ws-welcome-title">{{ 'onboarding_ws_title'|trans({':company': entrepriseNom}) }}</h2>
                            <p class="ws-welcome-intro">{{ 'onboarding_ws_intro'|trans }}</p>
                        </div>

                        <div class="ws-welcome-steps">
                            {% if _step_clients %}
                                <button type="button" class="ws-step-card"
                                    data-action="click->workspace-manager#loadComponent"
                                    data-workspace-manager-component-name-param="{{ _step_clients.composant_twig }}"
                                    data-workspace-manager-group-name-param="Production"
                                    data-workspace-manager-entity-name-param="{{ _step_clients.entity_name|default('') }}"
                                    data-workspace-manager-icon-param="{{ _step_clients.icone|default('') }}"
                                    data-workspace-manager-description-param="">
                                    <span class="ws-step-num">1</span>
                                    <span class="ws-step-icon">{{ ux_icon(resolve_icon_name('client'), {height: '22px', width: '22px'}) }}</span>
                                    <span class="ws-step-text">
                                        <strong>{{ 'onboarding_ws_step_clients_title'|trans }}</strong>
                                        <span>{{ 'onboarding_ws_step_clients_desc'|trans }}</span>
                                    </span>
                                </button>
                            {% endif %}

                            {% if _step_taxes %}
                                <button type="button" class="ws-step-card"
                                    data-action="click->workspace-manager#loadComponent"
                                    data-workspace-manager-component-name-param="{{ _step_taxes.composant_twig }}"
                                    data-workspace-manager-group-name-param="Finances"
                                    data-workspace-manager-entity-name-param="{{ _step_taxes.entity_name|default('') }}"
                                    data-workspace-manager-icon-param="{{ _step_taxes.icone|default('') }}"
                                    data-workspace-manager-description-param="">
                                    <span class="ws-step-num">2</span>
                                    <span class="ws-step-icon">{{ ux_icon(resolve_icon_name('taxe'), {height: '22px', width: '22px'}) }}</span>
                                    <span class="ws-step-text">
                                        <strong>{{ 'onboarding_ws_step_taxes_title'|trans }}</strong>
                                        <span>{{ 'onboarding_ws_step_taxes_desc'|trans }}</span>
                                    </span>
                                </button>
                            {% endif %}

                            {% if _step_invites and isEntrepriseAdmin %}
                                <button type="button" class="ws-step-card"
                                    data-action="click->workspace-manager#loadComponent"
                                    data-workspace-manager-component-name-param="{{ _step_invites.composant_twig }}"
                                    data-workspace-manager-group-name-param="Administration"
                                    data-workspace-manager-entity-name-param="{{ _step_invites.entity_name|default('') }}"
                                    data-workspace-manager-icon-param="{{ _step_invites.icone|default('') }}"
                                    data-workspace-manager-description-param="">
                                    <span class="ws-step-num">3</span>
                                    <span class="ws-step-icon">{{ ux_icon(resolve_icon_name('invite'), {height: '22px', width: '22px'}) }}</span>
                                    <span class="ws-step-text">
                                        <strong>{{ 'onboarding_ws_step_invites_title'|trans }}</strong>
                                        <span>{{ 'onboarding_ws_step_invites_desc'|trans }}</span>
                                    </span>
                                </button>
                            {% endif %}
                        </div>

                        <p class="ws-welcome-hint">{{ 'onboarding_ws_hint'|trans }}</p>
                    </div>
                {% else %}
                    {# Squelette initial — supprimé dès le premier onglet créé #}
                    <div class="workspace-skeleton workspace-initial-skeleton">
                        <div class="skeleton-header">
                            <div class="skeleton-icon"></div>
                            <div style="flex-grow: 1;">
                                <div class="skeleton-line" style="width: 40%; height: 24px;"></div>
                                <div class="skeleton-line" style="width: 80%; margin-top: 10px;"></div>
                            </div>
                        </div>
                        <div class="skeleton-line" style="height: 40px; width: 100%; margin-bottom: 1rem;"></div>
                        <div class="skeleton-line" style="height: 40px; width: 100%; margin-bottom: 1rem;"></div>
                        <div class="skeleton-line" style="height: 40px; width: 100%; margin-bottom: 1rem;"></div>
                        <div class="skeleton-row" style="height: 300px;"></div>
                    </div>
                {% endif %}
            </div>
        </div>

        {# COLONNE 4 : COLONNE DE VISUALISATION #}
        <div class="menu-col-4" data-workspace-manager-target="visualizationColumn">
            <div class="tab-panel-container">
                {# La barre où les titres des onglets apparaîtront #}
                <div class="tab-header" role="tablist" aria-label="Entités ouvertes" data-workspace-manager-target="tabContainer">
                    </div>
                {# La zone où le contenu de l'onglet actif s'affichera #}
                <div class="tab-content-container" data-workspace-manager-target="tabContentContainer">
                    </div>
            </div>
        </div>
    </div>

    {# Template caché pour générer la liste des rubriques (utilisé par Stimulus) #}
    <template data-workspace-manager-target="rubriquesTemplate">
        {# On fusionne les groupes normaux et le groupe de paramètres pour que la logique de chargement des rubriques fonctionne pour tous. #}
        {% set all_groups = menu.colonne_1.groupes|merge({(menu.colonne_1.parametres_group.nom): menu.colonne_1.parametres_group}) %}
        <div class="rubriques-list">
            {% for group_name, group_data in all_groups %}
                <div id="rubriques-{{ group_name|replace({' ': '_'}) }}">
                    {% for rubrique_name, rubrique_data in group_data.rubriques %}
                        <div class="rubrique-item"
                            role="button"
                            tabindex="0"
                            data-action="click->workspace-manager#loadComponent"
                            data-workspace-manager-component-name-param="{{ rubrique_data.composant_twig }}"
                            data-workspace-manager-group-name-param="{{ group_name }}"
                            data-workspace-manager-entity-name-param="{{ rubrique_data.entity_name|default('') }}"
                            data-workspace-manager-icon-param="{{ rubrique_data.icone|default('') }}"
                            data-workspace-manager-description-param=""
                        >
                            <twig:UX:Icon name="{{ resolve_icon_name(rubrique_data.icone) }}" class="rubrique-icon" />
                            <span class="rubrique-text">{{ rubrique_name }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% endfor %}
        </div>
    </template>

    {# Template pour un seul onglet (le titre cliquable) #}
    <template data-workspace-manager-target="tabTemplate">
        <div class="tab-item" data-action="click->workspace-manager#activateTab">
            <span class="tab-item-icon"></span>
            <span class="tab-item-title" data-role="tab-title"></span>
            <button class="tab-item-close" data-action="click->workspace-manager#closeTab" aria-label="Fermer l'onglet">
                <twig:UX:Icon name="{{ resolve_icon_name('action:close') }}" />
            </button>
        </div>
    </template>

    {# Template pour un onglet de l'espace de travail (col-3) #}
    <template data-workspace-manager-target="workspaceTabTemplate">
        <div class="workspace-tab-item" role="tab" tabindex="0" aria-selected="false"
             data-action="click->workspace-manager#activateWorkspaceTab">
            <span class="workspace-tab-icon"></span>
            <span class="workspace-tab-title"></span>
            <button class="workspace-tab-close" type="button"
                    data-action="click->workspace-manager#closeWorkspaceTab"
                    aria-label="Fermer l'onglet">
                <twig:UX:Icon name="{{ resolve_icon_name('action:close') }}" />
            </button>
        </div>
    </template>

    {# Template pour le contenu d'un onglet (l'accordéon) #}
    <template data-workspace-manager-target="tabContentTemplate">
        <div class="tab-content">
            <div class="accordion-search-bar" data-action="click->workspace-manager#focusSearch">
                <twig:UX:Icon name="{{ resolve_icon_name('action:search') }}" class="search-icon" />
                <input type="text"
                    class="accordion-search-input"
                    placeholder="Filtrer Ici"
                    aria-label="Filtrer les attributs"
                    data-action="input->workspace-manager#filter"
                    data-workspace-manager-target="searchInput"
                >
                <button type="button" class="icon-button" data-action="click->workspace-manager#resetFilter" title="Réinitialiser">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:reset') }}" />
                </button>
                <span class="separator"></span>
                <button type="button" class="icon-button" data-action="click->workspace-manager#closeTab" title="Fermer l'onglet">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:exit') }}" />
                </button>
            </div>
            <div class="accordion"> {# Le contrôleur workspace-manager gère déjà cet élément #}
                {# L'accordéon avec les détails de l'entité sera généré ici par Stimulus #}
            </div>
            <div class="no-results-message" data-workspace-manager-target="noResultsMessage" style="display: none;">
                Aucun attribut ne correspond à votre recherche.
            </div>
        </div>
    </template>
</div>