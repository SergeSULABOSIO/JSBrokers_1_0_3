<div
    data-controller="list-summary"
    data-list-summary-currency-code-value="{{ display_currency_code()|default('EUR') }}"
    class="jsb-list-summary"
    role="region"
    aria-label="Totaux de la liste"
>
    <label class="jsb-list-summary__label" aria-hidden="true">Totaliser :</label>
    <select
        class="jsb-list-summary__select"
        aria-label="Choisir l'attribut à totaliser"
        data-action="list-summary#recalculate"
        data-list-summary-target="attributeSelector"
    >
        <option value="">-- Choisir --</option>
    </select>
    <span class="jsb-list-summary__divider" aria-hidden="true"></span>
    <span class="jsb-list-summary__item">
        <span class="jsb-list-summary__item-label">Total</span>
        <span class="jsb-list-summary__item-value"
            data-list-summary-target="globalTotal"
            aria-live="polite"
            aria-atomic="true">—</span>
    </span>
    <span class="jsb-list-summary__divider" aria-hidden="true"></span>
    <span class="jsb-list-summary__item">
        <span class="jsb-list-summary__item-label">Sélection</span>
        <span class="jsb-list-summary__item-value"
            data-list-summary-target="selectionTotal"
            aria-live="polite"
            aria-atomic="true">—</span>
    </span>
</div>
