{# templates/components/dialog/_form_content.html.twig #}
{% form_theme form 'themes/_collection_widget.html.twig' %}
{% set title = isCreationMode
    ? formCanvas.parametres.titre_creation
    : formCanvas.parametres.titre_modification|replace({'%id%': entity.id})
%}
    <div class="row gx-0" data-icon-name="{{ entityCanvas.parametres.icone|default('') }}">
        {# La colonne des attributs est incluse ici et gère sa propre classe de colonne (ex: col-auto) #}
        {% include 'components/dialog/_calculated_attributes.html.twig' with { entity: entity, canvas: entityCanvas } %}

        {# La colonne du formulaire prend l'espace restant #}
        <div class="col form-column{% if formCanvas.parametres.form_class is defined %} {{ formCanvas.parametres.form_class }}{% endif %}">
            {# Entête contextuel opt-in (pastille de l'entité + description de l'édition
               et de son importance), au-dessus du cadre du formulaire. Rendu uniquement
               si le canvas pose form_intro : les autres dialogues sont inchangés. #}
            {% if formCanvas.parametres.form_intro is defined %}
                {% set intro = formCanvas.parametres.form_intro %}
                {# Rappel des informations pré-remplies dont les champs sont masqués
                   (rangées hidden du canvas) : l'utilisateur voit POUR QUI / SUR QUOI
                   il édite sans avoir à le mémoriser (Nielsen 6 — reconnaissance
                   plutôt que rappel). Meilleur effort : objets affichés via leur
                   « nom »/« libellé », scalaires tels quels, le reste est ignoré. #}
                {% set intro_facts = [] %}
                {% for row in formCanvas.form_layout|default([]) %}
                    {% set row_hidden = row.hidden is defined and row.hidden %}
                    {% for col in row.colonnes %}
                        {% for field in (col.champs is defined ? col.champs : [col]) %}
                            {% set fc = (field is mapping and field.field_code is defined) ? field.field_code : field %}
                            {# Champ masqué : rangée hidden du canvas OU champ parent injecté
                               dynamiquement (row_attr d-none, cf. renderFormCanvas). #}
                            {% set field_hidden = row_hidden
                                or (field is mapping and 'd-none' in (field.options.row_attr.class|default(''))) %}
                            {% if field_hidden and form[fc] is defined %}
                                {% set raw = form[fc].vars.data %}
                                {% set display = null %}
                                {% if raw is not null and raw is not iterable %}
                                    {% if raw.nom is defined %}{% set display = raw.nom %}
                                    {% elseif raw.libelle is defined %}{% set display = raw.libelle %}
                                    {% elseif raw.timestamp is defined %}{% set display = raw|date('d/m/Y') %}
                                    {% else %}{% set display = raw %}{% endif %}
                                {% endif %}
                                {% if display is not null and display != '' %}
                                    {% set fact_label = intro.facts_labels[fc]|default(form[fc].vars.label|default(fc|humanize)) %}
                                    {% set intro_facts = intro_facts|merge([{field: fc, label: fact_label, value: display}]) %}
                                {% endif %}
                            {% endif %}
                        {% endfor %}
                    {% endfor %}
                {% endfor %}
                {# Contexte parent (fourni par renderFormCanvas) : objets parents déjà
                   rattachés à l'entité — indispensable en ÉDITION où le parent n'est
                   pas dans le layout (ex. la tâche d'un feedback). Dédoublonné avec
                   les faits issus des champs masqués ci-dessus. #}
                {% for pf_field, pf_value in parentContextFacts|default({}) %}
                    {% set already_listed = intro_facts|filter(f => f.field == pf_field)|length > 0 %}
                    {% if not already_listed %}
                        {% set pf_form_label = form[pf_field] is defined ? form[pf_field].vars.label|default(pf_field|humanize) : pf_field|humanize %}
                        {% set fact_label = intro.facts_labels[pf_field]|default(pf_form_label) %}
                        {% set intro_facts = intro_facts|merge([{field: pf_field, label: fact_label, value: pf_value}]) %}
                    {% endif %}
                {% endfor %}
                <div class="form-intro" role="note">
                    <span class="form-intro-icon" aria-hidden="true">
                        {{ ux_icon(resolve_icon_name(intro.icone|default(entityCanvas.parametres.icone|default('action:role'))), {height: '26px', width: '26px'}) }}
                    </span>
                    <div class="form-intro-text">
                        <p class="form-intro-title">{{ intro.titre }}</p>
                        <p class="form-intro-desc">{{ intro.description }}</p>
                        {% if intro_facts is not empty %}
                            <dl class="form-intro-facts">
                                {% for fact in intro_facts %}
                                    <div class="form-intro-fact">
                                        <dt>{{ fact.label }}</dt>
                                        <dd>{{ fact.value }}</dd>
                                    </div>
                                {% endfor %}
                            </dl>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
            {# novalidate : la validation HTML5 native bloque silencieusement la soumission
               quand un champ `required` vide est dans une section masquée (le navigateur ne
               peut focaliser un champ caché). La validation de référence est côté SERVEUR ;
               un contrôle JS léger (dialog-instance#triggerSubmit) signale, lui, les seuls
               champs requis VISIBLES avant l'envoi. Robuste y compris sur la touche Entrée. #}
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            {% if formCanvas.form_layout is defined and formCanvas.form_layout is not empty %}
                {# Pour chaque ligne définie dans la configuration du layout... #}
                {% for row in formCanvas.form_layout %}
                    {# Le titre de groupe est un libellé sur sa propre ligne. #}
                    {% if row.group_title is defined %}
                        <div class="row">
                            <div class="col-12"><label class="form-label required">{{ row.group_title }}</label></div>
                        </div>
                    {% endif %}

                    {% set row_visibility_conditions = (row.visibility_conditions is defined) ? row.visibility_conditions|json_encode : null %}

                    <div class="row{% if row.hidden is defined and row.hidden %} d-none{% endif %}"
                        data-dialog-instance-target="formRow {% if row_visibility_conditions %}dynamicFieldContainer{% endif %}"
                        {% if row_visibility_conditions %}
                            data-visibility-conditions-value="{{ row_visibility_conditions }}"
                        {% endif %}
                    >
                        {% for col in row.colonnes %}
                            {# On utilise la largeur définie dans le canvas, sinon on divise équitablement #}
                            {% set col_class = col.width is defined ? 'col-md-' ~ col.width : 'col-md-' ~ (12 / row.colonnes|length)|round(0, 'floor') %}

                            {# FALLBACK : Si aucune condition n'est sur la ligne, on vérifie la colonne (ancien comportement). #}
                            {% set first_field_in_col = col.champs[0] ?? null %}
                            {% set col_visibility_conditions = (not row_visibility_conditions and first_field_in_col is mapping and first_field_in_col.visibility_conditions is defined) ? first_field_in_col.visibility_conditions|json_encode : null %}

                            <div class="{{ col_class }}"
                                {% if col_visibility_conditions %}
                                    data-dialog-instance-target="dynamicFieldContainer"
                                    data-visibility-conditions-value="{{ col_visibility_conditions }}"
                                {% endif %}
                            >
                                {% set champs_list = col.champs is defined ? col.champs : [col] %}
                                {% for field in champs_list %}
                                    {% set field_code = (field is mapping and field.field_code is defined) ? field.field_code : field %}
                                    {% if field is mapping and field.widget is defined and field.widget == 'collection' %}
                                        {# Pour les collections, on appelle form_widget directement pour éviter le div.mb-3 superflu. #}
                                        {% if form[field_code] is defined %}{{ form_row(form[field_code], {'manager_options': field.options, 'idEntreprise': idEntreprise, 'idInvite': idInvite}) }}{% endif %}
                                    {% else %}
                                        {# Pour les champs standards, on utilise form_row qui génère un div.mb-3. #}
                                        {% if form[field_code] is defined %}
                                            {% set current_field_options = (field is mapping and field.options is defined) ? field.options : {} %}
                                            {% set current_widget_attr = current_field_options.attr|default({}) %}

                                            {# Détection automatique des Textarea pour activer l'éditeur riche #}
                                            {% if 'textarea' in form[field_code].vars.block_prefixes %}
                                                {% set current_widget_attr = current_widget_attr|merge({'data-controller': 'rich-text'}) %}
                                            {% endif %}

                                            {# Icône de champ opt-in (field_icons du canvas) : la carte est rendue
                                               à la main pour poser une mini-pastille devant le libellé. Sans icône,
                                               form_row d'origine inchangé. #}
                                            {% set field_icon = formCanvas.parametres.field_icons[field_code]|default(null) %}
                                            {% if field_icon %}
                                                <div class="mb-3 dlg-field-card">
                                                    <div class="dlg-field-card-head">
                                                        <span class="dlg-field-card-icon" aria-hidden="true">{{ ux_icon(resolve_icon_name(field_icon), {height: '16px', width: '16px'}) }}</span>
                                                        {{ form_label(form[field_code]) }}
                                                    </div>
                                                    <div class="dlg-field-card-body">
                                                        {{ form_widget(form[field_code], {'manager_options': current_field_options, 'attr': current_widget_attr, 'idEntreprise': idEntreprise, 'idInvite': idInvite}) }}
                                                        {{ form_help(form[field_code]) }}
                                                        {{ form_errors(form[field_code]) }}
                                                    </div>
                                                </div>
                                            {% else %}
                                                {{ form_row(form[field_code], {'manager_options': current_field_options, 'attr': current_widget_attr, 'idEntreprise': idEntreprise, 'idInvite': idInvite}) }}
                                            {% endif %}
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endfor %}
                    </div>
                {% endfor %}
            {% else %}
                {{ form_widget(form) }}
            {% endif %}

            {# Suppress fields that are in the form type but intentionally absent from the canvas layout.
               Calling setRendered() prevents form_end(render_rest:true) from rendering them as stray widgets. #}
            {% if formCanvas.parametres.suppress_fields is defined %}
                {% for suppressedField in formCanvas.parametres.suppress_fields %}
                    {% if form[suppressedField] is defined %}{% do form[suppressedField].setRendered() %}{% endif %}
                {% endfor %}
            {% endif %}

            {{ form_end(form, {'render_rest': true}) }}
        </div>
    </div>
