{#
    Boîte de dialogue de sélection de clients existants à rattacher au portefeuille.
    Construite selon /ergonomie-web (modale accessible : role=dialog, aria-modal,
    aria-labelledby/-describedby, libellés explicites, statut jamais transmis par la
    seule couleur, zones cliquables ≥ 44px) et /charte-couleurs (classes Bootstrap +
    cobalt de marque, overlay --overlay-dark). L'ouverture/fermeture, la recherche et
    l'action d'ajout sont pilotées par le contrôleur Stimulus « collection ».
#}
<div class="jsb-picker-overlay" data-picker-overlay>
    <div class="jsb-picker-modal"
         role="dialog"
         aria-modal="true"
         aria-labelledby="jsb-picker-title"
         aria-describedby="jsb-picker-desc"
         tabindex="-1">

        <header class="jsb-picker-head">
            <div>
                <h2 id="jsb-picker-title" class="jsb-picker-title">
                    <twig:UX:Icon name="mdi:briefcase-account" style="width:20px;height:20px;" aria-hidden="true" />
                    Ajouter des clients au portefeuille
                </h2>
                <p id="jsb-picker-desc" class="jsb-picker-sub">
                    Portefeuille : <strong>{{ portefeuille.nom }}</strong>.
                    Seuls les clients <strong>sans portefeuille</strong> peuvent être ajoutés ; un client déjà rattaché n'est pas proposé.
                </p>
            </div>
            <button type="button" class="jsb-picker-close" data-picker-close aria-label="Fermer la fenêtre de sélection">
                <twig:UX:Icon name="hugeicons:cancel-01" style="width:18px;height:18px;" aria-hidden="true" />
            </button>
        </header>

        <div class="jsb-picker-search">
            <label for="jsb-picker-search-input" class="visually-hidden">Rechercher un client par nom ou e-mail</label>
            <input type="search"
                   id="jsb-picker-search-input"
                   class="form-control"
                   placeholder="Rechercher par nom ou e-mail…"
                   autocomplete="off"
                   data-picker-search>
        </div>

        <div class="jsb-picker-listwrap">
            {% if clients is empty %}
                <p class="jsb-picker-empty" role="status">Aucun client n'existe encore dans cet espace de travail.</p>
            {% else %}
                <table class="table jsb-picker-table">
                    <caption class="visually-hidden">Liste des clients de l'espace de travail et leur statut de rattachement</caption>
                    <thead>
                        <tr>
                            <th scope="col">Client</th>
                            <th scope="col">Statut</th>
                            <th scope="col" class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody data-picker-tbody>
                        {% for client in clients %}
                            {% set pf = client.portefeuille %}
                            {% set assigned = pf is not null %}
                            {% set isCurrent = assigned and pf.id == portefeuille.id %}
                            <tr data-picker-row data-search="{{ (client.nom ~ ' ' ~ (client.email ?? ''))|lower|e('html_attr') }}">
                                <td>
                                    <span class="jsb-picker-client-nom">{{ client.nom }}</span>
                                    {% if client.email %}<span class="jsb-picker-client-mail">{{ client.email }}</span>{% endif %}
                                </td>
                                <td>
                                    {% if isCurrent %}
                                        <span class="badge bg-success">Dans ce portefeuille</span>
                                    {% elseif assigned %}
                                        <span class="badge bg-secondary">Rattaché : {{ pf.nom }}</span>
                                    {% else %}
                                        <span class="badge bg-light text-dark border">Sans portefeuille</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    {% if assigned %}
                                        <span class="text-muted small">Aucune action</span>
                                    {% else %}
                                        <button type="button"
                                                class="btn btn-sm btn-primary jsb-picker-add"
                                                data-picker-attach
                                                data-attach-url="/admin/portefeuille/api/{{ portefeuille.id }}/attach-client/{{ client.id }}"
                                                aria-label="Ajouter le client {{ client.nom }} au portefeuille">
                                            <twig:UX:Icon name="gridicons:add" style="width:16px;height:16px;" aria-hidden="true" />
                                            Ajouter
                                        </button>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <p class="jsb-picker-empty" data-picker-empty role="status" hidden>Aucun client ne correspond à votre recherche.</p>
            {% endif %}
        </div>

        <footer class="jsb-picker-foot">
            <button type="button" class="btn btn-outline-secondary" data-picker-close>Fermer</button>
        </footer>
    </div>
</div>
