{#
    Boîte de dialogue de sélection de clients existants à rattacher au portefeuille.
    Alignée sur le pattern des dialogues et le modèle de liste de l'application
    (table.table-enhanced, entête collante), selon /ergonomie-web (role=dialog,
    aria-modal, libellés, statut jamais transmis par la seule couleur, cibles ≥44px,
    Échap, focus) et /charte-couleurs (cobalt de marque, overlay --overlay-dark).
    Le badge « statut » n'utilise PAS .badge (globalement forcé en bleu) mais des
    pastilles dédiées à bon contraste.
#}
<div class="jsb-picker-overlay" data-picker-overlay data-picker-base="/admin/portefeuille/api/{{ portefeuille.id }}">
    <div class="jsb-picker-modal"
         role="dialog"
         aria-modal="true"
         aria-labelledby="jsb-picker-title"
         aria-describedby="jsb-picker-desc"
         tabindex="-1">

        {# Barre de titre alignée sur le pattern du dialogue d'édition (dialog-manager) :
           pastille d'entité + titre .modal-title + bouton .btn-close. #}
        <div class="modal-header jsb-picker-header">
            <div class="d-flex align-items-center">
                <span class="me-2 d-inline-flex" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('portefeuille') }}" style="width:22px;height:22px;color:#0047AB;" />
                </span>
                <h5 id="jsb-picker-title" class="modal-title mb-0">Ajouter des clients à «&nbsp;{{ portefeuille.nom }}&nbsp;»</h5>
            </div>
            <button type="button" class="btn-close" data-picker-close aria-label="Fermer la fenêtre de sélection"></button>
        </div>

        {# Barre de progression : animée à chaque ajout/retrait (feedback visuel). #}
        <div class="jsb-picker-progress" data-picker-progress role="progressbar" aria-hidden="true">
            <div class="jsb-picker-progress-bar"></div>
        </div>

        {# Entête contextuel calqué sur le « form-intro » du formulaire d'édition :
           pastille + titre + description enrichie, puis statistiques. #}
        <div class="jsb-picker-intro">
            <span class="jsb-picker-intro-icon" aria-hidden="true">
                <twig:UX:Icon name="{{ resolve_icon_name('client') }}" style="width:26px;height:26px;" />
            </span>
            <div class="jsb-picker-intro-text">
                <p class="jsb-picker-intro-title">Sélection des clients à rattacher</p>
                <p id="jsb-picker-desc" class="jsb-picker-intro-desc">
                    Choisissez les clients à intégrer à «&nbsp;<strong>{{ portefeuille.nom }}</strong>&nbsp;».
                    Seuls les clients <strong>sans portefeuille</strong> sont rattachables : un client déjà
                    rattaché à un autre portefeuille n'est pas déplaçable ici (retirez-le d'abord de son
                    portefeuille d'origine). Le rattachement est immédiat et reste réversible via «&nbsp;Retirer&nbsp;».
                </p>

                {# Statistiques : clients dans ce portefeuille vs total de l'espace.
                   data-picker-count-current est mis à jour en direct par le JS à chaque ajout/retrait. #}
                <div class="jsb-picker-stats" role="status" aria-live="polite">
                    <span class="jsb-picker-stat">
                        <span class="jsb-picker-stat-num" data-picker-count-current>{{ clientsDansPortefeuille }}</span>
                        dans ce portefeuille
                    </span>
                    <span class="jsb-picker-stat-sep" aria-hidden="true">/</span>
                    <span class="jsb-picker-stat">
                        <span class="jsb-picker-stat-num">{{ clientsTotal }}</span>
                        au total
                    </span>
                </div>
            </div>
        </div>

        <div class="jsb-picker-search">
            <span class="jsb-picker-search-icon" aria-hidden="true">
                <twig:UX:Icon name="hugeicons:search-01" style="width:16px;height:16px;" />
            </span>
            <label for="jsb-picker-search-input" class="visually-hidden">Rechercher un client par nom ou e-mail</label>
            <input type="text"
                   id="jsb-picker-search-input"
                   class="form-control"
                   placeholder="Rechercher par nom ou e-mail…"
                   autocomplete="off"
                   data-picker-search>
        </div>

        <div class="jsb-picker-listwrap">
            {% if clients is empty %}
                <p class="jsb-picker-empty" role="status">Aucun client n'existe encore dans cet espace de travail.</p>
            {% else %}
                <table class="jsb-picker-table">
                    <caption class="visually-hidden">Liste des clients de l'espace de travail et leur statut de rattachement</caption>
                    <thead>
                        <tr>
                            <th scope="col">Client</th>
                            <th scope="col">Statut</th>
                            <th scope="col" class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody data-picker-tbody>
                        {% for client in clients %}
                            {% set pf = client.portefeuille %}
                            {% set assigned = pf is not null %}
                            {% set isCurrent = assigned and pf.id == portefeuille.id %}
                            {% set state = isCurrent ? 'current' : (assigned ? 'other' : 'free') %}
                            <tr data-picker-row
                                data-picker-state="{{ state }}"
                                data-client-id="{{ client.id }}"
                                data-client-nom="{{ client.nom|e('html_attr') }}"
                                data-search="{{ (client.nom ~ ' ' ~ (client.email ?? ''))|lower|e('html_attr') }}">
                                <td>
                                    <span class="jsb-picker-client-nom">{{ client.nom }}</span>
                                    {% if client.email %}<span class="jsb-picker-client-mail">{{ client.email }}</span>{% endif %}
                                </td>
                                <td data-picker-status>
                                    {% if isCurrent %}
                                        <span class="jsb-picker-chip jsb-picker-chip--current">Dans ce portefeuille</span>
                                    {% elseif assigned %}
                                        <span class="jsb-picker-chip jsb-picker-chip--other">Rattaché : {{ pf.nom }}</span>
                                    {% else %}
                                        <span class="jsb-picker-chip jsb-picker-chip--free">Sans portefeuille</span>
                                    {% endif %}
                                </td>
                                <td class="text-end" data-picker-action>
                                    {% if assigned and not isCurrent %}
                                        {# Rattaché à un AUTRE portefeuille : pas d'action ici. #}
                                        <span class="text-muted small">Aucune action</span>
                                    {% else %}
                                        {# Les DEUX boutons sont rendus (icônes serveur), on bascule leur
                                           visibilité côté JS après ajout/retrait : l'icône reste cohérente
                                           avec les boutons « supprimer » existants (alias action:delete). #}
                                        <button type="button"
                                                class="btn btn-sm btn-primary jsb-picker-btn"
                                                data-picker-attach
                                                data-attach-url="/admin/portefeuille/api/{{ portefeuille.id }}/attach-client/{{ client.id }}"
                                                aria-label="Ajouter le client {{ client.nom }} au portefeuille"
                                                {{ isCurrent ? 'hidden' : '' }}>
                                            <twig:UX:Icon name="{{ resolve_icon_name('action:add') }}" style="width:15px;height:15px;" aria-hidden="true" />
                                            Ajouter
                                        </button>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger jsb-picker-btn"
                                                data-picker-detach
                                                data-detach-url="/admin/portefeuille/api/{{ portefeuille.id }}/detach-client/{{ client.id }}"
                                                aria-label="Retirer le client {{ client.nom }} du portefeuille"
                                                {{ isCurrent ? '' : 'hidden' }}>
                                            <twig:UX:Icon name="{{ resolve_icon_name('action:delete') }}" style="width:15px;height:15px;" aria-hidden="true" />
                                            Retirer
                                        </button>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <p class="jsb-picker-empty" data-picker-empty role="status" hidden>Aucun client ne correspond à votre recherche.</p>
            {% endif %}
        </div>

        <footer class="jsb-picker-foot">
            <span class="jsb-picker-hint text-muted small">Astuce : filtrez la liste puis cliquez sur « Ajouter » ou « Retirer ».</span>
            <button type="button" class="btn btn-outline-secondary jsb-picker-btn" data-picker-close>
                <twig:UX:Icon name="{{ resolve_icon_name('action:close') }}" style="width:15px;height:15px;" aria-hidden="true" />
                Fermer
            </button>
        </footer>
    </div>
</div>
