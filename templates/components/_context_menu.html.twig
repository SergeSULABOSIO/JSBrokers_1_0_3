{#
    Menu contextuel (clic droit) sur la liste principale.
    Piloté par le contrôleur Stimulus `context-menu`.
    ARIA : role="menu" + role="menuitem" conformes au pattern WAI-ARIA Menu Button.
#}
<nav
    id="simpleContextMenu"
    class="context-menu"
    data-controller="context-menu"
    data-context-menu-target="menu"
    aria-label="Menu contextuel"
>
    <ul role="menu" aria-label="Actions disponibles">

        {# Ajouter #}
        <li
            role="menuitem"
            tabindex="-1"
            data-context-menu-target="btAjouter"
            data-action="click->context-menu#notify"
            data-context-menu-event-name-param="ui:toolbar.add-request"
        >
            <span class="context-menu-icon" aria-hidden="true"><twig:UX:Icon name="{{ resolve_icon_name('action:add') }}" style="width: 18px; height: 18px;" /></span>
            <span class="flex-grow-1">Ajouter</span>
            <span class="context-menu-shortcut" aria-label="Raccourci : A">A</span>
        </li>

        {# Ouvrir #}
        <li
            role="menuitem"
            tabindex="-1"
            data-context-menu-target="btOuvrir"
            data-action="click->context-menu#notify"
            data-context-menu-event-name-param="ui:toolbar.open-request"
        >
            <span class="context-menu-icon" aria-hidden="true"><twig:UX:Icon name="{{ resolve_icon_name('action:open') }}" style="width: 18px; height: 18px;" /></span>
            <span class="flex-grow-1">Ouvrir</span>
            <span class="context-menu-shortcut" aria-label="Raccourci : O">O</span>
        </li>

        {# Modifier #}
        <li
            role="menuitem"
            tabindex="-1"
            data-context-menu-target="btModifier"
            data-action="click->context-menu#notify"
            data-context-menu-event-name-param="ui:toolbar.edit-request"
        >
            <span class="context-menu-icon" aria-hidden="true"><twig:UX:Icon name="{{ resolve_icon_name('action:edit') }}" style="width: 18px; height: 18px;" /></span>
            <span class="flex-grow-1">Modifier</span>
            <span class="context-menu-shortcut" aria-label="Raccourci : M">M</span>
        </li>

        {# Séparateur + actions spécifiques injectées dynamiquement #}
        {# Note : la structure <li> > <ul> est valide — un <li> peut contenir n'importe quel contenu #}
        <li role="separator" class="separator" data-context-menu-target="specificActionsSeparator" style="display: none;"></li>
        <li class="specific-actions-wrapper p-0">
            <ul role="group" aria-label="Actions spécifiques" data-context-menu-target="specificActionsContainer" class="list-unstyled m-0 p-0">
                {# Les <li role="menuitem"> sont injectés ici par context-menu_controller.js #}
            </ul>
        </li>

        {# Tout cocher #}
        <li
            role="menuitem"
            tabindex="-1"
            data-context-menu-target="btToutCocher"
            data-action="click->context-menu#notify"
            data-context-menu-event-name-param="ui:toolbar.select-all-request"
        >
            <span class="context-menu-icon" aria-hidden="true"><twig:UX:Icon name="{{ resolve_icon_name('action:check') }}" style="width: 18px; height: 18px;" /></span>
            <span class="flex-grow-1">Tout cocher</span>
            <span class="context-menu-shortcut"></span>
        </li>

        {# Actualiser #}
        <li
            role="menuitem"
            tabindex="-1"
            data-context-menu-target="btActualiser"
            data-action="click->context-menu#notify"
            data-context-menu-event-name-param="ui:toolbar.refresh-request"
        >
            <span class="context-menu-icon" aria-hidden="true"><twig:UX:Icon name="{{ resolve_icon_name('action:reload') }}" style="width: 18px; height: 18px;" /></span>
            <span class="flex-grow-1">Actualiser</span>
            <span class="context-menu-shortcut" aria-label="Raccourci : R">R</span>
        </li>

        {# Supprimer — variante danger #}
        <li
            role="menuitem"
            tabindex="-1"
            class="is-danger"
            data-context-menu-target="btSupprimer"
            data-action="click->context-menu#notify"
            data-context-menu-event-name-param="app:delete-request"
        >
            <span class="context-menu-icon" aria-hidden="true"><twig:UX:Icon name="{{ resolve_icon_name('action:delete') }}" style="width: 18px; height: 18px;" /></span>
            <span class="flex-grow-1">Supprimer</span>
            <span class="context-menu-shortcut" aria-label="Raccourci : S">S</span>
        </li>

        <li role="separator" class="separator"></li>

        {# Paramètres #}
        <li
            role="menuitem"
            tabindex="-1"
            data-context-menu-target="btParametrer"
            data-action="click->context-menu#notify"
            data-context-menu-event-name-param="ui:toolbar.settings-request"
        >
            <span class="context-menu-icon" aria-hidden="true"><twig:UX:Icon name="{{ resolve_icon_name('action:settings') }}" style="width: 18px; height: 18px;" /></span>
            <span class="flex-grow-1">Paramètres</span>
            <span class="context-menu-shortcut"></span>
        </li>

        {# Quitter — variante danger #}
        <li
            role="menuitem"
            tabindex="-1"
            class="is-danger"
            data-context-menu-target="btQuitter"
            data-action="click->context-menu#notify"
            data-context-menu-event-name-param="ui:toolbar.close-request"
        >
            <span class="context-menu-icon" aria-hidden="true"><twig:UX:Icon name="{{ resolve_icon_name('action:exit') }}" style="width: 18px; height: 18px;" /></span>
            <span class="flex-grow-1">Quitter</span>
            <span class="context-menu-shortcut" aria-label="Raccourci : Q">Q</span>
        </li>

    </ul>
</nav>
