{#
   Composants réutilisables pour les e-mails (HTML « bulletproof » : tables +
   styles inline, seul format fiable d'un client mail à l'autre).

   - heading(icon, title) : titre de section précédé d'une icône d'illustration.
     `icon` est un alias d'IconCanvasProvider (ex. 'action:invite') ou un nom Iconify
     direct ; resolve_icon_name() fait le fallback. L'icône est rendue en SVG inline.
   - paragraph(html)      : paragraphe de corps (le contenu peut être du HTML).
   - button(url, label)   : bouton d'appel à l'action, cobalt, centré à gauche.
   - note(html)           : encart discret (mentions, expiration de lien…).

   Toutes les macros renvoient une (ou des) ligne(s) <tr> : elles s'insèrent dans
   la table de contenu fournie par emails/_layout.html.twig (bloc `content`).
#}

{% macro heading(icon, title) %}
    <tr>
        <td style="padding: 22px 0 4px;">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
                <td style="vertical-align: middle; padding-right: 9px; line-height: 0;">
                    {{ ux_icon(resolve_icon_name(icon), { width: '22', height: '22', style: 'color:#0047AB; vertical-align:middle;' }) }}
                </td>
                <td style="vertical-align: middle; font: 700 17px/1.3 Arial, Helvetica, sans-serif; color: #0d2440;">
                    {{ title }}
                </td>
            </tr></table>
        </td>
    </tr>
{% endmacro %}

{% macro paragraph(html) %}
    <tr>
        <td style="font: 400 15px/1.6 Arial, Helvetica, sans-serif; color: #343a40; padding: 7px 0;">
            {{ html|raw }}
        </td>
    </tr>
{% endmacro %}

{% macro button(url, label) %}
    <tr>
        <td style="padding: 14px 0 8px;">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
                <td style="border-radius: 8px; background-color: #0047AB;">
                    <a href="{{ url }}"
                       style="display: inline-block; padding: 13px 28px; font: 700 15px/1 Arial, Helvetica, sans-serif; color: #ffffff; text-decoration: none; border-radius: 8px;">
                        {{ label }}
                    </a>
                </td>
            </tr></table>
        </td>
    </tr>
{% endmacro %}

{% macro note(html) %}
    <tr>
        <td style="padding: 10px 0 2px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                    <td style="background-color: #f1f5fb; border-left: 3px solid #0047AB; border-radius: 6px; padding: 11px 14px; font: 400 13px/1.5 Arial, Helvetica, sans-serif; color: #495057;">
                        {{ html|raw }}
                    </td>
                </tr>
            </table>
        </td>
    </tr>
{% endmacro %}

{#
   perimetre(data) : rend le périmètre d'action d'un invité de façon lisible et
   professionnelle — une carte par module, chaque entité sur sa propre ligne, et
   les niveaux d'accès affichés en pastilles (Lecture / Écriture / …) plutôt qu'en
   une longue ligne dense. `data` est la sortie de
   WorkspaceAccessResolver::describePerimetreDetailed() :
     { owner: bool, gestionnaire: bool, modules: [ { nom, entites: [ { nom, niveaux[] } ] } ] }
   Les libellés textuels des niveaux garantissent que l'information ne repose jamais
   sur la seule couleur (WCAG 1.4.1).
#}
{% macro perimetre(data) %}
    {% if data.owner %}
        <tr>
            <td style="padding: 8px 0 4px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="background-color: #e8f0fb; border-left: 4px solid #0047AB; border-radius: 8px; padding: 14px 16px; font: 600 15px/1.5 Arial, Helvetica, sans-serif; color: #0d2440;">
                            Accès complet à l'espace de travail, en qualité de propriétaire de l'entreprise.
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    {% elseif data.modules is empty %}
        <tr>
            <td style="padding: 8px 0 4px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="background-color: #fff3cd; border-left: 4px solid #ffc107; border-radius: 8px; padding: 14px 16px; font: 400 14px/1.55 Arial, Helvetica, sans-serif; color: #664d03;">
                            Aucun accès ne vous a encore été attribué. Rapprochez-vous du propriétaire de l'espace de travail pour définir votre périmètre d'action.
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    {% else %}
        {% for module in data.modules %}
            <tr>
                <td style="padding: 8px 0;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                           style="border: 1px solid #dee2e6; border-radius: 10px; overflow: hidden;">
                        <tr>
                            <td style="background-color: #f1f5fb; border-left: 4px solid #0047AB; padding: 10px 16px; font: 700 14px/1.3 Arial, Helvetica, sans-serif; color: #0047AB; letter-spacing: .2px;">
                                {{ module.nom }}
                            </td>
                        </tr>
                        {% for entite in module.entites %}
                            <tr>
                                <td style="padding: 10px 16px;{% if not loop.first %} border-top: 1px solid #eef1f5;{% endif %}">
                                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                                        <tr>
                                            <td style="font: 600 14px/1.4 Arial, Helvetica, sans-serif; color: #343a40; vertical-align: middle; padding-right: 8px;">
                                                {{ entite.nom }}
                                            </td>
                                            <td align="right" style="vertical-align: middle;">
                                                {% for niveau in entite.niveaux %}
                                                    <span style="display: inline-block; background-color: #e8f0fb; color: #0047AB; font: 600 12px/1 Arial, Helvetica, sans-serif; padding: 5px 10px; border-radius: 20px; margin: 2px 0 2px 6px; white-space: nowrap;">{{ niveau }}</span>
                                                {% endfor %}
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        {% endfor %}
                    </table>
                </td>
            </tr>
        {% endfor %}
        {% if data.gestionnaire %}
            <tr>
                <td style="padding: 8px 0 2px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <td style="background-color: #e8f0fb; border-left: 4px solid #0047AB; border-radius: 8px; padding: 12px 16px; font: 600 14px/1.5 Arial, Helvetica, sans-serif; color: #0d2440;">
                                Vous êtes également habilité à gérer les invités et leurs rôles au sein de l'espace de travail.
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        {% endif %}
    {% endif %}
{% endmacro %}
