{#
   Layout commun à TOUS les e-mails sortants de JS Brokers.
   Objectif : cohérence corporate (en-tête de marque, signature, logo) quel que
   soit l'e-mail. HTML « bulletproof » : tables + styles inline.

   Contexte attendu (fourni par les services d'envoi) :
     - logoPath   : chemin ABSOLU du logo sur le disque, embarqué en inline (CID)
                    via email.image() → s'affiche toujours, sans blocage d'images.
     - senderEmail: adresse de contact affichée dans la signature.
   Les deux sont optionnels (rendu dégradé propre si absents).

   Bloc à remplir par les templates : `content` (suite de lignes <tr>, à composer
   avec les macros de emails/_macros.html.twig).
#}
{# `locale` est optionnel : repli 'fr' → les e-mails qui ne le fournissent pas
   restent inchangés ; ceux qui le passent (ex. confirmation de tokens) suivent
   la langue de l'utilisateur. #}
{% set lang = locale|default('fr') %}
<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>{% block subject %}JS Brokers{% endblock %}</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f3f3f3; -webkit-text-size-adjust: 100%;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f3f3f3;">
        <tr>
            <td align="center" style="padding: 24px 12px;">

                <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0"
                       style="width: 600px; max-width: 600px; background-color: #ffffff; border-radius: 14px; overflow: hidden; box-shadow: 0 8px 30px rgba(0, 71, 171, 0.10);">

                    {# ───────── En-tête de marque ───────── #}
                    <tr>
                        <td style="background: linear-gradient(135deg, #0047AB 0%, #003380 100%); background-color: #0047AB; padding: 22px 28px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
                                {% if logoPath is defined and email is defined %}
                                    <td style="vertical-align: middle; padding-right: 13px; line-height: 0;">
                                        <img src="{{ email.image(logoPath) }}" width="46" height="46" alt="JS Brokers"
                                             style="display: block; width: 46px; height: 46px; background-color: #ffffff; border-radius: 10px; padding: 5px;">
                                    </td>
                                {% endif %}
                                <td style="vertical-align: middle;">
                                    <div style="font: 700 21px/1.1 Arial, Helvetica, sans-serif; color: #ffffff;">JS Brokers</div>
                                    <div style="font: 400 12px/1.3 Arial, Helvetica, sans-serif; color: rgba(255,255,255,0.85); margin-top: 3px;">
                                        {{ 'email_layout_tagline'|trans({}, 'messages', lang) }}
                                    </div>
                                </td>
                            </tr></table>
                        </td>
                    </tr>

                    {# ───────── Contenu ───────── #}
                    <tr>
                        <td style="padding: 6px 28px 6px;">
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                                {% block content %}{% endblock %}
                            </table>
                        </td>
                    </tr>

                    {# ───────── Signature ───────── #}
                    <tr>
                        <td style="padding: 18px 28px 26px;">
                            <hr style="border: none; border-top: 1px solid #e9ecef; margin: 0 0 16px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
                                {% if logoPath is defined and email is defined %}
                                    <td style="vertical-align: top; padding-right: 13px; line-height: 0;">
                                        <img src="{{ email.image(logoPath) }}" width="42" height="42" alt=""
                                             style="display: block; width: 42px; height: 42px;">
                                    </td>
                                {% endif %}
                                <td style="vertical-align: top; font: 400 13px/1.5 Arial, Helvetica, sans-serif; color: #6c757d;">
                                    <div style="font-weight: 700; color: #0d2440;">{{ 'email_layout_signature_team'|trans({}, 'messages', lang) }}</div>
                                    <div>{{ 'email_layout_signature_role'|trans({}, 'messages', lang) }}</div>
                                    {% if senderEmail is defined %}
                                        <div style="margin-top: 4px;">
                                            <a href="mailto:{{ senderEmail }}" style="color: #0047AB; text-decoration: none;">{{ senderEmail }}</a>
                                        </div>
                                    {% endif %}
                                </td>
                            </tr></table>
                            <div style="font: 400 11px/1.45 Arial, Helvetica, sans-serif; color: #adb5bd; margin-top: 16px;">
                                {{ 'email_layout_auto_note'|trans({}, 'messages', lang) }}
                            </div>
                        </td>
                    </tr>

                </table>

            </td>
        </tr>
    </table>
</body>
</html>
