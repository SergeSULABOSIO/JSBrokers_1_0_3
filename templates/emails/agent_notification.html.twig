{% extends 'emails/_layout.html.twig' %}
{% import 'emails/_macros.html.twig' as m %}

{# E-mail interne (équipe JS Brokers) : rédigé en français. #}
{% block subject %}JS Brokers — {{ titre }}{% endblock %}

{% block content %}
    {{ m.heading(icone, titre) }}
    {{ m.paragraph(intro) }}

    {% if perimetre is defined %}
        {# Rendu structuré (cartes par module + pastilles de niveaux) : lisible et pro. #}
        {{ m.perimetre(perimetre) }}
    {% elseif details is defined %}
        {% for label, valeur in details %}
            {{ m.paragraph('<strong>' ~ label ~ '&nbsp;:</strong> ' ~ valeur) }}
        {% endfor %}
    {% endif %}

    {{ m.note(piedNote|default('Notification automatique adressée à l\'équipe JS Brokers pour information.')) }}
{% endblock %}
