{# templates/public/soa/soa_client_public.html.twig
   Page publique du SOA, consultée par le client (assuré) via son lien tokenisé,
   sans compte ni session. Vue épurée : le contexte (SoaContextBuilder, vueClient=true)
   ne contient pas les données de travail du courtier ; les partials partagés
   n'affichent donc que récapitulatif, contacts, polices, échéancier et sinistres.
#}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Relevé de Compte — {{ client.nom }} | {{ entreprise.nom|default('JS Brokers') }}</title>
    <link rel="icon" href="{{ asset('images/entreprises/logofav.png') }}" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    {% include 'admin/soa/_soa_styles.html.twig' %}
</head>
<body>

    <nav class="soa-actions-bar" aria-label="Actions du document">
        <button type="button" class="btn btn-primary btn-sm d-inline-flex align-items-center gap-2" onclick="window.print()">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M2.5 8a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1z"/><path d="M5 1a2 2 0 0 0-2 2v2H2a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h1v1a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1V3a2 2 0 0 0-2-2H5zM4 3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2H4V3zm1 5a2 2 0 0 0-2 2v1H2a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v-1a2 2 0 0 0-2-2H5zm7 2v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1z"/></svg>
            <span>Imprimer</span>
        </button>
    </nav>

    <main aria-label="Relevé de compte de {{ client.nom }}">
        <div class="soa-container">
            {% include 'admin/soa/_soa_header.html.twig' %}
            <p class="soa-lien-validite mb-0">
                Document généré le {{ soaDate|date('d/m/Y à H:i') }} —
                lien d'accès personnel valable jusqu'au <strong>{{ lienExpireAt|date('d/m/Y') }}</strong>.
                Pour un relevé à jour au-delà de cette date, contactez votre courtier.
            </p>
            {% include 'admin/soa/_soa_sections.html.twig' %}
            {% include 'admin/soa/_soa_footer.html.twig' %}
        </div>
    </main>

    {% include 'admin/soa/_soa_scripts.html.twig' %}
</body>
</html>
