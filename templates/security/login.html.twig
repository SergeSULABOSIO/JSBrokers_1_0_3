{% extends 'base.html.twig' %}

{% block title %}{{ pageName|default('Connexion') }} — JS Brokers{% endblock %}

{% block stylesheets %}
{{ parent() }}
{# Styles d'auth mutualisés (connexion, mot de passe oublié, réinitialisation). #}
{{ include('security/_auth_styles.html.twig') }}
{% endblock %}

{% block body %}
<main class="auth" data-controller="top-progress">

    {# Barre de progression globale : feedback de navigation (mdp oublié, créer un compte…). #}
    <div class="ent-progress-bar" data-top-progress-target="bar"
         role="progressbar" aria-label="Chargement en cours" aria-hidden="true"></div>

    <div class="auth__card">

        {# ---------- Panneau de marque ---------- #}
        {{ include('security/_auth_brand.html.twig') }}

        {# ---------- Panneau formulaire ---------- #}
        <section class="auth__form">

            {# Messages applicatifs (ex. : compte créé → vérifiez vos mails) relayés
               vers le toast applicatif, pour rester cohérent avec le reste de l'app. #}
            {{ include('components/_flash_toasts.html.twig') }}

            {% if app.user %}
                {# --- Utilisateur déjà authentifié --- #}
                <h1 class="auth__title">Vous êtes déjà connecté</h1>
                <p class="auth__subtitle">
                    Bonjour <strong>{{ app.user.nom }}</strong>, vous êtes connecté
                    en tant que <strong>{{ app.user.userIdentifier }}</strong>.
                </p>

                {% if app.user.verified == false %}
                    <div class="alert alert-warning" role="alert">
                        Votre adresse e-mail n'est pas encore vérifiée.
                        <a href="{{ path('app_reverify_email', {'send': 1}) }}" class="alert-link">
                            Renvoyer le lien de validation
                        </a>.
                    </div>
                {% endif %}

                <a href="{{ path('admin.entreprise.index') }}" class="btn btn-cobalt auth__submit">
                    Accéder à mon espace
                </a>
                <p class="auth__foot">
                    Ce n'est pas vous ?
                    <a href="{{ path('app_logout') }}">Se déconnecter</a>
                </p>

            {% else %}
                {# --- Formulaire de connexion --- #}
                <h1 class="auth__title">Connexion</h1>
                <p class="auth__subtitle">
                    Renseignez vos identifiants pour accéder à votre compte
                    et à la liste de vos entreprises.
                </p>

                {# Échec d'authentification (identifiants invalides, compte non vérifié…)
                   relayé vers le toast applicatif (notification-manager) plutôt qu'en
                   alerte « en ligne » — même canal que les messages flash, DRY. #}
                {% if error %}
                    <div data-controller="flash-toast"
                         data-flash-toast-messages-value="{{ [{ type: 'error', text: error.messageKey|trans(error.messageData, 'security') }]|json_encode|e('html_attr') }}"></div>
                {% endif %}

                <form method="post" novalidate
                      data-controller="form-submit"
                      data-action="submit->form-submit#submitting"
                      data-form-submit-loading-text-value="Connexion en cours…">
                    {# Email #}
                    <label for="inputEmail" class="form-label">Adresse e-mail</label>
                    <div class="auth__field">
                        <svg class="auth__field-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round" aria-hidden="true">
                            <rect x="2" y="4" width="20" height="16" rx="2"/>
                            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                        </svg>
                        <input type="email" name="email" id="inputEmail"
                               value="{{ last_username }}"
                               class="form-control"
                               autocomplete="email" required aria-required="true" autofocus
                               placeholder="vous@exemple.com">
                    </div>

                    {# Mot de passe (avec bascule afficher/masquer) #}
                    <label for="inputPassword" class="form-label">Mot de passe</label>
                    <div class="auth__field" data-controller="password-toggle">
                        <svg class="auth__field-icon" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round" aria-hidden="true">
                            <rect x="3" y="11" width="18" height="11" rx="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                        <input type="password" name="password" id="inputPassword"
                               class="form-control"
                               autocomplete="current-password" required aria-required="true"
                               data-password-toggle-target="input"
                               placeholder="••••••••">
                        <button type="button" class="auth__toggle"
                                data-action="password-toggle#toggle"
                                data-password-toggle-target="button"
                                aria-pressed="false"
                                aria-label="Afficher le mot de passe">
                            {# Œil ouvert (état : mot de passe masqué) #}
                            <svg data-password-icon viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round" aria-hidden="true">
                                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                            {# Œil barré (état : mot de passe affiché) #}
                            <svg data-password-icon class="is-hidden" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round" aria-hidden="true">
                                <path d="M9.88 9.88a3 3 0 0 0 4.24 4.24"/>
                                <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c6.5 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                                <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3.5 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                                <line x1="2" y1="2" x2="22" y2="22"/>
                            </svg>
                        </button>
                    </div>

                    {# Lien de récupération : accessible sans être connecté. #}
                    <p class="auth__inline-link">
                        <a href="{{ path('app_forgot_password') }}"
                           data-action="click->top-progress#show">Mot de passe oublié&nbsp;?</a>
                    </p>

                    {# Jeton CSRF #}
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    {# Se souvenir de moi #}
                    <div class="form-check mb-3">
                        <input type="checkbox" name="_remember_me" id="rememberMe" class="form-check-input">
                        <label for="rememberMe" class="form-check-label">
                            Se souvenir de moi (garder ma session ouverte)
                        </label>
                    </div>

                    <button type="submit" class="btn btn-cobalt w-100 auth__submit d-inline-flex align-items-center justify-content-center"
                            data-form-submit-target="button">
                        {{ ux_icon(resolve_icon_name('mdi:login'), {height: '20px', width: '20px'}) }}
                        <span class="ms-2">Se connecter</span>
                    </button>
                </form>

                <p class="auth__foot">
                    Je n'ai pas encore de compte utilisateur JS Brokers.
                    <a href="{{ path('app_register') }}" class="auth__foot-link"
                       data-action="click->top-progress#show">Créer un compte</a>
                </p>
            {% endif %}

        </section>
    </div>
</main>
{% endblock %}
