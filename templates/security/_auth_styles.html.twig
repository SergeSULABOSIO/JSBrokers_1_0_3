<style>
    /* ============================================================
       Pages d'authentification JS Brokers (connexion, mot de passe
       oublié, réinitialisation).
       Couleurs : charte officielle (cobalt #0047AB, neutres Bootstrap).
       Aucune couleur hors charte. Partagé par toutes les pages d'auth (DRY).
       ============================================================ */
    .auth {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        background-color: #f3f3f3; /* --bg-body */
    }

    /* Barre de progression globale : fixée en haut, cobalt, animée
       (même pattern que top-progress_controller). */
    .ent-progress-bar {
        position: fixed; top: 0; left: 0; width: 100%; height: 6px;
        background-color: #0047AB; display: none; z-index: 9999;
        animation: ent-progress-animation 1.5s infinite linear;
    }
    @keyframes ent-progress-animation {
        0%   { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    .auth__card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        width: 100%;
        max-width: 920px;
        background-color: #ffffff; /* --bg-white */
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 71, 171, 0.12); /* ombre cobalt subtile */
    }

    /* ---- Panneau de marque (gauche) ---- */
    .auth__brand {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 1.25rem;
        padding: 2.5rem;
        color: #ffffff; /* --text-white */
        background: linear-gradient(160deg, #0047AB 0%, #003380 100%); /* cobalt → cobalt-dark */
    }

    .auth__brand-logo {
        width: 64px;
        height: 64px;
        border-radius: 14px;
        background-color: #ffffff;
        padding: 8px;
        object-fit: contain;
    }

    .auth__brand-name {
        font-size: 1.6rem;
        font-weight: 700;
        margin: 0;
        line-height: 1.2;
    }

    .auth__brand-tagline {
        font-size: 1rem;
        line-height: 1.5;
        margin: 0;
        color: rgba(255, 255, 255, 0.85); /* texte secondaire sur fond sombre */
    }

    .auth__brand-points {
        list-style: none;
        padding: 0;
        margin: 0.5rem 0 0;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .auth__brand-points li {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.92rem;
        color: rgba(255, 255, 255, 0.92);
    }

    .auth__brand-points svg {
        flex: 0 0 auto;
        width: 18px;
        height: 18px;
    }

    /* ---- Panneau formulaire (droite) ---- */
    .auth__form {
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .auth__title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #212529; /* --text-dark */
        margin: 0 0 0.25rem;
        text-align: center;
    }

    .auth__subtitle {
        color: #6c757d; /* --text-muted */
        margin: 0 0 1.5rem;
        font-size: 0.95rem;
        text-align: center;
    }

    .auth__form .form-label {
        font-weight: 600;
        color: #343a40; /* --text-dark-secondary */
        margin-bottom: 0.35rem;
    }

    /* Champ avec icône en préfixe */
    .auth__field {
        position: relative;
        margin-bottom: 1rem;
    }

    .auth__field-icon {
        position: absolute;
        top: 50%;
        left: 0.85rem;
        transform: translateY(-50%);
        width: 20px;
        height: 20px;
        color: #6c757d; /* --text-muted */
        pointer-events: none;
    }

    .auth__field .form-control {
        height: 48px;            /* zone de saisie confortable */
        padding-left: 2.6rem;    /* place pour l'icône préfixe */
        color: #000000;          /* --text-black (contenu de champ) */
    }

    /* Focus visible conforme charte : bordure + anneau cobalt */
    .auth__form .form-control:focus {
        border-color: #0047AB;
        box-shadow: 0 0 0 0.25rem rgba(0, 71, 171, 0.35); /* --cobalt-focus-ring */
    }

    /* Bouton afficher/masquer le mot de passe (≥ 44×44, WCAG 2.5.5) */
    .auth__toggle {
        position: absolute;
        top: 50%;
        right: 0.35rem;
        transform: translateY(-50%);
        width: 44px;
        height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 0;
        background: transparent;
        color: #6c757d; /* --text-muted */
        border-radius: 8px;
        cursor: pointer;
    }
    .auth__toggle:hover { color: #0047AB; }      /* cobalt */
    .auth__toggle:focus-visible {
        outline: 2px solid #0047AB;
        outline-offset: 2px;
    }
    .auth__toggle svg { width: 20px; height: 20px; }
    .auth__toggle .is-hidden { display: none; }

    .auth__submit {
        height: 48px;
        font-weight: 600;
        font-size: 1rem;
        margin-top: 0.25rem;
    }

    /* Lien discret « mot de passe oublié ? », aligné à droite sous le champ. */
    .auth__inline-link {
        text-align: right;
        margin: -0.35rem 0 1rem;
        font-size: 0.85rem;
    }
    .auth__inline-link a {
        font-weight: 600;
        color: #0047AB; /* --cobalt */
        text-decoration: none;
    }
    .auth__inline-link a:hover { color: #003380; text-decoration: underline; } /* --cobalt-dark */
    .auth__inline-link a:focus-visible {
        outline: 2px solid #0047AB;
        outline-offset: 2px;
        border-radius: 4px;
    }

    .auth__foot {
        margin-top: 1.25rem;
        font-size: 0.85rem;
        color: #6c757d; /* --text-muted */
        text-align: center;
    }
    /* Lien de bas de carte : accent cobalt de marque, sur sa propre ligne */
    .auth__foot-link { display: block; margin-top: 0.35rem; }
    .auth__foot a {
        font-weight: 600;
        color: #0047AB; /* --cobalt */
        text-decoration: none;
    }
    .auth__foot a:hover { color: #003380; text-decoration: underline; } /* --cobalt-dark */
    .auth__foot a:focus-visible {
        outline: 2px solid #0047AB;
        outline-offset: 2px;
        border-radius: 4px;
    }

    /* ---- Responsive : empilement sous 768px ---- */
    @media (max-width: 767.98px) {
        .auth__card { grid-template-columns: 1fr; max-width: 460px; }
        .auth__brand {
            padding: 2rem;
            flex-direction: row;
            align-items: center;
            flex-wrap: wrap;
        }
        .auth__brand-tagline,
        .auth__brand-points { display: none; } /* on allège l'en-tête sur mobile */
        .auth__form { padding: 2rem; }
    }
</style>
