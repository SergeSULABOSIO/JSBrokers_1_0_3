{% extends 'base.html.twig' %}

{% block title %}{{ pageName|default('Mot de passe oublié') }} — JS Brokers{% endblock %}

{% block stylesheets %}
{{ parent() }}
{{ include('security/_auth_styles.html.twig') }}
{% endblock %}

{% block body %}
<main class="auth" data-controller="top-progress">

    {# Barre de progression globale, déclenchée à l'envoi du formulaire. #}
    <div class="ent-progress-bar" data-top-progress-target="bar"
         role="progressbar" aria-label="Chargement en cours" aria-hidden="true"></div>

    <div class="auth__card">

        {# ---------- Panneau de marque ---------- #}
        {{ include('security/_auth_brand.html.twig') }}

        {# ---------- Panneau formulaire ---------- #}
        <section class="auth__form">

            {# Messages applicatifs relayés vers le toast applicatif. #}
            {{ include('components/_flash_toasts.html.twig') }}

            <h1 class="auth__title">Mot de passe oublié&nbsp;?</h1>
            <p class="auth__subtitle">
                Indiquez l'adresse e-mail de votre compte&nbsp;: nous vous enverrons
                un lien pour définir un nouveau mot de passe.
            </p>

            <form method="post" novalidate
                  data-controller="form-submit"
                  data-action="submit->form-submit#submitting submit->top-progress#show"
                  data-form-submit-loading-text-value="Envoi du lien…">
                {# Email #}
                <label for="inputEmail" class="form-label">Adresse e-mail</label>
                <div class="auth__field">
                    <svg class="auth__field-icon" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round"
                         stroke-linejoin="round" aria-hidden="true">
                        <rect x="2" y="4" width="20" height="16" rx="2"/>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                    </svg>
                    <input type="email" name="email" id="inputEmail"
                           class="form-control"
                           autocomplete="email" required aria-required="true" autofocus
                           placeholder="vous@exemple.com">
                </div>

                <button type="submit" class="btn btn-cobalt w-100 auth__submit d-inline-flex align-items-center justify-content-center"
                        data-form-submit-target="button">
                    {{ ux_icon(resolve_icon_name('action:resend-invitation'), {height: '20px', width: '20px'}) }}
                    <span class="ms-2">Envoyer le lien</span>
                </button>
            </form>

            <p class="auth__foot">
                Vous vous souvenez de votre mot de passe&nbsp;?
                <a href="{{ path('app_login') }}" class="auth__foot-link"
                   data-action="click->top-progress#show">Retour à la connexion</a>
            </p>

        </section>
    </div>
</main>
{% endblock %}
