    {# ---------- Contact ---------- #}
    <section id="contact" class="public-section">
        <div class="public-section__head">
            <h2>{{ "contact_section_title" | trans }}</h2>
            <p>{{ "contact_section_description" | trans }}</p>
        </div>

        <div class="contact-card">
            {# Formulaire de contact public — même pattern que la page de connexion :
               libellé au-dessus, champ avec icône en préfixe (.contact-field-icon, icônes
               via IconCanvasProvider). À la soumission : feedback local sur le bouton
               (form-submit#submitting) + barre de progression (top-progress#show). La
               validation HTML5 native prévient l'envoi des champs vides côté client. #}
            {{ form_start(contactForm, {attr: {
                class: 'contact-form',
                'data-controller': 'form-submit',
                'data-action': 'submit->form-submit#submitting submit->top-progress#show'
            }}) }}

                {# Nom #}
                <div class="contact-field">
                    {{ form_label(contactForm.name, null, {label_attr: {class: 'form-label'}}) }}
                    <div class="contact-input">
                        {{ ux_icon(resolve_icon_name('utilisateur'), {height: '20px', width: '20px', class: 'contact-field-icon'}) }}
                        {{ form_widget(contactForm.name, {attr: {
                            class: 'form-control', autocomplete: 'name', placeholder: 'ContactForm.name'|trans
                        }}) }}
                    </div>
                    {{ form_errors(contactForm.name) }}
                </div>

                {# E-mail (pour pouvoir recontacter le visiteur) #}
                <div class="contact-field">
                    {{ form_label(contactForm.email, null, {label_attr: {class: 'form-label'}}) }}
                    <div class="contact-input">
                        {{ ux_icon(resolve_icon_name('invite'), {height: '20px', width: '20px', class: 'contact-field-icon'}) }}
                        {{ form_widget(contactForm.email, {attr: {
                            class: 'form-control', autocomplete: 'email', placeholder: 'ContactForm.email'|trans
                        }}) }}
                    </div>
                    {{ form_errors(contactForm.email) }}
                </div>

                {# Téléphone facultatif — révélé par la case à cocher (information progressive).
                   La case pilote l'affichage du champ via le contrôleur « disclosure ». #}
                <div class="contact-field contact-optional" data-controller="disclosure">
                    {# Le thème Bootstrap 5 rend déjà la case dans un <div class="form-check">
                       avec son <label class="form-check-label"> ; on ne rend donc QUE le
                       widget (pas de form_label séparé qui dupliquerait le libellé). #}
                    <div class="contact-consent">
                        {{ form_widget(contactForm.wantsPhone, {attr: {
                            'data-disclosure-target': 'trigger',
                            'data-action': 'disclosure#toggle',
                            'aria-controls': 'contact-phone-region'
                        }}) }}
                    </div>

                    <div class="contact-phone" id="contact-phone-region" data-disclosure-target="region" hidden>
                        {{ form_label(contactForm.phone, null, {label_attr: {class: 'form-label'}}) }}
                        <div class="contact-input">
                            {{ ux_icon(resolve_icon_name('contact'), {height: '20px', width: '20px', class: 'contact-field-icon'}) }}
                            {{ form_widget(contactForm.phone, {attr: {
                                class: 'form-control', autocomplete: 'tel', inputmode: 'tel',
                                placeholder: 'ContactForm.phone'|trans,
                                'data-disclosure-target': 'field'
                            }}) }}
                        </div>
                        {{ form_errors(contactForm.phone) }}
                    </div>
                </div>

                {# Objet du message #}
                <div class="contact-field">
                    {{ form_label(contactForm.objet, null, {label_attr: {class: 'form-label'}}) }}
                    <div class="contact-input">
                        {{ ux_icon(resolve_icon_name('action:description'), {height: '20px', width: '20px', class: 'contact-field-icon'}) }}
                        {{ form_widget(contactForm.objet, {attr: {class: 'form-select'}}) }}
                    </div>
                    {{ form_errors(contactForm.objet) }}
                </div>

                {# Message #}
                <div class="contact-field">
                    {{ form_label(contactForm.message, null, {label_attr: {class: 'form-label'}}) }}
                    <div class="contact-input contact-input--textarea">
                        {{ ux_icon(resolve_icon_name('feedback'), {height: '20px', width: '20px', class: 'contact-field-icon'}) }}
                        {{ form_widget(contactForm.message, {attr: {
                            class: 'form-control', rows: 5, maxlength: 400, placeholder: 'ContactForm.message'|trans
                        }}) }}
                    </div>
                    {{ form_errors(contactForm.message) }}
                </div>

                <button type="submit"
                        class="btn btn-cobalt contact-submit w-100 d-inline-flex align-items-center justify-content-center gap-2"
                        data-controller="ripple"
                        data-form-submit-target="button"
                        data-loading-text="{{ 'ContactForm.send' | trans }}">
                    {{ ux_icon(resolve_icon_name('action:resend-invitation'), {height: '20px', width: '20px'}) }}
                    <span>{{ "ContactForm.send" | trans }}</span>
                </button>

            {{ form_end(contactForm) }}
        </div>
    </section>

</main>

