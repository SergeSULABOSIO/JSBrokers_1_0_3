{% extends 'base.html.twig' %}

{% block title %}{{ pageName }} — JS Brokers{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ include('home/_home_styles.html.twig') }}
{% endblock %}

{% block body %}
{% set lang = lang|default(app.request.locale|default('fr')) %}

{# Lien d'évitement : premier élément focusable (WCAG 2.4.1). #}
<a href="#content" class="skip-link">{{ "home_skip_to_content" | trans }}</a>

{# Conteneur unique portant les contrôleurs de feedback : la barre de progression
   globale (top-progress) et le retour visuel local sur les liens d'action
   (form-submit#navigating). Il enveloppe en-tête, contenu et pied de page pour que
   TOUS les liens de navigation serveur de la vitrine (topbar, hero, tarifs, footer)
   partagent le même périmètre de contrôleur. #}
<div class="public-shell" data-controller="top-progress form-submit">

    {# Barre de progression globale (haut de page), cobalt animée. Déclenchée au clic
       sur tout lien menant à une requête serveur (data-action ci-dessous). #}
    <div class="ent-progress-bar" data-top-progress-target="bar"
         role="progressbar" aria-label="{{ 'home_skip_to_content' | trans }}" aria-hidden="true"></div>

    {# Retour serveur (accusé d'envoi du formulaire de contact) relayé en toast applicatif. #}
    {{ include('components/_flash_toasts.html.twig') }}

{# En-tête public (logo, nav, langue, CTA) #}
{{ include('components/_public_topbar.html.twig') }}

<main id="content">

    {# ---------- Hero ---------- #}
    <section class="public-hero">
        <div class="public-hero__inner">
            {# Badge « Nouveau » : l'assistant IA, l'argument différenciant — ancre vers son bloc. #}
            <a href="#feature-ia" class="public-hero__flag" data-controller="ripple">
                {{ ux_icon(resolve_icon_name('assistant-ia'), {height: '16px', width: '16px', 'aria-hidden': 'true'}) }}
                <span>{{ "security_hero_ia_badge" | trans }}</span>
            </a>
            <h1>{{ "security_Work_faster_and_efficiently" | trans }}</h1>
            <p class="public-hero__lead">{{ "security_Work_faster__description" | trans | raw }}</p>
            <div class="public-hero__actions">
                {% if app.user %}
                    {# Navigation serveur → feedback local (spinner) + barre de progression. #}
                    <a href="{{ path('app_login') }}"
                       class="btn btn-hero-primary d-inline-flex align-items-center gap-2"
                       data-controller="ripple"
                       data-action="click->form-submit#navigating click->top-progress#show"
                       data-loading-text="{{ 'security_my_work_space' | trans }}">
                        {{ ux_icon(resolve_icon_name('dashboard'), {height: '20px', width: '20px'}) }}
                        <span>{{ "security_my_work_space" | trans }}</span>
                    </a>
                {% else %}
                    {# Navigation serveur → feedback local (spinner) + barre de progression. #}
                    <a href="{{ path('app_register', {idUtilisateur: -1}) }}"
                       class="btn btn-hero-primary d-inline-flex align-items-center gap-2"
                       data-controller="ripple"
                       data-action="click->form-submit#navigating click->top-progress#show"
                       data-loading-text="{{ 'security_new_account' | trans }}">
                        {{ ux_icon(resolve_icon_name('action:add'), {height: '20px', width: '20px'}) }}
                        <span>{{ "security_new_account" | trans }}</span>
                    </a>
                {% endif %}
                {# Ancre interne (défilement) : ripple au clic, pas de barre (aucune requête serveur). #}
                <a href="#pricing_plan"
                   class="btn btn-hero-ghost d-inline-flex align-items-center gap-2"
                   data-controller="ripple">
                    {{ ux_icon(resolve_icon_name('action:view'), {height: '20px', width: '20px'}) }}
                    <span>{{ "security_tarif" | trans }}</span>
                </a>
            </div>
        </div>
    </section>

