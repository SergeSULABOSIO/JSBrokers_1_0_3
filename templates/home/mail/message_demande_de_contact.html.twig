{% extends 'emails/_layout.html.twig' %}
{% import 'emails/_macros.html.twig' as m %}

{% block subject %}JS Brokers — Demande de contact{% endblock %}

{% block content %}
    {{ m.heading('contact', 'Nouvelle demande de contact') }}
    {{ m.paragraph('Une nouvelle demande de contact vient d\'être reçue via le site JS Brokers.') }}

    {{ m.heading('utilisateur', 'Coordonnées') }}
    {{ m.paragraph(
        '<strong>Nom&nbsp;:</strong> ' ~ data.name ~ '<br>
         <strong>E-mail&nbsp;:</strong> <a href="mailto:' ~ data.email ~ '" style="color:#0047AB; text-decoration:none;">' ~ data.email ~ '</a>'
    ) }}

    {{ m.heading('action:description', 'Message') }}
    {{ m.paragraph(data.message|nl2br) }}

    {{ m.note('Pour répondre, utilisez directement l\'adresse e-mail ci-dessus (définie en « Répondre à »).') }}
{% endblock %}
