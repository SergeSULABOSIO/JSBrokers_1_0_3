<style>
    /* ============================================================
       Vitrine publique JS Brokers — en-tête, hero, fonctionnalités,
       tarifs et pied de page.
       Charte : cobalt #0047AB / #003380, neutres Bootstrap, fond #f3f3f3.
       Aucune couleur hors charte. Styles scopés à la vitrine (non chargés
       dans l'espace de travail). Convention reprise de _auth_styles.html.twig.
       ============================================================ */

    /* L'espace de travail impose globalement `body, html { overflow: hidden }`
       (interactive-menu.css, chargé partout) ; on rétablit le défilement sur
       cette page publique autonome (même correctif que la page CGU). */
    html, body { height: auto !important; overflow: auto !important; }
    body { background-color: #f3f3f3; }

    /* Hauteur de l'en-tête fixe : sert d'offset au contenu et aux ancres. */
    .public-shell { --public-topbar-h: 64px; padding-top: var(--public-topbar-h); }
    /* Les ancres internes (#features, #pricing_plan) ne doivent pas passer sous
       l'en-tête fixe : on réserve sa hauteur lors du saut. */
    html { scroll-behavior: smooth; scroll-padding-top: var(--public-topbar-h, 64px); }

    /* Barre de progression globale : fixée tout en haut, cobalt, animée
       (même pattern que top-progress_controller / pages d'auth). */
    .ent-progress-bar {
        position: fixed; top: 0; left: 0; width: 100%; height: 6px;
        background-color: #0047AB; display: none; z-index: 1100;
        animation: ent-progress-animation 1.5s infinite linear;
    }
    @keyframes ent-progress-animation {
        0%   { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    /* Lien d'évitement (WCAG 2.4.1) : visible uniquement au focus clavier. */
    .skip-link {
        position: absolute; left: 0.75rem; top: -3rem;
        z-index: 1200; padding: 0.6rem 1rem;
        background-color: #0047AB; color: #ffffff; border-radius: 0 0 8px 8px;
        text-decoration: none; font-weight: 600;
        transition: top 0.15s ease-in-out;
    }
    .skip-link:focus { top: 0; outline: 2px solid #ffffff; outline-offset: -4px; }

    /* ---------- En-tête public FIXE (toujours visible au-dessus de la page) ---------- */
    .public-topbar {
        position: fixed; top: 0; left: 0; right: 0; width: 100%; z-index: 1030;
        background-color: #ffffff; border-bottom: 1px solid #dee2e6;
        box-shadow: 0 1px 8px rgba(0, 71, 171, 0.06); /* légère ombre quand on défile dessous */
    }
    .public-topbar__inner {
        max-width: 1140px; margin: 0 auto; padding: 0.6rem 1.5rem;
        display: flex; align-items: center; gap: 1.25rem;
    }
    .public-brand {
        display: inline-flex; align-items: center; gap: 0.6rem;
        text-decoration: none; flex: 0 0 auto;
    }
    .public-brand img { border-radius: 8px; }
    .public-brand span { font-weight: 700; color: #0047AB; font-size: 1.1rem; }

    .public-nav { display: flex; gap: 1.25rem; margin-left: 0.5rem; }
    .public-nav a {
        display: inline-flex; align-items: center; min-height: 44px;
        color: #343a40; text-decoration: none; font-weight: 600; font-size: 0.95rem;
    }
    .public-nav a:hover { color: #0047AB; }
    .public-nav a:focus-visible {
        outline: 2px solid #0047AB; outline-offset: 2px; border-radius: 4px;
    }

    .public-topbar__actions {
        display: flex; align-items: center; gap: 0.6rem; margin-left: auto;
    }

    /* Bascule de langue (.cs-lang) : style global dans assets/styles/app.css. */

    /* CTA d'en-tête : hauteur de zone cliquable confortable (≥ 44px). */
    .public-cta {
        display: inline-flex; align-items: center; min-height: 44px;
        font-weight: 600; white-space: nowrap;
    }

    /* ---------- Hero (gradient cobalt, comme .auth__brand) ---------- */
    .public-hero {
        background: linear-gradient(160deg, #0047AB 0%, #003380 100%);
        color: #ffffff;
    }
    .public-hero__inner {
        max-width: 920px; margin: 0 auto; padding: 4rem 1.5rem 4.5rem;
        text-align: center;
    }
    .public-hero h1 {
        font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 700;
        margin: 0 0 1rem; line-height: 1.2;
    }
    .public-hero__lead {
        font-size: 1.1rem; line-height: 1.6; margin: 0 auto 2rem;
        max-width: 680px; color: rgba(255, 255, 255, 0.9);
    }
    .public-hero__actions {
        display: flex; flex-wrap: wrap; gap: 0.85rem; justify-content: center;
    }
    /* CTA primaire sur fond cobalt : blanc plein, texte cobalt (contraste fort). */
    .public-hero .btn-hero-primary {
        background-color: #ffffff; color: #0047AB; border: 1px solid #ffffff;
        min-height: 48px; padding: 0 1.6rem; font-weight: 700;
        display: inline-flex; align-items: center;
    }
    .public-hero .btn-hero-primary:hover { background-color: #e8f0fb; color: #003380; }
    /* CTA secondaire : contour blanc sur fond cobalt. */
    .public-hero .btn-hero-ghost {
        background-color: transparent; color: #ffffff; border: 1px solid rgba(255, 255, 255, 0.7);
        min-height: 48px; padding: 0 1.6rem; font-weight: 600;
        display: inline-flex; align-items: center;
    }
    .public-hero .btn-hero-ghost:hover { background-color: rgba(255, 255, 255, 0.12); color: #ffffff; }
    .public-hero .btn-hero-primary:focus-visible,
    .public-hero .btn-hero-ghost:focus-visible {
        outline: 2px solid #ffffff; outline-offset: 2px;
    }

    /* ---------- Sections de contenu ---------- */
    .public-section { max-width: 1140px; margin: 0 auto; padding: 3.5rem 1.5rem; }
    .public-section__head { text-align: center; margin-bottom: 2.5rem; }
    .public-section__head h2 {
        font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #212529; margin: 0 0 0.5rem;
    }
    .public-section__head p { color: #6c757d; margin: 0 auto; max-width: 640px; }

    /* Séparateur inter-sections : filet pleine largeur du contenu + losange cobalt
       centré. Ciblage automatique des 3 frontières (features→guide→pricing→contact)
       via le sélecteur de frère adjacent ; le hero (≠ .public-section) en est exclu,
       donc pas de séparateur sous le hero (déjà démarqué par son gradient).
       Purement décoratif (pseudo-éléments) : ni focusable ni annoncé aux lecteurs
       d'écran ; aucune information portée par la couleur seule. */
    .public-section + .public-section { position: relative; }
    .public-section + .public-section::before {
        content: ""; position: absolute;
        top: 0; left: 1.5rem; right: 1.5rem;
        height: 1px; background-color: #dee2e6;   /* --border-light */
    }
    .public-section + .public-section::after {
        content: ""; position: absolute;
        top: 0; left: 50%;
        width: 10px; height: 10px;
        transform: translate(-50%, -50%) rotate(45deg);
        background-color: #0047AB;                 /* --cobalt */
        border: 3px solid #f3f3f3;                 /* --bg-body : « coupe » le filet derrière le losange */
        box-sizing: content-box;
    }

    /* ---------- Plans tarifaires (tokens) ----------
       Cartes sémantiques, hiérarchie visuelle progressive (gratuit → prépayé),
       plan « Professionnel » mis en avant. Couleurs : charte (cobalt #0047AB,
       neutres Bootstrap). Aucune information portée par la couleur seule
       (icône ✓ vs − + libellé explicite). */
    .pp-card {
        position: relative;
        display: flex; flex-direction: column; height: 100%;
        background-color: #ffffff; border: 1px solid #dee2e6; border-radius: 16px;
        overflow: hidden;
        transition: box-shadow .2s ease, transform .2s ease;
    }
    .pp-card:hover { box-shadow: 0 12px 32px rgba(0, 71, 171, .12); transform: translateY(-4px); }

    /* Plan mis en avant : accent cobalt + élévation permanente. */
    .pp-card--featured { border: 2px solid #0047AB; box-shadow: 0 12px 32px rgba(0, 71, 171, .18); }
    @media (min-width: 768px) {
        .pp-card--featured { transform: scale(1.03); }
        .pp-card--featured:hover { transform: scale(1.03) translateY(-4px); }
    }

    /* Bandeau « Recommandé » (plan mis en avant uniquement). */
    .pp-flag {
        margin: 0; padding: .4rem; background-color: #0047AB; color: #ffffff;
        font-size: .72rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
        display: flex; align-items: center; justify-content: center; gap: .35rem;
    }

    /* En-tête : nom du plan, prix, accroche. */
    .pp-head { padding: 1.75rem 1.5rem 1.25rem; text-align: center; border-bottom: 1px solid #f0f0f0; }
    .pp-name { display: block; font-size: .8rem; font-weight: 700; letter-spacing: .08em;
        text-transform: uppercase; color: #0047AB; margin-bottom: .5rem; }
    /* Zone de prix à hauteur réservée : garantit que le prix, le badge, le profil
       et la liste de fonctions s'alignent d'une carte à l'autre, qu'il y ait une
       promo (prix barré + pastille) ou non. */
    .pp-price-zone { min-height: 4.5rem; display: flex; flex-direction: column;
        align-items: center; justify-content: center; gap: .4rem; margin-bottom: .85rem; }
    .pp-price { font-size: 2.4rem; font-weight: 800; color: #212529; line-height: 1; margin: 0; }
    /* Avant → après sur une seule ligne, alignés sur la ligne de base. */
    .pp-price-row { display: flex; align-items: baseline; justify-content: center; gap: .55rem; flex-wrap: wrap; }
    .pp-badge { display: inline-block; background-color: #e8f0fb; color: #0047AB;
        font-size: .72rem; font-weight: 600; letter-spacing: .03em; text-transform: uppercase;
        padding: .2rem .6rem; border-radius: 999px; margin-bottom: .4rem; }
    .pp-lead { margin: 0 0 .4rem; font-weight: 600; color: #343a40; }
    .pp-profil { margin: 0; color: #6c757d; font-size: .88rem; }

    /* Promo active : prix d'origine barré (inline, à gauche du prix remisé) +
       pastille code promo. Badge JAUNE (charte : --warning #ffc107) à texte sombre
       et gras pour une visibilité maximale par le client. */
    .pp-price-old { font-size: 1.15rem; font-weight: 600; color: #6c757d;
        text-decoration: line-through; margin: 0; }
    .pp-promo { display: inline-flex; align-items: center; gap: .4rem;
        background-color: #ffc107; color: #212529;
        font-size: .82rem; font-weight: 800; letter-spacing: .02em;
        padding: .32rem .75rem; border-radius: 999px; margin: 0;
        box-shadow: 0 2px 6px rgba(255,193,7,.45); }
    .pp-promo__code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-weight: 800; letter-spacing: .04em; }

    /* Liste des caractéristiques. */
    .pp-features { list-style: none; margin: 0; padding: .75rem 1.5rem;
        display: flex; flex-direction: column; flex: 1 1 auto; }
    .pp-feature { display: flex; align-items: flex-start; gap: .6rem;
        padding: .55rem .25rem; font-size: .9rem; color: #212529; }
    .pp-feature + .pp-feature { border-top: 1px solid #f5f5f5; }
    .pp-feature__icon { flex: 0 0 auto; width: 20px; height: 20px; margin-top: 1px; color: #0047AB; }
    .pp-feature--off { color: #6c757d; }                 /* non inclus : neutre (pas d'alarme rouge) */
    .pp-feature--off .pp-feature__icon { color: #adb5bd; }
    .pp-value { font-weight: 700; color: #0047AB; }        /* valeur quantitative mise en avant */
    /* Assistant IA : l'argument premium des paquets — pastille cobalt-subtile en tête. */
    .pp-feature--ia {
        font-weight: 700; color: #0047AB;
        background: #e8f0fb; border-radius: 8px; padding: .55rem .6rem;
    }

    /* ── Assistant IA (hero + bloc feature) ─────────────────────────────────── */
    /* Badge du hero : lien-ancre vers le bloc IA (fond translucide sur cobalt). */
    .public-hero__flag {
        display: inline-flex; align-items: center; gap: .45rem;
        font-size: .85rem; font-weight: 700; letter-spacing: .02em;
        color: #ffffff; text-decoration: none;
        background: rgba(255, 255, 255, 0.14); border: 1px solid rgba(255, 255, 255, 0.35);
        border-radius: 999px; padding: .4rem .95rem; margin-bottom: 1.1rem;
    }
    .public-hero__flag:hover { background: rgba(255, 255, 255, 0.24); color: #ffffff; }
    .public-hero__flag:focus-visible { outline: 2px solid #ffffff; outline-offset: 2px; }

    /* Surtitre « Nouveau » du bloc feature IA (sur fond cobalt). */
    .feature-row__flag {
        display: inline-flex; align-items: center; gap: .4rem;
        font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em;
        color: #ffffff; background: rgba(255, 255, 255, 0.16);
        border-radius: 999px; padding: .3rem .7rem; margin: 0 0 .75rem;
    }

    /* Démonstration de chat (remplace l'image du bloc) : carte blanche, bulles
       assistant/utilisateur — mêmes codes visuels que le vrai chat du workspace. */
    .ia-demo {
        background: #ffffff; border: 1px solid #dee2e6; border-radius: 14px;
        padding: 1rem 1.1rem; width: 100%; max-width: 420px;
        display: flex; flex-direction: column; gap: .6rem;
        box-shadow: 0 12px 34px rgba(0, 0, 0, 0.18);
    }
    .ia-demo__head {
        display: flex; align-items: center; gap: .45rem; margin: 0 0 .2rem;
        font-size: .8rem; font-weight: 700; color: #0047AB;
        text-transform: uppercase; letter-spacing: .04em;
    }
    .ia-demo__msg {
        margin: 0; padding: .55rem .8rem; border-radius: 12px;
        font-size: .875rem; line-height: 1.45; color: #212529; max-width: 92%;
    }
    .ia-demo__msg--user { align-self: flex-end; background: #e8f0fb; border-top-right-radius: 4px; }
    .ia-demo__msg--bot { align-self: flex-start; background: #f8f9fa; border: 1px solid #dee2e6; border-top-left-radius: 4px; }

    /* Pied : bouton d'appel à l'action (zone cliquable ≥ 48px, WCAG 2.5.5). */
    .pp-foot { padding: 1.25rem 1.5rem 1.5rem; margin-top: auto; }
    .pp-cta {
        width: 100%; min-height: 48px;
        display: inline-flex; align-items: center; justify-content: center; gap: .5rem;
        font-weight: 600; padding: .7rem 1rem; border-radius: 10px;
        border: 1px solid transparent; text-decoration: none;
        transition: background-color .15s ease, color .15s ease, border-color .15s ease;
    }
    .pp-cta:hover { font-weight: 600; }                    /* neutralise le a:hover{font-weight:bold} global */
    .pp-cta:focus-visible { outline: 2px solid #0047AB; outline-offset: 2px; }
    .pp-cta--solid { background-color: #0047AB; border-color: #0047AB; color: #ffffff; }
    .pp-cta--solid:hover, .pp-cta--solid:focus { background-color: #003380; border-color: #003380; color: #ffffff; }
    .pp-cta--outline { background-color: #ffffff; border-color: #0047AB; color: #0047AB; }
    .pp-cta--outline:hover, .pp-cta--outline:focus { background-color: #0047AB; color: #ffffff; }
    .pp-cta--ghost { background-color: #ffffff; border-color: #ced4da; color: #495057; }
    .pp-cta--ghost:hover, .pp-cta--ghost:focus { background-color: #f8f9fa; border-color: #6c757d; color: #212529; }

    /* Bloc fonctionnalité : alterné texte / image, responsive. */
    .feature-row {
        display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: center;
        padding: 2rem; border-radius: 12px; margin-bottom: 1.5rem;
    }
    .feature-row:last-child { margin-bottom: 0; }
    .feature-row--cobalt {
        background: linear-gradient(160deg, #0047AB 0%, #003380 100%); color: #ffffff;
    }
    .feature-row--light {
        background-color: #ffffff; border: 1px solid #dee2e6;
        box-shadow: 0 4px 16px rgba(0, 71, 171, 0.06);
    }
    /* Sur les lignes paires, l'image passe à gauche (desktop). */
    .feature-row--reverse .feature-row__media { order: -1; }

    .feature-row__title {
        display: flex; align-items: center; gap: 0.5rem;
        font-size: 1.25rem; font-weight: 700; margin: 0 0 0.75rem;
    }
    .feature-row--light .feature-row__title { color: #212529; }
    .feature-row__desc { line-height: 1.6; margin: 0 0 1rem; }
    .feature-row--light .feature-row__desc { color: #495057; }
    .feature-row--cobalt .feature-row__desc { color: rgba(255, 255, 255, 0.9); }

    /* Intitulé de liste : surtitre discret en capitales (hiérarchie / signifiance). */
    .feature-row__intro {
        font-weight: 700; margin: 0 0 0.6rem;
        font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em;
    }
    .feature-row--light .feature-row__intro { color: #6c757d; }      /* --text-muted */
    .feature-row--cobalt .feature-row__intro { color: rgba(255, 255, 255, 0.75); }

    .feature-row__list {
        list-style: none; padding: 0; margin: 0;
        display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.2rem 0.6rem;
    }
    /* Chaque entrée : pastille « ✓ » + libellé, dans une zone qui se révèle au survol
       (reconnaissance plutôt que rappel ; le ✓ signale une capacité incluse). */
    .feature-row__list li {
        display: flex; align-items: flex-start; gap: 0.55rem;
        padding: 0.3rem 0.5rem; border-radius: 8px;
        font-size: 0.9rem; line-height: 1.45;
        transition: background-color 0.15s ease;
    }
    .feature-row__list li::before {
        content: "\2713"; /* ✓ */
        flex: 0 0 auto; margin-top: 0.05em;
        width: 18px; height: 18px; border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.7rem; font-weight: 700; line-height: 1;
    }
    /* Cartes claires : ✓ cobalt sur pastille cobalt très clair (--bg-cobalt-subtle),
       survol sur fond neutre (--bg-body). */
    .feature-row--light .feature-row__list li { color: #343a40; }
    .feature-row--light .feature-row__list li::before { background-color: #e8f0fb; color: #0047AB; }
    .feature-row--light .feature-row__list li:hover { background-color: #f3f3f3; }
    /* Cartes cobalt : ✓ blanc sur voile blanc translucide, survol légèrement éclairci. */
    .feature-row--cobalt .feature-row__list li { color: rgba(255, 255, 255, 0.92); }
    .feature-row--cobalt .feature-row__list li::before { background-color: rgba(255, 255, 255, 0.18); color: #ffffff; }
    .feature-row--cobalt .feature-row__list li:hover { background-color: rgba(255, 255, 255, 0.10); }

    .feature-row__media img {
        width: 100%; height: auto; border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    }
    /* Visuels source en portrait : recadrés en carré (object-fit) pour garder la
       même emprise verticale que les autres blocs de la section. */
    .feature-row__media--portrait img { aspect-ratio: 1 / 1; object-fit: cover; }

    /* ---------- Pied de page public ---------- */
    .public-footer {
        background-color: #ffffff; border-top: 1px solid #dee2e6; margin-top: 1rem;
    }
    .public-footer__inner {
        max-width: 1140px; margin: 0 auto; padding: 2.5rem 1.5rem 1.5rem;
        display: flex; flex-wrap: wrap; align-items: flex-start; gap: 1.5rem;
    }
    .public-footer__brand { display: flex; align-items: center; gap: 0.75rem; flex: 1 1 280px; text-decoration: none; }
    .public-footer__brand:hover { opacity: 0.85; }
    .public-footer__brand img { border-radius: 8px; }
    .public-footer__name { font-weight: 700; color: #0047AB; margin: 0; font-size: 1.05rem; }
    .public-footer__tagline { color: #6c757d; margin: 0; font-size: 0.9rem; max-width: 360px; }

    .public-footer__links { display: flex; flex-wrap: wrap; gap: 0.25rem 1.25rem; }
    .public-footer__links a {
        display: inline-flex; align-items: center; min-height: 44px;
        color: #495057; text-decoration: none; font-size: 0.92rem; font-weight: 600;
    }
    .public-footer__links a:hover { color: #0047AB; }
    .public-footer__links a:focus-visible { outline: 2px solid #0047AB; outline-offset: 2px; border-radius: 4px; }

    .public-footer__credit {
        max-width: 1140px; margin: 0 auto; padding: 1rem 1.5rem;
        border-top: 1px solid #dee2e6; text-align: center;
        color: #6c757d; font-size: 0.85rem;
    }

    /* ---------- Interactivité : survol des cartes + onde au clic des boutons ---------- */
    /* Onde (ripple) : `overflow: hidden` rogne le span enfant aux limites du bouton ;
       l'ombre/anneau de focus propre au bouton n'est PAS rognée (overflow ne s'applique
       qu'aux descendants). `position: relative` cale le positionnement de l'onde. */
    .public-shell .btn { position: relative; overflow: hidden; }

    /* Lignes de fonctionnalités : légère élévation + zoom discret de l'image au survol. */
    .feature-row { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .feature-row--light:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 28px rgba(0, 71, 171, 0.12);
    }
    .feature-row--cobalt:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 32px rgba(0, 51, 128, 0.35);
    }
    .feature-row__media img { transition: transform 0.3s ease; }
    .feature-row:hover .feature-row__media img { transform: scale(1.02); }

    /* Cartes tarifaires : élévation + ombre cobalt au survol (override .shadow Bootstrap). */
    #pricing_plan .card {
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }
    #pricing_plan .card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 36px rgba(0, 71, 171, 0.18) !important;
    }

    /* Accessibilité : on neutralise les animations si l'utilisateur les a désactivées. */
    @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        .feature-row, .feature-row__media img, #pricing_plan .card { transition: none; }
        .feature-row--light:hover, .feature-row--cobalt:hover,
        #pricing_plan .card:hover, .feature-row:hover .feature-row__media img { transform: none; }
    }

    /* ---------- Section Contact ---------- */
    .contact-card {
        max-width: 720px; margin: 0 auto;
        background-color: #ffffff; border: 1px solid #dee2e6; border-radius: 12px;
        padding: 2rem; box-shadow: 0 4px 16px rgba(0, 71, 171, 0.06);
    }
    .contact-field { margin-bottom: 1.1rem; }
    .contact-form .form-label { font-weight: 600; color: #343a40; margin-bottom: 0.35rem; }

    /* Champ avec icône en préfixe — même pattern que la page de connexion (.auth__field). */
    .contact-input { position: relative; }
    .contact-field-icon {
        position: absolute; top: 50%; left: 0.85rem; transform: translateY(-50%);
        width: 20px; height: 20px; color: #6c757d; pointer-events: none; /* --text-muted */
    }
    /* Sur le textarea, l'icône se cale en haut (pas au centre vertical). */
