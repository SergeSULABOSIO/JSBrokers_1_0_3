<style>
    /* ============================================================
       Vitrine publique JS Brokers — en-tête, hero, fonctionnalités,
       tarifs et pied de page.
       Charte : cobalt #0047AB / #003380, neutres Bootstrap, fond #f3f3f3.
       Aucune couleur hors charte. Styles scopés à la vitrine (non chargés
       dans l'espace de travail). Convention reprise de _auth_styles.html.twig.
       ============================================================ */

    /* L'espace de travail impose globalement `body, html { overflow: hidden }`
       (interactive-menu.css, chargé partout) ; on rétablit le défilement sur
       cette page publique autonome (même correctif que la page CGU). */
    html, body { height: auto !important; overflow: auto !important; }
    body { background-color: #f3f3f3; }

    /* Lien d'évitement (WCAG 2.4.1) : visible uniquement au focus clavier. */
    .skip-link {
        position: absolute; left: 0.75rem; top: -3rem;
        z-index: 1200; padding: 0.6rem 1rem;
        background-color: #0047AB; color: #ffffff; border-radius: 0 0 8px 8px;
        text-decoration: none; font-weight: 600;
        transition: top 0.15s ease-in-out;
    }
    .skip-link:focus { top: 0; outline: 2px solid #ffffff; outline-offset: -4px; }

    /* ---------- En-tête public collant ---------- */
    .public-topbar {
        position: sticky; top: 0; z-index: 1030;
        background-color: #ffffff; border-bottom: 1px solid #dee2e6;
    }
    .public-topbar__inner {
        max-width: 1140px; margin: 0 auto; padding: 0.6rem 1.5rem;
        display: flex; align-items: center; gap: 1.25rem;
    }
    .public-brand {
        display: inline-flex; align-items: center; gap: 0.6rem;
        text-decoration: none; flex: 0 0 auto;
    }
    .public-brand img { border-radius: 8px; }
    .public-brand span { font-weight: 700; color: #0047AB; font-size: 1.1rem; }

    .public-nav { display: flex; gap: 1.25rem; margin-left: 0.5rem; }
    .public-nav a {
        display: inline-flex; align-items: center; min-height: 44px;
        color: #343a40; text-decoration: none; font-weight: 600; font-size: 0.95rem;
    }
    .public-nav a:hover { color: #0047AB; }
    .public-nav a:focus-visible {
        outline: 2px solid #0047AB; outline-offset: 2px; border-radius: 4px;
    }

    .public-topbar__actions {
        display: flex; align-items: center; gap: 0.6rem; margin-left: auto;
    }

    /* Bascule de langue (reprise visuelle de .cgu-lang). */
    .public-lang { display: inline-flex; border: 1px solid #dee2e6; border-radius: 8px; overflow: hidden; }
    .public-lang a {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 44px; min-height: 36px; padding: 0 0.6rem;
        font-size: 0.85rem; font-weight: 600;
        color: #6c757d; text-decoration: none; background-color: #ffffff;
    }
    .public-lang a + a { border-left: 1px solid #dee2e6; }
    .public-lang a:hover { color: #0047AB; }
    .public-lang a.is-active { background-color: #0047AB; color: #ffffff; }
    .public-lang a:focus-visible { outline: 2px solid #0047AB; outline-offset: -2px; }

    /* CTA d'en-tête : hauteur de zone cliquable confortable (≥ 44px). */
    .public-cta {
        display: inline-flex; align-items: center; min-height: 44px;
        font-weight: 600; white-space: nowrap;
    }

    /* ---------- Hero (gradient cobalt, comme .auth__brand) ---------- */
    .public-hero {
        background: linear-gradient(160deg, #0047AB 0%, #003380 100%);
        color: #ffffff;
    }
    .public-hero__inner {
        max-width: 920px; margin: 0 auto; padding: 4rem 1.5rem 4.5rem;
        text-align: center;
    }
    .public-hero h1 {
        font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 700;
        margin: 0 0 1rem; line-height: 1.2;
    }
    .public-hero__lead {
        font-size: 1.1rem; line-height: 1.6; margin: 0 auto 2rem;
        max-width: 680px; color: rgba(255, 255, 255, 0.9);
    }
    .public-hero__actions {
        display: flex; flex-wrap: wrap; gap: 0.85rem; justify-content: center;
    }
    /* CTA primaire sur fond cobalt : blanc plein, texte cobalt (contraste fort). */
    .public-hero .btn-hero-primary {
        background-color: #ffffff; color: #0047AB; border: 1px solid #ffffff;
        min-height: 48px; padding: 0 1.6rem; font-weight: 700;
        display: inline-flex; align-items: center;
    }
    .public-hero .btn-hero-primary:hover { background-color: #e8f0fb; color: #003380; }
    /* CTA secondaire : contour blanc sur fond cobalt. */
    .public-hero .btn-hero-ghost {
        background-color: transparent; color: #ffffff; border: 1px solid rgba(255, 255, 255, 0.7);
        min-height: 48px; padding: 0 1.6rem; font-weight: 600;
        display: inline-flex; align-items: center;
    }
    .public-hero .btn-hero-ghost:hover { background-color: rgba(255, 255, 255, 0.12); color: #ffffff; }
    .public-hero .btn-hero-primary:focus-visible,
    .public-hero .btn-hero-ghost:focus-visible {
        outline: 2px solid #ffffff; outline-offset: 2px;
    }

    /* ---------- Sections de contenu ---------- */
    .public-section { max-width: 1140px; margin: 0 auto; padding: 3.5rem 1.5rem; }
    .public-section__head { text-align: center; margin-bottom: 2.5rem; }
    .public-section__head h2 {
        font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: #212529; margin: 0 0 0.5rem;
    }
    .public-section__head p { color: #6c757d; margin: 0 auto; max-width: 640px; }

    /* Bloc fonctionnalité : alterné texte / image, responsive. */
    .feature-row {
        display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: center;
        padding: 2rem; border-radius: 12px; margin-bottom: 1.5rem;
    }
    .feature-row:last-child { margin-bottom: 0; }
    .feature-row--cobalt {
        background: linear-gradient(160deg, #0047AB 0%, #003380 100%); color: #ffffff;
    }
    .feature-row--light {
        background-color: #ffffff; border: 1px solid #dee2e6;
        box-shadow: 0 4px 16px rgba(0, 71, 171, 0.06);
    }
    /* Sur les lignes paires, l'image passe à gauche (desktop). */
    .feature-row--reverse .feature-row__media { order: -1; }

    .feature-row__title {
        display: flex; align-items: center; gap: 0.5rem;
        font-size: 1.25rem; font-weight: 700; margin: 0 0 0.75rem;
    }
    .feature-row--light .feature-row__title { color: #212529; }
    .feature-row__desc { line-height: 1.6; margin: 0 0 1rem; }
    .feature-row--light .feature-row__desc { color: #495057; }
    .feature-row--cobalt .feature-row__desc { color: rgba(255, 255, 255, 0.9); }

    .feature-row__intro { font-weight: 600; margin: 0 0 0.5rem; }
    .feature-row__list {
        list-style: none; padding: 0; margin: 0;
        display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.35rem 1rem;
    }
    .feature-row__list li {
        position: relative; padding-left: 1.3rem; font-size: 0.92rem; line-height: 1.5;
    }
    .feature-row__list li::before {
        content: ""; position: absolute; left: 0; top: 0.55em;
        width: 7px; height: 7px; border-radius: 50%;
    }
    .feature-row--light .feature-row__list li::before { background-color: #0047AB; }
    .feature-row--cobalt .feature-row__list li::before { background-color: #ffffff; }
    .feature-row--cobalt .feature-row__list li { color: rgba(255, 255, 255, 0.92); }
    .feature-row--light .feature-row__list li { color: #343a40; }

    .feature-row__media img {
        width: 100%; height: auto; border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    }

    /* ---------- Pied de page public ---------- */
    .public-footer {
        background-color: #ffffff; border-top: 1px solid #dee2e6; margin-top: 1rem;
    }
    .public-footer__inner {
        max-width: 1140px; margin: 0 auto; padding: 2.5rem 1.5rem 1.5rem;
        display: flex; flex-wrap: wrap; align-items: flex-start; gap: 1.5rem;
    }
    .public-footer__brand { display: flex; align-items: center; gap: 0.75rem; flex: 1 1 280px; }
    .public-footer__brand img { border-radius: 8px; }
    .public-footer__name { font-weight: 700; color: #0047AB; margin: 0; font-size: 1.05rem; }
    .public-footer__tagline { color: #6c757d; margin: 0; font-size: 0.9rem; max-width: 360px; }

    .public-footer__links { display: flex; flex-wrap: wrap; gap: 0.25rem 1.25rem; }
    .public-footer__links a {
        display: inline-flex; align-items: center; min-height: 44px;
        color: #495057; text-decoration: none; font-size: 0.92rem; font-weight: 600;
    }
    .public-footer__links a:hover { color: #0047AB; }
    .public-footer__links a:focus-visible { outline: 2px solid #0047AB; outline-offset: 2px; border-radius: 4px; }

    .public-footer__credit {
        max-width: 1140px; margin: 0 auto; padding: 1rem 1.5rem;
        border-top: 1px solid #dee2e6; text-align: center;
        color: #6c757d; font-size: 0.85rem;
    }

    /* ---------- Responsive ---------- */
    @media (max-width: 991.98px) {
        .feature-row__list { grid-template-columns: 1fr; }
    }
    @media (max-width: 767.98px) {
        .public-nav { display: none; }                 /* on allège l'en-tête sur mobile */
        .public-topbar__inner { gap: 0.6rem; }
        .feature-row { grid-template-columns: 1fr; padding: 1.5rem; }
        .feature-row--reverse .feature-row__media { order: 0; } /* image au-dessus du texte */
        .public-hero__inner { padding: 3rem 1.25rem; }
    }
</style>
