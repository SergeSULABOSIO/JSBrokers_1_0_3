{% extends 'console/form.html.twig' %}

{# Formulaire du plan tarifaire : champs regroupés en sections (fieldsets) à légende
   illustrée, sur le même modèle que la création/édition d'un coupon
   (.cs-fieldset / .cs-legend). Le thème de champ (icône incrustée via data-icon)
   est appliqué par le parent.

   Les « Paquets prépayés » sont édités via une collection stylisée + une boîte de
   dialogue (contrôleur Stimulus `packs-editor`) ; le champ caché `packsJson` reste
   la source de vérité soumise au serveur (décodée par le contrôleur PHP). #}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── Collection des paquets prépayés ───────────────────────────────── */
        .cs-packs { display: flex; flex-direction: column; gap: .6rem; margin-bottom: 1rem; }
        .cs-pack {
            display: flex; align-items: center; gap: .9rem;
            background: #fff; border: 1px solid #dee2e6; border-radius: 10px;
            padding: .7rem .9rem; transition: box-shadow .15s ease, border-color .15s ease;
        }
        .cs-pack:hover { border-color: #0047AB; box-shadow: 0 4px 14px rgba(0,71,171,.08); }
        .cs-pack-icon {
            flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
            width: 40px; height: 40px; border-radius: 9px;
            background: #e8f0fb; color: #0047AB;
        }
        .cs-pack-icon svg { width: 22px; height: 22px; }
        .cs-pack-main { flex: 1 1 auto; min-width: 0; }
        .cs-pack-name { display: block; font-weight: 700; color: #212529; font-size: 1rem; }
        .cs-pack-meta { display: flex; flex-wrap: wrap; align-items: center; gap: .4rem .75rem; margin-top: .2rem; }
        .cs-pack-tokens {
            display: inline-flex; align-items: center; gap: .3rem;
            background: #e8f0fb; color: #0047AB; font-weight: 700;
            font-size: .78rem; padding: .15rem .55rem; border-radius: 999px;
        }
        .cs-pack-tokens svg { width: 14px; height: 14px; }
        .cs-pack-price {
            display: inline-flex; align-items: center; gap: .3rem;
            color: #495057; font-size: .85rem; font-weight: 600;
        }
        .cs-pack-price svg { width: 15px; height: 15px; color: #6c757d; }
        .cs-pack-actions { flex: 0 0 auto; display: inline-flex; gap: .25rem; }
        .cs-pack-btn {
            display: inline-flex; align-items: center; justify-content: center;
            width: 38px; height: 38px; border: 1px solid #dee2e6; border-radius: 8px;
            background: #fff; color: #6c757d; cursor: pointer; transition: all .15s ease;
        }
        .cs-pack-btn:hover { border-color: #0047AB; color: #0047AB; background: #f8f9fa; }
        .cs-pack-btn:focus-visible { outline: none; border-color: #0047AB; box-shadow: 0 0 0 .2rem rgba(0,71,171,.35); }
        .cs-pack-btn--danger:hover { border-color: #dc3545; color: #dc3545; }
        .cs-pack-btn svg { width: 18px; height: 18px; }

        .cs-packs-empty {
            display: flex; align-items: center; gap: .55rem;
            color: #6c757d; font-size: .9rem; font-style: italic;
            background: #fff; border: 1px dashed #ced4da; border-radius: 10px;
            padding: 1rem; margin-bottom: 1rem;
        }

        .cs-packs-add {
            display: inline-flex; align-items: center; gap: .45rem;
            min-height: 44px; padding: .5rem 1rem;
            background: #fff; color: #0047AB; font-weight: 600;
            border: 1px solid #0047AB; border-radius: 8px; cursor: pointer;
            transition: all .15s ease;
        }
        .cs-packs-add:hover { background: #0047AB; color: #fff; }
        .cs-packs-add:focus-visible { outline: none; box-shadow: 0 0 0 .25rem rgba(0,71,171,.35); }

        /* ── Boîte de dialogue d'ajout / édition ───────────────────────────── */
        .cs-pack-dialog {
            width: min(92vw, 460px); padding: 0; border: 0; border-radius: 14px;
            box-shadow: 0 20px 60px rgba(0,71,171,.18); color: #212529;
        }
        .cs-pack-dialog::backdrop { background: rgba(0,0,0,.65); }
        .cs-pack-dialog-head {
            display: flex; align-items: center; gap: .6rem;
            padding: 1.1rem 1.25rem; border-bottom: 2px solid #0047AB;
        }
        .cs-pack-dialog-icon { display: inline-flex; color: #0047AB; }
        .cs-pack-dialog-title { font-size: 1.1rem; font-weight: 700; color: #212529; margin: 0; }
        .cs-pack-dialog-body { padding: 1.25rem; }
        .cs-pack-fld { margin-bottom: 1rem; }
        .cs-pack-fld:last-child { margin-bottom: 0; }
        .cs-pack-fld label { display: block; font-weight: 600; color: #343a40; font-size: .9rem; margin-bottom: .35rem; }
        .cs-pack-fld input {
            width: 100%; height: 46px; padding: 0 .8rem;
            border: 1px solid #ced4da; border-radius: 8px; font-size: 1rem; color: #000; background: #fff;
        }
        .cs-pack-fld input:focus { outline: none; border-color: #0047AB; box-shadow: 0 0 0 .25rem rgba(0,71,171,.35); }
        .cs-pack-fld-row { display: flex; gap: .85rem; }
        .cs-pack-fld-row .cs-pack-fld { flex: 1; }
        .cs-pack-error {
            margin: .9rem 0 0; padding: .6rem .8rem; border-radius: 8px;
            background: #f8d7da; color: #842029; font-size: .85rem;
        }
        .cs-pack-dialog-foot {
            display: flex; justify-content: flex-end; gap: .6rem;
            padding: 1rem 1.25rem; background: #f8f9fa;
            border-top: 1px solid #dee2e6;
            border-bottom-left-radius: 14px; border-bottom-right-radius: 14px;
        }
        .cs-pack-dialog-foot .btn { display: inline-flex; align-items: center; gap: .4rem; min-height: 44px; }

        @media (max-width: 575.98px) {
            .cs-pack-fld-row { flex-direction: column; gap: 0; }
        }
    </style>
{% endblock %}

{% block console_form_body %}
    <fieldset class="cs-fieldset">
        <legend class="cs-legend">
            {{ ux_icon(resolve_icon_name('offre'), {height:'16px', width:'16px'}) }}
            Offre gratuite
        </legend>
        <div class="row">
            <div class="col-md">{{ form_row(form.freeAllowance) }}</div>
            <div class="col-md">{{ form_row(form.freeWindowHours) }}</div>
        </div>
    </fieldset>

    <fieldset class="cs-fieldset">
        <legend class="cs-legend">
            {{ ux_icon(resolve_icon_name('tranche'), {height:'16px', width:'16px'}) }}
            Métrage &amp; conversion
        </legend>
        <div class="row">
            <div class="col-md">{{ form_row(form.readWeight) }}</div>
            <div class="col-md">{{ form_row(form.defaultWriteWeight) }}</div>
        </div>
        {{ form_row(form.usdPerToken) }}
    </fieldset>

    {# ── Paquets prépayés : collection éditable + boîte de dialogue ───────── #}
    <fieldset class="cs-fieldset" data-controller="packs-editor">
        <legend class="cs-legend">
            {{ ux_icon(resolve_icon_name('offre'), {height:'16px', width:'16px'}) }}
            Paquets prépayés
        </legend>

        {# Source de vérité soumise au serveur, synchronisée par le contrôleur. #}
        {{ form_widget(form.packsJson, {attr: {'data-packs-editor-target': 'input'}}) }}

        <div class="cs-packs" data-packs-editor-target="list" role="list"></div>

        <p class="cs-packs-empty" data-packs-editor-target="empty" hidden>
            {{ ux_icon(resolve_icon_name('action:information'), {height:'18px', width:'18px'}) }}
            Aucun paquet prépayé pour le moment. Ajoutez-en un avec le bouton ci-dessous.
        </p>

        <button type="button" class="cs-packs-add" data-action="packs-editor#add">
            {{ ux_icon(resolve_icon_name('action:add'), {height:'18px', width:'18px'}) }}
            <span>Ajouter un paquet</span>
        </button>

        {# Gabarit d'une carte de paquet, cloné par le contrôleur Stimulus. #}
        <template data-packs-editor-target="rowTemplate">
            <div class="cs-pack" role="listitem">
                <span class="cs-pack-icon" aria-hidden="true">{{ ux_icon(resolve_icon_name('offre'), {height:'22px', width:'22px'}) }}</span>
                <div class="cs-pack-main">
                    <span class="cs-pack-name" data-field="label"></span>
                    <div class="cs-pack-meta">
                        <span class="cs-pack-tokens">
                            {{ ux_icon(resolve_icon_name('action:count'), {height:'14px', width:'14px'}) }}
                            <span data-field="tokens"></span>&nbsp;tokens
                        </span>
                        <span class="cs-pack-price">
                            {{ ux_icon(resolve_icon_name('monnaie'), {height:'15px', width:'15px'}) }}
                            <span data-field="price"></span>&nbsp;$ TTC
                        </span>
                    </div>
                </div>
                <div class="cs-pack-actions">
                    <button type="button" class="cs-pack-btn" data-action="packs-editor#edit" data-key=""
                            aria-label="Modifier ce paquet" title="Modifier">
                        {{ ux_icon(resolve_icon_name('action:edit'), {height:'18px', width:'18px'}) }}
                    </button>
                    <button type="button" class="cs-pack-btn cs-pack-btn--danger" data-action="packs-editor#delete" data-key=""
                            aria-label="Supprimer ce paquet" title="Supprimer">
                        {{ ux_icon(resolve_icon_name('action:delete'), {height:'18px', width:'18px'}) }}
                    </button>
                </div>
            </div>
        </template>

        {# Boîte de dialogue d'ajout / édition (sans <form> imbriqué : champs sans
           name, boutons type=button — la soumission réelle passe par packsJson). #}
        <dialog class="cs-pack-dialog" data-packs-editor-target="dialog" aria-labelledby="cs-pack-dialog-title">
            <div class="cs-pack-dialog-head">
                <span class="cs-pack-dialog-icon" aria-hidden="true">{{ ux_icon(resolve_icon_name('offre'), {height:'22px', width:'22px'}) }}</span>
                <h2 class="cs-pack-dialog-title" id="cs-pack-dialog-title" data-packs-editor-target="dialogTitle">Nouveau paquet</h2>
            </div>

            <div class="cs-pack-dialog-body">
                <div class="cs-pack-fld">
                    <label for="cs-pack-label">Nom du plan</label>
                    <input type="text" id="cs-pack-label" maxlength="60" autocomplete="off"
                           placeholder="Ex. Intermédiaire"
                           data-packs-editor-target="fieldLabel" aria-describedby="cs-pack-error"
                           data-action="keydown.enter->packs-editor#save">
                </div>
                <div class="cs-pack-fld-row">
                    <div class="cs-pack-fld">
                        <label for="cs-pack-tokens">Tokens offerts</label>
                        <input type="number" id="cs-pack-tokens" min="1" step="1" inputmode="numeric"
                               placeholder="Ex. 10000"
                               data-packs-editor-target="fieldTokens" aria-describedby="cs-pack-error"
                               data-action="keydown.enter->packs-editor#save">
                    </div>
                    <div class="cs-pack-fld">
                        <label for="cs-pack-price">Prix de vente TTC ($)</label>
                        <input type="number" id="cs-pack-price" min="0" step="0.01" inputmode="decimal"
                               placeholder="Ex. 10"
                               data-packs-editor-target="fieldPrice" aria-describedby="cs-pack-error"
                               data-action="keydown.enter->packs-editor#save">
                    </div>
                </div>
                <p class="cs-pack-error" id="cs-pack-error" data-packs-editor-target="error" role="alert" hidden></p>
            </div>

            <div class="cs-pack-dialog-foot">
                <button type="button" class="btn btn-outline-secondary" data-action="packs-editor#cancel">
                    {{ ux_icon(resolve_icon_name('action:cancel'), {height:'16px', width:'16px'}) }}
                    <span>Annuler</span>
                </button>
                <button type="button" class="btn btn-cobalt" data-action="packs-editor#save">
                    {{ ux_icon(resolve_icon_name('action:save'), {height:'16px', width:'16px'}) }}
                    <span>Valider</span>
                </button>
            </div>
        </dialog>

        {# Boîte de confirmation stylisée et réutilisable du projet : la suppression
           d'un paquet passe par elle (au lieu du window.confirm() du navigateur). #}
        {{ include('components/_confirmation_dialog.html.twig') }}
    </fieldset>

    <fieldset class="cs-fieldset">
        <legend class="cs-legend">
            {{ ux_icon(resolve_icon_name('action:settings'), {height:'16px', width:'16px'}) }}
            Poids d'écriture par entité (JSON)
        </legend>
        {{ form_row(form.writeWeightsJson) }}
    </fieldset>
{% endblock %}
