{# Navigation de la Console, regroupée par fonction (Comptes / Ventes / Finance)
   pour éviter le débordement de la barre. Chaque groupe est un menu déroulant
   accessible bâti sur <details>/<summary> (état exposé nativement) et piloté par
   le contrôleur Stimulus `nav-menu` (un seul ouvert, fermeture clic-dehors/Échap).
   L'état actif est déduit du préfixe de la route courante (un groupe est actif si
   l'une de ses rubriques l'est). #}
{% set route = app.request.attributes.get('_route')|default('') %}
{% set groups = [
    { label: 'CRM', icon: 'piste', items: [
        { r: 'console.crm.dashboard',     p: 'console.crm.dashboard',         icon: 'dashboard',      label: 'Tableau de bord' },
        { r: 'console.crm.client.',       p: 'console.crm.client.index',      icon: 'client',         label: 'Clients' },
        { r: 'console.crm.pipeline.',     p: 'console.crm.pipeline.index',    icon: 'piste',          label: 'Pipeline' },
        { r: 'console.crm.tache.',        p: 'console.crm.tache.index',       icon: 'tache',          label: 'Tâches' },
        { r: 'console.crm.cs',            p: 'console.crm.cs',                icon: 'action:analyser', label: 'Customer Success' },
        { r: 'console.crm.ticket.',       p: 'console.crm.ticket.index',      icon: 'feedback',       label: 'Support' },
        { r: 'console.crm.campagne.',     p: 'console.crm.campagne.index',    icon: 'action:premium', label: 'Marketing' },
        { r: 'console.crm.notification.', p: 'console.crm.notification.index', icon: 'action:alert',  label: 'Notifications' },
        { r: 'console.crm.entreprise.',   p: 'console.crm.entreprise.index',  icon: 'entreprise',     label: 'Entreprises' },
    ] },
    { label: 'Pilotage', icon: 'dashboard', items: [
        { r: 'console.crm.cfo',     p: 'console.crm.cfo',            icon: 'revenu',    label: 'CFO' },
        { r: 'console.crm.ceo',     p: 'console.crm.ceo',            icon: 'dashboard', label: 'CEO' },
        { r: 'console.crm.rapport.', p: 'console.crm.rapport.index', icon: 'document',  label: 'Rapports' },
    ] },
    { label: 'Comptes', icon: 'client', items: [
        { r: 'console.collaborateur.', p: 'console.collaborateur.index', icon: 'action:role', label: 'Collaborateurs' },
        { r: 'console.utilisateur.',   p: 'console.utilisateur.index',   icon: 'utilisateur',  label: 'Utilisateurs' },
        { r: 'console.client.',        p: 'console.client.index',        icon: 'client',       label: 'Clients' },
        { r: 'console.entreprise.',    p: 'console.entreprise.index',    icon: 'entreprise',   label: 'Entreprises' },
    ] },
    { label: 'Ventes', icon: 'operation', items: [
        { r: 'console.vente.',  p: 'console.vente.index',  icon: 'operation', label: 'Ventes' },
        { r: 'console.coupon.', p: 'console.coupon.index', icon: 'offre',     label: 'Coupons' },
    ] },
    { label: 'Finance', icon: 'charge', items: [
        { r: 'console.depense.',  p: 'console.depense.index',  icon: 'depense',  label: 'Dépenses' },
        { r: 'console.charge.',   p: 'console.charge.index',   icon: 'charge',   label: 'Charges' },
        { r: 'console.document.', p: 'console.document.index', icon: 'document', label: 'Documents comptables' },
        { r: 'console.taxe.',     p: 'console.taxe.index',     icon: 'taxe',     label: 'Fiscalité' },
    ] },
] %}
<nav class="cs-nav" aria-label="Sections de la console" data-controller="nav-menu">
    {# Tableau de bord : lien direct (pas de sous-rubriques). #}
    {% set dashActive = route == 'console.dashboard' %}
    <a href="{{ path('console.dashboard') }}" class="cs-nav-link {{ dashActive ? 'is-active' }}"
       data-action="click->top-progress#show" {% if dashActive %}aria-current="page"{% endif %}>
        {{ ux_icon(resolve_icon_name('dashboard'), {height: '18px', width: '18px'}) }}
        <span>Tableau de bord</span>
    </a>

    {% for g in groups %}
        {# Groupe « Ventes » : le Plan tarifaire (super-admin) en fait partie.
           Groupe « CRM » : les Paramètres CRM (super-admin) en font partie. #}
        {% set isVentes = g.label == 'Ventes' %}
        {% set isCrm = g.label == 'CRM' %}
        {% set gActive = (isVentes and route starts with 'console.plan.') or (isCrm and route starts with 'console.crm.parametres.') %}
        {% for it in g.items %}
            {% if route starts with it.r %}{% set gActive = true %}{% endif %}
        {% endfor %}

        <details class="cs-menu" data-nav-menu-target="menu" data-action="toggle->nav-menu#opened">
            <summary class="cs-nav-link {{ gActive ? 'is-active' }}" aria-haspopup="true">
                {{ ux_icon(resolve_icon_name(g.icon), {height: '18px', width: '18px'}) }}
                <span>{{ g.label }}</span>
                <span class="cs-menu-caret" aria-hidden="true"></span>
            </summary>
            <div class="cs-menu-panel">
                {% for it in g.items %}
                    {% set active = route starts with it.r %}
                    <a href="{{ path(it.p) }}" class="{{ active ? 'is-active' }}"
                       data-action="click->top-progress#show" {% if active %}aria-current="page"{% endif %}>
                        {{ ux_icon(resolve_icon_name(it.icon), {height: '18px', width: '18px'}) }}
                        <span>{{ it.label }}</span>
                    </a>
                {% endfor %}
                {% if isVentes and is_granted('ROLE_SUPER_ADMIN') %}
                    {% set planActive = route starts with 'console.plan.' %}
                    <a href="{{ path('console.plan.index') }}" class="{{ planActive ? 'is-active' }}"
                       data-action="click->top-progress#show" {% if planActive %}aria-current="page"{% endif %}>
                        {{ ux_icon(resolve_icon_name('action:settings'), {height: '18px', width: '18px'}) }}
                        <span>Plan tarifaire</span>
                    </a>
                {% endif %}
                {% if isCrm and is_granted('ROLE_SUPER_ADMIN') %}
                    {% set crmParamActive = route starts with 'console.crm.parametres.' %}
                    <a href="{{ path('console.crm.parametres.index') }}" class="{{ crmParamActive ? 'is-active' }}"
                       data-action="click->top-progress#show" {% if crmParamActive %}aria-current="page"{% endif %}>
                        {{ ux_icon(resolve_icon_name('action:settings'), {height: '18px', width: '18px'}) }}
                        <span>Paramètres CRM</span>
                    </a>
                {% endif %}
            </div>
        </details>
    {% endfor %}
</nav>
