{% extends 'console/base.html.twig' %}

{% block console_subtitle %}<p>Référentiel des types de charges supportées par JS Brokers (comptes OHADA classe 6).</p>{% endblock %}

{% block console_actions %}
    <a href="{{ path('console.charge.new') }}" class="btn btn-sm btn-cobalt" data-action="click->top-progress#show">
        {{ ux_icon(resolve_icon_name('action:add'), {height:'18px', width:'18px'}) }}
        <span class="ms-1">Nouvelle</span>
    </a>
{% endblock %}

{% block console_body %}
<div class="cs-panel">
    {% if charges.getTotalItemCount > 0 %}
        <table class="cs-table">
            <thead><tr><th>Code</th><th>Libellé</th><th>Compte OHADA</th><th>Destination</th><th>Comportement</th><th>Périodicité</th><th>Budget / mois</th><th>État</th></tr></thead>
            <tbody>
            {% for c in charges %}
                <tr data-cm-row>
                    <td><strong>{{ c.code }}</strong></td>
                    <td>{{ c.libelle }}</td>
                    <td><span class="cs-badge cs-badge--cobalt">{{ c.compteOhada }}</span> <small style="color:#6c757d;">{{ c.compteOhadaLabel }}</small></td>
                    <td>{{ c.destinationLabel }}</td>
                    <td>{{ c.comportementLabel }}</td>
                    <td>{{ c.periodiciteLabel }}</td>
                    <td>{% if c.montantBudgeteMensuel is not null %}{{ c.montantBudgeteMensuelFloat|number_format(2, '.', ' ') }} ${% else %}—{% endif %}</td>
                    <td>
                        {% if c.actif %}
                            <span class="cs-badge cs-badge--ok">Active</span>
                        {% else %}
                            <span class="cs-badge cs-badge--muted">Inactive</span>
                        {% endif %}
                    </td>
                    <td hidden data-cm-actions>
                        <a href="{{ path('console.charge.edit', {id: c.id}) }}" class="cs-icon-btn"
                           data-action="click->top-progress#show" title="Éditer" aria-label="Éditer {{ c.code }}">
                            {{ ux_icon(resolve_icon_name('action:edit'), {height:'18px', width:'18px'}) }}
                        </a>
                        <form action="{{ path('console.charge.delete', {id: c.id}) }}" method="post" style="display:inline;"
                              data-controller="confirm-action" data-action="submit->confirm-action#request"
                              data-confirm-action-title-value="Supprimer la charge"
                              data-confirm-action-body-value="Supprimer le type de charge « {{ c.code }} » ?"
                              data-confirm-action-irreversible-value="true">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-charge-' ~ c.id) }}">
                            <button type="submit" class="cs-icon-btn is-danger" title="Supprimer" aria-label="Supprimer {{ c.code }}">
                                {{ ux_icon(resolve_icon_name('action:delete'), {height:'18px', width:'18px'}) }}
                            </button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        <div class="cs-pagination">{{ knp_pagination_render(charges) }}</div>
    {% else %}
        <div class="cs-empty">
            <p>Aucun type de charge. Créez votre première catégorie de charge.</p>
            <a href="{{ path('console.charge.new') }}" class="btn btn-cobalt mt-2" data-action="click->top-progress#show">
                {{ ux_icon(resolve_icon_name('action:add'), {height:'18px', width:'18px'}) }}
                <span class="ms-1">Nouvelle charge</span>
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}
