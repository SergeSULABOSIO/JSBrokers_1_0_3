{% extends 'console/base.html.twig' %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Formulaire de la Console — inspiré de la page de connexion :
       carte blanche, accents cobalt, champs hauts et confortables. */
    .cs-form-wrap { max-width: 720px; margin: 0 auto; }
    /* L'entête générique de la console (.cs-head, rendu par base.html.twig) est masqué
       sur les pages de formulaire : on rend ici notre propre entête à l'intérieur de la
       colonne étroite (.cs-form-wrap), exactement comme l'entreprise place .ent-back +
       .ent-head dans la même colonne que .ent-form-card. */
    .cs-head { display: none; }
    /* Lien de retour en haut (chevron + libellé), au-dessus du titre. */
    .cs-back { display:inline-flex; align-items:center; gap:.35rem; font-size:.9rem; color:#6c757d; text-decoration:none; margin-bottom:1rem; }
    .cs-back:hover { color:#0047AB; }
    /* Entête du formulaire : titre + description (modèle .ent-head). */
    .cs-form-head { margin-bottom: 1.5rem; }
    /* Titre + icône d'illustration alignés sur une même ligne. */
    .cs-head-title { display: flex; align-items: center; gap: .7rem; margin-bottom: .25rem; }
    .cs-form-head h1 { font-size: 1.6rem; font-weight: 700; color:#212529; margin: 0; }
    /* Pastille cobalt (même langage visuel que .cs-pack-icon), portée par `formIcon`. */
    .cs-head-icon {
        flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
        width: 46px; height: 46px; border-radius: 11px;
        background: #e8f0fb; color: #0047AB;
    }
    .cs-head-icon svg { width: 26px; height: 26px; }
    .cs-form-head p { color:#6c757d; margin:0; }
    /* Séparateur entre le texte d'entête et la carte (modèle entreprise : le message
       de description se termine par un <hr>). */
    .cs-form-head hr { margin: 1.25rem 0 0; border:0; border-top:1px solid #dee2e6; opacity:1; }
    .cs-form-card {
        background:#fff; border:1px solid #dee2e6; border-radius:14px;
        padding:1.75rem; box-shadow:0 10px 40px rgba(0,71,171,.08);
    }
    /* Illustration en cercle, centrée en haut de la carte (modèle .ent-thumb /
       .ent-thumb-placeholder de l'entreprise). Cohabite avec la pastille du titre :
       le cercle est l'illustration principale de la carte, la pastille rappelle
       l'icône au niveau du titre. */
    .cs-thumb { display:flex; justify-content:center; margin-bottom:1.5rem; }
    .cs-thumb-placeholder {
        display:flex; align-items:center; justify-content:center;
        width:150px; height:150px; border-radius:50%;
        border:1px solid #dee2e6; background:#f8f9fa; transition: box-shadow .2s ease;
    }
    .cs-thumb-placeholder:hover { box-shadow:0 4px 16px rgba(0,71,171,.12); }
    .cs-thumb-placeholder svg { width:64px; height:64px; color:#0047AB; }
    /* Sections du formulaire : chaque groupe = panneau distinct avec légende à icône
       (modèle .ent-fieldset / .ent-legend de l'entreprise). */
    .cs-fieldset {
        border:1px solid #dee2e6; border-radius:10px; background:#f8f9fa;
        padding:1.15rem 1.25rem .35rem; margin:0 0 1.1rem;
    }
    .cs-fieldset:last-of-type { margin-bottom:0; }
    .cs-legend {
        display:inline-flex; align-items:center; gap:.45rem;
        font-size:.78rem; text-transform:uppercase; letter-spacing:.04em; font-weight:700;
        color:#0047AB; margin-bottom:1rem; padding:0; width:auto; float:none;
    }
    /* Les champs (blancs) ressortent sur le fond clair du panneau. */
    .cs-fieldset .form-control,
    .cs-fieldset .form-select { background:#fff; }
    .cs-form-card .form-label { font-weight:600; color:#343a40; margin-bottom:.35rem; }
    .cs-form-card .form-control,
    .cs-form-card .form-select { height:48px; font-size:1rem; color:#000; }
    .cs-form-card textarea.form-control { height:auto; }
    .cs-form-card .form-control:focus,
    .cs-form-card .form-select:focus { border-color:#0047AB; box-shadow:0 0 0 .25rem rgba(0,71,171,.35); }
    .cs-form-card .form-check-input:checked { background-color:#0047AB; border-color:#0047AB; }
    .cs-form-card .form-check-input:focus { border-color:#0047AB; box-shadow:0 0 0 .25rem rgba(0,71,171,.35); }
    /* Le champ à icône incrustée (.cs-field) est défini dans console/base.html.twig
       — pattern unique partagé par toute la console (formulaires et filtres). */
    /* Barre d'actions toujours visible : épinglée en bas de la carte (même pattern
       que .ent-actions de l'édition d'entreprise), adaptée aux mesures de la carte
       console (padding 1.75rem, rayon 14px). Reste dans le <form> pour ne pas
       affecter la soumission / le jeton CSRF. */
    .cs-form-actions {
        position: sticky; bottom: 0; z-index: 5;
        display:flex; align-items:center; gap:.75rem;
        /* Neutralise le padding 1.75rem de .cs-form-card pour coller la barre aux bords */
        margin: 1.5rem -1.75rem -1.75rem;
        padding: 1rem 1.75rem;
        background:#fff; border-top:1px solid #dee2e6;
        border-bottom-left-radius:14px; border-bottom-right-radius:14px;
        box-shadow: 0 -4px 12px rgba(0,71,171,.06);
    }
    .cs-form-actions .btn { height:46px; display:inline-flex; align-items:center; }
    /* Lien de retour intégré à gauche de la barre, séparé des boutons (repris de
       .ent-actions-back / .ent-actions-sep). margin-left:auto pousse le séparateur
       + les boutons à droite, le lien restant ancré à gauche. */
    .cs-actions-back {
        display:inline-flex; align-items:center; gap:.35rem;
        font-size:.9rem; color:#6c757d; text-decoration:none; white-space:nowrap;
        transition: color .15s ease;
    }
    .cs-actions-back:hover { color:#0047AB; }
    .cs-actions-sep { flex:0 0 auto; width:1px; height:28px; background:#dee2e6; margin-left:auto; }

    @media (max-width: 575.98px) {
        .cs-form-actions { flex-direction: column-reverse; align-items: stretch; }
        .cs-form-actions .btn { width: 100%; }
        .cs-actions-sep { display: none; }
        .cs-actions-back { width: 100%; justify-content: center; }
    }
</style>
{% endblock %}

{% form_theme form 'console/_form_theme.html.twig' %}

{% block console_body %}
<div class="cs-form-wrap">
    <a href="{{ backUrl|default(path('console.dashboard')) }}" class="cs-back" data-action="click->top-progress#show">
        {{ ux_icon('hugeicons:arrow-left-01', {height:'18px', width:'18px'}) }}
        {{ backLabel|default('Retour') }}
    </a>

    <div class="cs-form-head">
        <div class="cs-head-title">
            {# Icône d'illustration du titre : pastille cobalt (même esprit que
               .cs-pack-icon) ; l'icône est choisie par le contrôleur via `formIcon`,
               repli sur l'icône console. #}
            <span class="cs-head-icon" aria-hidden="true">
                {{ ux_icon(resolve_icon_name(formIcon|default('offre')), {height:'26px', width:'26px'}) }}
            </span>
            <h1>{{ pageName }}</h1>
        </div>
        {% if description is defined and description %}<p>{{ description|raw }}</p>{% endif %}
        <hr>
    </div>

    <div class="cs-form-card">
        {# Illustration en cercle, centrée en haut de la carte (modèle entreprise).
           L'icône est choisie par le contrôleur via `formIcon` ; repli sur l'icône console. #}
        <div class="cs-thumb">
            <div class="cs-thumb-placeholder" aria-hidden="true">
                {{ ux_icon(resolve_icon_name(formIcon|default('offre')), {height:'64px', width:'64px'}) }}
            </div>
        </div>

        {{ form_start(form, {attr: {
            novalidate: 'novalidate',
            'data-controller': 'form-submit',
            'data-action': 'submit->form-submit#submitting submit->top-progress#show',
            'data-form-submit-loading-text-value': submitLabel|default('Enregistrement…')
        }}) }}
            {% block console_form_body %}{{ form_widget(form) }}{% endblock %}

            <div class="cs-form-actions">
                <a href="{{ backUrl|default(path('console.dashboard')) }}" class="cs-actions-back"
                   data-action="click->top-progress#show">
                    {{ ux_icon('hugeicons:arrow-left-01', {height:'18px', width:'18px'}) }}
                    <span>{{ backLabel|default('Retour') }}</span>
                </a>

                <span class="cs-actions-sep" aria-hidden="true"></span>

                <button type="submit" class="btn btn-cobalt d-inline-flex align-items-center"
                        data-form-submit-target="button">
                    {{ ux_icon(resolve_icon_name('action:save'), {height:'18px', width:'18px'}) }}
                    <span class="ms-1">{{ submitLabel|default('Enregistrer') }}</span>
                </button>
                <a href="{{ backUrl|default(path('console.dashboard')) }}"
                   class="btn btn-outline-secondary d-inline-flex align-items-center"
                   data-action="click->form-submit#navigating click->top-progress#show"
                   data-loading-text="Annulation…">
                    {{ ux_icon(resolve_icon_name('action:cancel'), {height:'18px', width:'18px'}) }}
                    <span class="ms-1">Annuler</span>
                </a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
