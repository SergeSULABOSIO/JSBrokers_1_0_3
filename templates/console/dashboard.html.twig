{% extends 'console/base.html.twig' %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Bandeau personnalisé du tableau de bord (profil du collaborateur). */
    .cs-db-greeting { margin-bottom: 1rem; }
    .cs-db-score { display:flex; align-items:center; gap:.7rem; padding:.5rem .9rem;
        background:#f8f9fa; border:1px solid #dee2e6; border-radius:12px; }
    .cs-db-quick { display:flex; flex-wrap:wrap; gap:.5rem; margin-top:1rem;
        padding-top:1rem; border-top:1px solid #f0f0f0; }
    .cs-db-quick-link { display:inline-flex; align-items:center; gap:.4rem;
        padding:.45rem .75rem; border-radius:8px; text-decoration:none;
        background:#eef2fb; color:#0047AB; font-size:.85rem; font-weight:600; }
    .cs-db-quick-link:hover { background:#0047AB; color:#fff; }
    .cs-db-quick-link:hover svg { color:#fff; }
    .cs-db-quick-link:focus-visible { outline:2px solid #0047AB; outline-offset:2px; }
</style>
{% endblock %}

{% block console_subtitle %}<p>Bonjour {{ app.user.nom }} — voici votre espace, adapté à votre département.</p>{% endblock %}

{% block console_body %}
    {# ── Bandeau personnalisé selon le profil (département, fonction, périmètre,
         score d'évaluation) + accès rapides aux seules rubriques autorisées. ── #}
    {% set quickLinks = [
        { p: 'console.vente.index',         icon: 'operation',       label: 'Ventes' },
        { p: 'console.coupon.index',        icon: 'offre',           label: 'Coupons' },
        { p: 'console.depense.index',       icon: 'depense',         label: 'Dépenses' },
        { p: 'console.document.index',      icon: 'document',        label: 'Documents comptables' },
        { p: 'console.taxe.index',          icon: 'taxe',            label: 'Fiscalité' },
        { p: 'console.crm.dashboard',       icon: 'piste',           label: 'CRM' },
        { p: 'console.crm.ticket.index',    icon: 'feedback',        label: 'Support' },
        { p: 'console.crm.campagne.index',  icon: 'action:premium',  label: 'Campagnes' },
        { p: 'console.client.index',        icon: 'client',          label: 'Clients' },
        { p: 'console.entreprise.index',    icon: 'entreprise',      label: 'Entreprises' },
        { p: 'console.collaborateur.index', icon: 'action:role',     label: 'Collaborateurs' },
        { p: 'console.evaluation.index',    icon: 'action:analyser', label: 'Évaluations' },
    ]|filter(l => console_can_access(l.p)) %}

    <div class="cs-panel cs-db-greeting">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div>
                <div class="d-flex align-items-center flex-wrap gap-2 mb-1">
                    {% if app.user.departement %}
                        <span class="cs-badge cs-badge--cobalt">
                            {{ ux_icon(resolve_icon_name(app.user.departement.icon), {height:'14px', width:'14px'}) }}
                            {{ app.user.departement.label }}
                        </span>
                    {% elseif is_granted('ROLE_SUPER_ADMIN') %}
                        <span class="cs-badge cs-badge--cobalt">Super-administrateur · accès complet</span>
                    {% else %}
                        <span class="cs-badge cs-badge--warn">Non affecté · accès complet</span>
                    {% endif %}
                    {% if app.user.fonction %}
                        <span class="cs-badge {{ app.user.fonction.badgeClass }}">{{ app.user.fonction.label }}</span>
                    {% endif %}
                </div>
                <p class="text-muted mb-0" style="font-size:.9rem;">
                    {% if app.user.departement %}
                        {{ app.user.departement.description }}
                    {% else %}
                        Vous avez accès à l'ensemble des rubriques de la console.
                    {% endif %}
                </p>
            </div>

            {% if monScore is not null %}
                {# Score d'évaluation personnel (période annuelle courante), en lecture. #}
                <div class="cs-db-score" data-meta-tip="Votre score d'évaluation pour {{ monScoreAnnee }}">
                    <span class="cs-kpi-icon">{{ ux_icon(resolve_icon_name('action:analyser'), {height:'22px', width:'22px'}) }}</span>
                    <div>
                        <div style="font-size:1.4rem;font-weight:700;color:#212529;line-height:1;">
                            {{ monScore }} <span style="font-size:.85rem;color:#6c757d;">/ 100</span>
                        </div>
                        <div class="cs-kpi-lbl">Mon évaluation {{ monScoreAnnee }} ·
                            <span class="cs-badge {{ monScoreClass }}">{{ monScoreMention }}</span>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>

        {% if quickLinks is not empty %}
            <div class="cs-db-quick">
                {% for l in quickLinks %}
                    <a href="{{ path(l.p) }}" class="cs-db-quick-link" data-action="click->top-progress#show">
                        {{ ux_icon(resolve_icon_name(l.icon), {height:'16px', width:'16px'}) }}
                        <span>{{ l.label }}</span>
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# ── Colonne centrale unique : pile de blocs pliables, un par ligne ──
       Même comportement que le tableau de bord de l'espace de travail
       courtiers : chaque bloc est une carte <details> repliable au clic,
       sensible au survol (db-dashboard-block), chargée à la demande puis
       rafraîchie toutes les 3 minutes. ── #}
    <div class="cs-db">

        {# ── Indicateurs de la plateforme : sans cadre, rendus dès le chargement
             (toujours visibles) et rafraîchis silencieusement toutes les 3 min. ── #}
        <div class="mb-3"
             data-controller="lazy-block"
             data-lazy-block-url-value="{{ path('console.dashboard.block_kpis') }}"
             data-lazy-block-interval-value="180000"
             data-lazy-block-skip-initial-value="true">
            {{ include('console/dashboard/_block_kpis.html.twig') }}
        </div>

        {% if console_can_access('console.vente.index') %}
        {# ── Revenu des ventes : deux vues (par mois / par paquet) dans un
             bloc unique avec bascule, sur le modèle du bloc « Production »
             du tableau de bord courtiers. ── #}
        <details open class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block"
                 data-controller="chart-modes" data-chart-modes-active-value="mois">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon('mdi:chart-box-outline', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Revenu des ventes</span>
                    <small id="cs-db-revenue-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron ms-auto', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="px-3 pt-2 pb-2 bg-white border-bottom d-flex align-items-center gap-2">
                <div class="db-prod-tabs">
                    <button type="button" class="db-task-toggle active" data-mode="mois"
                            data-chart-modes-target="tab" data-action="chart-modes#switch"
                            aria-pressed="true" title="Revenu par mois">
                        {{ ux_icon('mdi:chart-bar', {style: 'width:12px;height:12px;'}) }}
                        Par mois
                    </button>
                    <button type="button" class="db-task-toggle" data-mode="pack"
                            data-chart-modes-target="tab" data-action="chart-modes#switch"
                            aria-pressed="false" title="Répartition par paquet">
                        {{ ux_icon('mdi:chart-pie', {style: 'width:12px;height:12px;'}) }}
                        Par paquet
                    </button>
                    <button type="button" class="db-task-toggle" data-mode="pays"
                            data-chart-modes-target="tab" data-action="chart-modes#switch"
                            aria-pressed="false" title="Revenu par pays">
                        {{ ux_icon('mdi:earth', {style: 'width:12px;height:12px;'}) }}
                        Par pays
                    </button>
                </div>
            </div>
            <div class="card-body p-3"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_revenue') }}"
                 data-lazy-block-interval-value="180000"
                 data-lazy-block-status-id-value="cs-db-revenue-update">
                <div class="db-skeleton-block" style="height:300px;"></div>
            </div>
        </details>

        {# ── Dernières ventes (recherche + rafraîchissement du fragment) ──
             Fermé par défaut : ni chargement ni rafraîchissement tant que le
             bloc n'est pas ouvert (économie de bande passante). ── #}
        <details class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon('mdi:cash-multiple', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Dernières ventes</span>
                    <small id="cs-db-ventes-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    <a href="{{ path('console.vente.index') }}" class="db-task-new-btn ms-auto"
                       onclick="event.stopPropagation();"
                       data-action="click->top-progress#show"
                       data-meta-tip="Voir toutes les ventes"
                       aria-label="Voir toutes les ventes">
                        {{ ux_icon('hugeicons:view', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    </a>
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="card-body p-0"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_ventes') }}">
                <div class="db-skeleton-block m-3" style="height:140px;"></div>
            </div>
        </details>

        {% endif %}

        {% if console_can_access('console.depense.index') %}
        {# ── Dernières dépenses (recherche + rafraîchissement du fragment) ──
             Pendant du bloc Ventes : décaissements de JS Brokers. Fermé par
             défaut (chargement/rafraîchissement uniquement à l'ouverture). ── #}
        <details class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon(resolve_icon_name('depense'), {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Dernières dépenses</span>
                    <small id="cs-db-depenses-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    <a href="{{ path('console.depense.index') }}" class="db-task-new-btn ms-auto"
                       onclick="event.stopPropagation();"
                       data-action="click->top-progress#show"
                       data-meta-tip="Voir toutes les dépenses"
                       aria-label="Voir toutes les dépenses">
                        {{ ux_icon('hugeicons:view', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    </a>
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="card-body p-0"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_depenses') }}">
                <div class="db-skeleton-block m-3" style="height:140px;"></div>
            </div>
        </details>

        {% endif %}

        {% if console_can_access('console.entreprise.index') %}
        {# ── Dernières entreprises créées (fermé par défaut) ── #}
        <details class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon('mdi:office-building-outline', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Dernières entreprises créées</span>
                    <small id="cs-db-entreprises-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    <a href="{{ path('console.entreprise.index') }}" class="db-task-new-btn ms-auto"
                       onclick="event.stopPropagation();"
                       data-action="click->top-progress#show"
                       data-meta-tip="Voir toutes les entreprises"
                       aria-label="Voir toutes les entreprises">
                        {{ ux_icon('hugeicons:view', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    </a>
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="card-body p-0"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_entreprises') }}">
                <div class="db-skeleton-block m-3" style="height:140px;"></div>
            </div>
        </details>

        {% endif %}

        {% if console_can_access('console.client.index') %}
        {# ── Derniers clients : comptes en mode payant (fermé par défaut) ── #}
        <details class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon('mdi:account-cash-outline', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Derniers clients</span>
                    <small id="cs-db-clients-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    <a href="{{ path('console.client.index') }}" class="db-task-new-btn ms-auto"
                       onclick="event.stopPropagation();"
                       data-action="click->top-progress#show"
                       data-meta-tip="Voir tous les clients"
                       aria-label="Voir tous les clients">
                        {{ ux_icon('hugeicons:view', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    </a>
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="card-body p-0"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_clients') }}">
                <div class="db-skeleton-block m-3" style="height:140px;"></div>
            </div>
        </details>

        {% endif %}

        {% if console_can_access('console.utilisateur.index') %}
        {# ── Derniers utilisateurs créés (fermé par défaut) ── #}
        <details class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon('mdi:account-multiple-outline', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Derniers utilisateurs créés</span>
                    <small id="cs-db-utilisateurs-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    <a href="{{ path('console.utilisateur.index') }}" class="db-task-new-btn ms-auto"
                       onclick="event.stopPropagation();"
                       data-action="click->top-progress#show"
                       data-meta-tip="Voir tous les utilisateurs"
                       aria-label="Voir tous les utilisateurs">
                        {{ ux_icon('hugeicons:view', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    </a>
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="card-body p-0"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_utilisateurs') }}">
                <div class="db-skeleton-block m-3" style="height:140px;"></div>
            </div>
        </details>

        {% endif %}

        {% if console_can_access('console.coupon.index') %}
        {# ── Derniers coupons (fermé par défaut) ── #}
        <details class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon(resolve_icon_name('offre'), {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Derniers coupons</span>
                    <small id="cs-db-coupons-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    <a href="{{ path('console.coupon.index') }}" class="db-task-new-btn ms-auto"
                       onclick="event.stopPropagation();"
                       data-action="click->top-progress#show"
                       data-meta-tip="Voir tous les coupons"
                       aria-label="Voir tous les coupons">
                        {{ ux_icon('hugeicons:view', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    </a>
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="card-body p-0"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_coupons') }}">
                <div class="db-skeleton-block m-3" style="height:140px;"></div>
            </div>
        </details>

        {% endif %}

        {% if console_can_access('console.plan.index') %}
        {# ── Plans tarifaires : paquets prépayés effectifs (config, fermé par défaut) ── #}
        <details class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon(resolve_icon_name('action:premium'), {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Plans tarifaires</span>
                    <small id="cs-db-plans-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    {% if is_granted('ROLE_SUPER_ADMIN') %}
                        <a href="{{ path('console.plan.index') }}" class="db-task-new-btn ms-auto"
                           onclick="event.stopPropagation();"
                           data-action="click->top-progress#show"
                           data-meta-tip="Éditer le plan tarifaire"
                           aria-label="Éditer le plan tarifaire">
                            {{ ux_icon('hugeicons:view', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                        </a>
                    {% endif %}
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron{% if not is_granted("ROLE_SUPER_ADMIN") %} ms-auto{% endif %}', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="card-body p-0"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_plans') }}">
                <div class="db-skeleton-block m-3" style="height:140px;"></div>
            </div>
        </details>

        {% endif %}

        {% if console_can_access('console.taxe.index') %}
        {# ── Fiscalité : taxes dues par JS Brokers sur ses ventes (fermé par défaut) ── #}
        <details class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon(resolve_icon_name('taxe'), {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Fiscalité</span>
                    <small id="cs-db-taxes-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    <a href="{{ path('console.taxe.index') }}" class="db-task-new-btn ms-auto"
                       onclick="event.stopPropagation();"
                       data-action="click->top-progress#show"
                       data-meta-tip="Gérer les taxes sur les ventes"
                       aria-label="Gérer les taxes sur les ventes">
                        {{ ux_icon('hugeicons:view', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    </a>
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="card-body p-0"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_taxes') }}">
                <div class="db-skeleton-block m-3" style="height:140px;"></div>
            </div>
        </details>
        {% endif %}

    </div>
{% endblock %}
