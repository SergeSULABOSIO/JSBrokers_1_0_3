{% extends 'console/base.html.twig' %}

{% block console_subtitle %}<p>Vue d'ensemble de la plateforme JS Brokers : comptes, ventes et revenu.</p>{% endblock %}

{% block console_body %}
    {# ── Colonne centrale unique : pile de blocs pliables, un par ligne ──
       Même comportement que le tableau de bord de l'espace de travail
       courtiers : chaque bloc est une carte <details> repliable au clic,
       sensible au survol (db-dashboard-block), chargée à la demande puis
       rafraîchie toutes les 3 minutes. ── #}
    <div class="cs-db">

        {# ── Indicateurs de la plateforme : sans cadre, rendus dès le chargement
             (toujours visibles) et rafraîchis silencieusement toutes les 3 min. ── #}
        <div class="mb-3"
             data-controller="lazy-block"
             data-lazy-block-url-value="{{ path('console.dashboard.block_kpis') }}"
             data-lazy-block-interval-value="180000"
             data-lazy-block-skip-initial-value="true">
            {{ include('console/dashboard/_block_kpis.html.twig') }}
        </div>

        {# ── Revenu des ventes : deux vues (par mois / par paquet) dans un
             bloc unique avec bascule, sur le modèle du bloc « Production »
             du tableau de bord courtiers. ── #}
        <details open class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block"
                 data-controller="chart-modes" data-chart-modes-active-value="mois">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon('mdi:chart-box-outline', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Revenu des ventes</span>
                    <small id="cs-db-revenue-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron ms-auto', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="px-3 pt-2 pb-2 bg-white border-bottom d-flex align-items-center gap-2">
                <div class="db-prod-tabs">
                    <button type="button" class="db-task-toggle active" data-mode="mois"
                            data-chart-modes-target="tab" data-action="chart-modes#switch"
                            aria-pressed="true" title="Revenu par mois">
                        {{ ux_icon('mdi:chart-bar', {style: 'width:12px;height:12px;'}) }}
                        Par mois
                    </button>
                    <button type="button" class="db-task-toggle" data-mode="pack"
                            data-chart-modes-target="tab" data-action="chart-modes#switch"
                            aria-pressed="false" title="Répartition par paquet">
                        {{ ux_icon('mdi:chart-pie', {style: 'width:12px;height:12px;'}) }}
                        Par paquet
                    </button>
                    <button type="button" class="db-task-toggle" data-mode="pays"
                            data-chart-modes-target="tab" data-action="chart-modes#switch"
                            aria-pressed="false" title="Revenu par pays">
                        {{ ux_icon('mdi:earth', {style: 'width:12px;height:12px;'}) }}
                        Par pays
                    </button>
                </div>
            </div>
            <div class="card-body p-3"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_revenue') }}"
                 data-lazy-block-interval-value="180000"
                 data-lazy-block-status-id-value="cs-db-revenue-update">
                <div class="db-skeleton-block" style="height:300px;"></div>
            </div>
        </details>

        {# ── Dernières ventes (recherche + rafraîchissement du fragment) ──
             Fermé par défaut : ni chargement ni rafraîchissement tant que le
             bloc n'est pas ouvert (économie de bande passante). ── #}
        <details class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon('mdi:cash-multiple', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Dernières ventes</span>
                    <small id="cs-db-ventes-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    <a href="{{ path('console.vente.index') }}" class="db-task-new-btn ms-auto"
                       onclick="event.stopPropagation();"
                       data-action="click->top-progress#show"
                       data-meta-tip="Voir toutes les ventes"
                       aria-label="Voir toutes les ventes">
                        {{ ux_icon('hugeicons:view', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    </a>
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="card-body p-0"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_ventes') }}">
                <div class="db-skeleton-block m-3" style="height:140px;"></div>
            </div>
        </details>

        {# ── Dernières entreprises créées (fermé par défaut) ── #}
        <details class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon('mdi:office-building-outline', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Dernières entreprises créées</span>
                    <small id="cs-db-entreprises-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    <a href="{{ path('console.entreprise.index') }}" class="db-task-new-btn ms-auto"
                       onclick="event.stopPropagation();"
                       data-action="click->top-progress#show"
                       data-meta-tip="Voir toutes les entreprises"
                       aria-label="Voir toutes les entreprises">
                        {{ ux_icon('hugeicons:view', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    </a>
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="card-body p-0"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_entreprises') }}">
                <div class="db-skeleton-block m-3" style="height:140px;"></div>
            </div>
        </details>

        {# ── Derniers utilisateurs créés (fermé par défaut) ── #}
        <details class="db-block-details card border-0 shadow-sm mb-3 db-dashboard-block">
            <summary class="card-header border-0 bg-white py-2 px-3">
                <div class="d-flex align-items-center gap-2">
                    {{ ux_icon('mdi:account-multiple-outline', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    <span class="small fw-semibold" style="color:#0047AB;">Derniers utilisateurs créés</span>
                    <small id="cs-db-utilisateurs-update" class="text-muted ms-1" style="font-size:.68rem;"></small>
                    <a href="{{ path('console.utilisateur.index') }}" class="db-task-new-btn ms-auto"
                       onclick="event.stopPropagation();"
                       data-action="click->top-progress#show"
                       data-meta-tip="Voir tous les utilisateurs"
                       aria-label="Voir tous les utilisateurs">
                        {{ ux_icon('hugeicons:view', {style: 'width:15px;height:15px;color:#0047AB;'}) }}
                    </a>
                    {{ ux_icon('mdi:chevron-down', {class: 'db-block-chevron', style: 'width:15px;height:15px;color:#6c757d;'}) }}
                </div>
            </summary>
            <div class="card-body p-0"
                 data-controller="lazy-block"
                 data-lazy-block-url-value="{{ path('console.dashboard.block_utilisateurs') }}">
                <div class="db-skeleton-block m-3" style="height:140px;"></div>
            </div>
        </details>

    </div>
{% endblock %}
