{% extends 'console/base.html.twig' %}

{% block console_subtitle %}<p>L'entonnoir suivi par le CRM : utilisateurs classiques + agents devenus clients (au moins un achat). Filtrez par Clients ou Prospects. Étape et santé calculées automatiquement.</p>{% endblock %}

{% block console_body %}
{{ include('console/crm/_styles.html.twig') }}

<div class="cs-panel">
    <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
        {% for key, label in {'': 'Tous', client: 'Clients', prospect: 'Prospects'} %}
            <a href="{{ path('console.crm.client.index', q ? {q: q, type: key} : {type: key}) }}"
               class="cs-badge {{ (type|default('')) == key ? 'cs-badge--cobalt' : 'cs-badge--muted' }}" style="text-decoration:none;"
               data-action="click->top-progress#show">{{ label }}</a>
        {% endfor %}
    </div>

    <form method="get" class="mb-3" data-action="submit->top-progress#show">
        {% if type %}<input type="hidden" name="type" value="{{ type }}">{% endif %}
        <div class="cs-field" style="max-width:420px;">
            <span class="cs-field-icon">{{ ux_icon(resolve_icon_name('action:search'), {height:'18px', width:'18px'}) }}</span>
            <input type="search" name="q" value="{{ q }}" class="form-control" placeholder="Rechercher (nom, e-mail)…">
        </div>
    </form>

    {% if clients.getTotalItemCount > 0 %}
        <table class="cs-table">
            <thead><tr><th>Compte</th><th>Type</th><th>Étape</th><th>Santé</th><th>Solde tokens</th><th>Inscrit</th><th style="text-align:right;">Actions</th></tr></thead>
            <tbody>
            {% for u in clients %}
                {% set p = profils[u.id]|default(null) %}
                {% set estClient = (metrics[u.id].count|default(0)) > 0 %}
                <tr>
                    <td>
                        <a href="{{ path('console.crm.client.show', {id: u.id}) }}" class="fw-semibold text-decoration-none">{{ u.nom ?: u.email }}</a>
                        {% set nbInvite = invitedIn[u.id]|default(0) %}
                        {% if nbInvite > 0 %}
                            <span class="cs-badge cs-badge--cobalt ms-1" style="font-size:.68rem;"
                                  title="Ce compte est aussi invité comme collaborateur dans {{ nbInvite }} entreprise{{ nbInvite > 1 ? 's' }}">
                                {{ ux_icon(resolve_icon_name('invite'), {height:'12px', width:'12px'}) }} Invité{% if nbInvite > 1 %} · {{ nbInvite }}{% endif %}
                            </span>
                        {% endif %}
                        <div class="text-muted" style="font-size:.8rem;">{{ u.email }}</div>
                    </td>
                    <td>
                        {% if estClient %}<span class="cs-badge cs-badge--ok">Client</span>
                        {% else %}<span class="cs-badge cs-badge--muted">Prospect</span>{% endif %}
                    </td>
                    <td>
                        {% if p %}
                            <span class="crm-stage {{ p.etapePipeline == 'churn' ? 'crm-stage--churn' }}">{{ crm_stage_label(p.etapePipeline) }}</span>
                        {% else %}—{% endif %}
                    </td>
                    <td>
                        {% if p %}
                            <span class="crm-health">
                                <span class="crm-dot" style="background:{{ crm_health_hex(p.scoreCouleur) }};"></span>
                                <span class="crm-score" style="color:{{ crm_health_hex(p.scoreCouleur) }};">{{ p.scoreSante }}</span>
                            </span>
                        {% else %}—{% endif %}
                    </td>
                    <td>{{ (u.paidTokens + u.freeTokens)|number_format(0, '.', ' ') }}</td>
                    <td>{{ u.createdAt ? u.createdAt|format_datetime('short','none', locale: app.user.locale) : '—' }}</td>
                    <td style="text-align:right;">
                        <a href="{{ path('console.crm.client.show', {id: u.id}) }}" class="cs-icon-btn" data-action="click->top-progress#show" title="Ouvrir la fiche" aria-label="Ouvrir la fiche de {{ u.nom ?: u.email }}">
                            {{ ux_icon(resolve_icon_name('action:view'), {height:'18px', width:'18px'}) }}
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        <div class="cs-pagination">{{ knp_pagination_render(clients) }}</div>
    {% else %}
        <div class="cs-empty"><p>Aucun client ne correspond à cette recherche.</p></div>
    {% endif %}
</div>
{% endblock %}
