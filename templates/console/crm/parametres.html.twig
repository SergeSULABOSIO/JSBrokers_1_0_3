{% extends 'console/base.html.twig' %}

{% block console_subtitle %}<p>Poids du score de santé, seuils de couleur et paramètres d'automatisation. Vides ou absents = valeurs par défaut.</p>{% endblock %}

{% block console_body %}
{{ include('console/crm/_styles.html.twig') }}
<form method="post" action="{{ path('console.crm.parametres.index') }}">
    <input type="hidden" name="_token" value="{{ csrf_token('crm-parametres') }}">

    <div class="cs-panel">
        <h2 class="cs-panel-title">Poids du score de santé (total conseillé : 100)</h2>
        <div class="row g-3">
            {% for key, defaut in labels %}
                <div class="col-sm-4">
                    <label class="form-label">{{ key|capitalize }}</label>
                    <input type="number" min="0" max="100" name="w_{{ key }}" class="form-control" value="{{ weights[key]|default(defaut) }}">
                </div>
            {% endfor %}
        </div>
    </div>

    <div class="cs-panel">
        <h2 class="cs-panel-title">Seuils de couleur</h2>
        <div class="row g-3">
            <div class="col-sm-4"><label class="form-label">Vert ≥</label><input type="number" name="t_vert" class="form-control" value="{{ thresholds.vert }}"></div>
            <div class="col-sm-4"><label class="form-label">Jaune ≥</label><input type="number" name="t_jaune" class="form-control" value="{{ thresholds.jaune }}"></div>
            <div class="col-sm-4"><label class="form-label">Orange ≥</label><input type="number" name="t_orange" class="form-control" value="{{ thresholds.orange }}"></div>
        </div>
    </div>

    <div class="cs-panel">
        <h2 class="cs-panel-title">Automatisations</h2>
        <div class="row g-3">
            <div class="col-sm-4"><label class="form-label">Inactivité (jours)</label><input type="number" min="1" name="a_inactivite" class="form-control" value="{{ automation.inactiviteJours }}"></div>
            <div class="col-sm-4"><label class="form-label">Solde bas (tokens)</label><input type="number" min="0" name="a_soldebas" class="form-control" value="{{ automation.soldeBas }}"></div>
            <div class="col-sm-4"><label class="form-label">Churn (jours d'inactivité)</label><input type="number" min="1" name="a_churn" class="form-control" value="{{ automation.churnJours }}"></div>
        </div>
    </div>

    <div class="mt-3"><button type="submit" class="btn btn-cobalt">Enregistrer les paramètres</button></div>
</form>
{% endblock %}
