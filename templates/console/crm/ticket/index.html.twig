{% extends 'console/base.html.twig' %}
{% import 'console/crm/_ticket_macros.html.twig' as ticketm %}

{% block console_subtitle %}<p>Tickets de support des clients : réception, suivi, SLA.</p>{% endblock %}

{% block console_actions %}
    <a href="{{ path('console.crm.ticket.new') }}" class="btn btn-sm btn-cobalt" data-action="click->top-progress#show">
        {{ ux_icon(resolve_icon_name('action:add'), {height:'18px', width:'18px'}) }}<span class="ms-1">Nouveau ticket</span>
    </a>
{% endblock %}

{% block console_body %}
{{ include('console/crm/_styles.html.twig') }}

<div class="cs-panel">
    <div class="mb-3">
        <div class="db-prod-tabs">
            <a href="{{ path('console.crm.ticket.index') }}" class="db-task-toggle {{ statut is null ? 'active' : '' }}" aria-pressed="{{ statut is null ? 'true' : 'false' }}">Tous</a>
            {% for key, label in {ouvert:'Ouvert', en_cours:'En cours', resolu:'Résolu', clos:'Clos'} %}
                <a href="{{ path('console.crm.ticket.index', {statut: key}) }}" class="db-task-toggle {{ statut == key ? 'active' : '' }}" aria-pressed="{{ statut == key ? 'true' : 'false' }}">{{ label }} ({{ compteurs[key]|default(0) }})</a>
            {% endfor %}
        </div>
    </div>

    {% if tickets.getTotalItemCount > 0 %}
        <table class="cs-table">
            <thead><tr><th>Réf.</th><th>Client</th><th>Sujet</th><th>Priorité</th><th>SLA</th><th>Statut</th><th style="text-align:right;">Action</th></tr></thead>
            <tbody>
            {% for t in tickets %}
                <tr>
                    <td>{{ t.reference }}</td>
                    <td>{% if t.client %}<a href="{{ path('console.crm.client.show', {id: t.client.id}) }}">{{ t.client.nom ?: t.client.email }}</a>{% else %}—{% endif %}</td>
                    <td>{{ ticketm.sujet(t) }}</td>
                    <td>{{ t.priorite }}</td>
                    <td>{% if t.slaDepasse %}<span class="cs-badge cs-badge--danger">Dépassé</span>{% elseif t.slaDueAt %}{{ t.slaDueAt|format_datetime('short','short', locale: app.user.locale) }}{% else %}—{% endif %}</td>
                    <td>{{ ticketm.statutBadge(t) }}</td>
                    <td style="text-align:right;">
                        <div class="d-inline-flex align-items-center gap-1">
                            <form method="post" action="{{ path('console.crm.ticket.statut', {id: t.id}) }}" class="d-inline-flex">
                                <input type="hidden" name="_token" value="{{ csrf_token('crm-ticket-statut-' ~ t.id) }}">
                                <select name="statut" class="form-select form-select-sm" style="width:auto;" onchange="this.form.submit()" aria-label="Changer le statut du ticket {{ t.reference }}">
                                    {% for key, label in {ouvert:'Ouvert', en_cours:'En cours', resolu:'Résolu', clos:'Clos'} %}
                                        <option value="{{ key }}" {{ t.statut == key ? 'selected' }}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </form>
                            <a href="{{ path('console.crm.ticket.show', {id: t.id}) }}"
                               class="cs-icon-btn" title="Ouvrir le ticket {{ t.reference }}" aria-label="Ouvrir la fiche du ticket {{ t.reference }}"
                               data-action="click->top-progress#show">
                                {{ ux_icon(resolve_icon_name('action:view'), {height:'16px', width:'16px'}) }}
                            </a>
                            {% if t.client %}
                                <a href="{{ path('console.crm.client.show', {id: t.client.id, _fragment: 'tab-support'}) }}"
                                   class="cs-icon-btn" title="Gérer le support de {{ t.client.nom ?: t.client.email }}" aria-label="Ouvrir la fiche support du client">
                                    {{ ux_icon(resolve_icon_name('feedback'), {height:'16px', width:'16px'}) }}
                                </a>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        <div class="cs-pagination">{{ knp_pagination_render(tickets) }}</div>
    {% else %}
        <div class="cs-empty"><p>Aucun ticket.</p></div>
    {% endif %}
</div>
{% endblock %}
