{% extends 'console/base.html.twig' %}

{% block console_actions %}
    <a href="{{ path('console.crm.ticket.index') }}" class="btn btn-sm btn-outline-secondary">{{ ux_icon(resolve_icon_name('action:exit'), {height:'16px', width:'16px'}) }}<span class="ms-1">Retour</span></a>
{% endblock %}

{% block console_body %}
{{ include('console/crm/_styles.html.twig') }}
<div class="cs-panel" style="max-width:680px;">
    <form method="post" action="{{ path('console.crm.ticket.new') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('crm-ticket-new') }}">
        <div class="mb-3">
            <label class="form-label">Client *</label>
            <select name="client" class="form-select" required>
                <option value="">— Choisir —</option>
                {% for c in clients %}<option value="{{ c.id }}" {{ preClient == c.id ? 'selected' }}>{{ c.nom ?: c.email }} ({{ c.email }})</option>{% endfor %}
            </select>
        </div>
        <div class="mb-3"><label class="form-label">Sujet *</label><input type="text" name="sujet" class="form-control" required></div>
        <div class="row g-2 mb-3">
            <div class="col-sm-6"><label class="form-label">Priorité</label><select name="priorite" class="form-select"><option value="basse">Basse</option><option value="normale" selected>Normale</option><option value="haute">Haute</option><option value="urgente">Urgente</option></select></div>
            <div class="col-sm-6"><label class="form-label">Canal</label><select name="canal" class="form-select"><option value="email">E-mail</option><option value="telephone">Téléphone</option><option value="chat">Chat</option></select></div>
        </div>
        <div class="mb-3"><label class="form-label">Description</label><textarea name="description" class="form-control" rows="4"></textarea></div>
        <button type="submit" class="btn btn-cobalt">Créer le ticket</button>
    </form>
</div>
{% endblock %}
