{% extends 'console/base.html.twig' %}

{% block console_subtitle %}<p>Revenus, valeur vie client (LTV), rentabilité et meilleurs clients — année {{ kpis.annee }}.</p>{% endblock %}

{% block console_body %}
{{ include('console/crm/_styles.html.twig') }}

<div class="crm-dash">
<div class="cs-kpis">
    <div class="cs-kpi"><div class="cs-kpi-icon">{{ ux_icon(resolve_icon_name('revenu'), {height:'24px', width:'24px'}) }}</div><div class="cs-kpi-body"><div class="cs-kpi-val">{{ kpis.revenuUsd|number_format(0,'.',' ') }} $</div><div class="cs-kpi-lbl">Revenu (TTC, {{ kpis.annee }})</div></div></div>
    <div class="cs-kpi"><div class="cs-kpi-icon">{{ ux_icon(resolve_icon_name('type-revenu'), {height:'24px', width:'24px'}) }}</div><div class="cs-kpi-body"><div class="cs-kpi-val">{{ kpis.revenuHorsTaxe|number_format(0,'.',' ') }} $</div><div class="cs-kpi-lbl">Produit (HT)</div></div></div>
    <div class="cs-kpi"><div class="cs-kpi-icon">{{ ux_icon(resolve_icon_name('action:premium'), {height:'24px', width:'24px'}) }}</div><div class="cs-kpi-body"><div class="cs-kpi-val">{{ kpis.finance.resultat|number_format(0,'.',' ') }} $</div><div class="cs-kpi-lbl">Résultat</div></div></div>
    <div class="cs-kpi"><div class="cs-kpi-icon">{{ ux_icon(resolve_icon_name('action:analyser'), {height:'24px', width:'24px'}) }}</div><div class="cs-kpi-body"><div class="cs-kpi-val">{{ kpis.finance.rentabilite|number_format(1,'.',' ') }} %</div><div class="cs-kpi-lbl">Rentabilité</div></div></div>
    <div class="cs-kpi"><div class="cs-kpi-icon">{{ ux_icon(resolve_icon_name('client'), {height:'24px', width:'24px'}) }}</div><div class="cs-kpi-body"><div class="cs-kpi-val">{{ ltv|number_format(2,'.',' ') }} $</div><div class="cs-kpi-lbl">LTV moyenne</div></div></div>
    <div class="cs-kpi"><div class="cs-kpi-icon">{{ ux_icon(resolve_icon_name('monnaie'), {height:'24px', width:'24px'}) }}</div><div class="cs-kpi-body"><div class="cs-kpi-val">{{ kpis.saas.arpc|number_format(2,'.',' ') }} $</div><div class="cs-kpi-lbl">ARPC</div></div></div>
    <div class="cs-kpi"><div class="cs-kpi-icon">{{ ux_icon(resolve_icon_name('action:cart'), {height:'24px', width:'24px'}) }}</div><div class="cs-kpi-body"><div class="cs-kpi-val">{{ kpis.saas.cac|number_format(2,'.',' ') }} $</div><div class="cs-kpi-lbl">CAC</div></div></div>
    <div class="cs-kpi"><div class="cs-kpi-icon">{{ ux_icon(resolve_icon_name('action:renew'), {height:'24px', width:'24px'}) }}</div><div class="cs-kpi-body"><div class="cs-kpi-val">{{ kpis.saas.retention|number_format(1,'.',' ') }} %</div><div class="cs-kpi-lbl">Rétention</div></div></div>
</div>

<div class="cs-panel-row">
    <div class="cs-panel cs-panel--flex">
        <h2 class="cs-panel-title">{{ chartVentesMois.titre }}</h2>
        <div class="cs-chart">{{ render_chart(chartVentesMois.chart) }}</div>
    </div>
    <div class="cs-panel cs-panel--flex">
        <h2 class="cs-panel-title">{{ chartVentesPays.titre }}</h2>
        <div class="cs-chart">{{ render_chart(chartVentesPays.chart) }}</div>
    </div>
</div>

<div class="cs-panel">
    <h2 class="cs-panel-title">Top clients (revenu cumulé)</h2>
    {% if topClients|length > 0 %}
        <table class="cs-table">
            <thead><tr><th>Client</th><th>Achats</th><th style="text-align:right;">Revenu</th></tr></thead>
            <tbody>
            {% for c in topClients %}
                <tr><td>{{ c.nom ?: c.email }}</td><td>{{ c.nb }}</td><td style="text-align:right;">{{ c.montant|number_format(2,'.',' ') }} $</td></tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}<div class="cs-empty"><p>Aucune vente enregistrée.</p></div>{% endif %}
</div>
</div>{# /.crm-dash #}
{% endblock %}
