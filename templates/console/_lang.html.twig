{# Bascule de langue (FR/EN) de la Console : on reste sur la page courante en ne
   changeant que ?lang= (persisté côté serveur via applyLangPreference). #}
{% import 'components/_lang_flag.html.twig' as flags %}
{% set lang = app.user.locale %}
{% set switchRoute = app.request.attributes.get('_route')|default('console.dashboard') %}
{% set switchParams = (app.request.attributes.get('_route_params')|default({}))|merge(app.request.query.all) %}
<span class="cs-lang" role="group" aria-label="Langue / Language">
    <a href="{{ path(switchRoute, switchParams|merge({'lang': 'fr'})) }}"
       class="{{ lang == 'fr' ? 'is-active' : '' }}" title="Français" lang="fr"
       data-action="click->top-progress#show" {% if lang == 'fr' %}aria-current="true"{% endif %}>{{ flags.fr() }}FR</a>
    <a href="{{ path(switchRoute, switchParams|merge({'lang': 'en'})) }}"
       class="{{ lang == 'en' ? 'is-active' : '' }}" title="English" lang="en"
       data-action="click->top-progress#show" {% if lang == 'en' %}aria-current="true"{% endif %}>{{ flags.uk('cs-lang-uk') }}EN</a>
</span>
