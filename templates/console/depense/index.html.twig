{% extends 'console/base.html.twig' %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Barre de filtres : même grille alignée que la liste des ventes (DRY visuel). */
    .cs-filterbar { display: grid; grid-template-columns: repeat(auto-fit, minmax(185px, 1fr)); gap: .85rem 1rem; align-items: end; }
    .cs-filterbar .cs-filter { display: flex; flex-direction: column; min-width: 0; }
    .cs-filterbar .form-label { margin: 0 0 .35rem; font-size: .8rem; font-weight: 600; color: #6c757d;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cs-filterbar .cs-filter-actions { grid-column: 1 / -1; flex-direction: row; justify-content: flex-end; gap: .5rem; }
    .cs-filterbar .cs-filter-actions .btn { display: inline-flex; align-items: center; white-space: nowrap; }
</style>
{% endblock %}

{% block console_subtitle %}<p>Suivi et filtrage des sorties de fonds de JS Brokers, classées par type de charge.</p>{% endblock %}

{% block console_actions %}
    <a href="{{ path('console.depense.new') }}" class="btn btn-sm btn-cobalt" data-action="click->top-progress#show">
        {{ ux_icon(resolve_icon_name('action:add'), {height:'18px', width:'18px'}) }}
        <span class="ms-1">Nouvelle</span>
    </a>
{% endblock %}

{% block console_body %}
    {# ── Volumes (sur le périmètre filtré) ── #}
    <div class="cs-kpis" style="margin-bottom:1.25rem;">
        <div class="cs-kpi"><span class="cs-kpi-icon" aria-hidden="true">{{ ux_icon(resolve_icon_name('depense'), {height:'24px', width:'24px'}) }}</span>
            <span class="cs-kpi-body"><span class="cs-kpi-val">{{ totals.count }}</span><span class="cs-kpi-lbl">Dépenses</span></span></div>
        <div class="cs-kpi"><span class="cs-kpi-icon" aria-hidden="true">{{ ux_icon(resolve_icon_name('monnaie'), {height:'24px', width:'24px'}) }}</span>
            <span class="cs-kpi-body"><span class="cs-kpi-val">{{ totals.montant|number_format(2, '.', ' ') }} $</span><span class="cs-kpi-lbl">Total (hors annulées)</span></span></div>
        <div class="cs-kpi"><span class="cs-kpi-icon" aria-hidden="true">{{ ux_icon(resolve_icon_name('paiement'), {height:'24px', width:'24px'}) }}</span>
            <span class="cs-kpi-body"><span class="cs-kpi-val">{{ totals.montantPaye|number_format(2, '.', ' ') }} $</span><span class="cs-kpi-lbl">Décaissé (payé)</span></span></div>
        <div class="cs-kpi"><span class="cs-kpi-icon" aria-hidden="true">{{ ux_icon(resolve_icon_name('action:ongoing'), {height:'24px', width:'24px'}) }}</span>
            <span class="cs-kpi-body"><span class="cs-kpi-val">{{ (totals.montant - totals.montantPaye)|number_format(2, '.', ' ') }} $</span><span class="cs-kpi-lbl">Engagé non payé</span></span></div>
    </div>

    {# ── Filtres (formulaire GET, sans JS) ── #}
    <div class="cs-panel" style="margin-bottom:1.25rem;">
        <form method="get" data-action="submit->top-progress#show" class="cs-filterbar">
            <div class="cs-filter"><label class="form-label" for="f-from">Du</label>
                <div class="cs-field">
                    <span class="cs-field-icon">{{ ux_icon(resolve_icon_name('action:calendar'), {height:'18px', width:'18px'}) }}</span>
                    <input id="f-from" type="date" name="from" value="{{ filtres.from }}" class="form-control" placeholder="Date de début">
                </div>
            </div>
            <div class="cs-filter"><label class="form-label" for="f-to">Au</label>
                <div class="cs-field">
                    <span class="cs-field-icon">{{ ux_icon(resolve_icon_name('action:calendar'), {height:'18px', width:'18px'}) }}</span>
                    <input id="f-to" type="date" name="to" value="{{ filtres.to }}" class="form-control" placeholder="Date de fin">
                </div>
            </div>
            <div class="cs-filter"><label class="form-label" for="f-charge">Charge</label>
                <div class="cs-field">
                    <span class="cs-field-icon">{{ ux_icon(resolve_icon_name('charge'), {height:'18px', width:'18px'}) }}</span>
                    <select id="f-charge" name="charge" class="form-select">
                        <option value="">Toutes</option>
                        {% for c in charges %}<option value="{{ c.id }}" {{ filtres.charge == c.id ? 'selected' }}>{{ c.libelle }}</option>{% endfor %}
                    </select>
                </div>
            </div>
            <div class="cs-filter"><label class="form-label" for="f-destination">Destination</label>
                <div class="cs-field">
                    <span class="cs-field-icon">{{ ux_icon(resolve_icon_name('action:analyser'), {height:'18px', width:'18px'}) }}</span>
                    <select id="f-destination" name="destination" class="form-select">
                        <option value="">Toutes</option>
                        {% for key, label in destinations %}<option value="{{ key }}" {{ filtres.destination == key ? 'selected' }}>{{ label }}</option>{% endfor %}
                    </select>
                </div>
            </div>
            <div class="cs-filter"><label class="form-label" for="f-statut">Statut</label>
                <div class="cs-field">
                    <span class="cs-field-icon">{{ ux_icon(resolve_icon_name('action:filter'), {height:'18px', width:'18px'}) }}</span>
                    <select id="f-statut" name="statut" class="form-select">
                        <option value="">Tous</option>
                        {% for key, label in statuts %}<option value="{{ key }}" {{ filtres.statut == key ? 'selected' }}>{{ label }}</option>{% endfor %}
                    </select>
                </div>
            </div>
            <div class="cs-filter"><label class="form-label" for="f-q" title="Recherche (bénéficiaire, réf., description)">Recherche</label>
                <div class="cs-field">
                    <span class="cs-field-icon">{{ ux_icon(resolve_icon_name('action:search'), {height:'18px', width:'18px'}) }}</span>
                    <input id="f-q" type="text" name="q" value="{{ filtres.q }}" class="form-control" placeholder="Bénéficiaire, réf.…">
                </div>
            </div>
            <div class="cs-filter cs-filter-actions">
                <button type="submit" class="btn btn-cobalt">{{ ux_icon(resolve_icon_name('action:filter'), {height:'18px', width:'18px'}) }}<span class="ms-1">Filtrer</span></button>
                <a href="{{ path('console.depense.index') }}" class="btn btn-outline-secondary" data-action="click->top-progress#show">Réinitialiser</a>
            </div>
        </form>
    </div>

    {# ── Liste ── #}
    <div class="cs-panel">
        {% if depenses.getTotalItemCount > 0 %}
            <table class="cs-table">
                <thead><tr><th>Date</th><th>Référence</th><th>Bénéficiaire</th><th>Charge</th><th>Destination</th><th>Statut</th><th>Montant</th><th style="text-align:right;">Actions</th></tr></thead>
                <tbody>
                {% for d in depenses %}
                    <tr>
                        <td>{{ d.dateDepense|format_datetime('medium', 'none', locale: app.user.locale) }}</td>
                        <td>{% if d.reference %}<code>{{ d.reference }}</code>{% else %}—{% endif %}</td>
                        <td>{{ d.beneficiaire ?: '—' }}</td>
                        <td><span class="cs-badge cs-badge--cobalt">{{ d.charge.code }}</span><br><small style="color:#6c757d;">{{ d.charge.compteOhada }} · {{ d.charge.libelle }}</small></td>
                        <td>{{ d.charge.destinationLabel }}</td>
                        <td>
                            {% if d.statut == 'payee' %}<span class="cs-badge cs-badge--ok">{{ d.statutLabel }}</span>
                            {% elseif d.statut == 'annulee' %}<span class="cs-badge cs-badge--muted">{{ d.statutLabel }}</span>
                            {% else %}<span class="cs-badge cs-badge--cobalt">{{ d.statutLabel }}</span>{% endif %}
                        </td>
                        <td>{{ d.montantFloat|number_format(2, '.', ' ') }} {{ d.devise }}</td>
                        <td style="text-align:right;">
                            <a href="{{ path('console.depense.edit', {id: d.id}) }}" class="cs-icon-btn"
                               data-action="click->top-progress#show" title="Éditer" aria-label="Éditer la dépense">
                                {{ ux_icon(resolve_icon_name('action:edit'), {height:'18px', width:'18px'}) }}
                            </a>
                            <form action="{{ path('console.depense.delete', {id: d.id}) }}" method="post" style="display:inline;"
                                  data-controller="confirm-action" data-action="submit->confirm-action#request"
                                  data-confirm-action-title-value="Supprimer la dépense"
                                  data-confirm-action-body-value="Supprimer cette dépense de {{ d.montantFloat|number_format(2, '.', ' ') }} {{ d.devise }} ?"
                                  data-confirm-action-irreversible-value="true">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-depense-' ~ d.id) }}">
                                <button type="submit" class="cs-icon-btn is-danger" title="Supprimer" aria-label="Supprimer la dépense">
                                    {{ ux_icon(resolve_icon_name('action:delete'), {height:'18px', width:'18px'}) }}
                                </button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            <div class="cs-pagination">{{ knp_pagination_render(depenses) }}</div>
        {% else %}
            <div class="cs-empty">
                <p>Aucune dépense pour ces critères.</p>
                <a href="{{ path('console.depense.new') }}" class="btn btn-cobalt mt-2" data-action="click->top-progress#show">
                    {{ ux_icon(resolve_icon_name('action:add'), {height:'18px', width:'18px'}) }}
                    <span class="ms-1">Nouvelle dépense</span>
                </a>
            </div>
        {% endif %}
    </div>
{% endblock %}
