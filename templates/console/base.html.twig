{% extends 'base.html.twig' %}

{% block title %}{{ pageName|default('Console') }} — JS Brokers{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ============================================================
       Console JS Brokers — charte cobalt #0047AB, neutres Bootstrap.
       Même structure que l'espace entreprise : barre de titre fixe en
       haut, contenu défilant en dessous, pied de page officiel.
       ============================================================ */
    .cs-page {
        height: 100vh; background-color: #f3f3f3;
        display: flex; flex-direction: column; overflow: hidden;
    }
    .cs-progress-bar {
        position: fixed; top: 0; left: 0; width: 100%; height: 6px;
        background-color: #0047AB; display: none; z-index: 9999;
        animation: cs-progress-animation 1.5s infinite linear;
    }
    @keyframes cs-progress-animation {
        0%   { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    /* Barre de titre fixe */
    .cs-topbar {
        flex: 0 0 auto;
        display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; flex-wrap: wrap; padding: .6rem 1.25rem;
        background-color: #ffffff; border-bottom: 1px solid #dee2e6;
    }
    .cs-brand { display: flex; align-items: center; gap: .6rem; text-decoration: none; flex: 0 0 auto; }
    .cs-brand img { width: 34px; height: 34px; border-radius: 8px; }
    .cs-brand span { font-weight: 700; color: #0047AB; font-size: 1.05rem; }
    .cs-brand small { display: block; font-weight: 600; color: #6c757d; font-size: .7rem; letter-spacing: .04em; text-transform: uppercase; }

    /* Navigation des sections : liens directs (.cs-nav-link) + menus déroulants (.cs-menu). */
    .cs-nav { display: flex; align-items: center; gap: .15rem; flex-wrap: wrap; flex: 1 1 auto; justify-content: center; }
    .cs-nav-link {
        display: inline-flex; align-items: center; gap: .35rem;
        padding: .4rem .65rem; border-radius: 8px; text-decoration: none;
        color: #495057; font-size: .88rem; font-weight: 600; white-space: nowrap;
        background: transparent; border: 0; cursor: pointer; font-family: inherit;
    }
    .cs-nav-link:hover { background-color: #eef2fb; color: #0047AB; }
    .cs-nav-link:focus-visible { outline: 2px solid #0047AB; outline-offset: 2px; }
    .cs-nav-link.is-active { background-color: #0047AB; color: #ffffff; }
    .cs-nav-link.is-active svg { color: #ffffff; }

    /* Groupe déroulant bâti sur <details>/<summary>. */
    .cs-menu { position: relative; }
    .cs-menu > summary { list-style: none; }
    .cs-menu > summary::-webkit-details-marker { display: none; }
    .cs-menu-caret {
        width: 0; height: 0; margin-left: .1rem;
        border-left: 4px solid transparent; border-right: 4px solid transparent;
        border-top: 5px solid currentColor; transition: transform .15s ease;
    }
    .cs-menu[open] > summary .cs-menu-caret { transform: rotate(180deg); }
    .cs-menu[open] > summary:not(.is-active) { background-color: #eef2fb; color: #0047AB; }

    /* Panneau du menu : carte blanche posée sous le déclencheur. */
    .cs-menu-panel {
        position: absolute; top: calc(100% + .35rem); left: 0; z-index: 1000;
        min-width: 230px; padding: .35rem;
        background: #ffffff; border: 1px solid #dee2e6; border-radius: 10px;
        box-shadow: 0 10px 30px rgba(0,71,171,.12);
        display: flex; flex-direction: column; gap: .1rem;
    }
    .cs-menu-panel a {
        display: inline-flex; align-items: center; gap: .5rem;
        padding: .5rem .65rem; border-radius: 8px; text-decoration: none;
        color: #495057; font-size: .88rem; font-weight: 600; white-space: nowrap;
    }
    .cs-menu-panel a:hover { background-color: #eef2fb; color: #0047AB; }
    .cs-menu-panel a:focus-visible { outline: 2px solid #0047AB; outline-offset: 2px; }
    .cs-menu-panel a.is-active { background-color: #0047AB; color: #ffffff; }
    .cs-menu-panel a.is-active svg { color: #ffffff; }

    .cs-topbar-right { display: flex; align-items: center; gap: .5rem; flex: 0 0 auto; }
    .cs-user { display: inline-flex; align-items: center; gap: .4rem; color: #495057; font-size: .9rem; font-weight: 600; }
    .cs-user-icon { color: #6c757d; }
    .cs-sep { width: 1px; height: 24px; background-color: #dee2e6; }

    /* Bascule de langue (.cs-lang) : style global dans assets/styles/app.css. */

    /* Zone défilante + contenu : colonne flex pour que le contenu pousse le pied
       de page tout en bas, même quand la page est plus courte que la fenêtre. */
    .cs-scroll { flex: 1 1 auto; min-height: 0; overflow-y: auto; display: flex; flex-direction: column; }
    .cs-content { width: 100%; max-width: 1280px; margin: 0 auto; padding: 1.5rem; flex: 1 0 auto; }
    .cs-head { margin-bottom: 1.25rem; display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
    .cs-head-text { min-width: 0; }
    .cs-head-actions { flex: 0 0 auto; display: flex; align-items: center; gap: .5rem; }
    .cs-head h1 { font-size: 1.5rem; font-weight: 700; color: #212529; margin: 0 0 .25rem; }
    .cs-head p { color: #6c757d; margin: 0; max-width: 70ch; }
    /* Titre de rubrique + pastille d'icône alignés sur une même ligne. Même langage
       visuel que .cs-head-icon des formulaires (console/form.html.twig) pour unifier
       l'identité des deux familles de pages. L'icône est portée par `pageIcon`. */
    .cs-head-title { display: flex; align-items: center; gap: .7rem; margin-bottom: .25rem; }
    .cs-head-title h1 { margin: 0; }   /* la marge basse est reportée sur .cs-head-title */
    .cs-head-icon {
        flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
        width: 46px; height: 46px; border-radius: 11px;
        background: #e8f0fb; color: #0047AB;
    }
    .cs-head-icon svg { width: 26px; height: 26px; }

    /* Cartes / panneaux réutilisables */
    .cs-panel { background:#fff; border:1px solid #dee2e6; border-radius:12px; padding:1.25rem; }
    .cs-panel + .cs-panel { margin-top: 1.25rem; }
    .cs-panel-title { font-size:1.05rem; font-weight:700; color:#212529; margin:0 0 1rem; }
    /* Rangée de deux panneaux à hauteurs alignées */
    .cs-panel-row { display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:1.25rem; margin-top:1.25rem; align-items:stretch; }
    .cs-panel--flex { display:flex; flex-direction:column; }
    .cs-panel-foot { margin:1rem 0 0; }            /* pied de panneau aligné en bas */
    .cs-panel--flex .cs-panel-foot { margin-top:auto; padding-top:1rem; }
    /* Conteneur de graphique à hauteur fixe (maintainAspectRatio:false) */
    .cs-chart { position:relative; height:300px; }
    .cs-panel--flex .cs-chart { flex:0 0 auto; }   /* hauteur déterministe, pas d'expansion flex */
    .cs-chart canvas { max-width:100%; }

    /* Grille de KPIs */
    .cs-kpis { display:grid; grid-template-columns: repeat(auto-fill, minmax(210px,1fr)); gap:1rem; align-items:stretch; }
    .cs-kpi { background:#fff; border:1px solid #dee2e6; border-radius:12px; padding:1.1rem 1.2rem; display:flex; align-items:center; gap:.9rem; transition:box-shadow .15s ease; }
    .cs-kpi:hover { box-shadow:0 8px 24px rgba(0,71,171,.10); }
    .cs-kpi-icon { width:46px; height:46px; flex:0 0 auto; border-radius:10px; background:#eef2fb; color:#0047AB; display:inline-flex; align-items:center; justify-content:center; }
    .cs-kpi-body { display:flex; flex-direction:column; gap:.15rem; min-width:0; }
    .cs-kpi-val { font-size:1.5rem; font-weight:700; color:#212529; line-height:1.15; }
    .cs-kpi-lbl { font-size:.82rem; color:#6c757d; line-height:1.25; }

    /* Tableaux */
    .cs-table { width:100%; border-collapse:collapse; }
    .cs-table th, .cs-table td { padding:.6rem .7rem; text-align:left; border-bottom:1px solid #f0f0f0; font-size:.9rem; }
    .cs-table th { color:#6c757d; font-weight:600; font-size:.78rem; text-transform:uppercase; letter-spacing:.03em; }
    .cs-table tbody tr:hover { background:#f8f9fa; }
    .cs-badge { display:inline-block; padding:.15rem .55rem; border-radius:999px; font-size:.75rem; font-weight:700; }
    .cs-badge--ok { background:#e6f4ea; color:#137333; }
    .cs-badge--muted { background:#eef0f2; color:#6c757d; }
    .cs-badge--cobalt { background:#eef2fb; color:#0047AB; }
    .cs-badge--warn { background:#fff3cd; color:#b58100; }
    .cs-badge--danger { background:#fde8e6; color:#c5221f; }

    /* Boutons icône */
    .cs-icon-btn { width:38px; height:38px; display:inline-flex; align-items:center; justify-content:center; border:0; background:transparent; border-radius:8px; color:#6c757d; cursor:pointer; text-decoration:none; }
    .cs-icon-btn:hover { background:#e9ecef; color:#212529; }
    .cs-icon-btn.is-danger:hover { background:#f8d7da; color:#dc3545; }
    .cs-icon-btn:focus-visible { outline:2px solid #0047AB; outline-offset:2px; }

    /* ---------- Champ de saisie à icône incrustée ----------
       Pattern UNIQUE de tout l'espace console, identique à la page de
       connexion : un seul champ continu, l'icône à l'intérieur à gauche,
       jamais de boîte d'icône séparée. `top:50%` cale l'icône au centre du
       champ quelle que soit sa hauteur (formulaire 48px ou filtre 38px). */
    .cs-field { position:relative; }
    .cs-field-icon {
        position:absolute; left:.9rem; top:50%; transform:translateY(-50%);
        width:18px; height:18px; color:#6c757d; pointer-events:none; z-index:4;
        display:inline-flex; align-items:center; justify-content:center;
    }
    .cs-field .form-control,
    .cs-field .form-select { padding-left:2.6rem; }
    .cs-field .form-control:focus,
    .cs-field .form-select:focus { border-color:#0047AB; box-shadow:0 0 0 .2rem rgba(0,71,171,.25); }
    /* Zone de texte : icône calée sur la première ligne. */
    .cs-field--top .cs-field-icon { top:1.65rem; }
    /* Bascule afficher/masquer du mot de passe (cible tactile ≥ 40px). */
    .cs-field--password .form-control { padding-right:3rem; }
    .cs-field-toggle {
        position:absolute; right:.35rem; top:50%; transform:translateY(-50%);
        width:40px; height:40px; display:inline-flex; align-items:center; justify-content:center;
        border:0; background:transparent; color:#6c757d; border-radius:8px; cursor:pointer; z-index:4;
    }
    .cs-field-toggle:hover { color:#0047AB; }
    .cs-field-toggle:focus-visible { outline:2px solid #0047AB; outline-offset:2px; }
    .cs-field-toggle svg { width:20px; height:20px; }
    .cs-field-toggle .is-hidden { display:none; }

    .cs-empty { text-align:center; padding:2.5rem 1.5rem; background:#fff; border:1px dashed #ced4da; border-radius:12px; color:#6c757d; }
    .cs-pagination { display:flex; justify-content:center; margin-top:1.25rem; }

    /* ---------- Pied de page public réutilisé (mêmes styles que la vitrine) ----------
       Les classes public-footer sont définies dans _home_styles ;
       on les redéclare ici car la console n'inclut pas la feuille de la vitrine,
       sinon le pied de page s'affiche non stylé. La bascule de langue (.cs-lang)
       est désormais stylée globalement dans app.css.
       NB : ne jamais écrire « .public-footer<slash><étoile> » dans ce commentaire — la
       séquence étoile-slash fermerait le commentaire CSS et invaliderait la règle
       .public-footer ci-dessous (pied de page rendu transparent sur fond gris).
       Pied de page collé au contenu (pas de bande grise au-dessus) : il repose
       franchement sur un fond blanc, sur toute la largeur de la zone défilante. */
    .public-footer { background-color: #fff; border-top: 1px solid #dee2e6; margin-top: 0; }
    .public-footer__inner { max-width: 1280px; margin: 0 auto; padding: 2.5rem 1.5rem 1.5rem;
        display: flex; flex-wrap: wrap; align-items: flex-start; gap: 1.5rem; }
    .public-footer__brand { display: flex; align-items: center; gap: .75rem; flex: 1 1 280px; text-decoration: none; }
    .public-footer__brand:hover { opacity: .85; }
    .public-footer__brand img { border-radius: 8px; }
    .public-footer__name { font-weight: 700; color: #0047AB; margin: 0; font-size: 1.05rem; }
    .public-footer__tagline { color: #6c757d; margin: 0; font-size: .9rem; max-width: 360px; }
    .public-footer__links { display: flex; flex-wrap: wrap; gap: .25rem 1.25rem; }
    .public-footer__links a { display: inline-flex; align-items: center; min-height: 44px;
        color: #495057; text-decoration: none; font-size: .92rem; font-weight: 600; }
    .public-footer__links a:hover { color: #0047AB; }
    .public-footer__links a:focus-visible { outline: 2px solid #0047AB; outline-offset: 2px; border-radius: 4px; }
    .public-footer__credit { max-width: 1280px; margin: 0 auto; padding: 1rem 1.5rem;
        border-top: 1px solid #dee2e6; text-align: center; color: #6c757d; font-size: .85rem; }

    @media (max-width: 991.98px) {
        .cs-nav { order: 3; flex-basis: 100%; justify-content: flex-start; }
    }
    @media (max-width: 575.98px) {
        .cs-user { display:none; } .cs-sep { display:none; }
    }
</style>
{% endblock %}

{% block body %}
<main class="cs-page" data-controller="top-progress">
    <div class="cs-progress-bar" data-top-progress-target="bar" role="progressbar" aria-hidden="true"></div>

    <header class="cs-topbar">
        <a href="{{ path('console.dashboard') }}" class="cs-brand" data-action="click->top-progress#show">
            <img src="{{ asset('images/entreprises/logofav.png') }}" alt="">
            <span>JS Brokers<small>Console</small></span>
        </a>

        {{ include('console/_nav.html.twig') }}

        <div class="cs-topbar-right">
            <span class="cs-user">
                {{ ux_icon(resolve_icon_name('utilisateur'), {height: '20px', width: '20px', class: 'cs-user-icon'}) }}
                {{ app.user.nom }}
            </span>
            <span class="cs-sep" aria-hidden="true"></span>
            {{ include('console/_lang.html.twig') }}
            <a href="{{ path('app_logout') }}" class="cs-icon-btn is-danger" data-action="click->top-progress#show"
               title="{{ 'boutons_user_logout'|trans }}" aria-label="{{ 'boutons_user_logout'|trans }}">
                {{ ux_icon(resolve_icon_name('action:exit'), {height: '20px', width: '20px'}) }}
            </a>
        </div>
    </header>

    <div class="cs-scroll">
        <div class="cs-content">
            {{ include('components/_flash_toasts.html.twig') }}

            <div class="cs-head">
                <div class="cs-head-text">
                    <div class="cs-head-title">
                        {% if pageIcon is defined and pageIcon %}
                            <span class="cs-head-icon" aria-hidden="true">
                                {{ ux_icon(resolve_icon_name(pageIcon), {height:'26px', width:'26px'}) }}
                            </span>
                        {% endif %}
                        <h1>{{ pageName }}</h1>
                    </div>
                    {% block console_subtitle %}{% endblock %}
                </div>
                <div class="cs-head-actions">{% block console_actions %}{% endblock %}</div>
            </div>

            {% block console_body %}{% endblock %}
        </div>

        {% include 'components/_public_footer.html.twig' with { lang: app.user.locale } %}
    </div>
</main>
{% endblock %}
