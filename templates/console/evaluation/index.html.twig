{% extends 'console/base.html.twig' %}

{% block console_subtitle %}<p>Suivi des objectifs et des performances des collaborateurs, par période.</p>{% endblock %}

{% block console_actions %}
    {# Sélecteur de période (année + trimestre), soumis en GET. #}
    <form method="get" class="d-flex align-items-center gap-2" data-action="change->top-progress#show">
        <select name="annee" class="form-select form-select-sm" onchange="this.form.submit()" aria-label="Année">
            {% for a in annees %}
                <option value="{{ a }}" {{ a == annee ? 'selected' }}>{{ a }}</option>
            {% endfor %}
        </select>
        <select name="trimestre" class="form-select form-select-sm" onchange="this.form.submit()" aria-label="Période">
            <option value="0" {{ trimestre == 0 ? 'selected' }}>Annuel</option>
            {% for t in 1..4 %}
                <option value="{{ t }}" {{ trimestre == t ? 'selected' }}>T{{ t }}</option>
            {% endfor %}
        </select>
        <noscript><button type="submit" class="btn btn-sm btn-cobalt">Afficher</button></noscript>
    </form>
{% endblock %}

{% block console_body %}
<div class="cs-panel">
    {% if lignes|length > 0 %}
        <table class="cs-table">
            <thead><tr><th>Collaborateur</th><th>Département</th><th>Score de la période</th><th>Mention</th><th style="text-align:right;">Actions</th></tr></thead>
            <tbody>
            {% for l in lignes %}
                <tr>
                    <td>{{ ux_icon(resolve_icon_name('utilisateur'), {height:'18px', width:'18px'}) }} {{ l.agent.nom }}</td>
                    <td>
                        {% if l.agent.departement %}
                            <span class="cs-badge cs-badge--cobalt">{{ l.agent.departement.label }}</span>
                        {% else %}
                            <span class="cs-badge cs-badge--muted">Non affecté</span>
                        {% endif %}
                    </td>
                    <td><strong>{{ l.score }}</strong> / 100</td>
                    <td><span class="cs-badge {{ l.mentionClass }}">{{ l.mention }}</span></td>
                    <td style="text-align:right;">
                        <a href="{{ path('console.evaluation.show', {id: l.agent.id, annee: annee, trimestre: trimestre}) }}"
                           class="cs-icon-btn" data-action="click->top-progress#show"
                           title="Ouvrir la fiche" aria-label="Ouvrir la fiche de {{ l.agent.nom }}">
                            {{ ux_icon(resolve_icon_name('action:view'), {height:'18px', width:'18px'}) }}
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <div class="cs-empty">Aucun collaborateur.</div>
    {% endif %}
</div>
{% endblock %}
