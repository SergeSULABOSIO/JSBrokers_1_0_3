{% extends 'console/base.html.twig' %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Jauge d'atteinte d'un objectif (charte cobalt). */
    .cs-gauge { background:#eef0f2; border-radius:999px; height:10px; overflow:hidden; min-width:120px; }
    .cs-gauge > span { display:block; height:100%; background:#0047AB; border-radius:999px; }
    .cs-score-big { font-size:2rem; font-weight:700; color:#212529; line-height:1; }
    .cs-objline-head { display:flex; justify-content:space-between; gap:1rem; align-items:baseline; }
    .cs-objline-meta { color:#6c757d; font-size:.82rem; }
</style>
{% endblock %}

{% block console_subtitle %}
    <p>
        {% if collaborateur.departement %}<span class="cs-badge cs-badge--cobalt">{{ collaborateur.departement.label }}</span>{% endif %}
        {% if collaborateur.fonction %}<span class="cs-badge {{ collaborateur.fonction.badgeClass }}">{{ collaborateur.fonction.label }}</span>{% endif %}
        Période : <strong>{{ fiche.periodeLabel }}</strong>
    </p>
{% endblock %}

{% block console_actions %}
    <a href="{{ path('console.evaluation.index', {annee: annee, trimestre: trimestre}) }}" class="btn btn-sm btn-outline-secondary"
       data-action="click->top-progress#show">
        {{ ux_icon(resolve_icon_name('action:view'), {height:'18px', width:'18px'}) }}
        <span class="ms-1">Toutes les évaluations</span>
    </a>
    {% if canManage %}
        <a href="{{ path('console.evaluation.objectif_new', {id: collaborateur.id, annee: annee, trimestre: trimestre}) }}"
           class="btn btn-sm btn-cobalt" data-action="click->top-progress#show">
            {{ ux_icon(resolve_icon_name('action:add'), {height:'18px', width:'18px'}) }}
            <span class="ms-1">Objectif</span>
        </a>
        <a href="{{ path('console.evaluation.evaluer', {id: collaborateur.id, annee: annee, trimestre: trimestre}) }}"
           class="btn btn-sm btn-outline-primary" data-action="click->top-progress#show">
            {{ ux_icon(resolve_icon_name('action:edit'), {height:'18px', width:'18px'}) }}
            <span class="ms-1">Évaluer</span>
        </a>
    {% endif %}
{% endblock %}

{% block console_body %}
{# Bandeau score global de la période. #}
<div class="cs-panel">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <span class="cs-kpi-icon">{{ ux_icon(resolve_icon_name('action:analyser'), {height:'26px', width:'26px'}) }}</span>
            <div>
                <div class="cs-score-big">{{ fiche.score }} <span style="font-size:1rem;color:#6c757d;">/ 100</span></div>
                <div class="cs-kpi-lbl">Score global pondéré</div>
            </div>
        </div>
        <span class="cs-badge {{ fiche.mentionClass }}" style="font-size:.9rem;">{{ fiche.mention }}</span>
        {% if evaluation and evaluation.cloturee %}
            <span class="cs-badge cs-badge--ok">{{ ux_icon(resolve_icon_name('action:check'), {height:'14px', width:'14px'}) }} Clôturée</span>
        {% endif %}
    </div>
</div>

{# Objectifs de la période avec jauge d'atteinte. #}
<div class="cs-panel">
    <h2 class="cs-panel-title">Objectifs de la période</h2>
    {% if fiche.lignes|length > 0 %}
        <table class="cs-table">
            <thead><tr><th>Objectif</th><th>Atteinte</th><th style="width:35%;">Progression</th><th>Poids</th></tr></thead>
            <tbody>
            {% for l in fiche.lignes %}
                {% set o = l.objectif %}
                <tr{% if canManage %} data-cm-row{% endif %}>
                    <td>
                        <div class="cs-objline-head"><strong>{{ o.titre }}</strong></div>
                        <div class="cs-objline-meta">
                            {% if l.metriqueLabel %}Auto · {{ l.metriqueLabel }}{% else %}Manuel{% endif %}
                            {% if o.description %} — {{ o.description }}{% endif %}
                        </div>
                    </td>
                    <td>
                        {{ l.atteinte|number_format(0, '.', ' ') }} / {{ o.cible|number_format(0, '.', ' ') }}
                        {{ o.unite }}
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="cs-gauge" style="flex:1;"><span style="width:{{ l.pourcentage }}%;"></span></div>
                            <span class="cs-objline-meta">{{ l.pourcentage }}%</span>
                        </div>
                    </td>
                    <td>{{ o.poids }} %</td>
                    {% if canManage %}
                        <td hidden data-cm-actions>
                            <a href="{{ path('console.evaluation.objectif_edit', {id: o.id, annee: annee, trimestre: trimestre}) }}"
                               class="cs-icon-btn" data-action="click->top-progress#show" title="Éditer" aria-label="Éditer {{ o.titre }}">
                                {{ ux_icon(resolve_icon_name('action:edit'), {height:'18px', width:'18px'}) }}
                            </a>
                            <form action="{{ path('console.evaluation.objectif_delete', {id: o.id, annee: annee, trimestre: trimestre}) }}" method="post" style="display:inline;"
                                  data-controller="confirm-action" data-action="submit->confirm-action#request"
                                  data-confirm-action-title-value="Supprimer l'objectif"
                                  data-confirm-action-body-value="Supprimer « {{ o.titre }} » ?"
                                  data-confirm-action-irreversible-value="true">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-objectif-' ~ o.id) }}">
                                <button type="submit" class="cs-icon-btn is-danger" title="Supprimer" aria-label="Supprimer {{ o.titre }}">
                                    {{ ux_icon(resolve_icon_name('action:delete'), {height:'18px', width:'18px'}) }}
                                </button>
                            </form>
                        </td>
                    {% endif %}
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <div class="cs-empty">Aucun objectif défini pour cette période.</div>
    {% endif %}
</div>

{# Appréciation du super-admin. #}
{% if evaluation and evaluation.appreciation %}
    <div class="cs-panel">
        <h2 class="cs-panel-title">Appréciation</h2>
        <p style="white-space:pre-line;margin:0;">{{ evaluation.appreciation }}</p>
    </div>
{% endif %}

{# Historique des périodes précédentes. #}
{% if fiche.historique|length > 0 %}
    <div class="cs-panel">
        <h2 class="cs-panel-title">Historique</h2>
        <table class="cs-table">
            <thead><tr><th>Période</th><th>Score</th><th>Mention</th><th style="text-align:right;">Fiche</th></tr></thead>
            <tbody>
            {% for h in fiche.historique %}
                <tr>
                    <td>{{ h.label }}</td>
                    <td><strong>{{ h.score }}</strong> / 100</td>
                    <td><span class="cs-badge {{ h.score >= 70 ? 'cs-badge--ok' : (h.score >= 40 ? 'cs-badge--warn' : 'cs-badge--danger') }}">
                        {{ h.score >= 90 ? 'Excellent' : (h.score >= 70 ? 'Atteint' : (h.score >= 40 ? 'Partiel' : 'Insuffisant')) }}
                    </span></td>
                    <td style="text-align:right;">
                        <a href="{{ path('console.evaluation.show', {id: collaborateur.id, annee: h.annee, trimestre: h.trimestre}) }}"
                           class="cs-icon-btn" data-action="click->top-progress#show" title="Ouvrir" aria-label="Ouvrir {{ h.label }}">
                            {{ ux_icon(resolve_icon_name('action:view'), {height:'18px', width:'18px'}) }}
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
