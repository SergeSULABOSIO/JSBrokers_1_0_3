{# Fragment AJAX : lignes des dernières entreprises créées (rechargées /3 min).
   data-row : repère utilisé par « dashboard-list » pour le filtrage client. #}
{% set consommations = consommations|default({}) %}
{% set geo = geo|default({}) %}
{% if dernieresEntreprises.getTotalItemCount > 0 %}
    <table class="cs-table">
        <thead><tr><th>Créée le</th><th>Entreprise</th><th>Propriétaire</th><th>Localisation</th><th>Collaborateurs</th>
            <th style="text-align:right;">Consommation</th><th style="text-align:right;">Solde restant</th></tr></thead>
        <tbody>
        {% for e in dernieresEntreprises %}
            {% set solde = e.utilisateur ? e.utilisateur.totalTokens : null %}
            {% set g = geo[e.id]|default({}) %}
            <tr data-row>
                <td>{{ e.createdAt ? e.createdAt|format_datetime('medium', 'none', locale: app.user.locale) : '—' }}</td>
                <td data-field="entreprise">{{ ux_icon(resolve_icon_name('entreprise'), {height:'16px', width:'16px'}) }} {{ e.nom }}</td>
                <td data-field="proprietaire">{{ e.utilisateur ? e.utilisateur.nom : '—' }}</td>
                <td data-field="localisation">
                    {% if g.ville or g.pays %}
                        {{ g.ville ?: '' }}{% if g.ville and g.pays %}, {% endif %}{{ g.pays ?: '' }}
                    {% else %}—{% endif %}
                </td>
                <td>{{ e.invites|length }}</td>
                <td style="text-align:right;">
                    {{ (consommations[e.id] ?? 0)|number_format(0, ',', ' ') }}
                    <small style="color:#6c757d;">jetons</small>
                </td>
                <td style="text-align:right;">
                    {% if solde is null %}
                        —
                    {% else %}
                        <span class="cs-badge {{ solde > 0 ? 'cs-badge--ok' : 'cs-badge--muted' }}"
                              title="Solde du propriétaire (gratuit + prépayé), partagé entre ses entreprises">
                            {{ solde|number_format(0, ',', ' ') }} jetons
                        </span>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% else %}
    <div class="cs-empty">Aucune entreprise enregistrée pour l'instant.</div>
{% endif %}
