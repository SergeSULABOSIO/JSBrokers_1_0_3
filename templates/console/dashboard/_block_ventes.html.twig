{# Fragment AJAX : barre de recherche + liste des dernières ventes.
   Calqué sur les blocs « liste » du tableau de bord courtiers : le champ de
   recherche reste statique tandis que seul le contenu de la liste est rechargé
   (fragment) toutes les 3 minutes ; le critère saisi est ré-appliqué après
   chaque rafraîchissement par le contrôleur Stimulus « dashboard-list ». #}
<div data-controller="dashboard-list"
     data-dashboard-list-url-value="{{ path('console.dashboard.ventes_fragment') }}"
     data-dashboard-list-interval-value="180000"
     data-dashboard-list-status-id-value="cs-db-ventes-update">
    <div class="px-3 pt-3 pb-2 d-flex align-items-center gap-1">
        {# Sélecteur du champ pris en compte par la recherche (data-field côté
           liste), précédé de son icône d'illustration (alias action:filter). #}
        <div class="input-group input-group-sm flex-shrink-0 ms-auto" style="max-width:175px;">
            <span class="input-group-text border-0 bg-light px-2">
                {{ ux_icon(resolve_icon_name('action:filter'), {style: 'width:14px;height:14px;color:#6c757d;'}) }}
            </span>
            <select class="form-select form-select-sm border-0 bg-light"
                    style="font-size:.72rem;"
                    aria-label="Champ de recherche"
                    data-dashboard-list-target="field"
                    data-action="change->dashboard-list#search">
                <option value="all">Tous les champs</option>
                <option value="acheteur">Acheteur</option>
                <option value="localisation">Localisation</option>
                <option value="paquet">Paquet</option>
            </select>
        </div>
        <div class="input-group input-group-sm flex-shrink-0" role="search" style="max-width:200px;">
            <span class="input-group-text border-0 bg-light px-2">
                {{ ux_icon('mdi:magnify', {style: 'width:14px;height:14px;color:#6c757d;'}) }}
            </span>
            {# Anti remplissage automatique de l'e-mail connecté
               (1Password / LastPass / Chrome) qui filtrait la liste à vide :
               - attributs autocomplete/ignore comme première barrière ;
               - readonly au chargement (un champ en lecture seule n'est jamais
                 auto-rempli), levé au focus par le contrôleur « dashboard-list ».
               Le champ démarre donc toujours vide. #}
            <input type="search"
                   name="cs-db-ventes-filter"
                   autocomplete="off"
                   autocapitalize="off"
                   autocorrect="off"
                   spellcheck="false"
                   readonly
                   data-form-type="other"
                   data-lpignore="true"
                   data-1p-ignore="true"
                   class="form-control form-control-sm border-0 bg-light"
                   style="font-size:.78rem;"
                   placeholder="Filtrer (acheteur, paquet…)"
                   aria-label="Filtrer les ventes"
                   data-dashboard-list-target="search"
                   data-action="focus->dashboard-list#unlock input->dashboard-list#search">
        </div>
    </div>
    <div class="px-3 pb-3" style="max-height:340px;overflow:auto;" data-dashboard-list-target="list">
        {% include 'console/dashboard/_ventes_list.html.twig' with { dernieresVentes: dernieresVentes, geo: geo } %}
    </div>
</div>
