{# Fragment AJAX : grille de KPIs de la plateforme (rechargé in extenso). #}
{% set kpiCards = [
    { icon: 'action:role',  val: kpis.nbAgents,      lbl: 'Collaborateurs JS Brokers' },
    { icon: 'utilisateur',  val: kpis.nbUsers,       lbl: 'Utilisateurs' },
    { icon: 'client',       val: kpis.nbClients,     lbl: 'Clients' },
    { icon: 'entreprise',   val: kpis.nbEntreprises, lbl: 'Entreprises' },
    { icon: 'operation',    val: kpis.nbVentes,      lbl: 'Ventes de tokens' },
    { icon: 'action:analyser', val: kpis.tauxConversion|number_format(1, ',', ' ') ~ ' %', lbl: 'Taux de conversion' },
    { icon: 'monnaie',      val: kpis.revenuUsd|number_format(2, '.', ' ') ~ ' $', lbl: 'Revenu total' },
    { icon: 'revenu',       val: kpis.revenuHorsTaxe|number_format(2, '.', ' ') ~ ' $', lbl: 'Revenu hors taxe' },
    { icon: 'tranche',      val: kpis.tokensVendus|number_format(0, ',', ' '), lbl: 'Tokens vendus' },
    { icon: 'offre',        val: kpis.remisesUsd|number_format(2, '.', ' ') ~ ' $', lbl: 'Remises accordées' },
] %}
<p class="text-muted mb-2" style="font-size:.72rem;">
    Volumes d'affaires de l'année {{ kpis.annee }} (ventes, revenu, taxes) ; effectifs et taux de conversion en cumulé.
</p>
<div class="cs-kpis">
    {% for c in kpiCards %}
        <div class="cs-kpi">
            <span class="cs-kpi-icon" aria-hidden="true">{{ ux_icon(resolve_icon_name(c.icon), {height: '24px', width: '24px'}) }}</span>
            <span class="cs-kpi-body">
                <span class="cs-kpi-val">{{ c.val }}</span>
                <span class="cs-kpi-lbl">{{ c.lbl }}</span>
            </span>
        </div>
    {% endfor %}
    {# Une carte par taxe active : montant représenté sur le revenu de l'année. #}
    {% for t in kpis.taxes %}
        <div class="cs-kpi">
            <span class="cs-kpi-icon" aria-hidden="true">{{ ux_icon(resolve_icon_name('taxe'), {height: '24px', width: '24px'}) }}</span>
            <span class="cs-kpi-body">
                <span class="cs-kpi-val">{{ t.montant|number_format(2, '.', ' ') }} $</span>
                <span class="cs-kpi-lbl">Taxe {{ t.taxe.code }}</span>
            </span>
        </div>
    {% endfor %}
</div>
