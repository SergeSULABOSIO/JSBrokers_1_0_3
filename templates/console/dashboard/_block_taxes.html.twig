{# Fiscalité JS Brokers : taxes actives ventilées sur le revenu total des ventes,
   avec synthèse (TTC, total taxes, hors taxe). Bloc statique — pas de recherche,
   pas de pagination : la configuration change rarement. #}
{% if taxes is not empty %}
    <div class="px-3 pb-3" style="max-height:340px;overflow:auto;">
        <table class="cs-table">
            <thead><tr><th>Libellé</th><th>Autorité fiscale</th><th style="text-align:right;">Taux</th><th style="text-align:right;">Montant dû</th></tr></thead>
            <tbody>
            {% for ligne in taxes %}
                <tr>
                    <td><span class="cs-badge cs-badge--cobalt">{{ ligne.taxe.code }}</span> {{ ligne.taxe.libelle }}</td>
                    <td>{{ ligne.taxe.autoriteNom }} ({{ ligne.taxe.autoriteAbreviation }})</td>
                    <td style="text-align:right;">{{ ligne.taxe.taux|number_format(2, '.', ' ') }} %</td>
                    <td style="text-align:right;">{{ ligne.montant|number_format(2, '.', ' ') }} $</td>
                </tr>
            {% endfor %}
            </tbody>
            <tfoot>
                <tr><th colspan="3" style="text-align:right;">Revenu total (TTC)</th><th style="text-align:right;">{{ revenuTotal|number_format(2, '.', ' ') }} $</th></tr>
                <tr><th colspan="3" style="text-align:right;">Total des taxes</th><th style="text-align:right;">{{ montantTaxes|number_format(2, '.', ' ') }} $</th></tr>
                <tr><th colspan="3" style="text-align:right;">Revenu hors taxe</th><th style="text-align:right;">{{ revenuHorsTaxe|number_format(2, '.', ' ') }} $</th></tr>
            </tfoot>
        </table>
    </div>
{% else %}
    <div class="cs-empty m-3">Aucune taxe active. Le revenu hors taxe est égal au revenu total.</div>
{% endif %}
