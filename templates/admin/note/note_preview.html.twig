{# templates/admin/note/note_preview.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aperçu : {{ note.typeString }} {{ note.reference }}</title>
    {# NOUVEAU : Ajout de la favicon #}
    <link rel="icon" href="{{ asset('images/entreprises/logofav.png') }}" type="image/png">
    {# On inclut Bootstrap pour le style #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
        }
        .invoice-container {
            max-width: 800px;
            margin: 2rem auto;
            background-color: #fff;
            border: 1px solid #dee2e6;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,.15);
        }
        .invoice-header {
            padding: 2rem;
            border-bottom: 1px solid #dee2e6;
        }
        .invoice-body {
            padding: 2rem;
        }
        .invoice-footer {
            padding: 2rem;
            background-color: #f8f9fa;
            border-top: 1px solid #dee2e6;
        }
        .actions-bar {
            padding: 1rem;
            text-align: center;
            background-color: #343a40;
        }
        .table thead th {
            text-align: right;
        }
        .table tbody td {
            text-align: right;
        }
        .table thead th:first-child, .table tbody td:first-child {
            text-align: left;
        }
        .total-section td {
            font-weight: bold;
        }

        /* NOUVEAU : Styles spécifiques pour l'impression */
        @media print {
            body {
                background-color: #fff; /* Fond blanc pour l'impression */
            }
            .actions-bar {
                display: none !important; /* Masque la barre d'actions lors de l'impression */
            }
            .invoice-container {
                margin: 0;
                border: none;
                box-shadow: none;
                max-width: 100%; /* La facture prend toute la largeur de la page */
            }
        }

        {# NOUVEAU : Styles spécifiques pour forcer le rendu visuel dans DomPDF #}
        {# Ces styles ne s'appliquent que lors de la génération du PDF grâce à la condition #}
        {% if logo_path_for_pdf is defined and logo_path_for_pdf %}
            @media print {
                .table-light {
                    background-color: #f8f9fa !important; /* Force le fond gris clair de l'en-tête */
                }
                .table tbody tr {
                    border-top-width: 1px !important; /* Force l'affichage de la ligne de séparation */
                    border-top-style: solid !important;
                    border-top-color: #dee2e6 !important;
                }
            }
        {% endif %}
    </style>
</head>
<body>

    <div class="actions-bar sticky-top">
        {# CORRECTION : Utilisation de Twig UX Icons, comme dans la barre d'outils principale. #}
        <button class="btn btn-light d-inline-flex align-items-center gap-2" data-controller="ripple" onclick="window.close()">
            <twig:UX:Icon name="{{ resolve_icon_name('action:close') }}" width="18px" height="18px" />
            <span>Retourner à l'édition</span>
        </button>

        <button class="btn btn-primary d-inline-flex align-items-center gap-2" data-controller="ripple" onclick="window.print()">
            <twig:UX:Icon name="{{ resolve_icon_name('action:print') }}" width="18px" height="18px" />
            <span>Imprimer</span>
        </button>

        {# NOUVEAU : Bouton pour télécharger en PDF #}
        <a href="{{ path('admin.note.download_pdf', {id: note.id}) }}" class="btn btn-danger d-inline-flex align-items-center gap-2" data-controller="ripple" target="_blank">
            <twig:UX:Icon name="{{ resolve_icon_name('action:download') }}" width="18px" height="18px" />
            <span>Télécharger en PDF</span>
        </a>
    </div>

    <div class="invoice-container">
        <div class="invoice-header">
            {# NOUVEAU : Logo de l'entreprise centré en haut #}
            <div class="text-center mb-4">
                {# CORRECTION : On utilise le chemin absolu pour le PDF s'il est fourni, sinon on utilise asset() pour le web #}
                {% if logo_path_for_pdf is defined and logo_path_for_pdf %}
                    <img src="{{ logo_path_for_pdf }}" alt="Logo" style="max-height: 80px;">
                {% elseif entreprise and entreprise.thumbnail %}
                    <img src="{{ asset('images/entreprises/' ~ entreprise.thumbnail) }}" alt="Logo" style="max-height: 80px;">
                {% else %}
                    <img src="{{ asset('images/entreprises/logofav.png') }}" alt="Logo JS Brokers" style="max-height: 80px;">
                {% endif %}
            </div>
            <div class="row align-items-center">
                <div class="col">
                    <h4 class="mt-2 mb-0">{{ entreprise.nom|default('Votre Entreprise') }}</h4>
                    <p class="text-muted">{{ entreprise.adresse|default('') }}</p>
                </div>
                <div class="col text-end">
                    <h2>{{ note.typeString }}</h2>
                    <p class="mb-1"><strong>Référence :</strong> {{ note.reference }}</p>
                    <p class="mb-0"><strong>Date :</strong> {{ note.sentAt|date('d/m/Y') }}</p>
                </div>
            </div>
            <hr>
            <div class="row">
                <div class="col">
                    {# NOUVEAU : Logique pour afficher les détails complets du destinataire #}
                    {% set destinataire = null %}
                    {% if note.client %}{% set destinataire = note.client %}{% endif %}
                    {% if note.assureur %}{% set destinataire = note.assureur %}{% endif %}
                    {% if note.partenaire %}{% set destinataire = note.partenaire %}{% endif %}
                    {% if note.autoritefiscale %}{% set destinataire = note.autoritefiscale %}{% endif %}

                    {% if destinataire %}
                        <strong>Destinataire :</strong>
                        <p class="mb-0 fw-bold">{{ destinataire.nom }}</p>
                        {% if destinataire.adresse is defined and destinataire.adresse %}
                            <p class="mb-0 text-muted">{{ destinataire.adresse }}</p>
                        {% endif %}
                        <p class="mb-0 text-muted small">
                            {% if destinataire.rccm is defined and destinataire.rccm %}RCCM: {{ destinataire.rccm }} / {% endif %}
                            {% if destinataire.idnat is defined and destinataire.idnat %}ID.NAT: {{ destinataire.idnat }} / {% endif %}
                            {% if destinataire.numimpot is defined and destinataire.numimpot %}N° Impôt: {{ destinataire.numimpot }}{% endif %}
                        </p>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="invoice-body">
            <h5>Détails de la note : {{ note.nom }}</h5>
            <table class="table mt-4">
                <thead class="table-light">
                    <tr>
                        <th>Article</th>
                        <th>Quantité</th>
                        <th>Prix Unitaire</th>
                        <th>Montant</th>
                    </tr>
                </thead>
                <tbody>
                    {% for article in note.articles %}
                        <tr>
                            <td>
                                <strong>{{ article.revenuFacture.nom|default('Article') }}</strong><br>
                                <small class="text-muted">{{ article.description }}</small>
                            </td>
                            <td>{{ article.quantite|number_format(2, ',', ' ') }}</td>
                            {# CORRECTION : Utilisation des valeurs HT #}
                            <td>{{ article.valeurUnitaireHT|number_format(2, ',', ' ') }} {{ monnaie }}</td>
                            <td>{{ article.montantArticleHT|number_format(2, ',', ' ') }} {{ monnaie }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    {# CORRECTION : Calcul du total HT #}
                    {% set totalHT = note.montantTotal - note.montantTaxe %}
                    <tr class="total-section">
                        <td colspan="3" class="text-end border-0"><strong>Total HT</strong></td>
                        <td class="border-0">{{ totalHT|number_format(2, ',', ' ') }} {{ monnaie }}</td>
                    </tr>
                    
                    {# NOUVEAU : Affichage de la taxe si applicable (pas sur les notes de crédit) #}
                    {% if note.type != 1 and note.montantTaxe > 0 %}
                        <tr>
                            <td colspan="3" class="text-end border-0">{{ note.nomTaxe }} ({{ note.tauxTaxe|number_format(2, ',', ' ') }}%)</td>
                            <td class="border-0">{{ note.montantTaxe|number_format(2, ',', ' ') }} {{ monnaie }}</td>
                        </tr>
                    {% endif %}

                    <tr class="total-section table-secondary">
                        <td colspan="3" class="text-end border-0"><strong>Total TTC</strong></td>
                        <td class="border-0">{{ note.montantTotal|number_format(2, ',', ' ') }} {{ monnaie }}</td>
                    </tr>
                    {# NOUVEAU : Montant total en lettres #}
                    <tr>
                        <td colspan="4" class="text-end border-0 fst-italic text-muted pt-3">
                            Arrêté la présente note à la somme de : {{ note.montantTotal|to_words(monnaie) }}.
                        </td>
                    </tr>
                </tfoot>
            </table>

            {# NOUVEAU : Affichage des comptes bancaires si applicable (pas sur les notes de crédit) #}
            {% if note.type != 1 and note.comptes is not empty %}
                <div class="mt-5">
                    <h6 class="border-bottom pb-2">Informations de paiement</h6>
                    {% for compte in note.comptes %}
                        <div class="mt-3">
                            <p class="mb-0"><strong>Banque :</strong> {{ compte.banque }}</p>
                            <p class="mb-0"><strong>Intitulé du compte :</strong> {{ compte.intitule }}</p>
                            <p class="mb-0"><strong>Numéro de compte :</strong> {{ compte.numero }}</p>
                            <p class="mb-0"><strong>Code SWIFT :</strong> {{ compte.codeSwift }}</p>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="invoice-footer text-center">
            {# NOUVEAU : Pied de page avec les infos de l'entreprise #}
            <p class="mb-1 fw-bold">{{ entreprise.nom|default('Votre Entreprise') }}</p>
            <p class="text-muted small fst-italic mb-0">
                {{ entreprise.adresse|default('') }}<br>
                Tel: {{ entreprise.telephone|default('N/A') }} / Site web: {{ entreprise.siteweb|default('N/A') }}<br>
                RCCM: {{ entreprise.rccm|default('N/A') }} / ID.NAT: {{ entreprise.idnat|default('N/A') }} / N° Impôt: {{ entreprise.numimpot|default('N/A') }}
            </p>
        </div>
    </div>

</body>
</html>