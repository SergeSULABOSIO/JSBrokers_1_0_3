{% extends 'base.html.twig' %}
{% import 'admin/entreprise/_form_macros.html.twig' as ff %}

{% block title %}{{ pageName }} — JS Brokers{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ============================================================
       Création d'une entreprise — cohérent avec l'édition, la liste
       et la connexion. Charte : cobalt #0047AB + neutres Bootstrap.
       ============================================================ */
    /* Page = colonne pleine hauteur : barre fixe + zone défilante */
    .ent-page { height: 100vh; display: flex; flex-direction: column; background-color: #f3f3f3; }

    /* Barre de progression globale (même pattern que l'espace de travail) :
       fixée en haut, cobalt, animée, affichée par Stimulus à chaque action. */
    .ent-progress-bar {
        position: fixed; top: 0; left: 0; width: 100%; height: 6px;
        background-color: #0047AB; display: none; z-index: 9999;
        animation: ent-progress-animation 1.5s infinite linear;
    }
    @keyframes ent-progress-animation {
        0%   { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    .ent-topbar {
        flex: 0 0 auto;
        display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; padding: .75rem 1.5rem;
        background-color: #ffffff; border-bottom: 1px solid #dee2e6;
    }

    /* Zone défilante : active la scrollbar verticale si le formulaire
       dépasse la hauteur disponible à l'écran. */
    .ent-scroll { flex: 1 1 auto; overflow-y: auto; }
    .ent-brand { display: flex; align-items: center; gap: .6rem; text-decoration: none; }
    .ent-brand img { width: 36px; height: 36px; border-radius: 8px; }
    .ent-brand span { font-weight: 700; color: #0047AB; font-size: 1.1rem; }
    .ent-topbar-user { display: flex; align-items: center; gap: 1rem; }
    .ent-topbar-user .ent-user-name { display: inline-flex; align-items: center; gap: .4rem; color: #495057; font-size: .95rem; font-weight: 600; }
    .ent-topbar-user .ent-user-icon { color: #6c757d; flex: 0 0 auto; }
    .ent-topbar-actions { display: flex; align-items: center; gap: .5rem; }
    .ent-topbar-sep { width: 1px; height: 24px; background-color: #dee2e6; }
    @media (max-width: 575.98px) {
        .ent-topbar-user .ent-user-name, .ent-topbar-sep { display: none; }
    }

    .ent-content { max-width: 820px; margin: 0 auto; padding: 1.5rem; }
    .ent-back { display: inline-flex; align-items: center; gap: .35rem; font-size: .9rem; color: #6c757d; text-decoration: none; margin-bottom: 1rem; }
    .ent-back:hover { color: #0047AB; }

    .ent-head { margin-bottom: 1.5rem; }
    .ent-head h1 { font-size: 1.6rem; font-weight: 700; color: #212529; margin: 0 0 .25rem; }
    .ent-head p { color: #6c757d; margin: 0; }

    .ent-form-card {
        background-color: #ffffff; border: 1px solid #dee2e6; border-radius: 12px;
        padding: 1.5rem 1.75rem; box-shadow: 0 4px 16px rgba(0, 71, 171, .06);
    }

    .ent-thumb { display: flex; justify-content: center; margin-bottom: 1.5rem; }
    /* Placeholder en cercle (création) : icône d'entité « entreprise » centrée,
       cohérent avec le cercle de la page d'édition. Comme aucun logo n'est encore
       téléversé, on affiche l'icône de marque plutôt qu'une photo. */
    .ent-thumb-placeholder {
        display: flex; align-items: center; justify-content: center;
        width: 150px; height: 150px; border-radius: 50%;
        border: 1px solid #dee2e6; background-color: #f8f9fa;
        transition: box-shadow .2s ease;
    }
    .ent-thumb-placeholder:hover { box-shadow: 0 4px 16px rgba(0, 71, 171, .12); }
    .ent-thumb-placeholder svg { width: 64px; height: 64px; color: #0047AB; }

    /* Chaque section = bloc distinct (panneau) à l'intérieur de la carte */
    .ent-fieldset {
        border: 1px solid #dee2e6; border-radius: 10px;
        background-color: #f8f9fa;
        padding: 1.15rem 1.25rem .35rem; margin: 0 0 1.1rem;
    }
    .ent-fieldset:last-of-type { margin-bottom: 0; }
    .ent-legend {
        display: inline-flex; align-items: center; gap: .45rem;
        font-size: .78rem; text-transform: uppercase; letter-spacing: .04em; font-weight: 700;
        color: #0047AB; margin-bottom: 1rem; padding: 0; width: auto; float: none;
    }
    /* Les champs (blancs) ressortent sur le fond clair du panneau */
    .ent-fieldset .form-control,
    .ent-fieldset .form-select { background-color: #ffffff; }

    /* Libellé : marqué et foncé (même pattern que la page de connexion) */
    .ent-form-card .form-label {
        font-weight: 600; color: #343a40; margin-bottom: .35rem;
    }
    /* Valeur saisie : champ haut et confortable, contenu en noir */
    .ent-form-card .form-control,
    .ent-form-card .form-select {
        height: 48px; font-size: 1rem; color: #000000;
    }
    .ent-form-card .form-control::placeholder { font-weight: 400; color: #adb5bd; }

    .ent-form-card .form-control:focus,
    .ent-form-card .form-select:focus {
        border-color: #0047AB;
        box-shadow: 0 0 0 .25rem rgba(0, 71, 171, .35);
    }

    /* Champ à icône préfixe (façon page de connexion) */
    .ent-field-group { margin-bottom: 1rem; }
    .ent-field { position: relative; }
    .ent-field-icon {
        position: absolute; top: 50%; left: .85rem; transform: translateY(-50%);
        width: 20px; height: 20px; color: #6c757d; pointer-events: none;
    }
    .ent-field .form-control,
    .ent-field .form-select { padding-left: 2.6rem; }

    /* Barre d'actions toujours visible : épinglée en bas de la zone défilante
       (symétrique de la barre de titre épinglée en haut). Reste dans le <form>
       pour ne pas affecter la soumission / le jeton CSRF. */
    .ent-actions {
        position: sticky; bottom: 0; z-index: 5;
        display: flex; align-items: center; gap: .75rem;
        margin: 1.25rem -1.75rem -1.5rem; padding: 1rem 1.75rem;
        background-color: #ffffff; border-top: 1px solid #dee2e6;
        border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;
        box-shadow: 0 -4px 12px rgba(0, 71, 171, .06);
    }

    /* Raccourci « Liste d'entreprises » repris dans la barre d'actions, à gauche,
       séparé des boutons par un fin séparateur vertical (même style que la topbar). */
    .ent-actions-back {
        display: inline-flex; align-items: center; gap: .35rem;
        font-size: .9rem; color: #6c757d; text-decoration: none; white-space: nowrap;
        transition: color .15s ease;
    }
    .ent-actions-back:hover { color: #0047AB; }
    /* margin-left:auto pousse le séparateur + le groupe de boutons vers la droite,
       le raccourci restant ancré à gauche. */
    .ent-actions-sep { flex: 0 0 auto; width: 1px; height: 28px; background-color: #dee2e6; margin-left: auto; }

    @media (max-width: 575.98px) {
        .ent-actions { flex-direction: column-reverse; align-items: stretch; }
        .ent-actions .btn { width: 100%; }
        .ent-actions-sep { display: none; }
        .ent-actions-back { width: 100%; justify-content: center; }
    }
</style>
{# Styles partagés : bascule de langue (.ent-lang) + pied de page officiel #}
{{ include('admin/entreprise/_chrome_styles.html.twig') }}
{% endblock %}

{% block body %}
<main class="ent-page" data-controller="top-progress">

    {# Barre de progression globale (pattern espace de travail) #}
    <div class="ent-progress-bar" data-top-progress-target="bar"
         role="progressbar" aria-label="{{ 'entreprise_loading' | trans }}" aria-hidden="true"></div>

    <header class="ent-topbar">
        <a href="{{ path('admin.entreprise.index') }}" class="ent-brand"
           data-action="click->top-progress#show">
            <img src="{{ asset('images/entreprises/logofav.png') }}" alt="">
            <span>JS Brokers</span>
        </a>
        <div class="ent-topbar-user">
            <span class="ent-user-name">
                {{ ux_icon(resolve_icon_name('utilisateur'), {height: '20px', width: '20px', class: 'ent-user-icon'}) }}
                {{ utilisateur.nom }}
            </span>
            <span class="ent-topbar-sep" aria-hidden="true"></span>
            <div class="ent-topbar-actions">
                {# Bascule de langue (FR/EN) : persiste la préférence via ?lang= #}
                {{ include('admin/entreprise/_topbar_lang.html.twig') }}
                <a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-danger border-0"
                   data-action="click->top-progress#show"
                   title="{{ "boutons_user_logout" | trans }}" aria-label="{{ "boutons_user_logout" | trans }}">
                    {{ ux_icon(resolve_icon_name('action:exit'), {height: '18px', width: '18px'}) }}
                </a>
            </div>
        </div>
    </header>

    <div class="ent-scroll">
    <div class="ent-content">

        <a href="{{ path('admin.entreprise.index') }}" class="ent-back"
           data-action="click->top-progress#show">
            {{ ux_icon(resolve_icon_name('hugeicons:arrow-left-01'), {height: '18px', width: '18px'}) }}
            {{ "entreprise_page_name_list" | trans }}
        </a>

        {# Retour succès / échec via toast applicatif (cohérent avec le reste de l'app) #}
        {{ include('components/_flash_toasts.html.twig') }}

        <div class="ent-head">
            <h1>{{ pageName }}</h1>
            <p>{{ "entreprise_creation_description_message" | trans({':user': utilisateur.nom}) | raw }}</p>
        </div>

        <div class="ent-form-card">

            {# Aucun logo encore téléversé : on illustre avec l'icône d'entité « entreprise »
               (cohérent avec l'icône utilisée partout dans l'app) plutôt qu'une photo. #}
            <div class="ent-thumb">
                <div class="ent-thumb-placeholder" aria-hidden="true">
                    {{ ux_icon(resolve_icon_name('entreprise'), {height: '64px', width: '64px'}) }}
                </div>
            </div>

            {{ form_start(form, {'attr': {
                'data-controller': 'form-submit pays-dependances',
                'data-action': 'submit->form-submit#submitting submit->top-progress#show',
                'data-form-submit-loading-text-value': 'entreprise_loading_create'|trans,
                'data-pays-dependances-url-template-value': path('admin.entreprise.api.villes', {codePays: 999999999}),
            }}) }}

                <fieldset class="ent-fieldset">
                    <legend class="ent-legend">
                        {{ ux_icon(resolve_icon_name('entreprise'), {height: '16px', width: '16px'}) }}
                        {{ 'entreprise_legend_identity' | trans }}
                    </legend>
                    {{ ff.field(form.nom, 'entreprise') }}
                    <div class="row">
                        <div class="col-md">{{ ff.field(form.siteweb, 'mdi:web') }}</div>
                        <div class="col-md">{{ form_row(form.capitalSociale) }}</div>
                    </div>
                    {{ form_row(form.thumbnailFile) }}
                </fieldset>

                <fieldset class="ent-fieldset">
                    <legend class="ent-legend">
                        {{ ux_icon(resolve_icon_name('contact'), {height: '16px', width: '16px'}) }}
                        {{ 'entreprise_legend_contact' | trans }}
                    </legend>
                    <div class="row">
                        <div class="col-md">{{ ff.field(form.adresse, 'mdi:address-marker-outline') }}</div>
                        <div class="col-md">{{ ff.field(form.telephone, 'ic:outline-phone') }}</div>
                    </div>
                    <div class="row">
                        <div class="col-md">{{ ff.field(form.pays, 'mdi:earth') }}</div>
                        <div class="col-md">{{ ff.field(form.ville, 'mdi:city') }}</div>
                    </div>
                </fieldset>

                <fieldset class="ent-fieldset">
                    <legend class="ent-legend">
                        {{ ux_icon(resolve_icon_name('taxe'), {height: '16px', width: '16px'}) }}
                        {{ 'entreprise_legend_registration' | trans }}
                    </legend>
                    <div class="row">
                        <div class="col-md">{{ ff.field(form.licence, 'clarity:license-outline-badged') }}</div>
                        <div class="col-md">{{ ff.field(form.rccm, 'document') }}</div>
                    </div>
                    <div class="row">
                        <div class="col-md">{{ ff.field(form.idnat, 'mdi:card-account-details-outline') }}</div>
                        <div class="col-md">{{ ff.field(form.numimpot, 'taxe') }}</div>
                    </div>
                </fieldset>

                {# Rappel important transformé en toast permanent (haut à droite, fixe, non fermable). #}
                {{ include('components/_workspace_params_toast.html.twig', {
                    message: 'entreprise_params_toast_create'|trans
                }) }}

                <div class="ent-actions">
                    <a href="{{ path('admin.entreprise.index') }}" class="ent-actions-back"
                       data-action="click->top-progress#show">
                        {{ ux_icon(resolve_icon_name('hugeicons:arrow-left-01'), {height: '18px', width: '18px'}) }}
                        <span>{{ "entreprise_page_name_list" | trans }}</span>
                    </a>
                    <span class="ent-actions-sep" aria-hidden="true"></span>
                    {{ form_widget(form.enregistrer, {
                        label_html: true,
                        label: ux_icon(resolve_icon_name('action:save'), {height: '18px', width: '18px'}) ~ '<span class="ms-1">' ~ ('commom_save'|trans) ~ '</span>',
                        attr: {
                            'class': 'btn btn-cobalt d-inline-flex align-items-center',
                            'data-form-submit-target': 'button',
                        }
                    }) }}
                    <a href="{{ path('admin.entreprise.index') }}" class="btn btn-outline-secondary d-inline-flex align-items-center"
                       data-action="click->form-submit#navigating click->top-progress#show" data-loading-text="{{ 'entreprise_loading_cancel' | trans }}">
                        {{ ux_icon(resolve_icon_name('action:cancel'), {height: '18px', width: '18px'}) }}
                        <span class="ms-1">{{ 'entreprise_cancel' | trans }}</span>
                    </a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>{# /.ent-content #}

    {# Pied de page public officiel JS Brokers : hors de la colonne étroite .ent-content
       pour occuper 100% de la largeur (même pattern que la liste des entreprises).
       Bascule de langue fonctionnelle via ?lang=. #}
    {% include 'components/_public_footer.html.twig' with { lang: app.user.locale } %}
    </div>{# /.ent-scroll #}
</main>
{% endblock %}
