{% extends 'base.html.twig' %}

{% block title %}{{ pageName }} — JS Brokers{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ============================================================
       Liste des entreprises — charte JS Brokers (cobalt #0047AB),
       neutres Bootstrap. Aucune couleur hors charte.
       ============================================================ */
    /* Page en pleine hauteur : la barre de titre reste fixe en haut,
       seul le contenu situé en dessous défile (zone .ent-scroll). */
    .ent-page {
        height: 100vh; background-color: #f3f3f3;
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* Barre de progression globale (même pattern que l'espace de travail) :
       fixée en haut, cobalt, animée, affichée par Stimulus à chaque action. */
    .ent-progress-bar {
        position: fixed; top: 0; left: 0; width: 100%; height: 6px;
        background-color: #0047AB; display: none; z-index: 9999;
        animation: ent-progress-animation 1.5s infinite linear;
    }
    @keyframes ent-progress-animation {
        0%   { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    /* Barre applicative */
    .ent-topbar {
        flex: 0 0 auto; /* barre de titre figée : ne défile pas avec le contenu */
        display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; flex-wrap: wrap; padding: .75rem 1.5rem;
        background-color: #ffffff; border-bottom: 1px solid #dee2e6;
    }

    /* Zone défilante : occupe toute la hauteur restante sous la barre de titre.
       min-height:0 indispensable pour qu'un enfant flex puisse défiler. */
    .ent-scroll { flex: 1 1 auto; min-height: 0; overflow-y: auto; }
    .ent-brand { display: flex; align-items: center; gap: .6rem; text-decoration: none; }
    .ent-brand img { width: 36px; height: 36px; border-radius: 8px; }
    .ent-brand span { font-weight: 700; color: #0047AB; font-size: 1.1rem; }
    .ent-topbar-user { display: flex; align-items: center; gap: 1rem; }
    .ent-topbar-user .ent-user-name { display: inline-flex; align-items: center; gap: .4rem; color: #495057; font-size: .95rem; font-weight: 600; }
    .ent-topbar-user .ent-user-icon { color: #6c757d; flex: 0 0 auto; }
    /* Groupe de boutons, à droite du nom utilisateur */
    .ent-topbar-actions { display: flex; align-items: center; gap: .5rem; }
    /* Séparateur entre le nom de l'utilisateur et le groupe de boutons */
    .ent-topbar-sep { width: 1px; height: 24px; background-color: #dee2e6; }

    /* Contenu */
    .ent-content { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }
    .ent-head { margin-bottom: 1.5rem; }
    .ent-head h1 { font-size: 1.6rem; font-weight: 700; color: #212529; margin: 0 0 .25rem; }
    .ent-head p { color: #6c757d; margin: 0; max-width: 60ch; }

    /* Grille responsive (remplace le .d-flex non-wrappé) */
    .ent-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.25rem;
    }

    .ent-card {
        display: flex; flex-direction: column;
        background-color: #ffffff; border: 1px solid #dee2e6; border-radius: 12px;
        overflow: hidden; transition: box-shadow .2s ease, transform .2s ease;
    }
    .ent-card:hover { box-shadow: 0 8px 24px rgba(0, 71, 171, .12); transform: translateY(-2px); }
    .ent-card-media { display: block; }
    .ent-card-img { width: 100%; height: 180px; object-fit: cover; display: block; background-color: #e9ecef; }

    .ent-card-body { padding: 1rem 1rem .5rem; }
    .ent-card-title { font-size: 1.15rem; font-weight: 700; margin: 0 0 .35rem; }
    .ent-card-title a { color: #0047AB; text-decoration: none; }
    .ent-card-title a:hover { color: #003380; text-decoration: underline; }
    .ent-card-address { color: #6c757d; font-size: .9rem; display: flex; align-items: center; gap: .35rem; margin: 0; }

    .ent-info {
        list-style: none; margin: .75rem 0 0; padding: .75rem 0 0;
        border-top: 1px solid #f0f0f0; display: flex; flex-direction: column; gap: .1rem;
    }
    .ent-info li {
        display: flex; align-items: center; gap: .5rem; font-size: .85rem; color: #6c757d;
        padding: .3rem .5rem; margin: 0 -.5rem; border-radius: 8px; cursor: default;
        transition: background-color .15s ease, color .15s ease;
    }
    /* Chaque détail réagit au survol : surface claire + accent cobalt sur la valeur */
    .ent-info li:hover { background-color: #f8f9fa; color: #495057; }
    .ent-info li:hover .ent-info-label { color: #495057; }
    .ent-info li:hover strong { color: #0047AB; }
    .ent-info .ent-info-label { display: inline-flex; align-items: center; gap: .4rem; }
    .ent-info strong { color: #212529; font-weight: 600; margin-left: auto; text-align: right; transition: color .15s ease; }

    .ent-card-foot {
        margin-top: auto; display: flex; align-items: center; justify-content: space-between;
        gap: .5rem; padding: .65rem 1rem; background-color: #f8f9fa; border-top: 1px solid #f0f0f0;
    }
    /* Pied de carte : indicateur de propriété (remplace les anciens boutons).
       L'icône + le libellé indiquent le rôle de l'utilisateur ; le survol/focus
       révèle l'explication détaillée dans une infobulle sombre. */
    .ent-card-foot { justify-content: flex-start; }
    .ent-owner-status {
        position: relative; display: inline-flex; align-items: center; gap: .5rem;
        font-size: .9rem; font-weight: 600; color: #495057;
        cursor: help; padding: .2rem .15rem; border-radius: 6px;
    }
    .ent-owner-status .ent-owner-icon { flex: 0 0 auto; color: #6c757d; }
    /* Le propriétaire est mis en avant par l'accent cobalt de la marque. */
    .ent-owner-status--owner { color: #0047AB; }
    .ent-owner-status--owner .ent-owner-icon { color: #0047AB; }
    .ent-owner-status:focus-visible { outline: 2px solid #0047AB; outline-offset: 2px; }

    /* Infobulle flottante sombre — même pattern que le tableau de bord : élément
       ajouté au <body> par le contrôleur owner-tip, en position fixe, qui suit
       la souris. Fond #212529, titre blanc gras, contenu gris clair non gras. */
    .ent-owner-floating-tip {
        position: fixed; z-index: 1090; display: none;
        min-width: 220px; max-width: 280px;
        background-color: #212529; border-radius: 8px; padding: .65rem .8rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, .35);
        pointer-events: none; text-align: left;
    }
    .ent-owner-tip-title { display: block; color: #ffffff; font-weight: 700; font-size: .85rem; margin-bottom: .25rem; }
    .ent-owner-tip-body  { display: block; color: #adb5bd; font-weight: 400; font-size: .8rem; line-height: 1.4; }

    .ent-actions { display: flex; align-items: center; gap: .25rem; }
    .ent-actions form { margin: 0; }
    .ent-icon-btn {
        width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center;
        border: 0; background: transparent; border-radius: 8px; color: #6c757d; cursor: pointer; text-decoration: none;
    }
    .ent-icon-btn:hover { background-color: #e9ecef; color: #212529; }
    .ent-icon-btn.is-danger:hover { background-color: #f8d7da; color: #dc3545; }
    .ent-icon-btn:focus-visible { outline: 2px solid #0047AB; outline-offset: 2px; }

    /* État vide */
    .ent-empty {
        text-align: center; padding: 3rem 1.5rem;
        background-color: #ffffff; border: 1px dashed #ced4da; border-radius: 12px;
    }
    .ent-empty h2 { font-size: 1.2rem; color: #212529; margin: 1rem 0 .5rem; }
    .ent-empty p { color: #6c757d; margin: 0 0 1.5rem; }

    .ent-pagination { display: flex; justify-content: center; margin-top: 1.5rem; }

    @media (max-width: 575.98px) {
        /* Sur petit écran : on masque le nom pour garder l'action primaire visible */
        .ent-topbar-user .ent-user-name,
        .ent-topbar-sep { display: none; }
    }
</style>
{# Styles partagés : pied de page officiel (bascule de langue .cs-lang globale) #}
{{ include('admin/entreprise/_chrome_styles.html.twig') }}
{% endblock %}

{% block body %}
<main class="ent-page" data-controller="top-progress entreprise-context-menu"
      data-entreprise-context-menu-edit-template-value="{{ 'entreprise_menu_edit_named'|trans({':company': '%name%'}) }}"
      data-entreprise-context-menu-delete-template-value="{{ 'entreprise_menu_delete_named'|trans({':company': '%name%'}) }}">

    {# Barre de progression globale (pattern espace de travail) #}
    <div class="ent-progress-bar" data-top-progress-target="bar"
         role="progressbar" aria-label="{{ 'entreprise_loading' | trans }}" aria-hidden="true"></div>

    {# Barre applicative : marque + utilisateur + déconnexion #}
    <header class="ent-topbar">
        <a href="{{ path('app_index') }}" class="ent-brand"
           data-action="click->top-progress#show"
           aria-label="{{ 'entreprise_brand_home' | trans }}" title="{{ 'entreprise_brand_home' | trans }}">
            <img src="{{ asset('images/entreprises/logofav.png') }}" alt="">
            <span>JS Brokers</span>
        </a>
        <div class="ent-topbar-user">
            <span class="ent-user-name">
                {{ ux_icon(resolve_icon_name('utilisateur'), {height: '20px', width: '20px', class: 'ent-user-icon'}) }}
                {{ utilisateur.nom }}
            </span>
            <span class="ent-topbar-sep" aria-hidden="true"></span>
            <div class="ent-topbar-actions">
                {# Accès à la Console JS Brokers, réservé aux agents (ROLE_ADMIN). #}
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('console.dashboard') }}" class="btn btn-sm btn-outline-primary"
                       data-action="click->top-progress#show" title="Console JS Brokers">
                        {{ ux_icon(resolve_icon_name('dashboard'), {height: '18px', width: '18px'}) }}
                        <span class="ms-1">Console</span>
                    </a>
                {% endif %}
                <a href="{{ path('admin.entreprise.create') }}" class="btn btn-sm btn-cobalt"
                   data-action="click->top-progress#show">
                    {{ ux_icon(resolve_icon_name('action:add'), {height: '18px', width: '18px'}) }}
                    <span class="ms-1">{{ "boutons_user_new_company" | trans }}</span>
                </a>
                <a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-danger border-0"
                   data-action="click->top-progress#show"
                   title="{{ "boutons_user_logout" | trans }}" aria-label="{{ "boutons_user_logout" | trans }}">
                    {{ ux_icon(resolve_icon_name('action:exit'), {height: '18px', width: '18px'}) }}
                </a>
                {# Bascule de langue (FR/EN) : ancrée à l'extrême droite de la barre de titre.
                   Persiste la préférence via ?lang=. #}
                {{ include('admin/entreprise/_topbar_lang.html.twig') }}
            </div>
        </div>
    </header>

    <div class="ent-scroll">
    <div class="ent-content">

        {# Messages flash (succès/suppression/PDF…) relayés en toast applicatif #}
        {{ include('components/_flash_toasts.html.twig') }}

        {# Solde de tokens en temps réel + accès recharge / détails (à côté de la
           liste des entreprises, comme demandé). #}
        {{ include('admin/token/_balance_widget.html.twig', { balance: tokenBalance }) }}

        {# En-tête de section (l'action primaire est dans la barre de titre) #}
        <div class="ent-head">
            <h1>{{ pageName }}</h1>
            <p>{{ "entreprise_description" | trans }}</p>
        </div>

        {% if entreprises.getTotalItemCount > 0 %}
            <div class="ent-grid">
                {% for entreprise in entreprises %}
                    {# Invité reliant l'utilisateur courant à CETTE entreprise (validateWorkspaceAccess exige
                       que l'invité appartienne à l'entreprise — l'invité global ne convient que pour une seule). #}
                    {% set userInvite = invite %}
                    {% for inv in entreprise.invites %}
                        {% if inv.utilisateur and inv.utilisateur.id == utilisateur.id %}{% set userInvite = inv %}{% endif %}
                    {% endfor %}
                    {% set dashboardUrl = path('app_espace_de_travail_component.index', {'idInvite': userInvite.id, 'idEntreprise': entreprise.id}) %}
                    <article class="ent-card" data-ec-nom="{{ entreprise.nom }}">
                        <a href="{{ dashboardUrl }}" class="ent-card-media"
                           data-action="click->top-progress#show"
                           aria-label="{{ 'entreprise_open_dashboard'|trans({':company': entreprise.nom}) }}">
                            <img class="ent-card-img"
                                 src="{{ entreprise.thumbnail ? vich_uploader_asset(entreprise, 'thumbnailFile') : '/images/entreprises/default_entreprise.jpg' }}"
                                 alt="{{ 'entreprise_logo_alt'|trans({':company': entreprise.nom}) }}">
                        </a>

                        <div class="ent-card-body">
                            <h2 class="ent-card-title">
                                <a href="{{ dashboardUrl }}" data-action="click->top-progress#show">{{ entreprise.nom }}</a>
                            </h2>
                            <p class="ent-card-address">
                                {{ ux_icon('mdi:address-marker-outline', {height: '16px', width: '16px'}) }}
                                {% set ville = nom_ville(entreprise.ville) %}
                                {% set pays = nom_pays(entreprise.pays) %}
                                {{ [entreprise.adresse, ville, pays]|filter(v => v)|join(', ') }}
                            </p>

                            <ul class="ent-info">
                                <li>
                                    <span class="ent-info-label">
                                        {{ ux_icon('ic:outline-phone', {height: '16px', width: '16px'}) }}
                                        {{ "entreprise_list_item_phone" | trans }}
                                    </span>
                                    <strong>{{ entreprise.telephone }}</strong>
                                </li>
                                <li>
                                    <span class="ent-info-label">
                                        {{ ux_icon('clarity:license-outline-badged', {height: '16px', width: '16px'}) }}
                                        {{ "entreprise_list_item_license_number" | trans }}
                                    </span>
                                    <strong>{{ entreprise.licence }}</strong>
                                </li>
                                <li>
                                    <span class="ent-info-label">
                                        {{ ux_icon('ic:outline-groups', {height: '16px', width: '16px'}) }}
                                        {{ "entreprise_list_item_collaborators" | trans }}
                                    </span>
                                    <strong>{{ entreprise.invites|length }}</strong>
                                </li>
                                <li>
                                    <span class="ent-info-label">
                                        {{ ux_icon('ic:twotone-date-range', {height: '16px', width: '16px'}) }}
                                        {{ "entreprise_list_item_createdat" | trans }}
                                    </span>
                                    <strong>{{ entreprise.createdAt | format_datetime("medium", "short", locale: app.user.locale) }}</strong>
                                </li>
                            </ul>
                        </div>

                        <div class="ent-card-foot">
                            {% if entreprise.utilisateur == utilisateur %}
                                {# Statut de propriété : l'utilisateur courant a créé cette entreprise.
                                   Survol/focus → infobulle sombre qui suit la souris (pattern du tableau de bord). #}
                                <div class="ent-owner-status ent-owner-status--owner" tabindex="0"
                                     role="note" aria-label="{{ 'entreprise_owner_aria' | trans }}"
                                     data-controller="owner-tip"
                                     data-owner-tip-title-value="{{ 'entreprise_owner_tip_title' | trans }}"
                                     data-owner-tip-body-value="{{ 'entreprise_owner_tip_body' | trans }}">
                                    {{ ux_icon(resolve_icon_name('action:role'), {height: '18px', width: '18px', class: 'ent-owner-icon'}) }}
                                    <span class="ent-owner-text">{{ 'entreprise_owner_label' | trans }}</span>
                                </div>
                                {# Actions conservées mais masquées : pilotées par le menu contextuel (clic droit).
                                   Le contrôleur entreprise-context-menu délègue à ces éléments. #}
                                <div class="ent-actions" style="display:none">
                                    <a class="ent-icon-btn" href="{{ path('admin.entreprise.edit', {'id': entreprise.id}) }}"
                                       data-action="click->top-progress#show"
                                       title="{{ 'commom_edit' | trans }}" aria-label="{{ 'entreprise_action_edit_aria'|trans({':company': entreprise.nom}) }}">
                                        {{ ux_icon('tabler:edit', {height: '20px', width: '20px'}) }}
                                    </a>
                                    <form action="{{ path('admin.entreprise.remove', {'id': entreprise.id}) }}" method="post"
                                          data-controller="confirm-action"
                                          data-action="submit->confirm-action#request"
                                          data-confirm-action-title-value="{{ 'entreprise_delete_confirm_title' | trans }}"
                                          data-confirm-action-body-value="{{ 'entreprise_delete_confirm_body'|trans({':company': entreprise.nom}) }}"
                                          data-confirm-action-irreversible-value="true"
                                          data-confirm-action-require-password-value="true">
                                        <input type="hidden" name="_method" value="DELETE">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-entreprise-' ~ entreprise.id) }}">
                                        <button type="submit" class="ent-icon-btn is-danger"
                                                title="{{ 'commom_delete' | trans }}" aria-label="{{ 'entreprise_action_delete_aria'|trans({':company': entreprise.nom}) }}">
                                            {{ ux_icon('fluent:delete-20-filled', {height: '20px', width: '20px'}) }}
                                        </button>
                                    </form>
                                </div>
                            {% else %}
                                {# Statut de propriété : l'utilisateur courant a été invité sur cette entreprise. #}
                                <div class="ent-owner-status ent-owner-status--guest" tabindex="0"
                                     role="note" aria-label="{{ 'entreprise_guest_aria'|trans({':owner': entreprise.utilisateur.nom}) }}"
                                     data-controller="owner-tip"
                                     data-owner-tip-title-value="{{ 'entreprise_guest_tip_title' | trans }}"
                                     data-owner-tip-body-value="{{ 'entreprise_guest_tip_body'|trans({':owner': entreprise.utilisateur.nom}) }}">
                                    {{ ux_icon(resolve_icon_name('partenaire'), {height: '18px', width: '18px', class: 'ent-owner-icon'}) }}
                                    <span class="ent-owner-text">{{ 'entreprise_guest_label' | trans }}</span>
                                </div>
                            {% endif %}
                        </div>
                    </article>
                {% endfor %}
            </div>

            <div class="ent-pagination">
                {{ knp_pagination_render(entreprises) }}
            </div>

        {% else %}
            {# État vide : un nouvel utilisateur n'est plus bloqué devant une page blanche #}
            <div class="ent-empty">
                {{ ux_icon('hugeicons:building-02', {height: '48px', width: '48px'}) }}
                <h2>{{ "entreprise_empty_title" | trans }}</h2>
                <p>{{ "entreprise_empty_help" | trans }}</p>
                <a href="{{ path('admin.entreprise.create') }}" class="btn btn-cobalt"
                   data-action="click->top-progress#show">
                    {{ ux_icon('gridicons:add', {height: '18px', width: '18px'}) }}
                    <span class="ms-1">{{ "boutons_user_new_company" | trans }}</span>
                </a>
            </div>
        {% endif %}

    </div>

    {# Pied de page public officiel JS Brokers (à l'intérieur de la zone défilante :
       la page est en hauteur fixe à scroll interne). La bascule de langue y est
       fonctionnelle via ?lang= ; lang = préférence de l'utilisateur connecté. #}
    {% include 'components/_public_footer.html.twig' with { lang: app.user.locale } %}
    </div>{# /.ent-scroll #}

    {# ── MENU CONTEXTUEL DES CARTES D'ENTREPRISE (design dark identique au workspace) ── #}
    {# Le contrôleur entreprise-context-menu n'ouvre ce menu que sur une carte actionnable
       (entreprise possédée) et délègue aux éléments existants de la carte :
       Éditer → lien d'édition, Supprimer → soumission du formulaire (confirm-action). #}
    <nav class="context-menu"
         data-entreprise-context-menu-target="menu"
         style="display:none;"
         tabindex="-1"
         aria-label="{{ 'entreprise_menu_aria' | trans }}"
         onmousedown="event.stopPropagation()">
        <ul role="menu" class="list-unstyled mb-0">
            <li role="menuitem" tabindex="-1" data-menu-key="workspace"
                data-action="click->entreprise-context-menu#onItemClick">
                <span class="context-menu-icon" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:open') }}" style="width:16px;height:16px;" />
                </span>
                <span class="flex-grow-1">{{ 'entreprise_menu_open_workspace' | trans }}</span>
            </li>
            <li role="menuitem" tabindex="-1" data-menu-key="edit"
                data-action="click->entreprise-context-menu#onItemClick">
                <span class="context-menu-icon" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:edit') }}" style="width:16px;height:16px;" />
                </span>
                <span class="flex-grow-1" data-entreprise-context-menu-target="editLabel">{{ 'commom_edit' | trans }}</span>
            </li>
            <li role="separator" class="separator" data-menu-key="sep"></li>
            <li role="menuitem" tabindex="-1" data-menu-key="delete" class="is-danger"
                data-action="click->entreprise-context-menu#onItemClick">
                <span class="context-menu-icon" aria-hidden="true">
                    <twig:UX:Icon name="{{ resolve_icon_name('action:delete') }}" style="width:16px;height:16px;" />
                </span>
                <span class="flex-grow-1" data-entreprise-context-menu-target="deleteLabel">{{ 'commom_delete' | trans }}</span>
            </li>
        </ul>
    </nav>
</main>
{% endblock %}
