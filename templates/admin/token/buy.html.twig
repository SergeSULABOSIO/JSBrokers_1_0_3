{% extends 'base.html.twig' %}

{% block title %}{{ pageName }} — JS Brokers{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Page en pleine hauteur : la barre de titre reste fixe en haut,
       seul le contenu situé en dessous défile (zone .tkb-scroll). */
    .tkb-page {
        height: 100vh; background-color: #f3f3f3;
        display: flex; flex-direction: column; overflow: hidden;
    }
    .tkb-topbar {
        flex: 0 0 auto; /* barre de titre figée : ne défile pas avec le contenu */
        display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; flex-wrap: wrap; padding: .75rem 1.5rem;
        background-color: #fff; border-bottom: 1px solid #dee2e6;
    }
    /* Zone défilante : occupe la hauteur restante sous la barre de titre.
       min-height:0 indispensable pour qu'un enfant flex puisse défiler. */
    .tkb-scroll { flex: 1 1 auto; min-height: 0; overflow-y: auto; }
    .tkb-brand { display: flex; align-items: center; gap: .6rem; text-decoration: none; }
    .tkb-brand img { width: 36px; height: 36px; border-radius: 8px; }
    .tkb-brand span { font-weight: 700; color: #0047AB; font-size: 1.1rem; }
    .tkb-content { max-width: 680px; margin: 0 auto; padding: 1.5rem; }
    .tkb-back { display:inline-flex; align-items:center; gap:.35rem; font-size:.9rem; color:#6c757d; text-decoration:none; margin-bottom:1rem; }
    .tkb-back:hover { color:#0047AB; }
    .tkb-head { margin-bottom: 1.25rem; }
    /* Titre + icône d'illustration alignés sur une même ligne. */
    .tkb-head-title { display: flex; align-items: center; gap: .7rem; margin-bottom: .25rem; }
    .tkb-head h1 { font-size: 1.5rem; font-weight: 700; color: #212529; margin: 0; }
    .tkb-head p { color: #6c757d; margin: 0; }
    /* Pastille cobalt (même langage visuel que .cs-pack-icon en Console). */
    .tkb-head-icon {
        flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center;
        width: 46px; height: 46px; border-radius: 11px;
        background: #e8f0fb; color: #0047AB;
    }
    .tkb-head-icon svg { width: 26px; height: 26px; }
    .tkb-card { background:#fff; border:1px solid #dee2e6; border-radius:12px; padding:1.5rem 1.75rem;
        box-shadow:0 4px 16px rgba(0,71,171,.06); }
    /* Illustration en cercle en haut de la carte — même modèle que .cs-thumb en
       Console : le cercle est l'illustration principale de la carte, la pastille
       du titre (.tkb-head-icon) rappelle l'icône au niveau de l'entête. */
    .tkb-thumb { display:flex; justify-content:center; margin-bottom:1.5rem; }
    .tkb-thumb-placeholder {
        display:flex; align-items:center; justify-content:center;
        width:150px; height:150px; border-radius:50%;
        border:1px solid #dee2e6; background:#f8f9fa; transition:box-shadow .2s ease;
    }
    .tkb-thumb-placeholder:hover { box-shadow:0 4px 16px rgba(0,71,171,.12); }
    .tkb-thumb-placeholder svg { width:64px; height:64px; color:#0047AB; }
    .tkb-sim-note { background:#fff3cd; border-left:3px solid #ffc107; border-radius:6px;
        padding:.7rem .9rem; font-size:.85rem; color:#664d03; margin-bottom:1.25rem; display:flex; gap:.5rem; align-items:flex-start; }
    .tkb-packs { display:grid; grid-template-columns:1fr; gap:.6rem; margin-bottom:1.25rem; }
    /* ── Groupe de champs : panneau STRICTEMENT identique à l'éditeur de tarif
       en Console (.cs-fieldset / .cs-legend). Panneau gris clair, légende cobalt
       en capitales, champs blancs incrustés d'une icône grise. ── */
    /* Rythme vertical délibéré (principe de proximité / Gestalt) : la gouttière
       INTER-groupes (1.5rem) domine nettement la gouttière INTER-champs (1.1rem),
       pour que chaque panneau se lise comme un bloc distinct. Padding interne
       uniforme : le panneau « respire » autant en haut qu'en bas. */
    .cs-fieldset { border:1px solid #dee2e6; border-radius:10px; background:#f8f9fa;
        padding:1.35rem; margin:0 0 1.5rem; }
    .cs-legend { display:inline-flex; align-items:center; gap:.45rem;
        font-size:.78rem; text-transform:uppercase; letter-spacing:.04em; font-weight:700;
        color:#0047AB; margin:0 0 1.15rem; padding:0; width:auto; float:none; }
    /* Gouttière inter-champs régulière ; le dernier champ d'un groupe se cale sur
       le padding bas du panneau (pas de double gouttière). */
    .tkb-card .cs-fieldset .mb-3 { margin-bottom:1.1rem; }
    .tkb-card .cs-fieldset > .mb-3:last-child,
    .tkb-card .cs-fieldset > .row:last-child .mb-3 { margin-bottom:0; }

    /* Libellés + champs : mêmes mesures que la carte de formulaire Console
       (.cs-form-card), les champs blancs ressortant sur le panneau gris. */
    .tkb-card .form-label { font-weight:600; color:#343a40; margin-bottom:.35rem; }
    .tkb-card .form-control,
    .tkb-card .form-select { height:48px; font-size:1rem; color:#000; background:#fff; }
    .tkb-card textarea.form-control { height:auto; }
    .tkb-card .form-control:focus,
    .tkb-card .form-select:focus { border-color:#0047AB; box-shadow:0 0 0 .25rem rgba(0,71,171,.35); }

    /* Champ à icône incrustée — pattern unique de la Console (.cs-field) :
       un seul champ continu, l'icône grise à gauche À L'INTÉRIEUR (jamais de
       boîte séparée). Rendu par le thème console/_form_theme via `data-icon`. */
    .cs-field { position:relative; }
    .cs-field-icon { position:absolute; left:.9rem; top:50%; transform:translateY(-50%);
        width:18px; height:18px; color:#6c757d; pointer-events:none; z-index:4;
        display:inline-flex; align-items:center; justify-content:center; }
    .cs-field .form-control,
    .cs-field .form-select { padding-left:2.6rem; }
    .cs-field .form-control:focus,
    .cs-field .form-select:focus { border-color:#0047AB; box-shadow:0 0 0 .2rem rgba(0,71,171,.25); }

    /* ── Choix de paquet : cartes radio sélectionnables (même esprit que les
       cartes .cs-pack de l'éditeur en Console). Toute la carte est cliquable,
       le pastillage radio est cobalt, et l'état sélectionné ressort nettement
       (bordure + fond cobalt clair). ── */
    .tkb-pack-choices { display:flex; flex-direction:column; gap:.6rem; }
    .tkb-pack-choices .form-check {
        position:relative; display:flex; align-items:center; gap:.8rem;
        margin:0; padding:.9rem 1.05rem;
        border:1px solid #dee2e6; border-radius:10px; background:#fff; cursor:pointer;
        transition:border-color .15s ease, box-shadow .15s ease, background-color .15s ease;
    }
    .tkb-pack-choices .form-check:hover {
        border-color:#0047AB; box-shadow:0 4px 14px rgba(0,71,171,.08);
    }
    /* Pastille radio cobalt, légèrement agrandie pour une cible nette. */
    .tkb-pack-choices .form-check-input {
        flex:0 0 auto; width:1.2rem; height:1.2rem; margin:0;
        border-color:#ced4da; cursor:pointer;
    }
    .tkb-pack-choices .form-check-input:checked { background-color:#0047AB; border-color:#0047AB; }
    .tkb-pack-choices .form-check-input:focus {
        border-color:#0047AB; box-shadow:0 0 0 .25rem rgba(0,71,171,.25);
    }
    .tkb-pack-choices .form-check-label {
        flex:1 1 auto; cursor:pointer; font-weight:600; color:#343a40; line-height:1.3;
    }
    /* Toute la surface de la carte est cliquable (recouvre l'étiquette). */
    .tkb-pack-choices .form-check-label::after { content:""; position:absolute; inset:0; }
    /* État sélectionné : carte mise en avant en cobalt clair (`:has` = sans JS). */
    .tkb-pack-choices .form-check:has(.form-check-input:checked) {
        border-color:#0047AB; background:#e8f0fb; box-shadow:0 4px 16px rgba(0,71,171,.12);
    }

    /* Bouton de paiement : couleur + survol = pattern canonique .btn-cobalt
       (cobalt → #003380 au survol, halo cobalt au focus, cf. app.css). */
    .tkb-pay { font-weight:600; }

    /* ── Barre d'actions épinglée en bas de la carte — même pattern que l'éditeur
       de tarif en Console (.cs-form-actions) : reste visible quel que soit le
       scroll (position:sticky), lien de retour ancré à gauche, action principale
       à droite. Les marges négatives neutralisent le padding de la carte pour
       coller la barre à ses bords (rayon bas aligné sur .tkb-card = 12px). ── */
    .tkb-form-actions {
        position:sticky; bottom:0; z-index:5;
        display:flex; align-items:center; gap:.75rem;
        margin:1.5rem -1.75rem -1.5rem;
        padding:1rem 1.75rem;
        background:#fff; border-top:1px solid #dee2e6;
        border-bottom-left-radius:12px; border-bottom-right-radius:12px;
        box-shadow:0 -4px 12px rgba(0,71,171,.06);
    }
    .tkb-form-actions .btn { height:46px; display:inline-flex; align-items:center; }
    /* Lien de retour ancré à gauche (même cible que .tkb-back en haut du formulaire). */
    .tkb-actions-back {
        display:inline-flex; align-items:center; gap:.35rem;
        font-size:.9rem; color:#6c757d; text-decoration:none; white-space:nowrap;
        transition:color .15s ease;
    }
    .tkb-actions-back:hover { color:#0047AB; }
    /* margin-left:auto pousse le séparateur + le bouton vers la droite. */
    .tkb-actions-sep { flex:0 0 auto; width:1px; height:28px; background:#dee2e6; margin-left:auto; }

    @media (max-width: 575.98px) {
        .tkb-form-actions { flex-direction:column-reverse; align-items:stretch; }
        .tkb-form-actions .btn { width:100%; }
        .tkb-actions-sep { display:none; }
        .tkb-actions-back { width:100%; justify-content:center; }
    }

    /* ── Code promo : champ unique (remise calculée en direct) + message d'erreur. ── */
    .tkb-coupon-error { color:#dc3545; font-size:.82rem; margin:.55rem 0 0; }

    .tkb-recap { background:#f8f9fa; border:1px solid #dee2e6; border-radius:10px;
        padding:.85rem 1.1rem; margin-bottom:1.25rem; }
    .tkb-recap-line { display:flex; justify-content:space-between; align-items:center;
        font-size:.92rem; color:#495057; padding:.2rem 0; }
    .tkb-recap-line--remise { color:#0f5132; font-weight:600; }
    .tkb-recap-line--total { border-top:1px solid #dee2e6; margin-top:.35rem; padding-top:.6rem;
        font-size:1.05rem; font-weight:800; color:#212529; }

    /* Barre de titre : actions à droite (bascule de langue + aide). */
    .tkb-actions { display:inline-flex; align-items:center; gap:.75rem; }

    /* ---------- Pied de page public officiel JS Brokers ---------- */
    .public-footer { background-color:#fff; border-top:1px solid #dee2e6; margin-top:1rem; }
    .public-footer__inner { max-width:1140px; margin:0 auto; padding:2.5rem 1.5rem 1.5rem; display:flex; flex-wrap:wrap; align-items:flex-start; gap:1.5rem; }
    .public-footer__brand { display:flex; align-items:center; gap:.75rem; flex:1 1 280px; text-decoration:none; }
    .public-footer__brand:hover { opacity:.85; }
    .public-footer__brand img { border-radius:8px; }
    .public-footer__name { font-weight:700; color:#0047AB; margin:0; font-size:1.05rem; }
    .public-footer__tagline { color:#6c757d; margin:0; font-size:.9rem; max-width:360px; }
    .public-footer__links { display:flex; flex-wrap:wrap; gap:.25rem 1.25rem; }
    .public-footer__links a { display:inline-flex; align-items:center; min-height:44px; color:#495057; text-decoration:none; font-size:.92rem; font-weight:600; }
    .public-footer__links a:hover { color:#0047AB; }
    .public-footer__links a:focus-visible { outline:2px solid #0047AB; outline-offset:2px; border-radius:4px; }
    .public-footer__credit { max-width:1140px; margin:0 auto; padding:1rem 1.5rem; border-top:1px solid #dee2e6; text-align:center; color:#6c757d; font-size:.85rem; }
</style>
{% endblock %}

{% block body %}
<main class="tkb-page" data-controller="top-progress">
    {# Barre de progression globale, déclenchée au clic sur la bascule de langue
       (barre de titre + pied de page) et les autres liens de navigation serveur. #}
    <div class="ent-progress-bar" data-top-progress-target="bar" role="progressbar"
         aria-label="Chargement en cours" aria-hidden="true"
         style="position:fixed;top:0;left:0;width:100%;height:6px;background:#0047AB;display:none;z-index:9999;"></div>

    <header class="tkb-topbar">
        <a href="{{ path('app_index') }}" class="tkb-brand" data-action="click->top-progress#show" aria-label="JS Brokers — accueil">
            <img src="{{ asset('images/entreprises/logofav.png') }}" alt="">
            <span>JS Brokers</span>
        </a>
        <div class="tkb-actions">
            {# Bascule de langue unifiée : ?lang= persiste la préférence (cf. TokenController::buy). #}
            {{ include('components/_lang_switch.html.twig', {route: 'admin.token.buy', params: app.request.query.all, uid: 'lang-tkb'}) }}
            <a href="{{ path('app_tokens_info') }}" target="_blank" rel="noopener"
               class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1"
               aria-label="{{ 'token_how_it_works'|trans }} ({{ 'token_new_tab'|trans }})">
                {{ ux_icon('mdi:help-circle-outline', {height: '16px', width: '16px'}) }}
                <span>{{ "token_how_it_works" | trans }}</span>
            </a>
        </div>
    </header>

    <div class="tkb-scroll">
    <div class="tkb-content">
        <a href="{{ path('admin.token.index') }}" class="tkb-back" data-action="click->top-progress#show">
            {{ ux_icon('mdi:arrow-left', {height: '16px', width: '16px'}) }}
            {{ "token_back_to_account" | trans }}
        </a>

        {{ include('components/_flash_toasts.html.twig') }}

        <div class="tkb-head">
            <div class="tkb-head-title">
                {# Icône d'illustration du titre : pastille cobalt (même esprit que
                   .cs-pack-icon en Console) ; `action:cart` rappelle l'achat de tokens. #}
                <span class="tkb-head-icon" aria-hidden="true">
                    {{ ux_icon(resolve_icon_name('action:cart'), {height: '26px', width: '26px'}) }}
                </span>
                <h1>{{ "token_buy.title" | trans }}</h1>
            </div>
            <p>{{ "token_buy.subtitle" | trans }}</p>
        </div>

        <div class="tkb-card">
            {# Illustration en cercle, centrée en haut de la carte (même modèle que la
               Console) ; reprend l'icône `action:cart` du parcours d'achat de tokens. #}
            <div class="tkb-thumb">
                <div class="tkb-thumb-placeholder" aria-hidden="true">
                    {{ ux_icon(resolve_icon_name('action:cart'), {height:'64px', width:'64px'}) }}
                </div>
            </div>

            <div class="tkb-sim-note">
                {{ ux_icon('mdi:flask-outline', {height: '18px', width: '18px'}) }}
                <span>{{ "token_buy.sim_note" | trans }}</span>
            </div>

            {# Thème de champ partagé avec la Console : incruste l'icône (alias `data-icon`
               défini dans TokenPurchaseType) à l'intérieur du champ — pattern .cs-field. #}
            {% form_theme form 'console/_form_theme.html.twig' %}

            {{ form_start(form, {'attr': {
                'data-controller': 'form-submit coupon-preview',
                'data-action': 'submit->form-submit#submitting submit->top-progress#show',
                'data-form-submit-loading-text-value': 'token_buy.processing'|trans,
                'data-coupon-preview-url-value': path('admin.token.coupon_preview'),
                'novalidate': 'novalidate'
            }}) }}

                <fieldset class="cs-fieldset">
                    <legend class="cs-legend">
                        {{ ux_icon(resolve_icon_name('action:cart'), {height: '16px', width: '16px'}) }}
                        {{ "token_buy.choose_pack" | trans }}
                    </legend>
                    {# `change` remonte des radios vers ce conteneur → rafraîchit l'aperçu. #}
                    <div class="tkb-pack-choices" data-action="change->coupon-preview#refresh">
                        {{ form_widget(form.pack) }}
                    </div>
                    {{ form_errors(form.pack) }}
                </fieldset>

                <fieldset class="cs-fieldset">
                    <legend class="cs-legend">
                        {{ ux_icon(resolve_icon_name('compte-bancaire'), {height: '16px', width: '16px'}) }}
                        {{ "token_buy.card_section" | trans }}
                    </legend>

                    {# Champs rendus par form_row : libellé + champ à icône incrustée
                       (via le thème console + `data-icon`), exactement comme en Console. #}
                    {{ form_row(form.cardHolder) }}
                    {{ form_row(form.cardNumber) }}

                    <div class="row">
                        <div class="col-md">{{ form_row(form.expiry) }}</div>
                        <div class="col-md">{{ form_row(form.cvc) }}</div>
                    </div>
                </fieldset>

                <fieldset class="cs-fieldset">
                    <legend class="cs-legend">
                        {{ ux_icon(resolve_icon_name('offre'), {height: '16px', width: '16px'}) }}
                        {{ "token_buy.coupon_section" | trans }}
                    </legend>
                    {# Un seul champ : la légende sert de titre visuel ; le libellé reste
                       présent pour les lecteurs d'écran (WCAG 3.3.2 / 4.1.2). Aucun bouton
                       « Appliquer » : la remise s'affiche en direct dans le récapitulatif à
                       mesure de la saisie (logique du contrôleur coupon-preview inchangée). #}
                    <label for="{{ form.couponCode.vars.id }}" class="visually-hidden">{{ form.couponCode.vars.label|trans }}</label>
                    {# data-icon (défini dans le FormType) → icône incrustée par le thème. #}
                    {{ form_widget(form.couponCode, {attr: {
                        class: 'form-control',
                        style: 'text-transform:uppercase;',
                        'data-coupon-preview-target': 'code',
                        'data-action': 'input->coupon-preview#refresh',
                    }}) }}
                    {{ form_errors(form.couponCode) }}
                    <p class="tkb-coupon-error" data-coupon-preview-target="error" hidden role="alert"></p>
                </fieldset>

                {# Récapitulatif du prix, recalculé en direct par le contrôleur coupon-preview. #}
                <div class="tkb-recap" data-coupon-preview-target="recap" hidden>
                    <div class="tkb-recap-line">
                        <span>{{ "token_buy.recap_base" | trans }}</span>
                        <span data-coupon-preview-target="base">—</span>
                    </div>
                    <div class="tkb-recap-line tkb-recap-line--remise" data-coupon-preview-target="remiseRow" hidden>
                        <span>{{ "token_buy.recap_remise" | trans }}</span>
                        <span data-coupon-preview-target="remise">—</span>
                    </div>
                    <div class="tkb-recap-line tkb-recap-line--total">
                        <span>{{ "token_buy.recap_total" | trans }}</span>
                        <span data-coupon-preview-target="final">—</span>
                    </div>
                </div>

                {{ form_rest(form) }}

                {# Barre d'actions épinglée : lien de retour (gauche) + paiement (droite),
                   structure et comportement identiques à .cs-form-actions en Console.
                   Reste dans le <form> pour ne pas affecter la soumission / le jeton CSRF. #}
                <div class="tkb-form-actions">
                    <a href="{{ path('admin.token.index') }}" class="tkb-actions-back"
                       data-action="click->top-progress#show">
                        {{ ux_icon('hugeicons:arrow-left-01', {height:'18px', width:'18px'}) }}
                        <span>{{ "token_back_to_account" | trans }}</span>
                    </a>

                    <span class="tkb-actions-sep" aria-hidden="true"></span>

                    <button type="submit" class="btn btn-cobalt tkb-pay d-inline-flex align-items-center justify-content-center gap-2"
                            data-form-submit-target="button">
                        {{ ux_icon(resolve_icon_name('action:cart'), {height: '18px', width: '18px'}) }}
                        <span>{{ "token_buy.pay" | trans }}</span>
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>

    {# Pied de page officiel JS Brokers (la bascule de langue y est fonctionnelle via ?lang=). #}
    {% include 'components/_public_footer.html.twig' with { lang: app.user.locale } %}
    </div>{# /.tkb-scroll #}
</main>
{% endblock %}
