{% extends 'base.html.twig' %}

{% block title %}{{ pageName }} — JS Brokers{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Page en pleine hauteur : la barre de titre reste fixe en haut,
       seul le contenu situé en dessous défile (zone .tkb-scroll). */
    .tkb-page {
        height: 100vh; background-color: #f3f3f3;
        display: flex; flex-direction: column; overflow: hidden;
    }
    .tkb-topbar {
        flex: 0 0 auto; /* barre de titre figée : ne défile pas avec le contenu */
        display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; flex-wrap: wrap; padding: .75rem 1.5rem;
        background-color: #fff; border-bottom: 1px solid #dee2e6;
    }
    /* Zone défilante : occupe la hauteur restante sous la barre de titre.
       min-height:0 indispensable pour qu'un enfant flex puisse défiler. */
    .tkb-scroll { flex: 1 1 auto; min-height: 0; overflow-y: auto; }
    .tkb-brand { display: flex; align-items: center; gap: .6rem; text-decoration: none; }
    .tkb-brand img { width: 36px; height: 36px; border-radius: 8px; }
    .tkb-brand span { font-weight: 700; color: #0047AB; font-size: 1.1rem; }
    .tkb-content { max-width: 680px; margin: 0 auto; padding: 1.5rem; }
    .tkb-back { display:inline-flex; align-items:center; gap:.35rem; font-size:.9rem; color:#6c757d; text-decoration:none; margin-bottom:1rem; }
    .tkb-back:hover { color:#0047AB; }
    .tkb-head { margin-bottom: 1.25rem; }
    .tkb-head h1 { font-size: 1.5rem; font-weight: 700; color: #212529; margin: 0 0 .25rem; }
    .tkb-head p { color: #6c757d; margin: 0; }
    .tkb-card { background:#fff; border:1px solid #dee2e6; border-radius:12px; padding:1.5rem 1.75rem;
        box-shadow:0 4px 16px rgba(0,71,171,.06); }
    .tkb-sim-note { background:#fff3cd; border-left:3px solid #ffc107; border-radius:6px;
        padding:.7rem .9rem; font-size:.85rem; color:#664d03; margin-bottom:1.25rem; display:flex; gap:.5rem; align-items:flex-start; }
    .tkb-packs { display:grid; grid-template-columns:1fr; gap:.6rem; margin-bottom:1.25rem; }
    .tkb-fieldset { border:0; padding:0; margin:0 0 1rem; }
    .tkb-legend { font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:.03em; color:#0047AB;
        display:flex; align-items:center; gap:.4rem; margin-bottom:.6rem; }
    .tkb-field { margin-bottom:.85rem; }
    .tkb-field label { display:block; font-size:.85rem; font-weight:600; color:#495057; margin-bottom:.25rem; }
    .tkb-field input { width:100%; padding:.55rem .7rem; border:1px solid #ced4da; border-radius:8px; font-size:.95rem; }
    .tkb-field input:focus { outline:none; border-color:#0047AB; box-shadow:0 0 0 3px rgba(0,71,171,.35); }
    .tkb-row { display:flex; gap:.85rem; }
    .tkb-row .tkb-field { flex:1; }
    .tkb-pack-choices { display:flex; flex-direction:column; gap:.5rem; }
    .tkb-pack-choices .form-check { padding:.6rem .85rem; border:1px solid #dee2e6; border-radius:8px; margin:0; }
    .tkb-submit { width:100%; background:#0047AB; border-color:#0047AB; color:#fff; font-weight:600; padding:.7rem; }
    .tkb-submit:hover { background:#003380; border-color:#003380; }
    .tkb-error { color:#dc3545; font-size:.82rem; margin-top:.2rem; }

    /* ── Champs « carte » : pattern identique au formulaire de connexion ──
       label au-dessus, icône en préfixe, champ haut de 48px, focus cobalt. */
    .tkb-card .form-label { font-weight:600; color:#343a40; margin-bottom:.35rem; }
    .tkb-ifield { position:relative; margin-bottom:1rem; }
    .tkb-ifield-icon {
        position:absolute; top:50%; left:.85rem; transform:translateY(-50%);
        width:20px; height:20px; color:#6c757d; pointer-events:none;
    }
    .tkb-ifield .form-control { height:48px; padding-left:2.6rem; color:#000; }
    .tkb-ifield .form-control:focus {
        border-color:#0047AB; box-shadow:0 0 0 .25rem rgba(0,71,171,.35);
    }
    .tkb-cardrow { display:flex; gap:.85rem; }
    .tkb-cardrow > div { flex:1; }

    /* Barre de titre : actions à droite (bascule de langue + aide). */
    .tkb-actions { display:inline-flex; align-items:center; gap:.75rem; }
    /* Bascule de langue : drapeaux SVG (FR / Royaume-Uni). */
    .tkb-lang { display:inline-flex; gap:.25rem; padding:.25rem; border:1px solid #dee2e6; border-radius:10px; background-color:#fff; }
    .tkb-lang a { display:inline-flex; align-items:center; justify-content:center; min-width:44px; min-height:36px; padding:0 .55rem; border-radius:7px; text-decoration:none; background-color:transparent; transition:background-color .15s ease; }
    .tkb-lang .public-lang__flag { width:26px; height:18px; display:block; border-radius:3px; box-shadow:0 0 0 1px rgba(0,0,0,.08); opacity:.5; filter:grayscale(.4); transition:opacity .15s ease, filter .15s ease; }
    .tkb-lang a:hover .public-lang__flag { opacity:.9; filter:none; }
    .tkb-lang a.is-active { background-color:#0047AB; }
    .tkb-lang a.is-active .public-lang__flag { opacity:1; filter:none; box-shadow:0 0 0 1px rgba(255,255,255,.6); }
    .tkb-lang a:focus-visible { outline:2px solid #0047AB; outline-offset:2px; }
    .public-lang__code { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0; }

    /* ---------- Pied de page public officiel JS Brokers ---------- */
    .public-footer { background-color:#fff; border-top:1px solid #dee2e6; margin-top:1rem; }
    .public-footer__inner { max-width:1140px; margin:0 auto; padding:2.5rem 1.5rem 1.5rem; display:flex; flex-wrap:wrap; align-items:flex-start; gap:1.5rem; }
    .public-footer__brand { display:flex; align-items:center; gap:.75rem; flex:1 1 280px; text-decoration:none; }
    .public-footer__brand:hover { opacity:.85; }
    .public-footer__brand img { border-radius:8px; }
    .public-footer__name { font-weight:700; color:#0047AB; margin:0; font-size:1.05rem; }
    .public-footer__tagline { color:#6c757d; margin:0; font-size:.9rem; max-width:360px; }
    .public-footer__links { display:flex; flex-wrap:wrap; gap:.25rem 1.25rem; }
    .public-footer__links a { display:inline-flex; align-items:center; min-height:44px; color:#495057; text-decoration:none; font-size:.92rem; font-weight:600; }
    .public-footer__links a:hover { color:#0047AB; }
    .public-footer__links a:focus-visible { outline:2px solid #0047AB; outline-offset:2px; border-radius:4px; }
    .public-footer__credit { max-width:1140px; margin:0 auto; padding:1rem 1.5rem; border-top:1px solid #dee2e6; text-align:center; color:#6c757d; font-size:.85rem; }

    /* Bascule de langue du pied de page (drapeaux SVG). */
    .public-lang { display:inline-flex; gap:.25rem; padding:.25rem; border:1px solid #dee2e6; border-radius:10px; background-color:#fff; }
    .public-lang a { display:inline-flex; align-items:center; justify-content:center; min-width:44px; min-height:36px; padding:0 .55rem; border-radius:7px; text-decoration:none; background-color:transparent; transition:background-color .15s ease; }
    .public-lang__flag { width:26px; height:18px; display:block; border-radius:3px; box-shadow:0 0 0 1px rgba(0,0,0,.08); opacity:.5; filter:grayscale(.4); transition:opacity .15s ease, filter .15s ease; }
    .public-lang a:hover .public-lang__flag { opacity:.9; filter:none; }
    .public-lang a.is-active { background-color:#0047AB; }
    .public-lang a.is-active .public-lang__flag { opacity:1; filter:none; box-shadow:0 0 0 1px rgba(255,255,255,.6); }
    .public-lang a:focus-visible { outline:2px solid #0047AB; outline-offset:2px; }
</style>
{% endblock %}

{% block body %}
{% import 'components/_lang_flag.html.twig' as flags %}
<main class="tkb-page" data-controller="top-progress">
    {# Barre de progression globale, déclenchée au clic sur la bascule de langue
       (barre de titre + pied de page) et les autres liens de navigation serveur. #}
    <div class="ent-progress-bar" data-top-progress-target="bar" role="progressbar"
         aria-label="Chargement en cours" aria-hidden="true"
         style="position:fixed;top:0;left:0;width:100%;height:6px;background:#0047AB;display:none;z-index:9999;"></div>

    <header class="tkb-topbar">
        <a href="{{ path('app_index') }}" class="tkb-brand" data-action="click->top-progress#show" aria-label="JS Brokers — accueil">
            <img src="{{ asset('images/entreprises/logofav.png') }}" alt="">
            <span>JS Brokers</span>
        </a>
        <div class="tkb-actions">
            {# Bascule de langue : ?lang= persiste la préférence de l'utilisateur (cf. TokenController::buy). #}
            <span class="tkb-lang" role="group" aria-label="Langue / Language">
                <a href="{{ path('admin.token.buy', app.request.query.all|merge({'lang': 'fr'})) }}"
                   class="{{ app.user.locale == 'fr' ? 'is-active' : '' }}" title="Français" lang="fr"
                   data-action="click->top-progress#show"
                   {% if app.user.locale == 'fr' %}aria-current="true"{% endif %}>{{ flags.fr() }}<span class="public-lang__code">FR</span></a>
                <a href="{{ path('admin.token.buy', app.request.query.all|merge({'lang': 'en'})) }}"
                   class="{{ app.user.locale == 'en' ? 'is-active' : '' }}" title="English" lang="en"
                   data-action="click->top-progress#show"
                   {% if app.user.locale == 'en' %}aria-current="true"{% endif %}>{{ flags.uk('lang-tkb-top') }}<span class="public-lang__code">EN</span></a>
            </span>
            <a href="{{ path('app_tokens_info') }}" target="_blank" rel="noopener"
               class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1"
               aria-label="{{ 'token_how_it_works'|trans }} ({{ 'token_new_tab'|trans }})">
                {{ ux_icon('mdi:help-circle-outline', {height: '16px', width: '16px'}) }}
                <span>{{ "token_how_it_works" | trans }}</span>
            </a>
        </div>
    </header>

    <div class="tkb-scroll">
    <div class="tkb-content">
        <a href="{{ path('admin.token.index') }}" class="tkb-back" data-action="click->top-progress#show">
            {{ ux_icon('mdi:arrow-left', {height: '16px', width: '16px'}) }}
            {{ "token_back_to_account" | trans }}
        </a>

        {{ include('components/_flash_toasts.html.twig') }}

        <div class="tkb-head">
            <h1>{{ "token_buy.title" | trans }}</h1>
            <p>{{ "token_buy.subtitle" | trans }}</p>
        </div>

        <div class="tkb-card">
            <div class="tkb-sim-note">
                {{ ux_icon('mdi:flask-outline', {height: '18px', width: '18px'}) }}
                <span>{{ "token_buy.sim_note" | trans }}</span>
            </div>

            {{ form_start(form, {'attr': {
                'data-controller': 'form-submit',
                'data-action': 'submit->form-submit#submitting submit->top-progress#show',
                'data-form-submit-loading-text-value': 'token_buy.processing'|trans,
                'novalidate': 'novalidate'
            }}) }}

                <fieldset class="tkb-fieldset">
                    <legend class="tkb-legend">
                        {{ ux_icon('mdi:package-variant-closed', {height: '16px', width: '16px'}) }}
                        {{ "token_buy.choose_pack" | trans }}
                    </legend>
                    <div class="tkb-pack-choices">
                        {{ form_widget(form.pack) }}
                    </div>
                    {{ form_errors(form.pack) }}
                </fieldset>

                <fieldset class="tkb-fieldset">
                    <legend class="tkb-legend">
                        {{ ux_icon('mdi:credit-card-outline', {height: '16px', width: '16px'}) }}
                        {{ "token_buy.card_section" | trans }}
                    </legend>

                    {# Titulaire de la carte #}
                    <label for="{{ form.cardHolder.vars.id }}" class="form-label">{{ form.cardHolder.vars.label|trans }}</label>
                    <div class="tkb-ifield">
                        {{ ux_icon(resolve_icon_name('utilisateur'), {class: 'tkb-ifield-icon'}) }}
                        {{ form_widget(form.cardHolder, {attr: {class: 'form-control'}}) }}
                    </div>
                    {{ form_errors(form.cardHolder) }}

                    {# Numéro de carte #}
                    <label for="{{ form.cardNumber.vars.id }}" class="form-label">{{ form.cardNumber.vars.label|trans }}</label>
                    <div class="tkb-ifield">
                        {{ ux_icon(resolve_icon_name('compte-bancaire'), {class: 'tkb-ifield-icon'}) }}
                        {{ form_widget(form.cardNumber, {attr: {class: 'form-control'}}) }}
                    </div>
                    {{ form_errors(form.cardNumber) }}

                    <div class="tkb-cardrow">
                        {# Expiration #}
                        <div>
                            <label for="{{ form.expiry.vars.id }}" class="form-label">{{ form.expiry.vars.label|trans }}</label>
                            <div class="tkb-ifield">
                                {{ ux_icon(resolve_icon_name('action:renew'), {class: 'tkb-ifield-icon'}) }}
                                {{ form_widget(form.expiry, {attr: {class: 'form-control'}}) }}
                            </div>
                            {{ form_errors(form.expiry) }}
                        </div>
                        {# CVC (code de sécurité) #}
                        <div>
                            <label for="{{ form.cvc.vars.id }}" class="form-label">{{ form.cvc.vars.label|trans }}</label>
                            <div class="tkb-ifield">
                                {{ ux_icon(resolve_icon_name('action:password'), {class: 'tkb-ifield-icon'}) }}
                                {{ form_widget(form.cvc, {attr: {class: 'form-control'}}) }}
                            </div>
                            {{ form_errors(form.cvc) }}
                        </div>
                    </div>
                </fieldset>

                <fieldset class="tkb-fieldset">
                    <legend class="tkb-legend">
                        {{ ux_icon(resolve_icon_name('offre'), {height: '16px', width: '16px'}) }}
                        {{ "token_buy.coupon_section" | trans }}
                    </legend>
                    <label for="{{ form.couponCode.vars.id }}" class="form-label">{{ form.couponCode.vars.label|trans }}</label>
                    <div class="tkb-ifield">
                        {{ ux_icon(resolve_icon_name('offre'), {class: 'tkb-ifield-icon'}) }}
                        {{ form_widget(form.couponCode, {attr: {class: 'form-control', style: 'text-transform:uppercase;'}}) }}
                    </div>
                    {{ form_errors(form.couponCode) }}
                </fieldset>

                <button type="submit" class="btn tkb-submit d-inline-flex align-items-center justify-content-center gap-2"
                        data-form-submit-target="button">
                    {{ ux_icon(resolve_icon_name('action:cart'), {height: '18px', width: '18px'}) }}
                    <span>{{ "token_buy.pay" | trans }}</span>
                </button>

                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>

    {# Pied de page officiel JS Brokers (la bascule de langue y est fonctionnelle via ?lang=). #}
    {% include 'components/_public_footer.html.twig' with { lang: app.user.locale } %}
    </div>{# /.tkb-scroll #}
</main>
{% endblock %}
