{# templates/admin/bordereau/bordereau_analysis.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analyse : Bordereau {{ bordereau.reference }}</title>
    <link rel="icon" href="{{ asset('images/entreprises/logofav.png') }}" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    {# On importe les assets pour Stimulus et les icônes #}
    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}
    <style>
        body { background-color: #f8f9fa; overflow-y: auto; } /* Permet le défilement vertical */
        .analysis-container { max-width: 900px; margin: 2rem auto; background-color: #fff; border: 1px solid #dee2e6; box-shadow: 0 0.5rem 1rem rgba(0,0,0,.15); }
        .analysis-header { padding: 2rem; border-bottom: 1px solid #dee2e6; }
        .analysis-body { padding: 2rem; }
        .analysis-footer { padding: 2rem; background-color: #f8f9fa; border-top: 1px solid #dee2e6; }
        .actions-bar { padding: 1rem; text-align: center; background-color: #343a40; }
        @media print {
            .actions-bar { display: none !important; }
            .analysis-container { margin: 0; border: none; box-shadow: none; max-width: 100%; }
        }
        .analysis-toolbar-badge-note {
            display: inline-flex;
            align-items: center;
            background: rgba(0, 71, 171, 0.2);
            color: rgba(255,255,255,0.65);
            font-size: 0.72rem;
            padding: 2px 8px;
            border-radius: 12px;
            border: 1px solid rgba(0, 71, 171, 0.35);
            cursor: pointer;
            transition: background 0.15s;
            line-height: 1.4;
        }
        .analysis-toolbar-badge-note:hover {
            background: rgba(0, 71, 171, 0.35);
        }
    </style>
</head>
{% set sheets_data_json = {} %}
{% for sheet in viewData.sheets %}
    {% set sheets_data_json = sheets_data_json|merge({(sheet.sheetName): sheet.data}) %}
{% endfor %}
<body
    data-controller="dialog-manager bordereau-analysis"
    data-bordereau-analysis-sheets-data-value="{{ sheets_data_json|json_encode|e('html_attr') }}"
    data-bordereau-analysis-chargements-value="{{ viewData.chargements|json_encode|e('html_attr') }}"
    data-bordereau-analysis-mapping-options-value="{{ viewData.mapping_options|json_encode|e('html_attr') }}"
    data-bordereau-analysis-type-revenus-value="{{ viewData.typeRevenus|json_encode|e('html_attr') }}"
    data-bordereau-analysis-bordereau-id-value="{{ bordereau.id }}"
    data-bordereau-analysis-id-entreprise-value="{{ invite.entreprise.id }}"
    data-bordereau-analysis-id-invite-value="{{ invite.id }}"
    data-bordereau-analysis-linked-notes-value="{{ linkedNotesData|json_encode|e('html_attr') }}"
    data-bordereau-analysis-note-form-canvas-value="{{ {'parametres': {'titre_creation': ('Facturer — Bordereau ' ~ bordereau.reference), 'endpoint_submit_url': '/admin/note/api/submit', 'endpoint_delete_url': '/admin/note/api/delete', 'endpoint_form_url': '/admin/note/api/get-form', 'isCreationMode': true, 'icone': 'note'}}|json_encode|e('html_attr') }}"
    {# CORRECTION : Ajout des valeurs de restauration pour le contrôleur Stimulus #}
    data-bordereau-analysis-selected-sheet-name-value="{{ selectedSheetName|default('') }}"
    data-bordereau-analysis-mapped-columns-value="{{ mappedColumns|json_encode|e('html_attr') }}"
    data-bordereau-analysis-analysis-results-value="{{ analysisResults|json_encode|e('html_attr') }}" {# Données brutes pour la sauvegarde #}
    data-bordereau-analysis-analysis-results-html-value="{{ analysisResultsHtml|json_encode|e('html_attr') }}" {# HTML pour l'affichage #}
    data-bordereau-analysis-analysis-stats-value="{{ analysisStats|default({})|json_encode|e('html_attr') }}"
    data-bordereau-analysis-system-field-formats-value="{{ viewData.system_field_formats|json_encode|e('html_attr') }}" {# NOUVEAU : Formats des champs système #}
    data-bordereau-analysis-current-analysis-step-value="{{ currentAnalysisStep|default(0) }}"
>

    <div class="actions-bar sticky-top d-flex flex-column">

        {# Barre principale : titre gauche + actions droite #}
        <div class="d-flex align-items-center justify-content-between w-100 px-3 py-2"> {# Main container for toolbar #}

            {# Bloc titre — gauche #}
            <div class="analysis-toolbar-title-block toolbar-title py-1">
                <div class="mt-1">
                    <twig:UX:Icon name="lucide:file-search" width="20px" height="20px" 
                                  class="text-white opacity-75" 
                                  data-bordereau-analysis-target="toolbarTitleIconPrepare" />
                    <twig:UX:Icon name="lucide:file-check" width="20px" height="20px" 
                                  class="text-white opacity-75 d-none" 
                                  data-bordereau-analysis-target="toolbarTitleIconSuccess" />
                </div>
                <div class="d-flex flex-column">
                    <div class="analysis-toolbar-ref">
                        <twig:UX:Icon name="lucide:hash" width="16px" height="16px" class="text-white opacity-70 me-1" />
                        {{ bordereau.reference }}
                    </div>
                    <div class="analysis-toolbar-name">
                        {{ bordereau.nom }}
                    </div>
                    <hr class="dropdown-divider my-1" style="border-color: rgba(255,255,255,0.2);" />
                    <div class="analysis-toolbar-meta">
                        <twig:UX:Icon name="lucide:building-2" width="12px" height="12px" class="me-1" />
                        {{ bordereau.assureur ? bordereau.assureur.nom : 'N/A' }}
                        <span class="mx-1">·</span>
                        <twig:UX:Icon name="lucide:calendar-range" width="12px" height="12px" class="me-1" />
                        {{ bordereau.periodeDebut|date('d/m/Y') }} &rarr; {{ bordereau.periodeFin|date('d/m/Y') }}
                        <span class="mx-1">·</span>
                        <twig:UX:Icon name="lucide:inbox" width="12px" height="12px" class="me-1" />
                        {{ bordereau.receivedAt ? bordereau.receivedAt|date('d/m/Y') : 'N/A' }}
                    </div>
                    <div class="analysis-toolbar-badges mt-1">
                        {% set stepText = '' %}
                        {% if currentAnalysisStep == 0 or currentAnalysisStep == 1 %}
                            {% set stepText = 'Étape 1 · Sélection' %}
                        {% elseif currentAnalysisStep == 2 %}
                            {% set stepText = 'Étape 2 · Mappage' %}
                        {% elseif currentAnalysisStep == 3 %}
                            {% set stepText = 'Étape 3 · Résultats' %}
                        {% else %} {# Assuming currentAnalysisStep is Bordereau::STATUT_ANALYSE_TERMINEE #}
                            {% set stepText = 'Analyse terminée' %}
                        {% endif %}
                        <span class="analysis-toolbar-badge-step me-2"
                              data-bordereau-analysis-target="toolbarBadgeStep">{{ stepText }}</span>

                        {% set statusBgColor = '' %}
                        {% set statusTextColor = '' %}
                        {% set statusText = '' %}

                        {% if currentAnalysisStep == 0 or currentAnalysisStep == 1 %}
                            {% set statusBgColor = 'rgba(108,117,125,0.4)' %}
                            {% set statusTextColor = '#ffffff' %}
                            {% set statusText = 'En attente' %}
                        {% elseif currentAnalysisStep == 2 %}
                            {% set statusBgColor = 'rgba(255,193,7,0.3)' %}
                            {% set statusTextColor = '#ffc107' %}
                            {% set statusText = 'En cours' %}
                        {% elseif currentAnalysisStep == 3 %}
                            {% set statusBgColor = 'rgba(25,135,84,0.3)' %}
                            {% set statusTextColor = '#d1e7dd' %}
                            {% set statusText = 'Analysé' %}
                        {% else %} {# Assuming currentAnalysisStep is Bordereau::STATUT_ANALYSE_TERMINEE #}
                            {% set statusBgColor = 'rgba(0,71,171,0.4)' %}
                            {% set statusTextColor = 'rgba(255,255,255,0.65)' %}
                            {% set statusText = 'Validé' %}
                        {% endif %}
                        <span class="analysis-toolbar-badge-status me-2"
                              data-bordereau-analysis-target="toolbarBadgeStatus"
                              style="background-color: {{ statusBgColor }}; color: {{ statusTextColor }};">{{ statusText }}</span>

                        {# Badge note liée — affiché ici (côté titre) dès qu'une note est créée ou retrouvée en BD #}
                        <button type="button"
                                class="analysis-toolbar-badge-note d-none"
                                data-bordereau-analysis-target="linkedNotesBadge"
                                data-action="click->bordereau-analysis#openLinkedNoteDialog">
                            <twig:UX:Icon name="{{ resolve_icon_name('note') }}" width="11px" height="11px" class="me-1" />
                            <span data-bordereau-analysis-target="linkedNotesBadgeText">Note liée</span>
                        </button>
                    </div>
                </div>
            </div>

            {# Bloc de droite : Recherche + Actions sur une seule ligne #}
            <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">

                {# ── BLOC RECHERCHE — visible uniquement à l'étape 3 ── #}
                <div class="analysis-search-block d-none"
                     data-bordereau-analysis-target="searchBlock">

                    <div class="input-group analysis-search-input-group" style="max-width: 380px;">
                        {# Compteur de résultats — prepend, toujours dans le flux #}
                        <span class="input-group-text analysis-search-count d-none px-2"
                              data-bordereau-analysis-target="searchResultCount"
                              aria-live="polite"></span>

                        {# Champ de saisie #}
                        <input type="search"
                               class="form-control analysis-search-input"
                               placeholder="Police, assuré, risque…"
                               aria-label="Rechercher dans les résultats"
                               data-bordereau-analysis-target="searchInput"
                               data-action="keydown->bordereau-analysis#triggerSearch" />

                        {# Bouton déclencheur #}
                        <button class="btn analysis-search-btn"
                                type="button"
                                data-action="click->bordereau-analysis#triggerSearch"
                                aria-label="Lancer la recherche">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15"
                                 fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.099zm-5.242 1.156a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11"/>
                            </svg>
                        </button>
                    </div>
                </div>

                {# Bloc actions — droite #}
                <div class="d-flex align-items-center gap-2" data-bordereau-analysis-target="actionsBlock">
                    {# ── ÉTAPE 2 : Retour + Lancer l'analyse ── #}
                    <button type="button"
                            class="btn btn-secondary d-inline-flex align-items-center gap-2 d-none"
                            data-bordereau-analysis-target="backToMappingButton"
                            data-action="click->bordereau-analysis#showStep"
                            data-step-number="1"
                            data-controller="ripple">
                        <twig:UX:Icon name="lucide:arrow-left-circle" width="18px" height="18px" />
                        <span>Retour</span>
                    </button>

                    <button type="submit"
                            class="btn btn-primary d-inline-flex align-items-center gap-2 d-none"
                            data-bordereau-analysis-target="submitButton"
                            data-action="click->bordereau-analysis#submitAnalysis"
                            data-controller="ripple">
                        <twig:UX:Icon name="{{ resolve_icon_name('action:analyser') }}" width="18px" height="18px" />
                        <span>Analyser</span>
                    </button>

                    {# ── ÉTAPE 3 : Valider + Facturer (post-validation) + Retour au mappage ── #}
                    <button type="button"
                            class="btn btn-success d-inline-flex align-items-center gap-2 d-none"
                            data-bordereau-analysis-target="validateButton"
                            data-action="click->bordereau-analysis#validateBordereau"
                            data-controller="ripple">
                        <twig:UX:Icon name="{{ resolve_icon_name('action:completed') }}" width="18px" height="18px" />
                        <span>Valider</span>
                    </button>

                    <button type="button"
                            class="btn btn-primary d-inline-flex align-items-center gap-2 d-none"
                            data-bordereau-analysis-target="factureButton"
                            data-action="click->bordereau-analysis#createFacture"
                            data-controller="ripple">
                        <twig:UX:Icon name="{{ resolve_icon_name('note') }}" width="18px" height="18px" />
                        <span>Facturer</span>
                    </button>


                    <button type="button"
                            class="btn btn-secondary d-inline-flex align-items-center gap-2 d-none"
                            data-bordereau-analysis-target="backToMappingButton"
                            data-action="click->bordereau-analysis#showStep"
                            data-step-number="2"
                            data-controller="ripple">
                        <twig:UX:Icon name="lucide:arrow-left-circle" width="18px" height="18px" />
                        <span>Retour</span>
                    </button>

                    <a href="{{ path('admin.bordereau.api.export_analysis_pdf', {'id': bordereau.id}) }}" 
                       class="btn btn-outline-light d-inline-flex align-items-center gap-2 d-none"
                       data-bordereau-analysis-target="exportPdfItem"
                       data-controller="ripple">
                        <twig:UX:Icon name="{{ resolve_icon_name('action:download') }}" width="18px" height="18px" />
                        <span>Exporter PDF</span>
                    </a>

                    {# ── Dropdown "options" ── #}
                    <div class="dropdown">
                        <button class="btn btn-icon d-inline-flex align-items-center justify-content-center"
                                data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="Plus d'options">
                            <twig:UX:Icon name="lucide:more-vertical" width="18px" height="18px" class="text-white" />
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow" data-bordereau-analysis-target="optionsMenu">
                            <li><button class="dropdown-item d-inline-flex align-items-center gap-2" onclick="window.print()"><twig:UX:Icon name="lucide:printer" width="16px" height="16px" /><span>Imprimer</span></button></li>
                            <li data-bordereau-analysis-target="bulkDivider" class="d-none"><hr class="dropdown-divider"></li>
                            <li data-bordereau-analysis-target="bulkCreateItem" class="d-none"><button class="dropdown-item d-inline-flex align-items-center gap-2" data-action="click->bordereau-analysis#bulkCreateAll"><twig:UX:Icon name="{{ resolve_icon_name('action:add') }}" width="16px" height="16px" /><span>Tout créer</span></button></li>
                            <li data-bordereau-analysis-target="bulkUpdateItem" class="d-none"><button class="dropdown-item d-inline-flex align-items-center gap-2" data-action="click->bordereau-analysis#bulkUpdateAll"><twig:UX:Icon name="{{ resolve_icon_name('action:edit') }}" width="16px" height="16px" /><span>Tout mettre à jour</span></button></li>
                            <li data-bordereau-analysis-target="reanalyzeItem" class="d-none"><button class="dropdown-item d-inline-flex align-items-center gap-2" data-action="click->bordereau-analysis#submitAnalysis"><twig:UX:Icon name="lucide:refresh-cw" width="16px" height="16px" /><span>Réanalyser</span></button></li>
                            <li data-bordereau-analysis-target="backToMappingDropdownItem" class="d-none"><hr class="dropdown-divider"></li>
                            <li data-bordereau-analysis-target="backToMappingDropdownItem" class="d-none"><button class="dropdown-item d-inline-flex align-items-center gap-2" data-action="click->bordereau-analysis#showStep" data-step-number="2"><twig:UX:Icon name="lucide:arrow-left-circle" width="16px" height="16px" /><span>Retour</span></button></li>
                            <li data-bordereau-analysis-target="noteActionsDivider" class="d-none"><hr class="dropdown-divider"></li>
                            <li data-bordereau-analysis-target="editNoteItem" class="d-none"><button class="dropdown-item d-inline-flex align-items-center gap-2" data-action="click->bordereau-analysis#openLinkedNoteDialog"><twig:UX:Icon name="{{ resolve_icon_name('action:edit') }}" width="16px" height="16px" /><span>Éditer la note</span></button></li>
                            <li data-bordereau-analysis-target="viewNoteItem" class="d-none"><button class="dropdown-item d-inline-flex align-items-center gap-2" data-action="click->bordereau-analysis#viewLinkedNote"><twig:UX:Icon name="{{ resolve_icon_name('action:view') }}" width="16px" height="16px" /><span>Voir la note</span></button></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><button class="dropdown-item d-inline-flex align-items-center gap-2" onclick="window.close()"><twig:UX:Icon name="lucide:x-circle" width="16px" height="16px" /><span>Fermer</span></button></li>
                        </ul>
                    </div>
                </div>

            </div>
        </div>

        {# Barre de progression #}
        <div class="toolbar-progress-bar-container" data-bordereau-analysis-target="progressBarContainer">
            <div class="toolbar-progress-bar" data-bordereau-analysis-target="progressBar"
                 role="progressbar" aria-label="Traitement en cours"
                 aria-valuemin="0" aria-valuemax="100"></div>
        </div>

    </div>

    <div class="analysis-container">
        <div class="analysis-header">
            <div class="text-center mb-4">
                {% if entreprise and entreprise.thumbnail %}
                    <img src="{{ asset('images/entreprises/' ~ entreprise.thumbnail) }}" alt="Logo" style="max-height: 80px;">
                {% else %}
                    {# Fallback sur un logo par défaut si l'entreprise n'en a pas #}
                    <img src="{{ asset('images/entreprises/logofav.png') }}" alt="Logo JS Brokers" style="max-height: 80px;">
                {% endif %}
            </div>
            <hr>
            <div class="row align-items-center">
                <div class="col">
                    <h2>{{ entreprise.nom|default('Votre Entreprise') }}</h2>
                    <p class="text-muted">{{ entreprise.adresse|default('') }}</p>
                </div>
                <div class="col text-end">
                    <h2>Analyse de Bordereau</h2>
                    <p class="mb-1"><strong>Référence :</strong> {{ bordereau.reference }}</p>
                    <p class="mb-0"><strong>Période :</strong> {{ bordereau.periodeDebut|date('d/m/Y') }} au {{ bordereau.periodeFin|date('d/m/Y') }}</p>
                </div>
            </div>
        </div>

        <div class="analysis-body">
            {% if error %}
                <div class="alert alert-danger">
                    <h4 class="alert-heading">Erreur d'analyse</h4>
                    <p>{{ error }}</p>
                </div>
            {% else %}
                {# ÉTAPE 1 : Sélection de la feuille. #}
                <div class="card shadow-sm mb-4" data-bordereau-analysis-target="step1">
                    <div class="card-header">
                        <h6 class="m-0 fw-bold">Étape 1: Sélection de la feuille de calcul</h6>
                    </div>
                    <div class="card-body">
                        {% if viewData.sheets|length > 1 %}
                            <p>Le fichier contient plusieurs feuilles. Veuillez sélectionner celle qui contient les données à analyser.</p>
                            <form>
                                {% for sheet in viewData.sheets %}
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" name="selectedSheet" id="sheet-{{ loop.index0 }}" value="{{ sheet.sheetName }}" {{ loop.first ? 'checked' : '' }} data-bordereau-analysis-target="sheetSelection">
                                        <label class="form-check-label" for="sheet-{{ loop.index0 }}">
                                            <strong>{{ sheet.sheetName }}</strong> <span class="text-muted">({{ sheet.columns|length }} colonnes détectées)</span>
                                        </label>
                                    </div>
                                {% endfor %}
                                <button type="button" class="btn btn-primary mt-3" data-action="click->bordereau-analysis#showMappingStep">
                                    Valider et passer à l'étape 2
                                    <twig:UX:Icon name="lucide:arrow-right" class="ms-2" />
                                </button>
                            </form>
                        {% elseif viewData.sheets|length == 1 %}
                            <p>Une seule feuille a été détectée : <strong>{{ viewData.sheets[0].sheetName }}</strong>. Passage automatique à l'étape suivante.</p>
                            <input type="radio" name="selectedSheet" value="{{ viewData.sheets[0].sheetName }}" checked class="d-none" data-bordereau-analysis-target="sheetSelection">
                        {% else %}
                             <div class="alert alert-warning">Aucune feuille de calcul contenant des données n'a été trouvée.</div>
                        {% endif %}
                    </div>
                </div>

                {# ÉTAPE 2 : Mappage des colonnes. #}
                <div class="card shadow-sm mb-4 d-none" data-bordereau-analysis-target="step2">
                    <div class="card-header">
                        <h6 class="m-0 fw-bold">Étape 2: Mappage des colonnes</h6>
                    </div>
                    <div class="card-body">
                        <p>Veuillez faire correspondre les colonnes de votre fichier avec les champs requis par le système.</p>
                        {# Le feedback a été déplacé dans la barre d'outils #}
                        
                        {% for sheet in viewData.sheets %}
                            <div data-bordereau-analysis-target="mappingContainer" data-sheet-name="{{ sheet.sheetName }}" data-is-first="{{ loop.first ? 'true' : 'false' }}" style="display: none;">
                                <h5 class="mb-3">Feuille : <span class="badge bg-secondary">{{ sheet.sheetName }}</span></h5>
                                <form class="column-mapping-form">
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-striped align-middle">
                                            <thead class="table-light">
                                                <tr>
                                                    <th style="width: 40%;">Colonne du fichier Excel</th>
                                                    <th style="width: 30%;">Correspondance système</th>
                                                    <th style="width: 30%;">Résultat de l'analyse</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            {% for col_letter, col_name in sheet.columns %}
                                                <tr>
                                                    <td data-column-name-cell="{{ col_letter }}">
                                                        {# Ajout d'un data-attribut pour cibler le texte de la colonne #}
                                                        <span class="badge bg-info me-2">{{ col_letter }}</span>
                                                        <span data-bordereau-analysis-target="columnNameText">{{ col_name|default('Colonne sans nom') }}</span>
                                                    </td>
                                                    <td>
                                                        <select name="mapping[{{ col_name }}]"
                                                                class="form-select form-select-sm"
                                                                data-bordereau-analysis-target="mappingSelect"
                                                                data-action="bordereau-analysis#validateColumn"
                                                                data-column-letter="{{ col_letter }}">
                                                            <option value="">Ignorer cette colonne</option> {# Cette option sera toujours présente #}
                                                        </select>
                                                    </td>
                                                    <td data-bordereau-analysis-target="analysisResult"
                                                        data-result-for="{{ col_letter }}" data-sheet-name="{{ sheet.sheetName }}"></td>
                                                </tr>
                                            {% else %}
                                                <tr>
                                                    <td colspan="2" class="text-center text-muted">Aucune colonne détectée dans cette feuille.</td>
                                                </tr>
                                                {% endfor %}
                                            </tbody>
                                        </table>
                                    </div>
                                    {# Le bouton de soumission a été déplacé dans la barre d'outils #}
                                </form>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# NOUVEAU : ÉTAPE 3 : Résultats de l'analyse des avenants #}
            <div class="card shadow-sm mb-4 d-none" data-bordereau-analysis-target="step3">
                <div class="card-header">
                    <h6 class="m-0 fw-bold">Étape 3: Résultats de l'analyse des avenants</h6>
                </div>
                <div class="card-body">
                    <p>Voici le résultat de la comparaison de votre bordereau avec les données existantes.</p>
                    {# NOUVEAU : Bloc de synthèse, alimenté par renderAnalysisSummary() #}
                    <div data-bordereau-analysis-target="analysisSummary" class="mb-3"></div>
                    
                    <ul data-bordereau-analysis-target="analysisResultsList" class="list-group"></ul>
                    {# Le bouton de retour a été déplacé dans la barre d'outils supérieure #}
                </div>
            </div>
        </div>

        <div class="analysis-footer text-center">
            <p class="mb-1 fw-bold">{{ entreprise.nom|default('Votre Entreprise') }}</p>
            <p class="text-muted small fst-italic mb-0">
                {{ entreprise.adresse|default('') }}<br>
                Tel: {{ entreprise.telephone|default('N/A') }} / Site web: {{ entreprise.siteweb|default('N/A') }}<br>
                RCCM: {{ entreprise.rccm|default('N/A') }} / ID.NAT: {{ entreprise.idnat|default('N/A') }} / N° Impôt: {{ entreprise.numimpot|default('N/A') }}
            </p>
        </div>
    </div>

    {# Le script Bootstrap est déjà inclus via importmap dans le <head> #}

    {# ── TOAST FEEDBACK (feedback utilisateur flottant) ── #}
    <div class="toast-container position-fixed bottom-0 end-0 p-3"
         style="z-index: 1100;"
         data-bordereau-analysis-target="toastContainer">

        <div id="jsb-analysis-toast"
             class="toast align-items-center border-0 shadow"
             role="status"
             aria-live="polite"
             aria-atomic="true"
             data-bs-autohide="false"
             data-bordereau-analysis-target="mappingStatusFeedback">

            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2"
                     data-bordereau-analysis-target="toastBody">
                    {# Contenu injecté dynamiquement par le contrôleur Stimulus #}
                </div>
                <button type="button"
                        class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"
                        aria-label="Fermer"></button>
            </div>
        </div>
    </div>

    {# ── Modal de confirmation de validation du bordereau ── #}
    <div class="modal fade"
         id="jsb-validate-bordereau-modal"
         tabindex="-1"
         aria-labelledby="jsbValidateBordereauModalLabel"
         aria-hidden="true"
         data-bordereau-analysis-target="validationModal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0" style="background-color: #0047AB;">
                    <div class="d-flex align-items-center gap-2">
                        <twig:UX:Icon name="{{ resolve_icon_name('action:completed') }}" width="20px" height="20px" class="text-white" />
                        <h5 class="modal-title text-white mb-0" id="jsbValidateBordereauModalLabel">
                            Valider ce bordereau ?
                        </h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body px-4 py-3">
                    <p class="mb-2 fw-semibold" style="color: #212529;">En confirmant, vous attestez que :</p>
                    <ul class="mb-3" style="color: #495057;">
                        <li>Tous les écarts ont été traités <span class="text-muted">(avenants créés ou mis à jour)</span></li>
                        <li>Les données sont conformes au fichier transmis par l'assureur</li>
                    </ul>
                    <div class="alert alert-warning d-flex align-items-start gap-2 py-2 mb-0" role="alert">
                        <twig:UX:Icon name="lucide:triangle-alert" width="16px" height="16px" class="mt-1 flex-shrink-0" />
                        <span class="small">Cette action est <strong>définitive</strong>. Le bordereau passera au statut <strong>Validé</strong> et sera prêt pour la facturation.</span>
                    </div>
                </div>
                <div class="modal-footer border-top px-4 py-3">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                        Annuler
                    </button>
                    <button type="button"
                            class="btn btn-success d-inline-flex align-items-center gap-2"
                            data-action="click->bordereau-analysis#confirmValidation">
                        <twig:UX:Icon name="{{ resolve_icon_name('action:completed') }}" width="16px" height="16px" />
                        <span>Confirmer</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

</body>
</html>