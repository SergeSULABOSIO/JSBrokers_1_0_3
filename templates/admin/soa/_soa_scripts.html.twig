{# templates/admin/soa/_soa_scripts.html.twig
   JS inline des rendus autonomes du SOA (accordéon des sections, infobulles,
   auto-impression via ?print). Partagé entre l'aperçu courtier et la page publique.
#}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        /* ── Toggle accordéon des sections ── */
        var sections = document.querySelectorAll('.soa-container > section');
        sections.forEach(function (section, idx) {
            var title = section.querySelector('.soa-section-title');
            var body  = section.querySelector('.soa-section-body');
            if (!title || !body) return;

            var chevron = document.createElement('span');
            chevron.className = 'soa-toggle-chevron';
            chevron.setAttribute('aria-hidden', 'true');
            chevron.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/></svg>';
            title.appendChild(chevron);

            /* Déplacer le contenu dans un div interne */
            var inner = document.createElement('div');
            inner.className = 'soa-section-body-inner';
            while (body.firstChild) { inner.appendChild(body.firstChild); }
            body.appendChild(inner);

            title.setAttribute('role', 'button');
            title.setAttribute('tabindex', '0');

            /* État initial instantané (sans animation) */
            body.style.transition = 'none';
            if (idx === 0) {
                body.style.maxHeight = body.scrollHeight + 'px';
                title.classList.add('soa-open');
                title.setAttribute('aria-expanded', 'true');
            } else {
                body.style.maxHeight = '0';
                title.setAttribute('aria-expanded', 'false');
            }
            body.offsetHeight;
            body.style.transition = '';

            function toggle() {
                var isOpen = title.classList.contains('soa-open');
                if (isOpen) {
                    body.style.maxHeight = body.scrollHeight + 'px';
                    body.offsetHeight;
                    body.style.maxHeight = '0';
                    title.classList.remove('soa-open');
                    title.setAttribute('aria-expanded', 'false');
                } else {
                    body.style.maxHeight = body.scrollHeight + 'px';
                    title.classList.add('soa-open');
                    title.setAttribute('aria-expanded', 'true');
                    body.addEventListener('transitionend', function onEnd(e) {
                        if (e.propertyName !== 'max-height') return;
                        if (title.classList.contains('soa-open')) {
                            body.style.maxHeight = 'none';
                        }
                        body.removeEventListener('transitionend', onEnd);
                    });
                }
            }

            title.addEventListener('click', toggle);
            title.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
            });
        });

        /* ── Infobulles de section (titre gras + description, design dark) ── */
        (function () {
            var tip = null;
            function getTip() {
                if (!tip) {
                    tip = document.createElement('div');
                    tip.className = 'soa-section-tip';
                    document.body.appendChild(tip);
                }
                return tip;
            }
            function position(mx, my) {
                if (!tip) return;
                var offset = 14;
                var left = mx - tip.offsetWidth / 2;
                var top  = my - tip.offsetHeight - offset;
                left = Math.max(8, Math.min(left, window.innerWidth - tip.offsetWidth - 8));
                if (top < 8) top = my + offset;
                tip.style.left = left + 'px';
                tip.style.top  = top + 'px';
            }
            document.addEventListener('mouseover', function (e) {
                var title = e.target.closest ? e.target.closest('.soa-section-title[data-soa-tip]') : null;
                if (!title) return;
                var heading = title.querySelector('h2');
                var t = getTip();
                t.innerHTML = '';
                if (heading) {
                    var ts = document.createElement('span');
                    ts.className = 'soa-tip-title';
                    ts.textContent = heading.textContent.trim();
                    t.appendChild(ts);
                }
                var ds = document.createElement('span');
                ds.className = 'soa-tip-desc';
                ds.textContent = title.dataset.soaTip || '';
                t.appendChild(ds);
                t.style.display = 'block';
                position(e.clientX, e.clientY);
            });
            document.addEventListener('mousemove', function (e) {
                if (tip && tip.style.display === 'block') position(e.clientX, e.clientY);
            });
            document.addEventListener('mouseout', function (e) {
                var title = e.target.closest ? e.target.closest('.soa-section-title[data-soa-tip]') : null;
                if (title && !title.contains(e.relatedTarget) && tip) tip.style.display = 'none';
            });
        }());

        /* ── Picker « Documents de la police » (pages autonomes, sans Stimulus) ──
           Ouverture au clic sur un bouton [data-soa-docs-url] : le HTML du picker
           (components/soa/_documents_picker.html.twig) est chargé puis inséré dans
           <body>. Fermeture par ✕ / clic sur l'arrière-plan / Échap, restitution du
           focus au bouton déclencheur, filtre sur les lignes [data-picker-row]. */
        (function () {
            var previousFocus = null;

            /* Barre de progression indéterminée en haut de fenêtre (créée à la demande),
               activée pendant le chargement du picker — même signal que le workspace. */
            function topProgress(active) {
                var bar = document.querySelector('.soa-progress-top');
                if (!bar) {
                    bar = document.createElement('div');
                    bar.className = 'soa-progress-top';
                    bar.setAttribute('role', 'progressbar');
                    bar.setAttribute('aria-hidden', 'true');
                    document.body.appendChild(bar);
                }
                bar.classList.toggle('is-active', !!active);
            }

            function closePicker() {
                var overlay = document.querySelector('[data-soa-docs-picker-root]');
                if (!overlay) return;
                overlay.remove();
                document.removeEventListener('keydown', onKeydown);
                if (previousFocus && document.contains(previousFocus)) previousFocus.focus();
                previousFocus = null;
            }

            function onKeydown(e) {
                if (e.key === 'Escape') closePicker();
            }

            function wirePicker(overlay) {
                overlay.addEventListener('click', function (e) {
                    if (e.target.closest('[data-picker-close]') || e.target === overlay) {
                        closePicker();
                    }
                });
                document.addEventListener('keydown', onKeydown);

                var search = overlay.querySelector('[data-picker-search]');
                if (search) {
                    /* Surligne chaque occurrence du mot-clé dans un élément [data-picker-hl]
                       (même logique que picker-base._highlightInto : nœuds DOM, zéro innerHTML
                       de texte utilisateur → aucun risque d'injection). */
                    var highlightInto = function (el, original, query) {
                        var q = (query || '').trim();
                        if (!q) { el.textContent = original; return; }
                        el.textContent = '';
                        var lower = original.toLowerCase();
                        var qlower = q.toLowerCase();
                        var i = 0;
                        var idx;
                        while ((idx = lower.indexOf(qlower, i)) !== -1) {
                            if (idx > i) el.appendChild(document.createTextNode(original.slice(i, idx)));
                            var mark = document.createElement('mark');
                            mark.className = 'jsb-picker-hl';
                            mark.textContent = original.slice(idx, idx + q.length);
                            el.appendChild(mark);
                            i = idx + q.length;
                        }
                        if (i < original.length) el.appendChild(document.createTextNode(original.slice(i)));
                    };
                    var filter = function () {
                        var raw = search.value.trim();
                        var q = raw.toLowerCase();
                        var visible = 0;
                        overlay.querySelectorAll('[data-picker-row]').forEach(function (row) {
                            var match = q === '' || (row.dataset.search || '').indexOf(q) !== -1;
                            row.style.display = match ? '' : 'none';
                            if (match) {
                                visible++;
                                row.querySelectorAll('[data-picker-hl]').forEach(function (el) {
                                    if (el.dataset.orig === undefined) el.dataset.orig = el.textContent;
                                    highlightInto(el, el.dataset.orig, raw);
                                });
                            }
                        });
                        var empty = overlay.querySelector('[data-picker-empty]');
                        if (empty) empty.hidden = visible !== 0;
                    };
                    search.addEventListener('input', filter);
                    search.focus();
                } else {
                    var dialog = overlay.querySelector('[role="dialog"]');
                    if (dialog) dialog.focus();
                }
            }

            document.addEventListener('click', function (e) {
                var btn = e.target.closest('[data-soa-docs-url]');
                if (!btn) return;
                if (document.querySelector('[data-soa-docs-picker-root]')) return; // déjà ouvert

                previousFocus = btn;
                // Double feedback immédiat (Nielsen 1) : barre de progression en haut
                // de fenêtre + spinner local sur le bouton déclencheur.
                btn.disabled = true;
                btn.classList.add('is-loading');
                btn.setAttribute('aria-busy', 'true');
                topProgress(true);
                fetch(btn.dataset.soaDocsUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function (response) {
                        if (!response.ok) throw new Error('HTTP ' + response.status);
                        return response.text();
                    })
                    .then(function (html) {
                        var holder = document.createElement('div');
                        holder.innerHTML = html.trim();
                        var overlay = holder.firstElementChild;
                        if (!overlay) throw new Error('Contenu vide');
                        document.body.appendChild(overlay);
                        wirePicker(overlay);
                    })
                    .catch(function () {
                        window.alert("Impossible de charger les documents de la police. Réessayez ou contactez votre courtier.");
                    })
                    .finally(function () {
                        btn.disabled = false;
                        btn.classList.remove('is-loading');
                        btn.removeAttribute('aria-busy');
                        topProgress(false);
                    });
            });
        }());

        /* ── Auto-impression via ?print ── */
        const params = new URLSearchParams(window.location.search);
        if (params.has('print')) { window.print(); }
    });
</script>
