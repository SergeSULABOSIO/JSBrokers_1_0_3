{# templates/admin/soa/_soa_scripts.html.twig
   JS inline des rendus autonomes du SOA (accordéon des sections, infobulles,
   auto-impression via ?print). Partagé entre l'aperçu courtier et la page publique.
#}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        /* ── Toggle accordéon des sections ── */
        var sections = document.querySelectorAll('.soa-container > section');
        sections.forEach(function (section, idx) {
            var title = section.querySelector('.soa-section-title');
            var body  = section.querySelector('.soa-section-body');
            if (!title || !body) return;

            var chevron = document.createElement('span');
            chevron.className = 'soa-toggle-chevron';
            chevron.setAttribute('aria-hidden', 'true');
            chevron.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/></svg>';
            title.appendChild(chevron);

            /* Déplacer le contenu dans un div interne */
            var inner = document.createElement('div');
            inner.className = 'soa-section-body-inner';
            while (body.firstChild) { inner.appendChild(body.firstChild); }
            body.appendChild(inner);

            title.setAttribute('role', 'button');
            title.setAttribute('tabindex', '0');

            /* État initial instantané (sans animation) */
            body.style.transition = 'none';
            if (idx === 0) {
                body.style.maxHeight = body.scrollHeight + 'px';
                title.classList.add('soa-open');
                title.setAttribute('aria-expanded', 'true');
            } else {
                body.style.maxHeight = '0';
                title.setAttribute('aria-expanded', 'false');
            }
            body.offsetHeight;
            body.style.transition = '';

            function toggle() {
                var isOpen = title.classList.contains('soa-open');
                if (isOpen) {
                    body.style.maxHeight = body.scrollHeight + 'px';
                    body.offsetHeight;
                    body.style.maxHeight = '0';
                    title.classList.remove('soa-open');
                    title.setAttribute('aria-expanded', 'false');
                } else {
                    body.style.maxHeight = body.scrollHeight + 'px';
                    title.classList.add('soa-open');
                    title.setAttribute('aria-expanded', 'true');
                    body.addEventListener('transitionend', function onEnd(e) {
                        if (e.propertyName !== 'max-height') return;
                        if (title.classList.contains('soa-open')) {
                            body.style.maxHeight = 'none';
                        }
                        body.removeEventListener('transitionend', onEnd);
                    });
                }
            }

            title.addEventListener('click', toggle);
            title.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
            });
        });

        /* ── Infobulles de section (titre gras + description, design dark) ── */
        (function () {
            var tip = null;
            function getTip() {
                if (!tip) {
                    tip = document.createElement('div');
                    tip.className = 'soa-section-tip';
                    document.body.appendChild(tip);
                }
                return tip;
            }
            function position(mx, my) {
                if (!tip) return;
                var offset = 14;
                var left = mx - tip.offsetWidth / 2;
                var top  = my - tip.offsetHeight - offset;
                left = Math.max(8, Math.min(left, window.innerWidth - tip.offsetWidth - 8));
                if (top < 8) top = my + offset;
                tip.style.left = left + 'px';
                tip.style.top  = top + 'px';
            }
            document.addEventListener('mouseover', function (e) {
                var title = e.target.closest ? e.target.closest('.soa-section-title[data-soa-tip]') : null;
                if (!title) return;
                var heading = title.querySelector('h2');
                var t = getTip();
                t.innerHTML = '';
                if (heading) {
                    var ts = document.createElement('span');
                    ts.className = 'soa-tip-title';
                    ts.textContent = heading.textContent.trim();
                    t.appendChild(ts);
                }
                var ds = document.createElement('span');
                ds.className = 'soa-tip-desc';
                ds.textContent = title.dataset.soaTip || '';
                t.appendChild(ds);
                t.style.display = 'block';
                position(e.clientX, e.clientY);
            });
            document.addEventListener('mousemove', function (e) {
                if (tip && tip.style.display === 'block') position(e.clientX, e.clientY);
            });
            document.addEventListener('mouseout', function (e) {
                var title = e.target.closest ? e.target.closest('.soa-section-title[data-soa-tip]') : null;
                if (title && !title.contains(e.relatedTarget) && tip) tip.style.display = 'none';
            });
        }());

        /* ── Auto-impression via ?print ── */
        const params = new URLSearchParams(window.location.search);
        if (params.has('print')) { window.print(); }
    });
</script>
