{# Carte de tarif GÉNÉRIQUE pour un paquet prépayé, alimentée par le paramétrage
   de la Console : plan_tarifaire().packs() (entité PlateformeParametres, repli sur
   les constantes TokenPricing). Tout paquet ajouté / édité / supprimé en Console se
   reflète automatiquement ici — nom, prix TTC et volume de tokens compris.

   Paramètres attendus (via include ... with) :
     - key      : clé technique du paquet (sert au lien d'achat) ;
     - pack      : { label, tokens, price } ;
     - featured  : booléen — met la carte en avant (« Recommandé ») ;
     - promo     : meilleure promo publique applicable (ou null) —
                   { code, type, valeur, montantFinal, remiseUsd }.
   La variable `lang` provient du contexte parent. #}
{# Langue de rendu de la carte : nombres et symbole monétaire s'y alignent. #}
{% set langue = lang|default(app.request.locale) %}
<article class="pp-card{{ featured ? ' pp-card--featured' : '' }}" aria-labelledby="pp-{{ key }}-name">
    {% if featured %}
        <p class="pp-flag">
            {{ ux_icon('mdi:star', {height: '14px', width: '14px', 'aria-hidden': 'true'}) }}
            {{ "security_pricing_recommended" | trans }}
        </p>
    {% endif %}
    <header class="pp-head">
        <span class="pp-name" id="pp-{{ key }}-name">{{ (pack.label|default(key|capitalize))|upper }}</span>
        {# Zone de prix à hauteur réservée : aligne les cartes entre elles, avec ou sans promo. #}
        <div class="pp-price-zone">
            {% if promo %}
                {# Promo active : prix d'origine barré → prix remisé (= prix facturé avec ce code).
                   <del> porte la sémantique « ancien prix » (lecteurs d'écran). #}
                <div class="pp-price-row">
                    <del class="pp-price-old">
                        <span class="visually-hidden">{{ "security_pricing_old_price" | trans }} </span>
                        {{ pack.price|format_montant(0, langue) }}
                    </del>
                    <p class="pp-price">
                        <span class="visually-hidden">{{ "security_pricing_new_price" | trans }} </span>
                        {{ promo.montantFinal|format_montant(0, langue) }}
                    </p>
                </div>
                <span class="pp-promo" aria-label="{{ 'security_pricing_promo_code' | trans }} {{ promo.code }}">
                    {{ ux_icon(resolve_icon_name('offre'), {height: '15px', width: '15px', 'aria-hidden': 'true'}) }}
                    <span class="pp-promo__code">{{ promo.code }}</span>
                    <span>{% if promo.type == 'percent' %}−{{ promo.valeur|number_format(0) }}%{% else %}{{ "security_pricing_pack_promo_off" | trans({'%amount%': promo.remiseUsd|format_montant(0, langue)}) }}{% endif %}</span>
                </span>
            {% else %}
                <p class="pp-price">{{ pack.price|format_montant(0, langue) }}</p>
            {% endif %}
        </div>
        <span class="pp-badge">{{ "security_pricing_pack_mode" | trans }}</span>
        <p class="pp-profil">{{ "security_pricing_pack_profil" | trans }}</p>
    </header>

    <ul class="pp-features">
        {# Assistant IA : l'argument premium des paquets payants — mis en tête et en évidence. #}
        <li class="pp-feature pp-feature--ia">
            {{ ux_icon(resolve_icon_name('assistant-ia'), {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_pack_option_ia" | trans }}</span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_pack_option_assistance" | trans }}</span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_pack_option_invite" | trans }}
                <strong class="pp-value">{{ "security_pricing_pack_option_invite_value" | trans }}</strong></span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_pack_option_donnees" | trans }}</span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_pack_option_volume" | trans }}
                <strong class="pp-value">{{ pack.tokens|format_nombre(0, langue) }}</strong></span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_pack_option_entreprise" | trans }}
                <strong class="pp-value">{{ "security_pricing_pack_option_entreprise_value" | trans }}</strong></span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_pack_option_dashboard" | trans }}</span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_pack_option_email" | trans }}
                <strong class="pp-value">{{ "security_pricing_pack_option_email_value" | trans }}</strong></span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_pack_option_fonctions" | trans }}</span>
        </li>
    </ul>

    <div class="pp-foot">
        <a href="{{ app.user ? path('admin.token.buy', promo ? {pack: key, coupon: promo.code} : {pack: key}) : path('app_register', {idUtilisateur: -1}) }}"
           class="pp-cta {{ featured ? 'pp-cta--solid' : 'pp-cta--outline' }}"
           data-controller="ripple"
           data-action="click->form-submit#navigating click->top-progress#show"
           data-loading-text="{{ 'security_pricing_pack_start' | trans }}">
            {{ ux_icon(resolve_icon_name('action:cart'), {height: '18px', width: '18px'}) }}
            <span>{{ "security_pricing_pack_start" | trans }}</span>
        </a>
    </div>
</article>
