<article class="pp-card" aria-labelledby="pp-basic-name">
    <header class="pp-head">
        <span class="pp-name" id="pp-basic-name">{{ "security_pricing_basic" | trans }}</span>
        {# Même zone de prix à hauteur réservée que les paquets payants, pour aligner les cartes. #}
        <div class="pp-price-zone">
            <p class="pp-price">{{ "security_pricing_basic_price" | trans }}</p>
        </div>
        <p class="pp-lead">{{ "security_pricing_basic_mode" | trans }}</p>
        <p class="pp-profil">{{ "security_pricing_basic_profil" | trans }}</p>
    </header>

    <ul class="pp-features">
        {# Assistant IA : non inclus dans l'offre gratuite — réservé aux paquets payants. #}
        <li class="pp-feature pp-feature--off">
            {{ ux_icon('mdi:minus-circle-outline', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_basic_option_ia" | trans }}</span>
        </li>
        <li class="pp-feature pp-feature--off">
            {{ ux_icon('mdi:minus-circle-outline', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_basic_option_assistance" | trans }}</span>
        </li>
        <li class="pp-feature pp-feature--off">
            {{ ux_icon('mdi:minus-circle-outline', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_basic_option_invite" | trans }}</span>
        </li>
        <li class="pp-feature pp-feature--off">
            {{ ux_icon('mdi:minus-circle-outline', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_basic_option_donnees" | trans }}</span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_basic_option_volume" | trans }}
                <strong class="pp-value">{{ plan_tarifaire().freeAllowance|format_nombre(0, lang|default(app.request.locale)) }}</strong></span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_basic_option_entreprise" | trans }}
                <strong class="pp-value">{{ "security_pricing_basic_option_entreprise_value" | trans({'%hours%': plan_tarifaire().freeWindowHours}) }}</strong></span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_basic_option_first_company" | trans }}
                <strong class="pp-value">{{ "security_pricing_basic_option_first_company_value" | trans }}</strong></span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_basic_option_dashboard" | trans }}</span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_basic_option_email" | trans }}
                <strong class="pp-value">{{ "security_pricing_basic_option_email_value" | trans }}</strong></span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_basic_option_fonctions" | trans }}</span>
        </li>
    </ul>

    <div class="pp-foot">
        <a href="{{ app.user ? path('app_login') : path('app_register', {idUtilisateur: -1}) }}"
           class="pp-cta pp-cta--ghost"
           data-controller="ripple"
           data-action="click->form-submit#navigating click->top-progress#show"
           data-loading-text="{{ 'security_pricing_start_basic' | trans }}">
            {{ ux_icon(resolve_icon_name('action:cart'), {height: '18px', width: '18px'}) }}
            <span>{{ "security_pricing_start_basic" | trans }}</span>
        </a>
    </div>
</article>
