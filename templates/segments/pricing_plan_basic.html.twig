<div class="card h-100 shadow">
    <div class="card-header bg-cobalt">
        <h3 class="card-title text-center text-light h5 mb-0">{{ "security_pricing_basic" | trans }}</h3>
    </div>
    <div class="card-body">
        <p class="card-title text-center h2">{{ "security_pricing_basic_price" | trans }}</p>
        <hr>
        <blockquote class="blockquote mb-0 text-center">
            <p>{{ "security_pricing_basic_mode" | trans }}</p>
            <footer class="blockquote-footer">{{ "security_pricing_basic_profil" | trans }}</footer>
        </blockquote>
        <hr>
        <div class="list-group list-group-flush">
            <div class="list-group-item d-flex align-items-center gap-2 text-danger">
                {{ ux_icon('healthicons:no', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_basic_option_assistance" | trans }}</span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-danger">
                {{ ux_icon('healthicons:no', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_basic_option_invite" | trans }}</span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-danger">
                {{ ux_icon('healthicons:no', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_basic_option_donnees" | trans }}</span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_basic_option_volume" | trans }}
                    <strong class="text-dark">[{{ "security_pricing_basic_option_volume_value" | trans }}]</strong></span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_basic_option_entreprise" | trans }}
                    <strong class="text-dark">[{{ "security_pricing_basic_option_entreprise_value" | trans }}]</strong></span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_basic_option_dashboard" | trans }}</span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_basic_option_email" | trans }}
                    <strong class="text-dark">[{{ "security_pricing_basic_option_email_value" | trans }}]</strong></span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_basic_option_fonctions" | trans }}</span>
            </div>
        </div>
    </div>
    <div class="card-footer text-center bg-white border-top-0">
        <a href="{{ app.user ? path('app_login') : path('app_register', {idUtilisateur: -1}) }}"
           class="btn btn-outline-secondary w-100">
            {{ "security_pricing_start_basic" | trans }}
        </a>
    </div>
</div>
