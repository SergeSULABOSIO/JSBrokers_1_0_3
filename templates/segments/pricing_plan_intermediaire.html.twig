{% set pack = plan_tarifaire().pack('intermediaire') %}
{% if pack %}
<article class="pp-card" aria-labelledby="pp-inter-name">
    <header class="pp-head">
        <span class="pp-name" id="pp-inter-name">{{ "security_pricing_intermediaire" | trans }}</span>
        <p class="pp-price">{{ "security_pricing_intermediaire_price" | trans({'%price%': pack.price}) }}</p>
        <span class="pp-badge">{{ "security_pricing_intermediaire_mode" | trans }}</span>
        <p class="pp-profil">{{ "security_pricing_intermediaire_profil" | trans }}</p>
    </header>

    <ul class="pp-features">
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_intermediaire_option_assistance" | trans }}</span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_intermediaire_option_invite" | trans }}
                <strong class="pp-value">{{ "security_pricing_intermediaire_option_invite_value" | trans }}</strong></span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_intermediaire_option_donnees" | trans }}</span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_intermediaire_option_volume" | trans }}
                <strong class="pp-value">{{ pack.tokens|number_format(0, '.', (lang|default(app.request.locale) == 'en' ? ',' : ' ')) }}</strong></span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_intermediaire_option_entreprise" | trans }}
                <strong class="pp-value">{{ "security_pricing_intermediaire_option_entreprise_value" | trans }}</strong></span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_intermediaire_option_dashboard" | trans }}</span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_intermediaire_option_email" | trans }}
                <strong class="pp-value">{{ "security_pricing_intermediaire_option_email_value" | trans }}</strong></span>
        </li>
        <li class="pp-feature">
            {{ ux_icon('mdi:check-circle', {class: 'pp-feature__icon', 'aria-hidden': 'true'}) }}
            <span>{{ "security_pricing_intermediaire_option_fonctions" | trans }}</span>
        </li>
    </ul>

    <div class="pp-foot">
        <a href="{{ app.user ? path('admin.token.buy', {pack: 'intermediaire'}) : path('app_register', {idUtilisateur: -1}) }}"
           class="pp-cta pp-cta--outline"
           data-controller="ripple"
           data-action="click->form-submit#navigating click->top-progress#show"
           data-loading-text="{{ 'security_pricing_start_intermediaire' | trans }}">
            {{ ux_icon(resolve_icon_name('action:cart'), {height: '18px', width: '18px'}) }}
            <span>{{ "security_pricing_start_intermediaire" | trans }}</span>
        </a>
    </div>
</article>
{% endif %}
