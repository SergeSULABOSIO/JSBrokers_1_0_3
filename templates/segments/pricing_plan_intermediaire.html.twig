<div class="card h-100 shadow">
    <div class="card-header bg-cobalt">
        <h3 class="card-title text-center text-light h5 mb-0">{{ "security_pricing_intermediaire" | trans }}</h3>
    </div>
    <div class="card-body">
        <p class="card-title text-center h2">{{ "security_pricing_intermediaire_price" | trans }}</p>
        <hr>
        <blockquote class="blockquote mb-0 text-center">
            <p><span class="badge rounded-pill bg-warning text-dark">{{ "security_pricing_intermediaire_mode" | trans }}</span></p>
            <footer class="blockquote-footer">{{ "security_pricing_intermediaire_profil" | trans }}</footer>
        </blockquote>
        <hr>
        <div class="list-group list-group-flush">
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_intermediaire_option_assistance" | trans }}</span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_intermediaire_option_invite" | trans }}
                    <strong class="text-dark">[{{ "security_pricing_intermediaire_option_invite_value" | trans }}]</strong></span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_intermediaire_option_donnees" | trans }}</span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_intermediaire_option_volume" | trans }}
                    <strong class="text-dark">[{{ "security_pricing_intermediaire_option_volume_value" | trans }}]</strong></span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_intermediaire_option_entreprise" | trans }}
                    <strong class="text-dark">[{{ "security_pricing_intermediaire_option_entreprise_value" | trans }}]</strong></span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_intermediaire_option_dashboard" | trans }}</span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_intermediaire_option_email" | trans }}
                    <strong class="text-dark">[{{ "security_pricing_intermediaire_option_email_value" | trans }}]</strong></span>
            </div>
            <div class="list-group-item d-flex align-items-center gap-2 text-muted">
                {{ ux_icon('mdi:check-bold', {height: '20px', width: '20px'}) }}
                <span>{{ "security_pricing_intermediaire_option_fonctions" | trans }}</span>
            </div>
        </div>
    </div>
    <div class="card-footer text-center bg-white border-top-0">
        <a href="{{ app.user ? path('admin.token.buy', {pack: 'intermediaire'}) : path('app_register', {idUtilisateur: -1}) }}"
           class="btn btn-outline-secondary w-100 d-inline-flex align-items-center justify-content-center gap-2"
           data-controller="ripple"
           data-action="click->form-submit#navigating click->top-progress#show"
           data-loading-text="{{ 'security_pricing_start_intermediaire' | trans }}">
            {{ ux_icon(resolve_icon_name('action:cart'), {height: '18px', width: '18px'}) }}
            <span>{{ "security_pricing_start_intermediaire" | trans }}</span>
        </a>
    </div>
</div>
