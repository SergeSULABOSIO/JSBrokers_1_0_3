<section id="pricing_plan" class="public-section">
    <div class="public-section__head">
        <h2>{{ "security_pricing_plan" | trans }}</h2>
        <p>{{ "security_pricing_plan_description" | trans({
            '%allowance%': plan_tarifaire().freeAllowance|number_format(0, '.', (lang|default(app.request.locale) == 'en' ? ',' : ' ')),
            '%hours%': plan_tarifaire().freeWindowHours,
        }) | raw }}</p>
    </div>
    <div class="row row-cols-1 row-cols-md-3 g-4">
        <div class="col">
            {# Plan Basic #}
            {% include 'segments/pricing_plan_basic.html.twig' %}
        </div>
        <div class="col">
            {# Plan Intermédiaire #}
            {% include 'segments/pricing_plan_intermediaire.html.twig' %}
        </div>
        <div class="col">
            {# Plan Professionnel #}
            {% include 'segments/pricing_plan_professionnel.html.twig' %}
        </div>
    </div>
    <div class="text-center mt-4">
        <a href="{{ path('app_tokens_info', {'lang': lang|default(app.request.locale)}) }}"
           class="d-inline-flex align-items-center gap-2 text-decoration-none">
            {{ ux_icon('mdi:help-circle-outline', {height: '18px', width: '18px'}) }}
            <span>{{ "security_pricing_tokens_learn_more" | trans }}</span>
        </a>
    </div>
</section>
