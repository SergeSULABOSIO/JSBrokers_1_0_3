# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
SYMFONY_DEPRECATIONS_HELPER=999999
# Les emails ne doivent jamais partir réellement pendant les tests.
MAILER_DSN=null://null
# L'assistant IA ne doit JAMAIS appeler une API réelle pendant les tests.
# Indispensable : une clé posée en variable d'environnement OS (ex.
# GEMINI_API_KEY globale Windows) prime sur les .env et activerait sinon
# un moteur réel — ce forçage la neutralise.
AI_ENGINE=simulated
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots
